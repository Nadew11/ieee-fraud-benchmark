[124.592659, "i", "cat << 'EOF' > train_eval.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.preprocessing import OrdinalEncoder\nfrom xgboost import XGBClassifier\nfrom sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier\n\n# Load data\ntrain = pd.read_csv('/data/train_identity.csv')\ntest = pd.read_csv('/data/test_identity.csv')\ntest = test.rename(columns=lambda x: x.replace('-', '_'))\n\n# Separate features and target\nX = train.drop(columns=['isFraud'])\ny = train['isFraud']\nX_test = test.copy()\n\n# Categorical features list\ncat_cols = [c for c in X.columns if X[c].dtype == 'O' or X[c].dtype == 'object']\nprint(\"Categorical features:\", cat_cols)\n\n# Fill missing values and ordinal encode for simplicity across model types\nX_encoded = X.copy()\nX_test_encoded = X_test.copy()\n\n# Ensure TransactionID is not treated as a feature\nX_encoded = X_encoded.drop(columns=['TransactionID'])\nX_test_encoded = X_test_encoded.drop(columns=['TransactionID'])\n\n# Ordinal encoding\nfor col in cat_cols:\n    # Convert to string and fillna\n    X_encoded[col] = X_encoded[col].astype(str).fillna('missing')\n    X_test_encoded[col] = X_test_encoded[col].astype(str).fillna('missing')\n    \n    # Fit ordinal encoder on train, transform train and test\n    oe = OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1)\n    X_encoded[col] = oe.fit_transform(X_encoded[[col]])\n    X_test_encoded[col] = oe.transform(X_test_encoded[[col]])\n\n# Let's do a 20% holdout split\nX_tr, X_val, y_tr, y_val = train_test_split(X_encoded, y, test_size=0.2, random_state=42, stratify=y)\n\n# Try HistGradientBoostingClassifier\nmodel_hgb = HistGradientBoostingClassifier(random_state=42)\nmodel_hgb.fit(X_tr, y_tr)\npreds_hgb = model_hgb.predict_proba(X_val)[:, 1]\nauc_hgb = roc_auc_score(y_val, preds_hgb)\nprint(f\"HistGradientBoosting holdout AUC: {auc_hgb:.4f}\")\n\n# Try XGBoost\nmodel_xgb = XGBClassifier(random_state=42, eval_metric='logloss')\nmodel_xgb.fit(X_tr, y_tr)\npreds_xgb = model_xgb.predict_proba(X_val)[:, 1]\nauc_xgb = roc_auc_score(y_val, preds_xgb)\nprint(f\"XGBoost holdout AUC: {auc_xgb:.4f}\")\n\n# Try Random Forest\nmodel_rf = RandomForestClassifier(random_state=42, n_estimators=100)\n# RandomForest needs numeric features with no NaN, so let's impute NaNs with -999 for RF\nX_tr_rf = X_tr.fillna(-999)\nX_val_rf = X_val.fillna(-999)\nmodel_rf.fit(X_tr_rf, y_tr)\npreds_rf = model_rf.predict_proba(X_val_rf)[:, 1]\nauc_rf = roc_auc_score(y_val, preds_rf)\nprint(f\"Random Forest holdout AUC: {auc_rf:.4f}\")\n\nEOF\npython3 train_eval.py\n"]
