[140.750966, "i", "cat << 'EOF' > check_overfitting.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.preprocessing import OrdinalEncoder\nfrom sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.pipeline import make_pipeline\n\ntrain = pd.read_csv('/data/train_identity.csv')\ny = train['isFraud']\nX = train.drop(columns=['isFraud', 'TransactionID'])\n\n# Encode categorical columns as strings\ncat_cols = [c for c in X.columns if X[c].dtype == 'O' or X[c].dtype == 'object']\nfor col in cat_cols:\n    X[col] = X[col].astype(str).fillna('missing')\n\noe = OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1)\nX_enc = X.copy()\nX_enc[cat_cols] = oe.fit_transform(X[cat_cols])\n\nX_tr, X_val, y_tr, y_val = train_test_split(X_enc, y, test_size=0.2, random_state=42, stratify=y)\n\n# 1. HistGradientBoosting with high regularization\nfor md in [2, 3, 5, None]:\n    for lr in [0.01, 0.05, 0.1]:\n        clf = HistGradientBoostingClassifier(max_depth=md, learning_rate=lr, random_state=42)\n        clf.fit(X_tr, y_tr)\n        tr_auc = roc_auc_score(y_tr, clf.predict_proba(X_tr)[:, 1])\n        val_auc = roc_auc_score(y_val, clf.predict_proba(X_val)[:, 1])\n        print(f\"HGB max_depth={md} lr={lr} -> Train AUC: {tr_auc:.4f}, Val AUC: {val_auc:.4f}\")\n\n# 2. Logistic Regression on numeric columns\nnum_cols = [c for c in X_enc.columns if c not in cat_cols]\npipe = make_pipeline(SimpleImputer(strategy='median'), StandardScaler(), LogisticRegression(C=0.1, random_state=42))\npipe.fit(X_tr[num_cols], y_tr)\ntr_auc = roc_auc_score(y_tr, pipe.predict_proba(X_tr[num_cols])[:, 1])\nval_auc = roc_auc_score(y_val, pipe.predict_proba(X_val[num_cols])[:, 1])\nprint(f\"Logistic Regression (num only) -> Train AUC: {tr_auc:.4f}, Val AUC: {val_auc:.4f}\")\n\n# 3. Random Forest with shallow depth\nclf_rf = RandomForestClassifier(max_depth=4, random_state=42, n_estimators=100)\nclf_rf.fit(X_tr.fillna(-999), y_tr)\ntr_auc = roc_auc_score(y_tr, clf_rf.predict_proba(X_tr.fillna(-999))[:, 1])\nval_auc = roc_auc_score(y_val, clf_rf.predict_proba(X_val.fillna(-999))[:, 1])\nprint(f\"RF max_depth=4 -> Train AUC: {tr_auc:.4f}, Val AUC: {val_auc:.4f}\")\n\nEOF\npython3 check_overfitting.py\n"]
[140.753147, "o", "cat << 'EOF' > check_overfitting.py"]
