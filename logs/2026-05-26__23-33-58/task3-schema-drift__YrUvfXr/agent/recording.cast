[160.668065, "i", "cat << 'EOF' > experiment.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.preprocessing import OneHotEncoder, StandardScaler, OrdinalEncoder\nfrom sklearn.compose import ColumnTransformer\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier, ExtraTreesClassifier\nfrom xgboost import XGBClassifier\n\ntrain = pd.read_csv('/data/train_identity.csv')\ny = train['isFraud']\nX = train.drop(columns=['isFraud', 'TransactionID'])\n\n# Let's inspect the percentage of missing values per column\nmissing_pct = X.isnull().mean()\n# Try keeping columns with less than 80% missing values\ncols_to_keep = missing_pct[missing_pct < 0.8].index.tolist()\nprint(f\"Keeping {len(cols_to_keep)} columns out of {X.shape[1]}\")\n\nX_filtered = X[cols_to_keep]\n\n# Categorical vs numeric\nnum_cols = X_filtered.select_dtypes(include=[np.number]).columns.tolist()\ncat_cols = X_filtered.select_dtypes(exclude=[np.number]).columns.tolist()\nprint(\"Numeric columns:\", len(num_cols))\nprint(\"Categorical columns:\", len(cat_cols))\n\n# Split\nX_tr, X_val, y_tr, y_val = train_test_split(X_filtered, y, test_size=0.2, random_state=42, stratify=y)\n\n# Pipeline for Logistic Regression with OneHot Encoding\nnum_transformer = Pipeline(steps=[\n    ('imputer', SimpleImputer(strategy='median')),\n    ('scaler', StandardScaler())\n])\ncat_transformer = Pipeline(steps=[\n    ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),\n    ('onehot', OneHotEncoder(handle_unknown='ignore', max_categories=50))\n])\npreprocessor = ColumnTransformer(transformers=[\n    ('num', num_transformer, num_cols),\n    ('cat', cat_transformer, cat_cols)\n])\n\n# Let's try Logistic Regression\nlr_pipeline = Pipeline(steps=[('preprocessor', preprocessor),\n                             ('classifier', LogisticRegression(C=0.01, max_iter=1000, random_state=42))])\nlr_pipeline.fit(X_tr, y_tr)\nprint(\"LR C=0.01 Train AUC:\", roc_auc_score(y_tr, lr_pipeline.predict_proba(X_tr)[:, 1]))\nprint(\"LR C=0.01 Val AUC:\", roc_auc_score(y_val, lr_pipeline.predict_proba(X_val)[:, 1]))\n\nlr_pipeline2 = Pipeline(steps=[('preprocessor', preprocessor),\n                             ('classifier', LogisticRegression(C=1.0, max_iter=1000, random_state=42))])\nlr_pipeline2.fit(X_tr, y_tr)\nprint(\"LR C=1.0 Train AUC:\", roc_auc_score(y_tr, lr_pipeline2.predict_proba(X_tr)[:, 1]))\nprint(\"LR C=1.0 Val AUC:\", roc_auc_score(y_val, lr_pipeline2.predict_proba(X_val)[:, 1]))\n\n# Try XGBoost on Ordinal Encoded\nX_oe = X_filtered.copy()\nfor col in cat_cols:\n    X_oe[col] = X_oe[col].astype(str).fillna('missing')\noe = OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1)\nX_oe[cat_cols] = oe.fit_transform(X_oe[cat_cols])\nX_tr_oe, X_val_oe, y_tr_oe, y_val_oe = train_test_split(X_oe, y, test_size=0.2, random_state=42, stratify=y)\n\nxgb = XGBClassifier(n_estimators=50, max_depth=3, learning_rate=0.05, random_state=42, eval_metric='logloss')\nxgb.fit(X_tr_oe, y_tr_oe)\nprint(\"XGB max_depth=3 lr=0.05 Train AUC:\", roc_auc_score(y_tr_oe, xgb.predict_proba(X_tr_oe)[:, 1]))\nprint(\"XGB max_depth=3 lr=0.05 Val AUC:\", roc_auc_score(y_val_oe, xgb.predict_proba(X_val_oe)[:, 1]))\n\nxgb2 = XGBClassifier(n_estimators=100, max_depth=2, learning_rate=0.01, random_state=42, eval_metric='logloss')\nxgb2.fit(X_tr_oe, y_tr_oe)\nprint(\"XGB max_depth=2 lr=0.01 Train AUC:\", roc_auc_score(y_tr_oe, xgb2.predict_proba(X_tr_oe)[:, 1]))\nprint(\"XGB max_depth=2 lr=0.01 Val AUC:\", roc_auc_score(y_val_oe, xgb2.predict_proba(X_val_oe)[:, 1]))\n\nEOF\npython3 experiment.py\n"]
