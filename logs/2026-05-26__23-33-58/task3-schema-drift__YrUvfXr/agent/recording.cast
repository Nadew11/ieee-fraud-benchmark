[44.48303, "i", "cat << 'EOF' > inspect_details.py\nimport pandas as pd\ntrain = pd.read_csv('/data/train_identity.csv')\ntest = pd.read_csv('/data/test_identity.csv')\n\n# Rename test columns to match train column names (replace '-' with '_')\ntest = test.rename(columns=lambda x: x.replace('-', '_'))\n\n# Let's verify common columns now\ncommon_cols = list(set(train.columns).intersection(set(test.columns)))\nprint(\"Common cols:\", len(common_cols), sorted(common_cols))\n\n# Let's check missing values in both\nprint(\"Train missing rows percent:\", train.isnull().mean().round(3).to_dict())\nprint(\"Test missing rows percent:\", test.isnull().mean().round(3).to_dict())\n\n# Let's check the types of these columns\nprint(\"Train col types:\", train.dtypes.to_dict())\nEOF\npython3 inspect_details.py\n"]
