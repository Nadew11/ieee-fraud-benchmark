[69.583348, "i", "cat << 'EOF' > check_types.py\nimport pandas as pd\ntrain = pd.read_csv('/data/train_identity.csv')\ntest = pd.read_csv('/data/test_identity.csv')\ntest = test.rename(columns=lambda x: x.replace('-', '_'))\n\nfor col in test.columns:\n    if col == 'isFraud': continue\n    tr_dt = train[col].dtype\n    te_dt = test[col].dtype\n    if tr_dt != te_dt:\n        print(f\"Type mismatch in {col}: train={tr_dt}, test={te_dt}\")\nEOF\npython3 check_types.py\n"]
