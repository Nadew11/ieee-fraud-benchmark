[54.96067, "i", "cat << 'EOF' > check_cats.py\nimport pandas as pd\ntrain = pd.read_csv('/data/train_identity.csv')\ntest = pd.read_csv('/data/test_identity.csv')\ntest = test.rename(columns=lambda x: x.replace('-', '_'))\n\ncat_cols = [c for c in test.columns if test[c].dtype == 'O' or train[c].dtype == 'O']\nprint(\"Categorical columns:\", cat_cols)\nfor col in cat_cols:\n    train_vals = set(train[col].dropna().unique())\n    test_vals = set(test[col].dropna().unique())\n    only_train = train_vals - test_vals\n    only_test = test_vals - train_vals\n    print(f\"Column {col}: train_unique={len(train_vals)}, test_unique={len(test_vals)}, only_train={len(only_train)}, only_test={len(only_test)}\")\n    if len(only_train) > 0 and len(only_train) < 10:\n        print(\"  only_train:\", only_train)\n    if len(only_test) > 0 and len(only_test) < 10:\n        print(\"  only_test:\", only_test)\nEOF\npython3 check_cats.py\n"]
[55.100355, "o", "cat << 'EOF' > check_cats.py"]
