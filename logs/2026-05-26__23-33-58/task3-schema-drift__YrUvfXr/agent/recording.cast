[334.724171, "i", "cat << 'EOF' > inspect_excel.py\nimport openpyxl\nwb = openpyxl.load_workbook('/output/fraud_risk.xlsx')\nprint(\"Sheet names:\", wb.sheetnames)\n\n# Inspect Data Quality Report\nws = wb['Data Quality Report']\nprint(\"--- Data Quality Report ---\")\nfor r in range(1, 12):\n    row_vals = [ws.cell(row=r, column=c).value for c in range(1, 4)]\n    row_types = [type(ws.cell(row=r, column=c).value) for c in range(1, 4)]\n    print(f\"Row {r} values:\", row_vals)\n    print(f\"Row {r} types:\", row_types)\n\n# Inspect Predictions\nws_pred = wb['Predictions']\nprint(\"--- Predictions ---\")\nfor r in range(1, 5):\n    row_vals = [ws_pred.cell(row=r, column=c).value for c in range(1, 3)]\n    row_types = [type(ws_pred.cell(row=r, column=c).value) for c in range(1, 3)]\n    print(f\"Row {r} values:\", row_vals)\n    print(f\"Row {r} types:\", row_types)\n\nprint(\"Total Prediction rows:\", ws_pred.max_row)\nEOF\npython3 inspect_excel.py\n"]
[334.734636, "o", "cat << 'EOF' > inspect_excel.py\r\n\u001b[?2004l\r\u001b[?2004h> import openpyxl\r\n\u001b[?2004l\r\u001b[?2004h> wb = openpyxl.load_workbook('/output/fraud_risk.xlsx')\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Sheet names:\", wb.sheetnames)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Inspect Data Quality Report\r\n\u001b[?2004l\r\u001b[?2004h> ws = wb['Data Quality Report']\r\n\u001b[?2004l\r\u001b[?2004h> print(\"--- Data Quality Report ---\")\r\n\u001b[?2004l\r\u001b[?2004h> for r in range(1, 12):\r\n\u001b[?2004l\r\u001b[?2004h>     row_vals = [ws.cell(row=r, column=c).value for c in range(1, 4)]\r\n\u001b[?2004l\r\u001b[?2004h>     row_types = [type(ws.cell(row=r, column=c).value) for c in range(1, 4)]\r\n\u001b[?2004l\r"]
[334.735008, "o", "\u001b[?2004h>     print(f\"Row {r} values:\", row_vals)\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Row {r} types:\", row_types)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Inspect Predictions\r\n\u001b[?2004l\r\u001b[?2004h> ws_pred = wb['Predictions']\r\n\u001b[?2004l\r\u001b[?2004h> print(\"--- Predictions ---\")\r\n\u001b[?2004l\r\u001b[?2004h> for r in range(1, 5):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.739071, "o", "    row_vals = [ws_pred.cell(row=r, column=c).value for c in range(1, 3)]\r\n\u001b[?2004l\r\u001b[?2004h>     row_types = [type(ws_pred.cell(row=r, column=c).value) for c in range(1, 3)]\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Row {r} values:\", row_vals)\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Row {r} types:\", row_types)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Total Prediction rows:\", ws_pred.max_row)\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
