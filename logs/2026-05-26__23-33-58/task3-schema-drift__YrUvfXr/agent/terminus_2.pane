[?2004hroot@8b9ff8325d75:/workspace# cat << 'EOF' > experiment.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.preprocessing import OneHotEncoder, StandardScaler, OrdinalEncoder
[?2004l[?2004h> from sklearn.compose import ColumnTransformer
[?2004l[?2004h> from sklearn.pipeline import Pipeline
[?2004l[?2004h> from sklearn.impute import SimpleImputer
[?2004l[?2004h> from sklearn.linear_model import LogisticRegression
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier, ExtraTreesClassifier
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> 
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> X = train.drop(columns=['isFraud', 'TransactionID'])
[?2004l[?2004h> 
[?2004l[?2004h> # Let's inspect the percentage of missing values per column
[?2004l[?2004h> missing_pct = X.isnull().mean()
[?2004l[?2004h> # Try keeping columns with less than 80% missing values
[?2004l[?2004h> cols_to_keep = missing_pct[missing_pct < 0.8].index.tolist()
[?2004l[?2004h> print(f"Keeping {len(cols_to_keep)} columns out of {X.shape[1]}")
[?2004l[?2004h> 
[?2004l[?2004h> X_filtered = X[cols_to_keep]
[?2004l[?2004h> 
[?2004l[?2004h> # Categorical vs numeric
[?2004l[?2004h> num_cols = X_filtered.select_dtypes(include=[np.number]).columns.tolist()
[?2004l[?2004h> cat_cols = X_filtered.select_dtypes(exclude=[np.number]).columns.tolist()
[?2004l[?2004h> print("Numeric columns:", len(num_cols))
[?2004l[?2004h> print("Categorical columns:", len(cat_cols))
[?2004l[?2004h> 
[?2004l[?2004h> # Split
[?2004l[?2004h> X_tr, X_val, y_tr, y_val = train_test_split(X_filtered, y, test_size=0.2, random_state=42, stratify=y)
[?2004l[?2004h> 
[?2004l[?2004h> # Pipeline for Logistic Regression with OneHot Encoding
[?2004l[?2004h> num_transformer = Pipeline(steps=[
[?2004l[?2004h>     ('imputer', SimpleImputer(strategy='median')),
[?2004l[?2004h>     ('scaler', StandardScaler())
[?2004l[?2004h> ])
[?2004l[?2004h> cat_transformer = Pipeline(steps=[
[?2004l[?2004h>     ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),
[?2004l[?2004h>     ('onehot', OneHotEncoder(handle_unknown='ignore', max_categories=50))
[?2004l[?2004h> ])
[?2004l[?2004h> preprocessor = ColumnTransformer(transformers=[
[?2004l[?2004h>     ('num', num_transformer, num_cols),
[?2004l[?2004h>     ('cat', cat_transformer, cat_cols)
[?2004l[?2004h> ])
[?2004l[?2004h> 
[?2004l[?2004h> # Let's try Logistic Regression
[?2004l[?2004h> lr_pipeline = Pipeline(steps=[('preprocessor', preprocessor),
[?2004l[?2004h>                              ('classifier', LogisticRegression(C=0.01, max_iter=1000, random_state=42))])
[?2004l[?2004h> lr_pipeline.fit(X_tr, y_tr)
[?2004l[?2004h> print("LR C=0.01 Train AUC:", roc_auc_score(y_tr, lr_pipeline.predict_proba(X_tr)[:, 1]))
[?2004l[?2004h> print("LR C=0.01 Val AUC:", roc_auc_score(y_val, lr_pipeline.predict_proba(X_val)[:, 1]))
[?2004l[?2004h> 
[?2004l[?2004h> lr_pipeline2 = Pipeline(steps=[('preprocessor', preprocessor),
[?2004l[?2004h>                              ('classifier', LogisticRegression(C=1.0, max_iter=1000, random_state=42))])
[?2004l[?2004h> lr_pipeline2.fit(X_tr, y_tr)
[?2004l[?2004h> print("LR C=1.0 Train AUC:", roc_auc_score(y_tr, lr_pipeline2.predict_proba(X_tr)[:, 1]))
[?2004l[?2004h> print("LR C=1.0 Val AUC:", roc_auc_score(y_val, lr_pipeline2.predict_proba(X_val)[:, 1]))
[?2004l[?2004h> 
[?2004l[?2004h> # Try XGBoost on Ordinal Encoded
[?2004l[?2004h> X_oe = X_filtered.copy()
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     X_oe[col] = X_oe[col].astype(str).fillna('missing')
[?2004l[?2004h> oe = OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1)
[?2004l[?2004h> X_oe[cat_cols] = oe.fit_transform(X_oe[cat_cols])
[?2004l[?2004h> X_tr_oe, X_val_oe, y_tr_oe, y_val_oe = train_test_split(X_oe, y, test_size=0.2, random_state=42, stratify=y)
[?2004l[?2004h> 
[?2004l[?2004h> xgb = XGBClassifier(n_estimators=50, max_depth=3, learning_rate=0.05, random_state=42, eval_metric='logloss')
[?2004l[?2004h> xgb.fit(X_tr_oe, y_tr_oe)
[?2004l[?2004h> print("XGB max_depth=3 lr=0.05 Train AUC:", roc_auc_score(y_tr_oe, xgb.predict_proba(X_tr_oe)[:, 1]))
[?2004l[?2004h> print("XGB max_depth=3 lr=0.05 Val AUC:", roc_auc_score(y_val_oe, xgb.predict_proba(X_val_oe)[:, 1]))
[?2004l[?2004h> 
[?2004l[?2004h> xgb2 = XGBClassifier(n_estimators=100, max_depth=2, learning_rate=0.01, random_state=42, eval_metric='logloss')
[?2004l[?2004h> xgb2.fit(X_tr_oe, y_tr_oe)
[?2004l[?2004h> print("XGB max_depth=2 lr=0.01 Train AUC:", roc_auc_score(y_tr_oe, xgb2.predict_proba(X_tr_oe)[:, 1]))
[?2004l[?2004h> print("XGB max_depth=2 lr=0.01 Val AUC:", roc_auc_score(y_val_oe, xgb2.predict_proba(X_val_oe)[:, 1]))
[?2004l[?2004h> 
