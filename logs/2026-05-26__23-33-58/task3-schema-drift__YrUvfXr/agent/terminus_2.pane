[?2004hroot@8b9ff8325d75:/workspace# cat << 'EOF' > check_overfitting.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.preprocessing import OrdinalEncoder
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier
[?2004l[?2004h> from sklearn.linear_model import LogisticRegression
[?2004l[?2004h> from sklearn.impute import SimpleImputer
[?2004l[?2004h> from sklearn.preprocessing import StandardScaler
[?2004l[?2004h> from sklearn.pipeline import make_pipeline
[?2004l[?2004h> 
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> X = train.drop(columns=['isFraud', 'TransactionID'])
[?2004l[?2004h> 
[?2004l[?2004h> # Encode categorical columns as strings
[?2004l[?2004h> cat_cols = [c for c in X.columns if X[c].dtype == 'O' or X[c].dtype == 'object']
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     X[col] = X[col].astype(str).fillna('missing')
[?2004l[?2004h> 
[?2004l[?2004h> oe = OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1)
[?2004l[?2004h> X_enc = X.copy()
[?2004l[?2004h> X_enc[cat_cols] = oe.fit_transform(X[cat_cols])
[?2004l[?2004h> 
[?2004l[?2004h> X_tr, X_val, y_tr, y_val = train_test_split(X_enc, y, test_size=0.2, random_state=42, stratify=y)
[?2004l[?2004h> 
[?2004l[?2004h> # 1. HistGradientBoosting with high regularization
[?2004l[?2004h> for md in [2, 3, 5, None]:
[?2004l[?2004h>     for lr in [0.01, 0.05, 0.1]:
[?2004l[?2004h>         clf = HistGradientBoostingClassifier(max_depth=md, learning_rate=lr, random_state=42)
[?2004l[?2004h>         clf.fit(X_tr, y_tr)
[?2004l[?2004h>         tr_auc = roc_auc_score(y_tr, clf.predict_proba(X_tr)[:, 1])
[?2004l[?2004h>         val_auc = roc_auc_score(y_val, clf.predict_proba(X_val)[:, 1])
[?2004l[?2004h>         print(f"HGB max_depth={md} lr={lr} -> Train AUC: {tr_auc:.4f}, Val AUC: {val_auc:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Logistic Regression on numeric columns
[?2004l[?2004h> num_cols = [c for c in X_enc.columns if c not in cat_cols]
[?2004l[?2004h> pipe = make_pipeline(SimpleImputer(strategy='median'), StandardScaler(), LogisticRegression(C=0.1, random_state=42))
[?2004l[?2004h> pipe.fit(X_tr[num_cols], y_tr)
[?2004l[?2004h> tr_auc = roc_auc_score(y_tr, pipe.predict_proba(X_tr[num_cols])[:, 1])
[?2004l[?2004h> val_auc = roc_auc_score(y_val, pipe.predict_proba(X_val[num_cols])[:, 1])
[?2004l[?2004h> print(f"Logistic Regression (num only) -> Train AUC: {tr_auc:.4f}, Val AUC: {val_auc:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # 3. Random Forest with shallow depth
[?2004l[?2004h> clf_rf = RandomForestClassifier(max_depth=4, random_state=42, n_estimators=100)
[?2004l[?2004h> clf_rf.fit(X_tr.fillna(-999), y_tr)
[?2004l[?2004h> tr_auc = roc_auc_score(y_tr, clf_rf.predict_proba(X_tr.fillna(-999))[:, 1])
[?2004l[?2004h> val_auc = roc_auc_score(y_val, clf_rf.predict_proba(X_val.fillna(-999))[:, 1])
[?2004l[?2004h> print(f"RF max_depth=4 -> Train AUC: {tr_auc:.4f}, Val AUC: {val_auc:.4f}")
