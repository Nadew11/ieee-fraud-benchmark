[?2004hroot@8b9ff8325d75:/workspace# cat << 'EOF' > train_eval.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.preprocessing import OrdinalEncoder
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier
[?2004l[?2004h> 
[?2004l[?2004h> # Load data
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> test = pd.read_csv('/data/test_identity.csv')
[?2004l[?2004h> test = test.rename(columns=lambda x: x.replace('-', '_'))
[?2004l[?2004h> 
[?2004l[?2004h> # Separate features and target
[?2004l[?2004h> X = train.drop(columns=['isFraud'])
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> X_test = test.copy()
[?2004l[?2004h> 
[?2004l[?2004h> # Categorical features list
[?2004l[?2004h> cat_cols = [c for c in X.columns if X[c].dtype == 'O' or X[c].dtype == 'object']
[?2004l[?2004h> print("Categorical features:", cat_cols)
[?2004l[?2004h> 
[?2004l[?2004h> # Fill missing values and ordinal encode for simplicity across model types
[?2004l[?2004h> X_encoded = X.copy()
[?2004l[?2004h> X_test_encoded = X_test.copy()
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure TransactionID is not treated as a feature
[?2004l[?2004h> X_encoded = X_encoded.drop(columns=['TransactionID'])
[?2004l[?2004h> X_test_encoded = X_test_encoded.drop(columns=['TransactionID'])
[?2004l[?2004h> 
[?2004l[?2004h> # Ordinal encoding
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     # Convert to string and fillna
[?2004l[?2004h>     X_encoded[col] = X_encoded[col].astype(str).fillna('missing')
[?2004l[?2004h>     X_test_encoded[col] = X_test_encoded[col].astype(str).fillna('missing')
[?2004l[?2004h>     
[?2004l[?2004h>     # Fit ordinal encoder on train, transform train and test
[?2004l[?2004h>     oe = OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1)
[?2004l[?2004h>     X_encoded[col] = oe.fit_transform(X_encoded[[col]])
[?2004l[?2004h>     X_test_encoded[col] = oe.transform(X_test_encoded[[col]])
[?2004l[?2004h> 
[?2004l[?2004h> # Let's do a 20% holdout split
[?2004l[?2004h> X_tr, X_val, y_tr, y_val = train_test_split(X_encoded, y, test_size=0.2, random_state=42, stratify=y)
[?2004l[?2004h> 
[?2004l[?2004h> # Try HistGradientBoostingClassifier
[?2004l[?2004h> model_hgb = HistGradientBoostingClassifier(random_state=42)
[?2004l[?2004h> model_hgb.fit(X_tr, y_tr)
[?2004l[?2004h> preds_hgb = model_hgb.predict_proba(X_val)[:, 1]
[?2004l[?2004h> auc_hgb = roc_auc_score(y_val, preds_hgb)
[?2004l[?2004h> print(f"HistGradientBoosting holdout AUC: {auc_hgb:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Try XGBoost
[?2004l[?2004h> model_xgb = XGBClassifier(random_state=42, eval_metric='logloss')
[?2004l[?2004h> model_xgb.fit(X_tr, y_tr)
[?2004l[?2004h> preds_xgb = model_xgb.predict_proba(X_val)[:, 1]
[?2004l[?2004h> auc_xgb = roc_auc_score(y_val, preds_xgb)
[?2004l[?2004h> print(f"XGBoost holdout AUC: {auc_xgb:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Try Random Forest
[?2004l[?2004h> model_rf = RandomForestClassifier(random_state=42, n_estimators=100)
[?2004l[?2004h> # RandomForest needs numeric features with no NaN, so let's impute NaNs with -999 for RF
[?2004l[?2004h> X_tr_rf = X_tr.fillna(-999)
[?2004l[?2004h> X_val_rf = X_val.fillna(-999)
