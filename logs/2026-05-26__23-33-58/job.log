])\nxgb_preds = clf_xgb.predict_proba(val_sub_proc[feature_cols])[:, 1]\nprint(f"XGBoost AUC: {roc_auc_score(val_sub_proc[target_col], xgb_preds):.6f}")\n\n# 2. HistGradientBoosting\nclf_hgb = HistGradientBoostingClassifier(random_state=42, max_iter=100)\nclf_hgb.fit(train_sub_proc[feature_cols], train_sub_proc[target_col])\nhgb_preds = clf_hgb.predict_proba(val_sub_proc[feature_cols])[:, 1]\nprint(f"HistGradientBoosting AUC: {roc_auc_score(val_sub_proc[target_col], hgb_preds):.6f}")\n\n# 3. RandomForest\nclf_rf = RandomForestClassifier(n_estimators=100, max_depth=8, random_state=42, class_weight=\'balanced\')\nclf_rf.fit(train_sub_proc[feature_cols], train_sub_proc[target_col])\nrf_preds = clf_rf.predict_proba(val_sub_proc[feature_cols])[:, 1]\nprint(f"Random Forest AUC: {roc_auc_score(val_sub_proc[target_col], rf_preds):.6f}")\n\nEOF\npython3 tune_model.py\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
