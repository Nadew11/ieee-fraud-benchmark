Sending keys: ["cat << 'EOF' > forward_selection.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.ensemble import RandomForestClassifier\n\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntrain_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\n\ntarget_col = 'isFraud'\nall_features = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\n\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\nX_train = pd.DataFrame(index=train_sub.index)\nX_val = pd.DataFrame(index=val_sub.index)\n\nnum_cols = train_df[all_features].select_dtypes(exclude=['object']).columns.tolist()\nfor col in num_cols:\n    median_val = train_sub[col].median()\n    if pd.isna(median_val):\n        median_val = 0\n    X_train[col] = train_sub[col].fillna(median_val)\n    X_val[col] = val_sub[col].fillna(median_val)\n\ncat_cols = train_df[all_features].select_dtypes(include=['object']).columns.tolist()\nfor col in cat_cols:\n    train_cats = train_sub[col].fillna('Missing').astype(str).unique()\n    cat_map = {cat: idx for idx, cat in enumerate(train_cats)}\n    X_train[col] = train_sub[col].fillna('Missing').astype(str).map(cat_map).fillna(-1).astype(int)\n    X_val[col] = val_sub[col].fillna('Missing').astype(str).map(cat_map).fillna(-1).astype(int)\n\ncurrent_features = []\nbest_auc = 0.5\n\nfor step in range(10):\n    best_new_feature = None\n    best_step_auc = 0.0\n    for f in all_features:\n        if f in current_features:\n            continue\n        candidate_features = current_features + [f]\n        clf = RandomForestClassifier(n_estimators=50, max_depth=5, random_state=42, class_weight='balanced', n_jobs=-1)\n        clf.fit(X_train[candidate_features], train_sub[target_col])\n        preds = clf.predict_proba(X_val[candidate_features])[:, 1]\n        auc = roc_auc_score(val_sub[target_col], preds)\n        if auc > best_step_auc:\n            best_step_auc = auc\n            best_new_feature = f\n    \n    if best_new_feature is not None and best_step_auc > best_auc:\n        current_features.append(best_new_feature)\n        best_auc = best_step_auc\n        print(f'Step {step+1}: Added {best_new_feature}, Validation AUC = {best_auc:.6f}')\n    else:\n        print('No improvement, stopping.')\n        break\n\nprint('Final feature subset:', current_features)\nprint('Final best validation AUC:', best_auc)\nEOF\npython3 -u forward_selection.py\n"] min_timeout_sec: 5.0 max_timeout_sec: 180.0
