cept Exception as e:\n        pass\n\ndf_auc = pd.DataFrame(feature_aucs).sort_values(by='val_auc', ascending=False)\nprint(df_auc.to_string(index=False))\nEOF\npython3 feature_selection.py\n"] min_timeout_sec: 5.0 max_timeout_sec: 180.0
