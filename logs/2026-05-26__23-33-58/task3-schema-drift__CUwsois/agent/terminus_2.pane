[?2004hroot@27e59b3c4e79:/workspace# cat << 'EOF' > test_robust_models.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.linear_model import LogisticRegression
[?2004l[?2004h> from sklearn.preprocessing import StandardScaler
[?2004l[?2004h> from sklearn.impute import SimpleImputer
[?2004l[?2004h> from sklearn.pipeline import Pipeline
[?2004l[?2004h> from sklearn.compose import ColumnTransformer
[?2004l[?2004h> from sklearn.preprocessing import OneHotEncoder
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier
[?2004l[?2004h> 
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> test = pd.read_csv('/data/test_identity.csv')
[?2004l[?2004h> test.columns = [c.replace('-', '_') for c in test.columns]
[?2004l[?2004h> 
[?2004l[?2004h> # Separate features
[?2004l[?2004h> X = train.drop(columns=['TransactionID', 'isFraud'])
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> num_cols = X.select_dtypes(include=['int64', 'float64']).columns.tolist()
[?2004l[?2004h> cat_cols = X.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> 
[?2004l[?2004h> # Create a preprocessing pipeline
[?2004l[?2004h> preprocessor = ColumnTransformer(
[?2004l[?2004h>     transformers=[
[?2004l[?2004h>         ('num', Pipeline([
[?2004l[?2004h>             ('imputer', SimpleImputer(strategy='median')),
[?2004l[?2004h>             ('scaler', StandardScaler())
[?2004l[?2004h>         ]), num_cols),
[?2004l[?2004h>         ('cat', Pipeline([
[?2004l[?2004h>             ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),
[?2004l[?2004h>             ('ohe', OneHotEncoder(handle_unknown='ignore'))
[?2004l[?2004h>         ]), cat_cols)
[?2004l[?2004h>     ]
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> X_train, X_holdout, y_train, y_holdout = train_test_split(
[?2004l[?2004h>     X, y, test_size=0.2, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # 1. Logistic Regression
[?2004l[?2004h> lr_pipeline = Pipeline([
[?2004l[?2004h>     ('preprocessor', preprocessor),
[?2004l[?2004h>     ('lr', LogisticRegression(random_state=42, class_weight='balanced', max_iter=1000, C=0.01))
[?2004l[?2004h> ])
[?2004l[?2004h> lr_pipeline.fit(X_train, y_train)
[?2004l[?2004h> preds_train_lr = lr_pipeline.predict_proba(X_train)[:, 1]
[?2004l[?2004h> preds_holdout_lr = lr_pipeline.predict_proba(X_holdout)[:, 1]
[?2004l[?2004h> print("LR - Train AUC:", roc_auc_score(y_train, preds_train_lr))
[?2004l[?2004h> print("LR - Holdout AUC:", roc_auc_score(y_holdout, preds_holdout_lr))
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Tuned XGBoost with regularized parameters
[?2004l[?2004h> # Let's use a simpler pipeline for tree models
[?2004l[?2004h> # For tree models, let's label-encode categories first or keep them ordinal
[?2004l[?2004h> X_tree = X.copy()
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     X_tree[col] = pd.factorize(X_tree[col])[0]
[?2004l[?2004h> 
[?2004l[?2004h> X_train_t, X_hold_t, y_train_t, y_hold_t = train_test_split(
[?2004l[?2004h>     X_tree, y, test_size=0.2, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> xgb = XGBClassifier(
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     eval_metric='logloss',
[?2004l[?2004h>     max_depth=2,
[?2004l[?2004h>     learning_rate=0.01,
[?2004l[?2004h>     n_estimators=150,
[?2004l[?2004h>     subsample=0.7,
[?2004l[?2004h>     colsample_bytree=0.7,
[?2004l[?2004h>     scale_pos_weight=20
[?2004l[?2004h> )
[?2004l[?2004h> xgb.fit(X_train_t, y_train_t)
[?2004l[?2004h> preds_train_xgb = xgb.predict_proba(X_train_t)[:, 1]
[?2004l[?2004h> preds_hold_xgb = xgb.predict_proba(X_hold_t)[:, 1]
[?2004l[?2004h> print("Tuned XGB - Train AUC:", roc_auc_score(y_train_t, preds_train_xgb))
[?2004l[?2004h> print("Tuned XGB - Holdout AUC:", roc_auc_score(y_hold_t, preds_hold_xgb))
[?2004l[?2004h> 
[?2004l[?2004h> # 3. Tuned HistGB
[?2004l[?2004h> hgb = HistGradientBoostingClassifier(
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     max_depth=2,
[?2004l[?2004h>     learning_rate=0.01,
[?2004l[?2004h>     max_iter=150,
[?2004l[?2004h>     min_samples_leaf=50
[?2004l[?2004h> )
[?2004l[?2004h> hgb.fit(X_train_t, y_train_t)
[?2004l[?2004h> preds_train_hgb = hgb.predict_proba(X_train_t)[:, 1]
[?2004l[?2004h> preds_hold_hgb = hgb.predict_proba(X_hold_t)[:, 1]
[?2004l[?2004h> print("Tuned HistGB - Train AUC:", roc_auc_score(y_train_t, preds_train_hgb))
[?2004l[?2004h> print("Tuned HistGB - Holdout AUC:", roc_auc_score(y_hold_t, preds_hold_hgb))
