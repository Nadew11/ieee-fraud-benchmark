[?2004hroot@27e59b3c4e79:/workspace# cat << 'EOF' > test_model.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier
[?2004l[?2004h> from sklearn.preprocessing import LabelEncoder
[?2004l[?2004h> 
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> test = pd.read_csv('/data/test_identity.csv')
[?2004l[?2004h> test.columns = [c.replace('-', '_') for c in test.columns]
[?2004l[?2004h> 
[?2004l[?2004h> # Identify categorical columns
[?2004l[?2004h> cat_cols = train.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> print("Categorical columns:", cat_cols)
[?2004l[?2004h> 
[?2004l[?2004h> # For each categorical column, let's convert to category or encode as integer
[?2004l[?2004h> # Let's combine train and test for consistent encoding
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     train[col] = train[col].astype(str)
[?2004l[?2004h>     test[col] = test[col].astype(str)
[?2004l[?2004h>     
[?2004l[?2004h>     # Encode with LabelEncoder
[?2004l[?2004h>     le = LabelEncoder()
[?2004l[?2004h>     all_vals = pd.concat([train[col], test[col]], axis=0)
[?2004l[?2004h>     le.fit(all_vals)
[?2004l[?2004h>     train[col] = le.transform(train[col])
[?2004l[?2004h>     test[col] = le.transform(test[col])
[?2004l[?2004h> 
[?2004l[?2004h> # Split train into 80% train and 20% holdout
[?2004l[?2004h> X = train.drop(columns=['TransactionID', 'isFraud'])
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> X_train, X_holdout, y_train, y_holdout = train_test_split(
[?2004l[?2004h>     X, y, test_size=0.2, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # We can use HistGradientBoostingClassifier which naturally handles missing values and categorical ints
[?2004l[?2004h> model = HistGradientBoostingClassifier(random_state=42, max_iter=100)
[?2004l[?2004h> model.fit(X_train, y_train)
[?2004l[?2004h> 
[?2004l[?2004h> preds_train = model.predict_proba(X_train)[:, 1]
[?2004l[?2004h> preds_holdout = model.predict_proba(X_holdout)[:, 1]
[?2004l[?2004h> 
[?2004l[?2004h> print("Train AUC:", roc_auc_score(y_train, preds_train))
[?2004l[?2004h> print("Holdout AUC:", roc_auc_score(y_holdout, preds_holdout))
[?2004l[?2004h> 
