[?2004hroot@27e59b3c4e79:/workspace# cat << 'EOF' > generate_report.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.linear_model import LogisticRegression
[?2004l[?2004h> from sklearn.preprocessing import StandardScaler
[?2004l[?2004h> from sklearn.impute import SimpleImputer
[?2004l[?2004h> from sklearn.pipeline import Pipeline
[?2004l[?2004h> from sklearn.compose import ColumnTransformer
[?2004l[?2004h> from sklearn.preprocessing import OneHotEncoder
[?2004l[?2004h> import openpyxl
[?2004l[?2004h> 
[?2004l[?2004h> # 1. Load data
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> test = pd.read_csv('/data/test_identity.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate total rows
[?2004l[?2004h> total_train_rows = len(train)
[?2004l[?2004h> total_test_rows = len(test)
[?2004l[?2004h> 
[?2004l[?2004h> # Map test columns from - to _ so they match
[?2004l[?2004h> test_cols_original = list(test.columns)
[?2004l[?2004h> test.columns = [c.replace('-', '_') for c in test.columns]
[?2004l[?2004h> 
[?2004ll[?2004h> # Count shared features (both columns share TransactionID and 40 features, so 41 columns total)
[?2004l[?2004h> shared_features = list(set(train.columns).intersection(set(test.columns)))
[?2004l[?2004h> shared_feature_count = len(shared_features)
[?2004l[?2004h> print("Shared feature count:", shared_feature_count)
[?2004l[?2004h> 
[?2004l[?2004h> # Separate features and target
[?2004lariabl[?2004h> X = train.drop(columns=['TransactionID', 'isFraud'])
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> 
[?2004lr[?2004h> num_cols = X.select_dtypes(include=['int64', 'float64']).columns.tolist()
[?2004l[?2004h> cat_cols = X.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> 
[?2004l[?2004h> # Create a preprocessing pipeline
[?2004lified splitting during [?2004h> preprocessor = ColumnTransformer(
[?2004lholdout evaluation to ensure equal[?2004h>     transformers=[
[?2004l[?2004h>         ('num', Pipeline([
[?2004l[?2004h>             ('imputer', SimpleImputer(strategy='median')),
[?2004l[?2004h>             ('scaler', StandardScaler())
[?2004l[?2004h>         ]), num_cols),
[?2004l[?2004h>         ('cat', Pipeline([
[?2004l[?2004h>             ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),
[?2004lsol[?2004h>             ('ohe', OneHotEncoder(handle_unknown='ignore'))
[?2004lsx')[?2004h>         ]), cat_cols)
[?2004l[?2004h>     ]
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # Split train into 80% train and 20% holdout for AUC verification
[?2004l[?2004h> X_train, X_holdout, y_train, y_holdout = train_test_split(
[?2004l[?2004h>     X, y, test_size=0.2, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # We will use Logistic Regression with C=0.01
[?2004l[?2004h> model = Pipeline([
[?2004l[?2004h>     ('preprocessor', preprocessor),
[?2004l[?2004h>     ('lr', LogisticRegression(random_state=42, class_weight='balanced', max_iter=1000, C=0.01))
[?2004l[?2004h> ])
[?2004l[?2004h> 
[?2004l[?2004h> # Fit on X_train
[?2004l[?2004h> model.fit(X_train, y_train)
[?2004l[?2004h> 
[?2004l[?2004h> # Evaluate on X_holdout
[?2004l[?2004h> preds_holdout = model.predict_proba(X_holdout)[:, 1]
[?2004l[?2004h> holdout_auc = float(roc_auc_score(y_holdout, preds_holdout))
[?2004l[?2004h> print("Holdout AUC:", holdout_auc)
[?2004l[?2004h> 
[?2004l[?2004h> # Generate predictions for every row in test set
[?2004l[?2004h> test_features = test.drop(columns=['TransactionID'])
[?2004l[?2004h> test_preds = model.predict_proba(test_features)[:, 1]
[?2004l[?2004h> 
[?2004l[?2004h> predictions_df = pd.DataFrame({
[?2004l[?2004h>     'TransactionID': test['TransactionID'].astype(int),
[?2004l[?2004h>     'fraud_prob': test_preds.astype(float)
[?2004l[?2004h> })
[?2004l[?2004h> 
[?2004l[?2004h> # Create openpyxl workbook
[?2004l[?2004h> wb = openpyxl.Workbook()
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Setup Predictions sheet
[?2004l[?2004h> ws_pred = wb.active
[?2004l[?2004h> ws_pred.title = "Predictions"
[?2004l[?2004h> 
[?2004l[?2004h> # Write header
[?2004l[?2004h> ws_pred.append(['TransactionID', 'fraud_prob'])
