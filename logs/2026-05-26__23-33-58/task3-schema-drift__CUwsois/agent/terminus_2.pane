[?2004hroot@27e59b3c4e79:/workspace# cat << 'EOF' > feature_analysis.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> 
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> test = pd.read_csv('/data/test_identity.csv')
[?2004l[?2004h> test.columns = [c.replace('-', '_') for c in test.columns]
[?2004l[?2004h> 
[?2004l[?2004h> # Identify categorical columns
[?2004l[?2004h> cat_cols = train.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     train[col] = train[col].astype(str).replace('nan', np.nan)
[?2004l[?2004h>     # Map to numeric categories for simple AUC calculation
[?2004l[?2004h>     train[col] = pd.factorize(train[col])[0]
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check single feature AUCs
[?2004l[?2004h> X = train.drop(columns=['TransactionID', 'isFraud'])
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> X_train, X_holdout, y_train, y_holdout = train_test_split(
[?2004l[?2004h>     X, y, test_size=0.2, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> feature_aucs = []
[?2004l[?2004h> for col in X.columns:
[?2004l[?2004h>     # handle NaNs
[?2004l[?2004h>     col_train = X_train[col].fillna(X_train[col].median() if X_train[col].notnull().any() else 0)
[?2004l[?2004h>     col_holdout = X_holdout[col].fillna(X_train[col].median() if X_train[col].notnull().any() else 0)
[?2004l[?2004h>     
[?2004l[?2004h>     try:
[?2004l[?2004h>         auc_train = roc_auc_score(y_train, col_train)
[?2004l[?2004h>         if auc_train < 0.5: auc_train = 1.0 - auc_train
[?2004l[?2004h>         auc_hold = roc_auc_score(y_holdout, col_holdout)
[?2004l[?2004h>         if auc_hold < 0.5: auc_hold = 1.0 - auc_hold
[?2004l[?2004h>         feature_aucs.append({
[?2004l[?2004h>             'col': col,
[?2004l[?2004h>             'train_auc': auc_train,
[?2004l[?2004h>             'holdout_auc': auc_hold,
[?2004l[?2004h>             'null_pct': train[col].isnull().mean()
[?2004l[?2004h>         })
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         pass
[?2004l[?2004h> 
[?2004l[?2004h> df_auc = pd.DataFrame(feature_aucs).sort_values(by='holdout_auc', ascending=False)
