[?2004hroot@27e59b3c4e79:/workspace# cat << 'EOF' > test_different_models.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> from sklearn.preprocessing import LabelEncoder
[?2004l[?2004h> 
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> test = pd.read_csv('/data/test_identity.csv')
[?2004l[?2004h> test.columns = [c.replace('-', '_') for c in test.columns]
[?2004l[?2004h> 
[?2004l[?2004h> # Let's preserve NaNs correctly instead of converting to 'nan' string
[?2004l[?2004h> # Or map missing to an actual value, or let XGBoost handle them
[?2004l[?2004h> cat_cols = train.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> 
[?2004l[?2004h> # For categorical features, let's keep NaN as NaN and use pd.Categorical
[?2004l[?2004h> # or label encode while keeping NaNs as -1
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     train[col] = train[col].astype(str).replace('nan', np.nan)
[?2004l[?2004h>     test[col] = test[col].astype(str).replace('nan', np.nan)
[?2004l[?2004h>     
[?2004l[?2004h>     # Combine to fit label encoder, but keep NaN as -1
[?2004l[?2004h>     non_null_train = train[col].dropna()
[?2004l[?2004h>     non_null_test = test[col].dropna()
[?2004l[?2004h>     all_vals = pd.concat([non_null_train, non_null_test], axis=0).unique()
[?2004l[?2004h>     
[?2004l[?2004h>     le = LabelEncoder()
[?2004l[?2004h>     le.fit(all_vals)
[?2004l[?2004h>     
[?2004l[?2004h>     # Map only non-null
[?2004l[?2004h>     train.loc[train[col].notnull(), col] = le.transform(train.loc[train[col].notnull(), col])
[?2004l[?2004h>     test.loc[test[col].notnull(), col] = le.transform(test.loc[test[col].notnull(), col])
[?2004l[?2004h>     
[?2004l[?2004h>     train[col] = train[col].astype(float)
[?2004l[?2004h>     test[col] = test[col].astype(float)
[?2004l[?2004h> 
[?2004l[?2004h> # Split train into 80% train and 20% holdout
[?2004l[?2004h> X = train.drop(columns=['TransactionID', 'isFraud'])
[?2004l[?2004h> y = train['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> X_train, X_holdout, y_train, y_holdout = train_test_split(
[?2004l[?2004h>     X, y, test_size=0.2, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # Let's test standard XGBoost classifier
[?2004l[?2004h> xgb = XGBClassifier(random_state=42, eval_metric='logloss', max_depth=4, learning_rate=0.05, n_estimators=100)
[?2004l[?2004h> xgb.fit(X_train, y_train)
[?2004l[?2004h> preds_train_xgb = xgb.predict_proba(X_train)[:, 1]
[?2004l[?2004h> preds_holdout_xgb = xgb.predict_proba(X_holdout)[:, 1]
[?2004l[?2004h> print("XGBoost - Train AUC:", roc_auc_score(y_train, preds_train_xgb))
[?2004l[?2004h> print("XGBoost - Holdout AUC:", roc_auc_score(y_holdout, preds_holdout_xgb))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's test HistGradientBoosting with some regularization
[?2004l[?2004h> hgb = HistGradientBoostingClassifier(random_state=42, max_depth=3, learning_rate=0.05, max_iter=100)
[?2004l[?2004h> hgb.fit(X_train, y_train)
[?2004l[?2004h> preds_train_hgb = hgb.predict_proba(X_train)[:, 1]
[?2004l[?2004h> preds_holdout_hgb = hgb.predict_proba(X_holdout)[:, 1]
[?2004l[?2004h> print("HistGB - Train AUC:", roc_auc_score(y_train, preds_train_hgb))
[?2004l[?2004h> print("HistGB - Holdout AUC:", roc_auc_score(y_holdout, preds_holdout_hgb))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check a simple Random Forest
[?2004l[?2004h> from sklearn.ensemble import RandomForestClassifier
[?2004l[?2004h> from sklearn.impute import SimpleImputer
[?2004l[?2004h> from sklearn.pipeline import Pipeline
[?2004l[?2004h> rf_pipeline = Pipeline([
[?2004l[?2004h>     ('imputer', SimpleImputer(strategy='median')),
[?2004l[?2004h>     ('rf', RandomForestClassifier(random_state=42, max_depth=5, n_estimators=100, class_weight='balanced'))
[?2004l[?2004h> ])
[?2004l[?2004h> rf_pipeline.fit(X_train, y_train)
[?2004l[?2004h> preds_train_rf = rf_pipeline.predict_proba(X_train)[:, 1]
[?2004l[?2004h> preds_holdout_rf = rf_pipeline.predict_proba(X_holdout)[:, 1]
[?2004l[?2004h> print("RF - Train AUC:", roc_auc_score(y_train, preds_train_rf))
[?2004l[?2004h> print("RF - Holdout AUC:", roc_auc_score(y_holdout, preds_holdout_rf))
