[254.273789, "i", "cat << 'EOF' > verify_xlsx.py\nimport openpyxl\n\nwb = openpyxl.load_workbook('/output/fraud_risk.xlsx')\nprint(\"Sheet names:\", wb.sheetnames)\n\nws_pred = wb['Predictions']\nprint(\"Predictions sheet min/max row:\", ws_pred.min_row, ws_pred.max_row)\nprint(\"Predictions header:\", [cell.value for cell in ws_pred[1]])\nprint(\"Predictions sample row 2:\", [cell.value for cell in ws_pred[2]], \"types:\", [type(cell.value) for cell in ws_pred[2]])\n\nws_dq = wb['Data Quality Report']\nprint(\"Data Quality Report contents:\")\nfor r in range(1, 5):\n    print(f\"  {ws_dq.cell(row=r, column=1).value}: {ws_dq.cell(row=r, column=2).value} (type B={type(ws_dq.cell(row=r, column=2).value)})\")\n\nprint(\"Row 6:\", [ws_dq.cell(row=6, column=col).value for col in range(1, 4)])\nfor r in range(7, 11):\n    print(f\"  Row {r}:\", [ws_dq.cell(row=r, column=col).value for col in range(1, 4)])\n\nEOF\npython3 verify_xlsx.py\n"]
