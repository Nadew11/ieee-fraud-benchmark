[99.335235, "o", "\u001b[?2004h>     all_vals = pd.concat([train[col], test[col]], axis=0)\r\n\u001b[?2004l\r\u001b[?2004h>     le.fit(all_vals)\r\n\u001b[?2004l\r\u001b[?2004h>     train[col] = le.transform(train[col])\r\n\u001b[?2004l\r\u001b[?2004h>     test[col] = le.transform(test[col])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Split train into 80% train and 20% holdout\r\n\u001b[?2004l\r\u001b[?2004h> X = train.drop(columns=['TransactionID', 'isFraud'])\r\n\u001b[?2004l\r\u001b[?2004h> y = train['isFraud']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> X_train, X_holdout, y_train, y_holdout = train_test_split(\r\n\u001b[?2004l\r\u001b[?2004h>     X, y, test_size=0.2, random_state=42, stratify=y\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # We can use HistGradientBoostingClassifier which naturally handles missing values and categorical ints\r\n\u001b[?2004l\r\u001b[?2004h> model = HistGradientBoostingClassifier(random_state=42, max_iter=100)\r\n\u001b[?2004l\r\u001b[?2004h> model.fit(X_train, y_train)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> preds_train = model.predict_proba(X_train)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> preds_holdout = model.predict_proba(X_holdout)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Train AUC:\", roc_auc_score(y_train, preds_train))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Holdout AUC:\", roc_auc_score(y_holdout, preds_holdout))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
