[208.105223, "i", "cat << 'EOF' > check_mixed_types.py\nimport pandas as pd\ntrain = pd.read_csv('/data/train_identity.csv')\ntest = pd.read_csv('/data/test_identity.csv')\n\nfor col in train.columns:\n    types = train[col].dropna().map(type).unique()\n    if len(types) > 1:\n        print(f\"Train col {col} has mixed types: {types}\")\n\nfor col in test.columns:\n    types = test[col].dropna().map(type).unique()\n    if len(types) > 1:\n        print(f\"Test col {col} has mixed types: {types}\")\nEOF\npython3 check_mixed_types.py\n"]
[208.13064, "o", "cat << 'EOF' > check_mixed_types.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> train = pd.read_csv('/data/train_identity.csv')\r\n\u001b[?2004l\r\u001b[?2004h> test = pd.read_csv('/data/test_identity.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for col in train.columns:\r\n\u001b[?2004l\r\u001b[?2004h>     types = train[col].dropna().map(type).unique()\r\n\u001b[?2004l\r\u001b[?2004h>     if len(types) > 1:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Train col {col} has mixed types: {types}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for col in test.columns:\r\n\u001b[?2004l\r\u001b[?2004h>     types = test[col].dropna().map(type).unique()\r\n\u001b[?2004l\r\u001b[?2004h>     if len(types) > 1:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Test col {col} has mixed types: {types}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
