[46.633128, "i", "cat << 'EOF' > inspect_details.py\nimport pandas as pd\ntrain = pd.read_csv('/data/train_identity.csv')\ntest = pd.read_csv('/data/test_identity.csv')\ntest.columns = [c.replace('-', '_') for c in test.columns]\n\nprint(\"Train TransactionID unique:\", train['TransactionID'].nunique() == len(train))\nprint(\"Test TransactionID unique:\", test['TransactionID'].nunique() == len(test))\nprint(\"Train target distribution:\", train['isFraud'].value_counts())\n\n# Check for null values in both datasets\ntrain_nulls = train.isnull().mean()\ntest_nulls = test.isnull().mean()\nprint(\"Train columns with >50% nulls:\", (train_nulls > 0.5).sum())\nprint(\"Test columns with >50% nulls:\", (test_nulls > 0.5).sum())\n\n# Let's inspect some sample rows for anomalies\nprint(train.head())\nEOF\npython3 inspect_details.py\n"]
