'])\r\n\u001b[?2004l\r\u001b[?2004h> # Write predictions data\r\n\u001b[?2004l\r\u001b[?2004h> for r in predictions_df.itertuples(index=False):\r\n\u001b[?2004l\r\u001b[?2004h>     ws_pred.append([int(r.TransactionID), float(r.fraud_prob)])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 3. Setup Data Quality Report sheet\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq = wb.create_sheet(title=\"Data Quality Report\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # A1 = total_train_rows, B1 = numeric count\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['A1'] = 'total_train_rows'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['B1'] = int(total_train_rows)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # A2 = total_test_rows, B2 = numeric count\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['A2'] = 'total_test_rows'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['B2'] = int(total_test_rows)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # A3 = shared_feature_count, B3 = numeric count\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['A3'] = 'shared_feature_count'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['B3'] = int(shared_feature_count)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # A4 = model_auc_on_train_holdout, B4 = numeric AUC value\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['A4'] = 'model_auc_on_train_holdout'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['B4'] = float(holdout_auc)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Row 6 header = issue_number, description, resolution\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['A6'] = 'issue_number'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['B6'] = 'description'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['C6'] = 'resolution'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Starting at row 7, document issues\r\n\u001b[?2004l\r\u001b[?2004h> issues = [\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 1,\r\n\u001b[?2004l\r\u001b[?2004h"]
[223.953315, "o", ">         'description': \"Column naming mismatch between source systems: System A (train) uses underscore separators (e.g., id_01) while System B (test) uses hyphen separators (e.g., id-01).\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[223.953618, "o", "        'resolution': \"Standardized the column names of System B (test) by replacing all hyphens with underscores, aligning them perfectly with System A's naming schema to enable consistent pipeline ingestion.\"\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h"]
[223.955813, "o", ">         'issue_number': 2,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': \"High rate of missing values (NaNs) across features: There are 12 columns in train and 13 columns in test with missingness rates exceeding 50%.\",\r\n\u001b[?2004l\r\u001b[?2004h>         'resolution': \"Applied robust imputation strategies in the preprocessing pipeline: used median values for numerical columns and introduced a dedicated 'missing' string category for categorical columns.\"\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 3,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': \"Inconsistent categorical levels (Out of Vocabulary values) in test features: Columns like id_30, id_31, id_33, id_34, and DeviceInfo contain unique categories in test not seen in train.\",\r\n\u001b[?2004l\r\u001b[?2004h>         'resolution': \"Configured scikit-learn OneHotEncoder with the 'handle_unknown=\"ignore\"' parameter to ensure the model pipeline processes unseen categorical values gracefully without causing errors or failures.\"\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 4,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': \"Severe target class imbalance: The 'isFraud' target variable contains only 274 fraud cases (3.42%) out of 8,000 observations in the training dataset.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[223.956984, "o", "        'resolution': \"Employed class-weighted loss adjustment ('class_weight=\"balanced\"') in Logistic Regression, and applied stratified splitting during holdout evaluation to ensure equal target distribution in splits.\"\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for idx, issue in enumerate(issues, start=7):\r\n\u001b[?2004l\r\u001b[?2004h>     ws_dq.cell(row=idx, column=1, value=int(issue['issue_number']))\r\n\u001b[?2004l\r\u001b[?2004h>     ws_dq.cell(row=idx, column=2, value=str(issue['description']))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[223.957382, "o", "    ws_dq.cell(row=idx, column=3, value=str(issue['resolution']))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Save to file\r\n\u001b[?2004l\r\u001b[?2004h> "]
[223.957709, "o", "wb.save('/output/fraud_risk.xlsx')\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Saved workbook to /output/fraud_risk.xlsx successfully!\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
