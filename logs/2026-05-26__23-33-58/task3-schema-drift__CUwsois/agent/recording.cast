[35.581872, "i", "cat << 'EOF' > inspect_data.py\nimport pandas as pd\ntrain = pd.read_csv('/data/train_identity.csv')\ntest = pd.read_csv('/data/test_identity.csv')\n\n# Let's map test columns from - to _ so they match\ntest_cols_mapped = [c.replace('-', '_') for c in test.columns]\ntest.columns = test_cols_mapped\n\nprint(\"Are mapped columns identical (excluding isFraud)?\", set(train.columns) - {'isFraud'} == set(test.columns))\nprint(\"Train cols not in test:\", set(train.columns) - set(test.columns))\nprint(\"Test cols not in train:\", set(test.columns) - set(train.columns))\n\n# Let's look at numerical vs categorical\ncat_cols = train.select_dtypes(include=['object']).columns.tolist()\nprint(\"Categorical columns:\", cat_cols)\n\nfor col in cat_cols:\n    if col in test.columns:\n        train_unique = set(train[col].dropna().unique())\n        test_unique = set(test[col].dropna().unique())\n        diff_train_test = train_unique - test_unique\n        diff_test_train = test_unique - train_unique\n        if diff_train_test or diff_test_train:\n            print(f\"Column {col} has mismatch:\")\n            print(f\"  In train but not test: {list(diff_train_test)[:5]}\")\n            print(f\"  In test but not train: {list(diff_test_train)[:5]}\")\n\nEOF\npython3 inspect_data.py\n"]
