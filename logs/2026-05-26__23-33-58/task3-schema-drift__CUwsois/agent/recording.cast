[237.557703, "o", "> # Row 6 header = issue_number, description, resolution\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['A6'] = 'issue_number'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['B6'] = 'description'\r\n\u001b[?2004l\r\u001b[?2004h> ws_dq['C6'] = 'resolution'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Starting at row 7, document issues\r\n\u001b[?2004l\r\u001b[?2004h> issues = [\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 1,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': \"Column naming mismatch between source systems: System A (train) uses underscore separators (e.g., id_01) while System B (test) uses hyphen separators (e.g., id-01).\",\r\n\u001b[?2004l\r\u001b[?2004h>         'resolution': \"Standardized the column names of System B (test) by replacing all hyphens with underscores, aligning them perfectly with System A's naming schema to enable consistent pipeline ingestion.\"\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 2,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': \"High rate of missing values (NaNs) across features: There are 12 columns in train and 13 columns in test with missingness rates exceeding 50%.\",\r\n\u001b[?2004l\r\u001b[?2004h>         'resolution': \"Applied robust imputation strategies in the preprocessing pipeline: used median values for numerical columns and introduced a dedicated 'missing' string category for categorical columns.\"\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
