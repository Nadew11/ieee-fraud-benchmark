[124.547224, "o", "# Row 7+: Documentation of issues\r\n\u001b[?2004l\r\u001b[?2004h> issues = [\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 1,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': 'Feature name mismatch between System A (train) and System B (test) exports. System A used underscores (e.g., id_01) while System B used hyphens (e.g., id-01).',\r\n\u001b[?2004l\r\u001b[?2004h>         'resolution': 'Standardized and aligned all feature names by replacing hyphens with underscores in the test dataset to ensure correct feature matching during merging and model inference.'\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 2,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': 'Categorical columns (such as id_30, id_31, id_33, id_34, and DeviceInfo) contained new categories and levels in the test set that were not present in the training set.',\r\n\u001b[?2004l\r\u001b[?2004h>         'resolution': 'Implemented a robust ordinal encoding strategy that maps unseen levels/categories in the test or validation datasets to a fallback indicator of -1, preventing out-of-vocabulary errors.'\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         'issue_number': 3,\r\n\u001b[?2004l\r\u001b[?2004h>         'description': 'Severe missing values (sparsity) exceeding 96% in multiple identity features (e.g., id_24, id_25, id_07, id_08, id_26, id_23, id_27, id_22, id_21).',\r\n\u001b[?2004l\r\u001b[?2004h>         'resolution': 'Imputed numeric missing values with a designated placeholder (-999) to let the XGBoost classifier natively identify split paths for missing data, and filled missing categories with \"Missing\" prior to ordinal encoding.'\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for idx, issue in enumerate(issues, start=7):\r\n\u001b[?2004l\r\u001b[?2004h>     dq_sheet[f'A{idx}'] = int(issue['issue_number'])\r\n\u001b[?2004l\r\u001b[?2004h>     dq_sheet[f'B{idx}'] = str(issue['description'])\r\n\u001b[?2004l\r\u001b[?2004h>     dq_sheet[f'C{idx}'] = str(issue['resolution'])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Save the workbook\r\n\u001b[?2004l\r\u001b[?2004h> wb.save('/output/fraud_risk.xlsx')\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Excel file saved and verified successfully!\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@16de4ef61b18:/workspace# python3 run_pipeline.py\r\n\u001b[?2004l\r"]
