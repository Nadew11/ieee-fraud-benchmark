[150.125981, "i", "cat << 'EOF' > tune_model.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier\nimport xgboost as xgb\n\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntrain_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\n\ntarget_col = 'isFraud'\nfeature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\n\n# Split\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\nprint(\"Train class ratio:\", train_sub[target_col].mean())\nprint(\"Holdout class ratio:\", val_sub[target_col].mean())\n\n# Let's try simple preprocessing first\ncat_cols = train_df[feature_cols].select_dtypes(include=['object']).columns.tolist()\nnum_cols = train_df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\n\ndef preprocess(train_fit, df_to_transform):\n    df_out = df_to_transform.copy()\n    for col in num_cols:\n        df_out[col] = df_out[col].fillna(df_out[col].median() if not df_out[col].isna().all() else 0)\n    for col in cat_cols:\n        df_out[col] = df_out[col].fillna('Missing').astype(str)\n        # Fit categories\n        train_cats = train_fit[col].fillna('Missing').astype(str).unique()\n        cat_map = {cat: idx for idx, cat in enumerate(train_cats)}\n        df_out[col] = df_out[col].map(cat_map).fillna(-1).astype(int)\n    return df_out\n\ntrain_sub_proc = preprocess(train_sub, train_sub)\nval_sub_proc = preprocess(train_sub, val_sub)\n\n# 1. XGBoost\nclf_xgb = xgb.XGBClassifier(\n    n_estimators=100,\n    max_depth=4,\n    learning_rate=0.05,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    eval_metric='auc'\n)\nclf_xgb.fit(train_sub_proc[feature_cols], train_sub_proc[target_col])\nxgb_preds = clf_xgb.predict_proba(val_sub_proc[feature_cols])[:, 1]\nprint(f\"XGBoost AUC: {roc_auc_score(val_sub_proc[target_col], xgb_preds):.6f}\")\n\n# 2. HistGradientBoosting\nclf_hgb = HistGradientBoostingClassifier(random_state=42, max_iter=100)\nclf_hgb.fit(train_sub_proc[feature_cols], train_sub_proc[target_col])\nhgb_preds = clf_hgb.predict_proba(val_sub_proc[feature_cols])[:, 1]\nprint(f\"HistGradientBoosting AUC: {roc_auc_score(val_sub_proc[target_col], hgb_preds):.6f}\")\n\n# 3. RandomForest\nclf_rf = RandomForestClassifier(n_estimators=100, max_depth=8, random_state=42, class_weight='balanced')\nclf_rf.fit(train_sub_proc[feature_cols], train_sub_proc[target_col])\nrf_preds = clf_rf.predict_proba(val_sub_proc[feature_cols])[:, 1]\nprint(f\"Random Forest AUC: {roc_auc_score(val_sub_proc[target_col], rf_preds):.6f}\")\n\nEOF\npython3 tune_model.py\n"]
[150.166802, "o", "cat << 'EOF' > tune_model.py\r\n"]
[150.177032, "o", "\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.model_selection import train_test_split\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_df = pd.read_csv('/data/train_identity.csv')\r\n\u001b[?2004l\r\u001b[?2004h> train_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> target_col = 'isFraud'\r\n\u001b[?2004l\r\u001b[?2004h> feature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Split\r\n\u001b[?2004l\r\u001b[?2004h> train_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Train class ratio:\", train_sub[target_col].mean())\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Holdout class ratio:\", val_sub[target_col].mean())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's try simple preprocessing first\r\n\u001b[?2004l\r\u001b[?2004h> cat_cols = train_df[feature_cols].select_dtypes(include=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h> num_cols = train_df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def preprocess(train_fit, df_to_transform):\r\n\u001b[?2004l\r\u001b[?2004h>     df_out = df_to_transform.copy()\r\n\u001b[?2004l\r\u001b[?2004h>     for col in num_cols:\r\n\u001b[?2004l\r\u001b[?2004h>         df_out[col] = df_out[col].fillna(df_out[col].median() if not df_out[col].isna().all() else 0)\r\n\u001b[?2004l\r\u001b[?2004h>     for col in cat_cols:\r\n\u001b[?2004l\r\u001b[?2004h>         df_out[col] = df_out[col].fillna('Missing').astype(str)\r\n\u001b[?2004l\r\u001b[?2004h>         # Fit categories\r\n\u001b[?2004l\r\u001b[?2004h>         train_cats = train_fit[col].fillna('Missing').astype(str).unique()\r\n\u001b[?2004l\r\u001b[?2004h>         cat_map = {cat: idx for idx, cat in enumerate(train_cats)}\r\n\u001b[?2004l\r\u001b[?2004h>         df_out[col] = df_out[col].map(cat_map).fillna(-1).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h>     return df_out\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_sub_proc = preprocess(train_sub, train_sub)\r\n\u001b[?2004l\r\u001b[?2004h> val_sub_proc = preprocess(train_sub, val_sub)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 1. XGBoost\r\n\u001b[?2004l\r\u001b[?2004h> "]
[150.179514, "o", "clf_xgb = xgb.XGBClassifier(\r\n\u001b[?2004l\r\u001b[?2004h>     n_estimators=100,\r\n\u001b[?2004l\r\u001b[?2004h>     max_depth=4,\r\n\u001b[?2004l\r\u001b[?2004h>     learning_rate=0.05,\r\n\u001b[?2004l\r\u001b[?2004h>     subsample=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     colsample_bytree=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     random_state=42,\r\n\u001b[?2004l\r\u001b[?2004h>     use_label_encoder=False,\r\n\u001b[?2004l\r\u001b[?2004h>     eval_metric='auc'\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> clf_xgb.fit(train_sub_proc[feature_cols], train_sub_proc[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> xgb_preds = clf_xgb.predict_proba(val_sub_proc[feature_cols])[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"XGBoost AUC: {roc_auc_score(val_sub_proc[target_col], xgb_preds):.6f}\")\r\n\u001b[?2004l\r"]
