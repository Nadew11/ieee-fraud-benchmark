> clf = RandomForestClassifier(n_estimators=100, max_depth=5, random_state=42, class_weight='balanced')\r\n\u001b[?2004l\r\u001b[?2004h> clf.fit(X_train, train_sub[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> auc_rf = roc_auc_score(val_sub[target_col], clf.predict_proba(X_val)[:, 1])\r\n\u001b[?2004l\r\u001b[?2004h> print(f'Selected Features RF holdout AUC: {auc_rf:.6f}')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> clf_xgb = xgb.XGBClassifier(n_estimators=50, max_depth=3, learning_rate=0.05, random_state=42, eval_metric='auc')\r\n\u001b[?2004l\r\u001b[?2004h> clf_xgb.fit(X_train, train_sub[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> auc_xgb = roc_auc_score(val_sub[target_col], clf_xgb.predict_proba(X_val)[:, 1])\r\n\u001b[?2004l\r\u001b[?2004h> print(f'Selected Features XGB holdout AUC: {auc_xgb:.6f}')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
