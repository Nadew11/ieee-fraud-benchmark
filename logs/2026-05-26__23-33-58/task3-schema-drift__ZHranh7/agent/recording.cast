[168.885419, "i", "cat << 'EOF' > test_correlations.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score\n\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntrain_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\n\ntarget = train_df['isFraud']\nprint('Total cases:', len(train_df), 'Fraud cases:', target.sum())\n\nfor col in train_df.columns:\n    if col in ['isFraud', 'TransactionID']:\n        continue\n    if train_df[col].dtype in [np.float64, np.int64]:\n        valid_mask = train_df[col].notna()\n        if valid_mask.sum() > 10:\n            try:\n                auc = roc_auc_score(target[valid_mask], train_df.loc[valid_mask, col])\n                if auc < 0.45 or auc > 0.55:\n                    print(f'{col} (numeric): AUC = {auc:.4f} (non-null: {valid_mask.sum()})')\n            except Exception as e:\n                pass\n    else:\n        counts = train_df.groupby(col)['isFraud'].agg(['count', 'mean']).sort_values('count', ascending=False)\n        if (counts['mean'] - target.mean()).abs().max() > 0.05:\n            print(f'{col} (categorical):\\n', counts.head(5))\nEOF\npython3 test_correlations.py\n"]
[168.892559, "o", "cat << 'EOF' > test_correlations.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_df = pd.read_csv('/data/train_identity.csv')\r\n\u001b[?2004l\r\u001b[?2004h> train_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> target = train_df['isFraud']\r\n\u001b[?2004l\r\u001b[?2004h> print('Total cases:', len(train_df), 'Fraud cases:', target.sum())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for col in train_df.columns:\r\n\u001b[?2004l\r\u001b[?2004h>     if col in ['isFraud', 'TransactionID']:\r\n\u001b[?2004l\r\u001b[?2004h>         continue\r\n\u001b[?2004l\r\u001b[?2004h>     if train_df[col].dtype in [np.float64, np.int64]:\r\n\u001b[?2004l\r\u001b[?2004h>         valid_mask = train_df[col].notna()\r\n\u001b[?2004l\r\u001b[?2004h>         if valid_mask.sum() > 10:\r\n\u001b[?2004l\r\u001b[?2004h>             try:\r\n\u001b[?2004l\r\u001b[?2004h>                 auc = roc_auc_score(target[valid_mask], train_df.loc[valid_mask, col])\r\n\u001b[?2004l\r\u001b[?2004h>                 if auc < 0.45 or auc > 0.55:\r\n\u001b[?2004l\r\u001b[?2004h>                     print(f'{col} (numeric): AUC = {auc:.4f} (non-null: {valid_mask.sum()})')\r\n\u001b[?2004l\r\u001b[?2004h>             except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>                 pass\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         counts = train_df.groupby(col)['isFraud'].agg(['count', 'mean']).sort_values('count', ascending=False)\r\n\u001b[?2004l\r\u001b[?2004h>         if (counts['mean'] - target.mean()).abs().max() > 0.05:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f'{col} (categorical):\\n', counts.head(5))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
