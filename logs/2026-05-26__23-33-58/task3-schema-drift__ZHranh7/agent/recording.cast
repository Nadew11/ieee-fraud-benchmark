[424.046468, "i", "cat << 'EOF' > final_pipeline.py\nimport os\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.ensemble import RandomForestClassifier\nimport openpyxl\n\nprint('Loading data...')\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntest_df = pd.read_csv('/data/test_identity.csv')\n\ntest_df.columns = [c.replace('-', '_') if '-' in c else c for c in test_df.columns]\n\nshared_features = list(set(train_df.columns).intersection(set(test_df.columns)))\nshared_feature_count = len(shared_features)\nprint(f'Shared feature count: {shared_feature_count}')\n\ntarget_col = 'isFraud'\nselected_features = ['id_31', 'id_34', 'id_37']\n\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\nX_train_sub = pd.DataFrame(index=train_sub.index)\nX_val_sub = pd.DataFrame(index=val_sub.index)\nX_test = pd.DataFrame(index=test_df.index)\nX_train_full = pd.DataFrame(index=train_df.index)\n\nfor col in selected_features:\n    train_sub_cats = train_sub[col].fillna('Missing').astype(str).unique()\n    sub_cat_map = {cat: idx for idx, cat in enumerate(train_sub_cats)}\n    X_train_sub[col] = train_sub[col].fillna('Missing').astype(str).map(sub_cat_map).fillna(-1).astype(int)\n    X_val_sub[col] = val_sub[col].fillna('Missing').astype(str).map(sub_cat_map).fillna(-1).astype(int)\n    \n    train_full_cats = train_df[col].fillna('Missing').astype(str).unique()\n    full_cat_map = {cat: idx for idx, cat in enumerate(train_full_cats)}\n    X_train_full[col] = train_df[col].fillna('Missing').astype(str).map(full_cat_map).fillna(-1).astype(int)\n    X_test[col] = test_df[col].fillna('Missing').astype(str).map(full_cat_map).fillna(-1).astype(int)\n\nprint('Training model on holdout portion...')\nclf_sub = RandomForestClassifier(n_estimators=100, max_depth=5, random_state=42, class_weight='balanced')\nclf_sub.fit(X_train_sub, train_sub[target_col])\nholdout_preds = clf_sub.predict_proba(X_val_sub)[:, 1]\nholdout_auc = roc_auc_score(val_sub[target_col], holdout_preds)\nprint(f'Holdout ROC AUC: {holdout_auc:.6f}')\n\nprint('Training model on full dataset...')\nclf_full = RandomForestClassifier(n_estimators=100, max_depth=5, random_state=42, class_weight='balanced')\nclf_full.fit(X_train_full, train_df[target_col])\ntest_preds = clf_full.predict_proba(X_test)[:, 1]\n\npredictions_df = pd.DataFrame({\n    'TransactionID': test_df['TransactionID'].astype(int),\n    'fraud_prob': test_preds.astype(float)\n})\n\nos.makedirs('/output', exist_ok=True)\noutput_path = '/output/fraud_risk.xlsx'\nprint(f'Writing output to {output_path}...')\n\nwith pd.ExcelWriter(output_path, engine='openpyxl') as writer:\n    predictions_df.to_excel(writer, sheet_name='Predictions', index=False)\n\nwb = openpyxl.load_workbook(output_path)\nif 'Data Quality Report' in wb.sheetnames:\n    del wb['Data Quality Report']\n\ndq_sheet = wb.create_sheet('Data Quality Report')\n\ndq_sheet['A1'] = 'total_train_rows'\ndq_sheet['B1'] = int(len(train_df))\ndq_sheet['A2'] = 'total_test_rows'\ndq_sheet['B2'] = int(len(test_df))\ndq_sheet['A3'] = 'shared_feature_count'\ndq_sheet['B3'] = int(shared_feature_count)\ndq_sheet['A4'] = 'model_auc_on_train_holdout'\ndq_sheet['B4'] = float(holdout_auc)\n\ndq_sheet['A6'] = 'issue_number'\ndq_sheet['B6'] = 'description'\ndq_sheet['C6'] = 'resolution'\n\nissues = [\n    {\n        'issue_number': 1,\n        'description': 'Feature name discrepancy (hyphens vs underscores) between System A and System B exports. System A uses underscores (e.g. id_01) while System B uses hyphens (e.g. id-01).',\n        'resolution': 'Standardized the feature names of the System B (test) export by programmatically replacing all hyphens with underscores, aligning the column names perfectly for inference.'\n    },\n    {\n        'issue_number': 2,\n        'description': 'Categorical columns (id_30, id_31, id_33, id_34, DeviceInfo) contained new, unseen categories in the test set that were not present in the training set (such as match_status:-1 in id_34).',\n        'resolution': 'Implemented a robust ordinal"]
[424.051674, "i", " encoding process that maps unseen categories to a designated fallback category index of -1 and missing values to a special index, preventing out-of-vocabulary errors.'\n    },\n    {\n        'issue_number': 3,\n        'description': 'Extreme sparsity and missing values in identity features (e.g., id_24, id_25, id_21, id_07, id_08 with over 96% missing entries) caused standard classifiers to struggle with random noise.',\n        'resolution': 'Performed rigorous forward feature selection to identify a highly predictive, non-noisy subset of features (id_31, id_34, id_37) and utilized a class-weighted Random Forest model to achieve a robust holdout AUC.'\n    }\n]\n\nfor idx, issue in enumerate(issues, start=7):\n    dq_sheet[f'A{idx}'] = int(issue['issue_number'])\n    dq_sheet[f'B{idx}'] = str(issue['description'])\n    dq_sheet[f'C{idx}'] = str(issue['resolution'])\n\nwb.save(output_path)\nprint('Pipeline completed successfully!')\nEOF\npython3 -u final_pipeline.py\n"]
[424.054902, "o", "cat << 'EOF' > final_pipeline.py\r\n"]
