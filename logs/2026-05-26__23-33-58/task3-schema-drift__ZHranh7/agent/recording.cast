[185.395045, "i", "cat << 'EOF' > test_simple_models.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.tree import DecisionTreeClassifier\nfrom sklearn.ensemble import ExtraTreesClassifier\nimport xgboost as xgb\n\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntrain_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\n\ntarget_col = 'isFraud'\nfeature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\n\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\nnum_cols = train_df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\n\nX_train_num = train_sub[num_cols].fillna(0)\nX_val_num = val_sub[num_cols].fillna(0)\n\nlr = LogisticRegression(max_iter=1000, random_state=42, class_weight='balanced')\nlr.fit(X_train_num, train_sub[target_col])\nauc_lr = roc_auc_score(val_sub[target_col], lr.predict_proba(X_val_num)[:, 1])\nprint(f'Logistic Regression (numeric only) AUC: {auc_lr:.6f}')\n\ndt = DecisionTreeClassifier(max_depth=3, random_state=42, class_weight='balanced')\ndt.fit(X_train_num, train_sub[target_col])\nauc_dt = roc_auc_score(val_sub[target_col], dt.predict_proba(X_val_num)[:, 1])\nprint(f'Decision Tree (numeric only, depth 3) AUC: {auc_dt:.6f}')\n\nclf_xgb = xgb.XGBClassifier(n_estimators=50, max_depth=3, learning_rate=0.05, random_state=42, use_label_encoder=False, eval_metric='auc')\nclf_xgb.fit(X_train_num, train_sub[target_col])\nauc_xgb = roc_auc_score(val_sub[target_col], clf_xgb.predict_proba(X_val_num)[:, 1])\nprint(f'XGBoost (numeric only) AUC: {auc_xgb:.6f}')\nEOF\npython3 test_simple_models.py\n"]
[185.397816, "o", "cat << 'EOF' > test_simple_models.py\r\n\u001b[?2004l\r"]
[185.397955, "o", "\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.model_selection import train_test_split\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.linear_model import LogisticRegression\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.tree import DecisionTreeClassifier\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.ensemble import ExtraTreesClassifier\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_df = pd.read_csv('/data/train_identity.csv')\r\n\u001b[?2004l\r\u001b[?2004h> train_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> target_col = 'isFraud'\r\n\u001b[?2004l\r\u001b[?2004h> feature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[185.401851, "o", "train_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> num_cols = train_df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> X_train_num = train_sub[num_cols].fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h> X_val_num = val_sub[num_cols].fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> lr = LogisticRegression(max_iter=1000, random_state=42, class_weight='balanced')\r\n\u001b[?2004l\r\u001b[?2004h> lr.fit(X_train_num, train_sub[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> auc_lr = roc_auc_score(val_sub[target_col], lr.predict_proba(X_val_num)[:, 1])\r\n\u001b[?2004l\r\u001b[?2004h> print(f'Logistic Regression (numeric only) AUC: {auc_lr:.6f}')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> dt = DecisionTreeClassifier(max_depth=3, random_state=42, class_weight='balanced')\r\n\u001b[?2004l\r\u001b[?2004h> dt.fit(X_train_num, train_sub[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> auc_dt = roc_auc_score(val_sub[target_col], dt.predict_proba(X_val_num)[:, 1])\r\n\u001b[?2004l\r\u001b[?2004h> print(f'Decision Tree (numeric only, depth 3) AUC: {auc_dt:.6f}')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> clf_xgb = xgb.XGBClassifier(n_estimators=50, max_depth=3, learning_rate=0.05, random_state=42, use_label_encoder=False, eval_metric='auc')\r\n\u001b[?2004l\r\u001b[?2004h> clf_xgb.fit(X_train_num, train_sub[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> auc_xgb = roc_auc_score(val_sub[target_col], clf_xgb.predict_proba(X_val_num)[:, 1])\r\n\u001b[?2004l\r\u001b[?2004h> print(f'XGBoost (numeric only) AUC: {auc_xgb:.6f}')\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
