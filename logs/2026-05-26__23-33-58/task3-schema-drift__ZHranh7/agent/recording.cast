[339.396694, "i", "cat << 'EOF' > test_target_encoding.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.ensemble import RandomForestClassifier, ExtraTreesClassifier\nimport xgboost as xgb\n\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntrain_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\n\ntarget_col = 'isFraud'\nfeature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\n\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\nX_train = pd.DataFrame(index=train_sub.index)\nX_val = pd.DataFrame(index=val_sub.index)\n\nnum_cols = train_df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\nfor col in num_cols:\n    median_val = train_sub[col].median()\n    if pd.isna(median_val):\n        median_val = 0\n    X_train[col] = train_sub[col].fillna(median_val)\n    X_val[col] = val_sub[col].fillna(median_val)\n\ncat_cols = train_df[feature_cols].select_dtypes(include=['object']).columns.tolist()\nfor col in cat_cols:\n    global_mean = train_sub[target_col].mean()\n    category_means = train_sub.groupby(col)[target_col].mean()\n    \n    m = 10\n    counts = train_sub.groupby(col)[target_col].count()\n    smooth_means = (counts * category_means + m * global_mean) / (counts + m)\n    \n    X_train[col] = train_sub[col].map(smooth_means).fillna(global_mean)\n    X_val[col] = val_sub[col].map(smooth_means).fillna(global_mean)\n\nprint('Features shape:', X_train.shape)\n\nclf_rf = RandomForestClassifier(n_estimators=100, max_depth=6, random_state=42, class_weight='balanced')\nclf_rf.fit(X_train, train_sub[target_col])\nauc_rf = roc_auc_score(val_sub[target_col], clf_rf.predict_proba(X_val)[:, 1])\nprint(f'RF with smoothed target encoding AUC: {auc_rf:.6f}')\n\nclf_et = ExtraTreesClassifier(n_estimators=100, max_depth=6, random_state=42, class_weight='balanced')\nclf_et.fit(X_train, train_sub[target_col])\nauc_et = roc_auc_score(val_sub[target_col], clf_et.predict_proba(X_val)[:, 1])\nprint(f'ET with smoothed target encoding AUC: {auc_et:.6f}')\n\nclf_xgb = xgb.XGBClassifier(n_estimators=100, max_depth=4, learning_rate=0.05, random_state=42, eval_metric='auc')\nclf_xgb.fit(X_train, train_sub[target_col])\nauc_xgb = roc_auc_score(val_sub[target_col], clf_xgb.predict_proba(X_val)[:, 1])\nprint(f'XGB with smoothed target encoding AUC: {auc_xgb:.6f}')\nEOF\npython3 -u test_target_encoding.py\n"]
[339.400204, "o", "cat << 'EOF' > test_target_encoding.py\r\n\u001b[?2004l\r"]
