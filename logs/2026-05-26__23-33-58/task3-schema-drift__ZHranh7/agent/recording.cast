[296.024474, "i", "cat << 'EOF' > test_missing_indicators.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.ensemble import RandomForestClassifier\nimport xgboost as xgb\n\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntrain_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\n\ntarget_col = 'isFraud'\nfeature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\n\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\ndef create_features(df, train_ref=None):\n    X = pd.DataFrame(index=df.index)\n    num_cols = df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\n    for col in num_cols:\n        X[col] = df[col].fillna(0)\n        X[f'{col}_isna'] = df[col].isna().astype(int)\n    \n    cat_cols = df[feature_cols].select_dtypes(include=['object']).columns.tolist()\n    for col in cat_cols:\n        if train_ref is not None:\n            freq = train_ref[col].value_counts()\n        else:\n            freq = df[col].value_counts()\n        X[col] = df[col].map(freq).fillna(0)\n        X[f'{col}_isna'] = df[col].isna().astype(int)\n    return X\n\nX_train = create_features(train_sub, train_sub)\nX_val = create_features(val_sub, train_sub)\n\nprint('Features shape:', X_train.shape)\n\nclf_rf = RandomForestClassifier(n_estimators=100, max_depth=6, random_state=42, class_weight='balanced')\nclf_rf.fit(X_train, train_sub[target_col])\nauc_rf = roc_auc_score(val_sub[target_col], clf_rf.predict_proba(X_val)[:, 1])\nprint(f'RF with missing indicators AUC: {auc_rf:.6f}')\n\nclf_xgb = xgb.XGBClassifier(n_estimators=100, max_depth=4, learning_rate=0.05, random_state=42, eval_metric='auc')\nclf_xgb.fit(X_train, train_sub[target_col])\nauc_xgb = roc_auc_score(val_sub[target_col], clf_xgb.predict_proba(X_val)[:, 1])\nprint(f'XGB with missing indicators AUC: {auc_xgb:.6f}')\nEOF\npython3 -u test_missing_indicators.py\n"]
[296.03157, "o", "cat << 'EOF' > test_missing_indicators.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.model_selection import train_test_split\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.ensemble import RandomForestClassifier\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_df = pd.read_csv('/data/train_identity.csv')\r\n\u001b[?2004l\r\u001b[?2004h> train_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> target_col = 'isFraud'\r\n\u001b[?2004l\r\u001b[?2004h> feature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def create_features(df, train_ref=None):\r\n\u001b[?2004l\r\u001b[?2004h>     X = pd.DataFrame(index=df.index)\r\n\u001b[?2004l\r\u001b[?2004h>     num_cols = df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h>     for col in num_cols:\r\n\u001b[?2004l\r\u001b[?2004h>         X[col] = df[col].fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h>         X[f'{col}_isna'] = df[col].isna().astype(int)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     cat_cols = df[feature_cols].select_dtypes(include=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h>     for col in cat_cols:\r\n\u001b[?2004l\r\u001b[?2004h>         if train_ref is not None:\r\n\u001b[?2004l\r\u001b[?2004h>             freq = train_ref[col].value_counts()\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             freq = df[col].value_counts()\r\n\u001b[?2004l\r\u001b[?2004h>         X[col] = df[col].map(freq).fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h>         X[f'{col}_isna'] = df[col].isna().astype(int)\r\n\u001b[?2004l\r\u001b[?2004h>     return X\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> X_train = create_features(train_sub, train_sub)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[296.031712, "o", "X_val = create_features(val_sub, train_sub)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print('Features shape:', X_train.shape)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> clf_rf = RandomForestClassifier(n_estimators=100, max_depth=6, random_state=42, class_weight='balanced')\r\n\u001b[?2004l\r\u001b[?2004h> clf_rf.fit(X_train, train_sub[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> auc_rf = roc_auc_score(val_sub[target_col], clf_rf.predict_proba(X_val)[:, 1])\r\n\u001b[?2004l\r\u001b[?2004h> print(f'RF with missing indicators AUC: {auc_rf:.6f}')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> clf_xgb = xgb.XGBClassifier(n_estimators=100, max_depth=4, learning_rate=0.05, random_state=42, eval_metric='auc')\r\n\u001b[?2004l\r\u001b[?2004h> clf_xgb.fit(X_train, train_sub[target_col])\r\n\u001b[?2004l\r\u001b[?2004h> auc_xgb = roc_auc_score(val_sub[target_col], clf_xgb.predict_proba(X_val)[:, 1])\r\n\u001b[?2004l\r\u001b[?2004h> print(f'XGB with missing indicators AUC: {auc_xgb:.6f}')\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
