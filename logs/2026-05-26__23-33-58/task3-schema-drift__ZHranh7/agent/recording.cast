[318.608362, "i", "cat << 'EOF' > feature_selection.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.ensemble import RandomForestClassifier\nimport xgboost as xgb\n\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntrain_df.columns = [c.replace('-', '_') if '-' in c else c for c in train_df.columns]\n\ntarget_col = 'isFraud'\n\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\nsignal_features = []\n\nfor col in train_df.columns:\n    if col in ['isFraud', 'TransactionID']:\n        continue\n    \n    if train_df[col].dtype in [np.float64, np.int64]:\n        valid_mask = train_sub[col].notna()\n        if valid_mask.sum() > 5:\n            try:\n                auc = roc_auc_score(train_sub.loc[valid_mask, target_col], train_sub.loc[valid_mask, col])\n                if abs(auc - 0.5) > 0.05:\n                    signal_features.append((col, auc, 'numeric'))\n            except:\n                pass\n    else: \n        valid_mask = train_sub[col].notna()\n        if valid_mask.sum() > 5:\n            means = train_sub.groupby(col)[target_col].mean()\n            encoded_train = train_sub[col].map(means).fillna(0)\n            try:\n                auc = roc_auc_score(train_sub[target_col], encoded_train)\n                if abs(auc - 0.5) > 0.05:\n                    signal_features.append((col, auc, 'categorical'))\n            except:\n                pass\n\nprint(f'Found {len(signal_features)} signal features:')\nfor f, auc, t in sorted(signal_features, key=lambda x: abs(x[1]-0.5), reverse=True):\n    print(f'  {f} ({t}): AUC = {auc:.4f}')\n\ntop_features = [x[0] for x in sorted(signal_features, key=lambda x: abs(x[1]-0.5), reverse=True)[:10]]\nprint('Top 10 selected features:', top_features)\n\nX_train = pd.DataFrame(index=train_sub.index)\nX_val = pd.DataFrame(index=val_sub.index)\n\nfor col in top_features:\n    col_type = [x[2] for x in signal_features if x[0] == col][0]\n    if col_type == 'numeric':\n        X_train[col] = train_sub[col].fillna(train_sub[col].median() if not train_sub[col].isna().all() else 0)\n        X_val[col] = val_sub[col].fillna(train_sub[col].median() if not train_sub[col].isna().all() else 0)\n    else:\n        means = train_sub.groupby(col)[target_col].mean()\n        X_train[col] = train_sub[col].map(means).fillna(train_sub[target_col].mean())\n        X_val[col] = val_sub[col].map(means).fillna(train_sub[target_col].mean())\n\nclf = RandomForestClassifier(n_estimators=100, max_depth=5, random_state=42, class_weight='balanced')\nclf.fit(X_train, train_sub[target_col])\nauc_rf = roc_auc_score(val_sub[target_col], clf.predict_proba(X_val)[:, 1])\nprint(f'Selected Features RF holdout AUC: {auc_rf:.6f}')\n\nclf_xgb = xgb.XGBClassifier(n_estimators=50, max_depth=3, learning_rate=0.05, random_state=42, eval_metric='auc')\nclf_xgb.fit(X_train, train_sub[target_col])\nauc_xgb = roc_auc_score(val_sub[target_col], clf_xgb.predict_proba(X_val)[:, 1])\nprint(f'Selected Features XGB holdout AUC: {auc_xgb:.6f}')\n\nEOF\npython3 -u feature_selection.py\n"]
