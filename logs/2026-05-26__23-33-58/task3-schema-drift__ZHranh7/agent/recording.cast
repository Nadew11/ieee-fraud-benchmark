[124.508209, "i", "cat << 'EOF' > run_pipeline.py\nimport os\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\nprint(\"Loading data...\")\ntrain_df = pd.read_csv('/data/train_identity.csv')\ntest_df = pd.read_csv('/data/test_identity.csv')\n\noriginal_test_cols = test_df.columns.tolist()\n\n# Issue 1: Standardize feature names\ntest_df.columns = [c.replace('-', '_') if '-' in c else c for c in test_df.columns]\n\n# Count shared features after standardization\nshared_features = list(set(train_df.columns).intersection(set(test_df.columns)))\nshared_feature_count = len(shared_features)\nprint(f\"Shared feature count: {shared_feature_count}\")\n\n# Define target and features\ntarget_col = 'isFraud'\nfeature_cols = [c for c in train_df.columns if c != target_col and c != 'TransactionID']\n\n# Train/Holdout split (80-20, stratified)\ntrain_sub, val_sub = train_test_split(train_df, test_size=0.20, random_state=42, stratify=train_df[target_col])\n\n# Categorical and Numeric column split\ncat_cols = train_df[feature_cols].select_dtypes(include=['object']).columns.tolist()\nnum_cols = train_df[feature_cols].select_dtypes(exclude=['object']).columns.tolist()\n\n# Preprocess function\ndef preprocess_data(train_fit, df_to_transform):\n    df_out = df_to_transform.copy()\n    \n    # Impute numeric\n    for col in num_cols:\n        df_out[col] = df_out[col].fillna(-999)\n    \n    # Ordinal encode categorical\n    for col in cat_cols:\n        df_out[col] = df_out[col].fillna('Missing').astype(str)\n        # Fit categories on train_fit\n        train_cats = train_fit[col].fillna('Missing').astype(str).unique()\n        cat_map = {cat: idx for idx, cat in enumerate(train_cats)}\n        # Map categories, default unseen to -1\n        df_out[col] = df_out[col].map(cat_map).fillna(-1).astype(int)\n        \n    return df_out\n\nprint(\"Preprocessing holdout split...\")\ntrain_sub_proc = preprocess_data(train_sub, train_sub)\nval_sub_proc = preprocess_data(train_sub, val_sub)\n\n# Train model on holdout split\nclf = xgb.XGBClassifier(\n    n_estimators=100,\n    max_depth=5,\n    learning_rate=0.1,\n    random_state=42,\n    use_label_encoder=False,\n    eval_metric='auc'\n)\n\nclf.fit(train_sub_proc[feature_cols], train_sub_proc[target_col])\n\nval_preds = clf.predict_proba(val_sub_proc[feature_cols])[:, 1]\nholdout_auc = roc_auc_score(val_sub_proc[target_col], val_preds)\nprint(f\"Model AUC on holdout: {holdout_auc:.6f}\")\n\n# Train final model on full train\nprint(\"Preprocessing full train and test...\")\ntrain_full_proc = preprocess_data(train_df, train_df)\ntest_proc = preprocess_data(train_df, test_df)\n\nfinal_clf = xgb.XGBClassifier(\n    n_estimators=100,\n    max_depth=5,\n    learning_rate=0.1,\n    random_state=42,\n    use_label_encoder=False,\n    eval_metric='auc'\n)\nfinal_clf.fit(train_full_proc[feature_cols], train_full_proc[target_col])\n\ntest_preds = final_clf.predict_proba(test_proc[feature_cols])[:, 1]\n\n# Create predictions df\npredictions_df = pd.DataFrame({\n    'TransactionID': test_df['TransactionID'],\n    'fraud_prob': test_preds\n})\n\n# Make sure numeric values are stored as float, TransactionID as int\npredictions_df['TransactionID'] = predictions_df['TransactionID'].astype(int)\npredictions_df['fraud_prob'] = predictions_df['fraud_prob'].astype(float)\n\n# Check shapes and counts\ntotal_train_rows = len(train_df)\ntotal_test_rows = len(test_df)\n\nprint(f\"Writing output to /output/fraud_risk.xlsx...\")\n\n# Write to Excel using openpyxl directly or via pandas ExcelWriter\nwith pd.ExcelWriter('/output/fraud_risk.xlsx', engine='openpyxl') as writer:\n    # 1. Predictions Sheet\n    predictions_df.to_excel(writer, sheet_name='Predictions', index=False)\n    \n    # 2. Data Quality Report Sheet\n    # We will build it manually using openpyxl or writes\n    workbook = writer.book\n    \n# Use openpyxl to write Data Quality Report cleanly\nimport openpyxl\nwb = openpyxl.load_workbook('/output/fraud_risk.xlsx')\n\n# If Data Quality Report exists, remove it first to rebuild\nif 'Data Quality Report' in wb.sheetnames:\n    del wb['Data Quality"]
[124.512889, "i", " Report']\n\ndq_sheet = wb.create_sheet('Data Quality Report')\n\n# Rows 1-4: Metrics\ndq_sheet['A1'] = 'total_train_rows'\ndq_sheet['B1'] = int(total_train_rows)\ndq_sheet['A2'] = 'total_test_rows'\ndq_sheet['B2'] = int(total_test_rows)\ndq_sheet['A3'] = 'shared_feature_count'\ndq_sheet['B3'] = int(shared_feature_count)\ndq_sheet['A4'] = 'model_auc_on_train_holdout'\ndq_sheet['B4'] = float(holdout_auc)\n\n# Row 6: Header\ndq_sheet['A6'] = 'issue_number'\ndq_sheet['B6'] = 'description'\ndq_sheet['C6'] = 'resolution'\n\n# Row 7+: Documentation of issues\nissues = [\n    {\n        'issue_number': 1,\n        'description': 'Feature name mismatch between System A (train) and System B (test) exports. System A used underscores (e.g., id_01) while System B used hyphens (e.g., id-01).',\n        'resolution': 'Standardized and aligned all feature names by replacing hyphens with underscores in the test dataset to ensure correct feature matching during merging and model inference.'\n    },\n    {\n        'issue_number': 2,\n        'description': 'Categorical columns (such as id_30, id_31, id_33, id_34, and DeviceInfo) contained new categories and levels in the test set that were not present in the training set.',\n        'resolution': 'Implemented a robust ordinal encoding strategy that maps unseen levels/categories in the test or validation datasets to a fallback indicator of -1, preventing out-of-vocabulary errors.'\n    },\n    {\n        'issue_number': 3,\n        'description': 'Severe missing values (sparsity) exceeding 96% in multiple identity features (e.g., id_24, id_25, id_07, id_08, id_26, id_23, id_27, id_22, id_21).',\n        'resolution': 'Imputed numeric missing values with a designated placeholder (-999) to let the XGBoost classifier natively identify split paths for missing data, and filled missing categories with \"Missing\" prior to ordinal encoding.'\n    }\n]\n\nfor idx, issue in enumerate(issues, start=7):\n    dq_sheet[f'A{idx}'] = int(issue['issue_number'])\n    dq_sheet[f'B{idx}'] = str(issue['description'])\n    dq_sheet[f'C{idx}'] = str(issue['resolution'])\n\n# Save the workbook\nwb.save('/output/fraud_risk.xlsx')\nprint(\"Excel file saved and verified successfully!\")\n\nEOF\npython3 run_pipeline.py\n"]
[124.513656, "o", "cat << 'EOF' > run_pipeline.py\r\n\u001b[?2004l\r Report']\r\n\r\ndq_sheet = wb.create\u001b[?2004h> "]
