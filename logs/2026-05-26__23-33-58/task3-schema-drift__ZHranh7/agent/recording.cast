[124.542666, "o", "    predictions_df.to_excel(writer, sheet_name='Predictions', index=False)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # 2. Data Quality Report Sheet\r\n\u001b[?2004l\r\u001b[?2004h>     # We will build it manually using openpyxl or writes\r\n\u001b[?2004l\r\u001b[?2004h>     workbook = writer.book\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> # Use openpyxl to write Data Quality Report cleanly\r\n\u001b[?2004l\r\u001b[?2004h> import openpyxl\r\n\u001b[?2004l\r\u001b[?2004h> wb = openpyxl.load_workbook('/output/fraud_risk.xlsx')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # If Data Quality Report exists, remove it first to rebuild\r\n\u001b[?2004l\r\u001b[?2004h> if 'Data Quality Report' in wb.sheetnames:\r\n\u001b[?2004l\r\u001b[?2004h>     del wb['Data Quality Report']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet = wb.create_sheet('Data Quality Report')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Rows 1-4: Metrics\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['A1'] = 'total_train_rows'\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['B1'] = int(total_train_rows)\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['A2'] = 'total_test_rows'\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['B2'] = int(total_test_rows)\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['A3'] = 'shared_feature_count'\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['B3'] = int(shared_feature_count)\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['A4'] = 'model_auc_on_train_holdout'\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['B4'] = float(holdout_auc)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Row 6: Header\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['A6'] = 'issue_number'\r\n\u001b[?2004l\r\u001b[?2004h> dq_sheet['B6'] = 'description'\r\n\u001b[?2004l\r\u001b[?2004h> "]
