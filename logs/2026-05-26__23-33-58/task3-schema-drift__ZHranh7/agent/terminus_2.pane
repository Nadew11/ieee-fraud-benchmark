[?2004hroot@16de4ef61b18:/workspace# cat << 'EOF' > detailed_inspect.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> train = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> test = pd.read_csv('/data/test_identity.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Rename test columns to match train columns (using underscores)
[?2004l[?2004h> test.columns = [c.replace('-', '_') if '-' in c else c for c in test.columns]
[?2004l[?2004h> 
[?2004l[?2004h> # Let's see if column sets now match (excluding isFraud)
[?2004l[?2004h> train_features = [c for c in train.columns if c != 'isFraud']
[?2004l[?2004h> test_features = test.columns.tolist()
[?2004l[?2004h> 
[?2004l[?2004h> print("Features match exactly after renaming:", set(train_features) == set(test_features))
[?2004l[?2004h> print("Shared features length:", len(set(train_features).intersection(set(test_features))))
[?2004l[?2004h> 
[?2004l[?2004h> # Check categorical columns vs numeric columns
[?2004l[?2004h> cat_cols = train[train_features].select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> print("Categorical columns:", cat_cols)
[?2004l[?2004h> 
[?2004l[?2004h> # Compare categories for each categorical column in both datasets
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     train_cats = set(train[col].dropna().unique())
[?2004l[?2004h>     test_cats = set(test[col].dropna().unique())
[?2004l[?2004h>     diff_train_test = train_cats - test_cats
[?2004l[?2004h>     diff_test_train = test_cats - train_cats
[?2004l[?2004h>     if diff_train_test or diff_test_train:
[?2004l[?2004h>         print(f"Category mismatch in {col}:")
[?2004l[?2004h>         print(f"  In train but not test: {diff_train_test}")
[?2004l[?2004h>         print(f"  In test but not train: {diff_test_train}")
[?2004l[?2004h> 
[?2004l[?2004h> # Check missing value percentage per column
[?2004l[?2004h> missing_train = train[train_features].isnull().mean()
[?2004l[?2004h> missing_test = test.isnull().mean()
[?2004l[?2004h> print("Top missing train:\n", missing_train.sort_values(ascending=False).head(5))
[?2004l[?2004h> print("Top missing test:\n", missing_test.sort_values(ascending=False).head(5))
[?2004l[?2004h> 
[?2004l[?2004h> EOF
