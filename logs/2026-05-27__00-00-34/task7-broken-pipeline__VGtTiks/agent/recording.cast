[304.500086, "i", "cat << 'EOF' > check_overlap.py\nimport pandas as pd\ndf = pd.read_csv('/data/train_transaction.csv').sort_values('TransactionDT').reset_index(drop=True)\nsplit_idx = int(len(df) * 0.8)\ntrain_df = df.iloc[:split_idx]\nval_df = df.iloc[split_idx:]\n\ntrain_fraud_cards = set(train_df[train_df['isFraud'] == 1]['card1'])\nval_fraud_df = val_df[val_df['isFraud'] == 1]\noverlap = val_fraud_df['card1'].isin(train_fraud_cards).mean()\nprint(f'Fraction of validation fraud cases with card1 in training fraud cases: {overlap:.4f}')\nEOF\npython3 check_overlap.py\n"]
[304.506399, "o", "cat << 'EOF' > check_overlap.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv').sort_values('TransactionDT').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.513704, "o", "split_idx = int(len(df) * 0.8)\r\n\u001b[?2004l\r\u001b[?2004h> train_df = df.iloc[:split_idx]\r\n\u001b[?2004l\r\u001b[?2004h> val_df = df.iloc[split_idx:]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_fraud_cards = set(train_df[train_df['isFraud'] == 1]['card1'])\r\n\u001b[?2004l\r\u001b[?2004h> val_fraud_df = val_df[val_df['isFraud'] == 1]\r\n\u001b[?2004l\r\u001b[?2004h> overlap = val_fraud_df['card1'].isin(train_fraud_cards).mean()\r\n\u001b[?2004l\r\u001b[?2004h> print(f'Fraction of validation fraud cases with card1 in training fraud cases: {overlap:.4f}')\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
