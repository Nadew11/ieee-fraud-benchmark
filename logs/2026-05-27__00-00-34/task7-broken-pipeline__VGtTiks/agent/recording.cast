[227.271365, "i", "cat << 'EOF' > check_dt.py\nimport pandas as pd\nfrom sklearn.tree import DecisionTreeClassifier\nfrom sklearn.metrics import roc_auc_score\ndf = pd.read_csv('/data/train_transaction.csv').sort_values('TransactionDT').reset_index(drop=True)\nTARGET = 'isFraud'\ncat_cols = ['ProductCD', 'card4', 'card6']\ndf_encoded = pd.get_dummies(df, columns=cat_cols, drop_first=True)\nDROP = ['TransactionID', TARGET]\nfeatures = [c for c in df_encoded.columns if c not in DROP]\nsplit_idx = int(len(df_encoded) * 0.8)\nX_train, y_train = df_encoded.iloc[:split_idx][features], df_encoded.iloc[:split_idx][TARGET]\nX_val, y_val = df_encoded.iloc[split_idx:][features], df_encoded.iloc[split_idx:][TARGET]\nfor depth in [1, 2, 3]:\n    dt = DecisionTreeClassifier(max_depth=depth, random_state=42)\n    dt.fit(X_train.fillna(-999), y_train)\n    p_train = dt.predict_proba(X_train.fillna(-999))[:, 1]\n    p_val = dt.predict_proba(X_val.fillna(-999))[:, 1]\n    print(f'Depth {depth}: Train AUC {roc_auc_score(y_train, p_train):.4f}, Val AUC {roc_auc_score(y_val, p_val):.4f}')\nEOF\npython3 check_dt.py\n"]
[227.289655, "o", "cat << 'EOF' > check_dt.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.tree import DecisionTreeClassifier\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv').sort_values('TransactionDT').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> TARGET = 'isFraud'\r\n\u001b[?2004l\r\u001b[?2004h> cat_cols = ['ProductCD', 'card4', 'card6']\r\n\u001b[?2004l\r\u001b[?2004h> df_encoded = pd.get_dummies(df, columns=cat_cols, drop_first=True)\r\n\u001b[?2004l\r\u001b[?2004h> DROP = ['TransactionID', TARGET]\r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df_encoded.columns if c not in DROP]\r\n\u001b[?2004l\r\u001b[?2004h> split_idx = int(len(df_encoded) * 0.8)\r\n\u001b[?2004l\r\u001b[?2004h> X_train, y_train = df_encoded.iloc[:split_idx][features], df_encoded.iloc[:split_idx][TARGET]\r\n\u001b[?2004l\r\u001b[?2004h> X_val, y_val = df_encoded.iloc[split_idx:][features], df_encoded.iloc[split_idx:][TARGET]\r\n\u001b[?2004l\r\u001b[?2004h> for depth in [1, 2, 3]:\r\n\u001b[?2004l\r\u001b[?2004h>     dt = DecisionTreeClassifier(max_depth=depth, random_state=42)\r\n\u001b[?2004l\r\u001b[?2004h>     dt.fit(X_train.fillna(-999), y_train)\r\n\u001b[?2004l\r\u001b[?2004h>     p_train = dt.predict_proba(X_train.fillna(-999))[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h>     p_val = dt.predict_proba(X_val.fillna(-999))[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h>     print(f'Depth {depth}: Train AUC {roc_auc_score(y_train, p_train):.4f}, Val AUC {roc_auc_score(y_val, p_val):.4f}')\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
