[263.916543, "i", "cat << 'EOF' > check_lr.py\nimport pandas as pd\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.preprocessing import StandardScaler\n\ndf = pd.read_csv('/data/train_transaction.csv').sort_values('TransactionDT').reset_index(drop=True)\nTARGET = 'isFraud'\ncat_cols = ['ProductCD', 'card4', 'card6']\ndf_encoded = pd.get_dummies(df, columns=cat_cols, drop_first=True)\nDROP = ['TransactionID', TARGET]\nfeatures = [c for c in df_encoded.columns if c not in DROP]\nsplit_idx = int(len(df_encoded) * 0.8)\n\nX_train = df_encoded.iloc[:split_idx][features].fillna(0)\ny_train = df_encoded.iloc[:split_idx][TARGET]\nX_val = df_encoded.iloc[split_idx:][features].fillna(0)\ny_val = df_encoded.iloc[split_idx:][TARGET]\n\nscaler = StandardScaler()\nX_train_sc = scaler.fit_transform(X_train)\nX_val_sc = scaler.transform(X_val)\n\nlr = LogisticRegression(max_iter=1000, random_state=42)\nlr.fit(X_train_sc, y_train)\np_val = lr.predict_proba(X_val_sc)[:, 1]\nprint('LR Val AUC:', roc_auc_score(y_val, p_val))\nEOF\npython3 check_lr.py\n"]
[263.923567, "o", "cat << 'EOF' > check_lr.py\r\n\u001b[?2004l\r"]
