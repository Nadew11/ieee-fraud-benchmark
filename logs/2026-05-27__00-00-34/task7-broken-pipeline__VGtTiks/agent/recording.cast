[407.024827, "i", "cat << 'EOF' > /data/pipeline.py\n#!/usr/bin/env python3\n\"\"\"\nFraud Detection Pipeline — v1.3 (Corrected)\n\"\"\"\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\n# 1. Load data\nprint(\"Loading data...\")\ndf = pd.read_csv(\"/data/train_transaction.csv\")\nprint(f\"Shape: {df.shape}\")\n\n# 2. Sort by TransactionDT to ensure temporal ordering\ndf = df.sort_values(\"TransactionDT\").reset_index(drop=True)\n\nTARGET = \"isFraud\"\n\n# 3. Categorical Encoding (Keep card4, card6, ProductCD and One-Hot Encode them)\ncat_cols = [\"ProductCD\", \"card4\", \"card6\"]\ndf_encoded = pd.get_dummies(df, columns=cat_cols, drop_first=True)\n\nDROP = [\"TransactionID\", TARGET]\nfeatures = [c for c in df_encoded.columns if c not in DROP]\n\n# 4. Temporal Split (First 80% train, last 20% validation)\nsplit_idx = int(len(df_encoded) * 0.8)\ntrain_df = df_encoded.iloc[:split_idx]\nval_df = df_encoded.iloc[split_idx:]\n\nX_train = train_df[features]\ny_train = train_df[TARGET]\nX_val = val_df[features]\ny_val = val_df[TARGET]\n\nprint(f\"Train size: {len(X_train)}, Val size: {len(X_val)}\")\nprint(f\"Val fraud rate: {y_val.mean():.4f}\")\n\n# 5. Train XGBoost (No StandardScaler, native NaN handling, proper eval_metric)\nmodel = xgb.XGBClassifier(\n    objective=\"binary:logistic\",\n    eval_metric=\"auc\",\n    n_estimators=300,\n    max_depth=6,\n    learning_rate=0.05,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    verbosity=0,\n)\nmodel.fit(\n    X_train, y_train,\n    eval_set=[(X_val, y_val)],\n    verbose=False,\n)\n\nprobs = model.predict_proba(X_val)[:, 1]\nauc = roc_auc_score(y_val, probs)\nprint(f\"\\nValidation AUC: {auc:.4f}\")\n\n# Write the AUC to the output file\nwith open(\"/output/auc.txt\", \"w\") as f:\n    f.write(f\"{auc:.4f}\\n\")\nprint(\"AUC written to /output/auc.txt\")\nEOF\nchmod +x /data/pipeline.py\npython3 /data/pipeline.py\n"]
[407.027355, "o", "cat << 'EOF' > /data/pipeline.py\r\n\u001b[?2004l\r\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> Fraud Detection Pipeline — v1.3 (Corrected)\r\n\u001b[?2004l\r\u001b[?2004h> \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> import warnings\r\n\u001b[?2004l\r\u001b[?2004h> warnings.filterwarnings(\"ignore\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 1. Load data\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Loading data...\")\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv(\"/data/train_transaction.csv\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Shape: {df.shape}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 2. Sort by TransactionDT to ensure temporal ordering\r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values(\"TransactionDT\").reset_index(drop=True)"]
[407.029179, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> TARGET = \"isFraud\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 3. Categorical Encoding (Keep card4, card6, ProductCD and One-Hot Encode them)\r\n\u001b[?2004l\r\u001b[?2004h> cat_cols = [\"ProductCD\", \"card4\", \"card6\"]\r\n\u001b[?2004l\r\u001b[?2004h> df_encoded = pd.get_dummies(df, columns=cat_cols, drop_first=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> DROP = [\"TransactionID\", TARGET]\r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df_encoded.columns if c not in DROP]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 4. Temporal Split (First 80% train, last 20% validation)\r\n\u001b[?2004l\r\u001b[?2004h> split_idx = int(len(df_encoded) * 0.8)\r\n\u001b[?2004l\r\u001b[?2004h> train_df = df_encoded.iloc[:split_idx]\r\n\u001b[?2004l\r\u001b[?2004h> val_df = df_encoded.iloc[split_idx:]"]
[407.029272, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> X_train = train_df[features]\r\n\u001b[?2004l\r\u001b[?2004h> y_train = train_df[TARGET]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[407.030494, "o", "X_val = val_df[features]\r\n\u001b[?2004l\r\u001b[?2004h> y_val = val_df[TARGET]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Train size: {len(X_train)}, Val size: {len(X_val)}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Val fraud rate: {y_val.mean():.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 5. Train XGBoost (No StandardScaler, native NaN handling, proper eval_metric)\r\n\u001b[?2004l\r\u001b[?2004h> model = xgb.XGBClassifier(\r\n\u001b[?2004l\r\u001b[?2004h>     objective=\"binary:logistic\",\r\n\u001b[?2004l\r\u001b[?2004h>     eval_metric=\"auc\",\r\n\u001b[?2004l\r\u001b[?2004h>     n_estimators=300,\r\n\u001b[?2004l\r\u001b[?2004h>     max_depth=6,\r\n\u001b[?2004l\r\u001b[?2004h>     learning_rate=0.05,\r\n\u001b[?2004l\r\u001b[?2004h>     subsample=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     colsample_bytree=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     random_state=42,\r\n\u001b[?2004l\r\u001b[?2004h>     use_label_encoder=False,\r\n\u001b[?2004l\r\u001b[?2004h>     verbosity=0,\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> model.fit(\r\n\u001b[?2004l\r\u001b[?2004h>     X_train, y_train,\r\n\u001b[?2004l\r\u001b[?2004h>     eval_set=[(X_val, y_val)],\r\n\u001b[?2004l\r\u001b[?2004h>     verbose=False,\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h"]
[407.03052, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> probs = model.predict_proba(X_val)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> auc = roc_auc_score(y_val, probs)\r\n\u001b[?2004l\r\u001b[?2004h> "]
