[128.68743, "i", "cat << 'EOF' > check_sep.py\nimport pandas as pd\ndf = pd.read_csv('/data/train_transaction.csv')\nfor col in df.select_dtypes('number').columns:\n    if col == 'isFraud': continue\n    c0 = df[df['isFraud'] == 0][col]\n    c1 = df[df['isFraud'] == 1][col]\n    overlap_min = max(c0.min(), c1.min())\n    overlap_max = min(c0.max(), c1.max())\n    if overlap_min > overlap_max:\n        print(f'{col} perfectly separates!')\n    else:\n        # Check how much overlap\n        overlap_c0 = ((c0 >= overlap_min) & (c0 <= overlap_max)).sum() / len(c0)\n        overlap_c1 = ((c1 >= overlap_min) & (c1 <= overlap_max)).sum() / len(c1)\n        print(f'{col}: overlap range [{overlap_min}, {overlap_max}], overlap fraction in c0: {overlap_c0:.4f}, c1: {overlap_c1:.4f}')\nEOF\npython3 check_sep.py\n"]
[128.699669, "o", "cat << 'EOF' > check_sep.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv')\r\n\u001b[?2004l\r\u001b[?2004h> for col in df.select_dtypes('number').columns:\r\n\u001b[?2004l\r\u001b[?2004h>     if col == 'isFraud': continue\r\n\u001b[?2004l\r\u001b[?2004h>     c0 = df[df['isFraud'] == 0][col]\r\n\u001b[?2004l\r\u001b[?2004h>     c1 = df[df['isFraud'] == 1][col]\r\n\u001b[?2004l\r\u001b[?2004h>     overlap_min = max(c0.min(), c1.min())\r\n\u001b[?2004l\r\u001b[?2004h> "]
