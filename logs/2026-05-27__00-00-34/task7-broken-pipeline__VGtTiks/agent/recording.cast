[205.007125, "i", "cat << 'EOF' > test_pipeline.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\n# Load data\ndf = pd.read_csv(\"/data/train_transaction.csv\")\n# Sort by TransactionDT to ensure chronological order\ndf = df.sort_values(\"TransactionDT\").reset_index(drop=True)\n\nTARGET = \"isFraud\"\n\n# Keep categorical columns and encode them\ncat_cols = [\"ProductCD\", \"card4\", \"card6\"]\ndf_encoded = pd.get_dummies(df, columns=cat_cols, drop_first=True)\n\nDROP = [\"TransactionID\", TARGET]\nfeatures = [c for c in df_encoded.columns if c not in DROP]\n\n# Split into train and validation (temporal split 80/20)\nsplit_idx = int(len(df_encoded) * 0.8)\ntrain_df = df_encoded.iloc[:split_idx]\nval_df = df_encoded.iloc[split_idx:]\n\nX_train = train_df[features]\ny_train = train_df[TARGET]\nX_val = val_df[features]\ny_val = val_df[TARGET]\n\n# Train XGBoost with proper evaluation metric\nmodel = xgb.XGBClassifier(\n    objective=\"binary:logistic\",\n    eval_metric=\"auc\",\n    n_estimators=300,\n    max_depth=6,\n    learning_rate=0.05,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    verbosity=0,\n)\nmodel.fit(\n    X_train, y_train,\n    eval_set=[(X_val, y_val)],\n    verbose=False,\n)\n\nprobs = model.predict_proba(X_val)[:, 1]\nauc   = roc_auc_score(y_val, probs)\nprint(f\"Corrected Validation AUC: {auc:.4f}\")\nEOF\npython3 test_pipeline.py\n"]
[205.013358, "o", "cat << 'EOF' > test_pipeline.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Load data\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv(\"/data/train_transaction.csv\")\r\n\u001b[?2004l\r\u001b[?2004h> # Sort by TransactionDT to ensure chronological order\r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values(\"TransactionDT\").reset_index(drop=True)"]
[205.013566, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> TARGET = \"isFraud\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
