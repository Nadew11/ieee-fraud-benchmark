[304.877862, "o", "\u001b[?2004h> print(f\"Val fraud rate: {y_val.mean():.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Train XGBoost with proper classification eval_metric and categorical support\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.877969, "o", "model = xgb.XGBClassifier(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.879868, "o", "    objective=\"binary:logistic\",\r\n\u001b[?2004l\r\u001b[?2004h>     eval_metric=\"auc\",\r\n\u001b[?2004l\r\u001b[?2004h>     n_estimators=300,\r\n\u001b[?2004l\r\u001b[?2004h>     max_depth=6,\r\n\u001b[?2004l\r\u001b[?2004h>     learning_rate=0.05,\r\n\u001b[?2004l\r\u001b[?2004h>     subsample=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     colsample_bytree=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     random_state=42,\r\n\u001b[?2004l\r\u001b[?2004h>     use_label_encoder=False,\r\n\u001b[?2004l\r\u001b[?2004h>     verbosity=0,\r\n\u001b[?2004l\r\u001b[?2004h>     enable_categorical=True,\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> model.fit(\r\n\u001b[?2004l\r\u001b[?2004h>     X_train, y_train,\r\n\u001b[?2004l\r\u001b[?2004h>     eval_set=[(X_val, y_val)],\r\n\u001b[?2004l\r\u001b[?2004h>     verbose=False,\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> probs = model.predict_proba(X_val)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> auc   = roc_auc_score(y_val, probs)\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"\\nValidation AUC: {auc:.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[304.885466, "o", "\u001b[?2004hroot@549b54a67146:/workspace# "]
[304.885568, "o", "chmod +x /workspace/pipeline.py\r\n\u001b[?2004l\r"]
