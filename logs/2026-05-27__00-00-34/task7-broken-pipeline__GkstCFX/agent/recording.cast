[286.768482, "i", "python3 -c \"\nimport pandas as pd, numpy as np\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\ndf = pd.read_csv('/data/train_transaction.csv')\ndf_sorted = df.sort_values('TransactionDT').reset_index(drop=True)\n\nTARGET = 'isFraud'\ncat_cols = ['ProductCD', 'card4', 'card6']\nfor col in cat_cols:\n    df_sorted[col] = df_sorted[col].astype('category')\n    \nfeatures = [c for c in df_sorted.columns if c not in ['TransactionID', TARGET]]\n\nsplit_idx = int(len(df_sorted) * 0.8)\ntrain_df = df_sorted.iloc[:split_idx]\nval_df = df_sorted.iloc[split_idx:]\n\nX_train = train_df[features]\ny_train = train_df[TARGET].values\nX_val = val_df[features]\ny_val = val_df[TARGET].values\n\nmodel = xgb.XGBClassifier(\n    objective='binary:logistic',\n    eval_metric='auc',\n    n_estimators=300,\n    max_depth=6,\n    learning_rate=0.05,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    verbosity=0,\n    enable_categorical=True\n)\nmodel.fit(\n    X_train, y_train,\n    eval_set=[(X_val, y_val)],\n    verbose=False,\n)\n\nprobs = model.predict_proba(X_val)[:, 1]\nauc   = roc_auc_score(y_val, probs)\nprint('Corrected Temporal Validation AUC:', auc)\n\"\n"]
[286.782285, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd, numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df_sorted = df.sort_values('TransactionDT').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> TARGET = 'isFraud'\r\n\u001b[?2004l\r\u001b[?2004h> cat_cols = ['ProductCD', 'card4', 'card6']\r\n\u001b[?2004l\r\u001b[?2004h> for col in cat_cols:\r\n\u001b[?2004l\r\u001b[?2004h>     df_sorted[col] = df_sorted[col].astype('category')\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df_sorted.columns if c not in ['TransactionID', TARGET]]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> split_idx = int(len(df_sorted) * 0.8)\r\n\u001b[?2004l\r\u001b[?2004h> train_df = df_sorted.iloc[:split_idx]\r\n\u001b[?2004l\r\u001b[?2004h> val_df = df_sorted.iloc[split_idx:]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> X_train = train_df[features]\r\n\u001b[?2004l\r\u001b[?2004h> y_train = train_df[TARGET].values\r\n\u001b[?2004l\r\u001b[?2004h> X_val = val_df[features]\r\n\u001b[?2004l\r\u001b[?2004h> y_val = val_df[TARGET].values\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> model = xgb.XGBClassifier(\r\n\u001b[?2004l\r\u001b[?2004h>     objective='binary:logistic',\r\n\u001b[?2004l\r\u001b[?2004h>     eval_metric='auc',\r\n\u001b[?2004l\r\u001b[?2004h>     n_estimators=300,\r\n\u001b[?2004l\r\u001b[?2004h>     max_depth=6,\r\n\u001b[?2004l\r\u001b[?2004h>     learning_rate=0.05,\r\n\u001b[?2004l\r\u001b[?2004h>     subsample=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     colsample_bytree=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     random_state=42,\r\n\u001b[?2004l\r\u001b[?2004h>     use_label_encoder=False,\r\n\u001b[?2004l\r\u001b[?2004h>     verbosity=0,\r\n\u001b[?2004l\r\u001b[?2004h>     enable_categorical=True\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> model.fit(\r\n\u001b[?2004l\r\u001b[?2004h>     X_train, y_train,\r\n\u001b[?2004l\r\u001b[?2004h>     eval_set=[(X_val, y_val)],\r\n\u001b[?2004l\r\u001b[?2004h>     verbose=False,\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> probs = model.predict_proba(X_val)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> auc   = roc_auc_score(y_val, probs)\r\n\u001b[?2004l\r\u001b[?2004h> print('Corrected Temporal Validation AUC:', auc)\r\n\u001b[?2004l\r\u001b[?2004h> \"\r\n\u001b[?2004l\r"]
