[144.551662, "i", "python3 -c \"\nimport pandas as pd, numpy as np\nfrom sklearn.model_selection import StratifiedKFold\nimport xgboost as xgb\nfrom sklearn.metrics import roc_auc_score\nfrom sklearn.preprocessing import StandardScaler\n\ndf = pd.read_csv('/data/train_transaction.csv')\nfeatures = [c for c in df.columns if c not in ['TransactionID', 'isFraud', 'ProductCD', 'card4', 'card6']]\n\ndef run_experiment(use_scaling, fill_val):\n    skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n    aucs = []\n    for train_idx, val_idx in skf.split(df, df['isFraud']):\n        df_train, df_val = df.iloc[train_idx], df.iloc[val_idx]\n        X_train = df_train[features]\n        X_val = df_val[features]\n        if fill_val is not None:\n            X_train = X_train.fillna(fill_val)\n            X_val = X_val.fillna(fill_val)\n        y_train = df_train['isFraud'].values\n        y_val = df_val['isFraud'].values\n        \n        if use_scaling:\n            scaler = StandardScaler()\n            X_train = scaler.fit_transform(X_train)\n            X_val = scaler.transform(X_val)\n            \n        model = xgb.XGBClassifier(objective='binary:logistic', eval_metric='logloss', n_estimators=100, max_depth=6, learning_rate=0.05, random_state=42, use_label_encoder=False, verbosity=0)\n        model.fit(X_train, y_train)\n        probs = model.predict_proba(X_val)[:, 1]\n        aucs.append(roc_auc_score(y_val, probs))\n    print(f'Scaling={use_scaling}, Fill={fill_val} -> CV AUC: {np.mean(aucs):.4f}')\n\nrun_experiment(True, -999)\nrun_experiment(False, None)\n\"\n"]
[144.55999, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd, numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.model_selection import StratifiedKFold\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.preprocessing import StandardScaler\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv')\r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df.columns if c not in ['TransactionID', 'isFraud', 'ProductCD', 'card4', 'card6']]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def run_experiment(use_scaling, fill_val):\r\n\u001b[?2004l\r\u001b[?2004h>     skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\r\n\u001b[?2004l\r\u001b[?2004h>     aucs = []\r\n\u001b[?2004l\r\u001b[?2004h>     for train_idx, val_idx in skf.split(df, df['isFraud']):\r\n\u001b[?2004l\r\u001b[?2004h>         df_train, df_val = df.iloc[train_idx], df.iloc[val_idx]\r\n\u001b[?2004l\r\u001b[?2004h>         X_train = df_train[features]\r\n\u001b[?2004l\r\u001b[?2004h>         X_val = df_val[features]\r\n\u001b[?2004l\r\u001b[?2004h>         if fill_val is not None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
