[91.083156, "i", "python3 -c \"\nimport pandas as pd, numpy as np\nfrom sklearn.preprocessing import StandardScaler\nimport xgboost as xgb\nfrom sklearn.metrics import roc_auc_score\ndf = pd.read_csv('/data/train_transaction.csv')\ndf = df.sort_values('TransactionDT').reset_index(drop=True)\nfeatures = [c for c in df.columns if c not in ['TransactionID', 'isFraud', 'ProductCD', 'card4', 'card6']]\nX = df[features].fillna(-999).values\ny = df['isFraud'].values\nscaler = StandardScaler()\nX = scaler.fit_transform(X)\nsplit_idx = int(len(df) * 0.8)\nX_train, X_val = X[:split_idx], X[split_idx:]\ny_train, y_val = y[:split_idx], y[split_idx:]\nmodel = xgb.XGBClassifier(objective='binary:logistic', eval_metric='rmse', n_estimators=300, max_depth=6, learning_rate=0.05, subsample=0.8, colsample_bytree=0.8, random_state=42, use_label_encoder=False, verbosity=0)\nmodel.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=False)\nprobs = model.predict_proba(X_val)[:, 1]\nprint('AUC:', roc_auc_score(y_val, probs))\n\"\n"]
[91.087812, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd, numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.preprocessing import StandardScaler\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('TransactionDT').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df.columns if c not in ['TransactionID', 'isFraud', 'ProductCD', 'card4', 'card6']]\r\n\u001b[?2004l\r\u001b[?2004h> X = df[features].fillna(-999).values\r\n\u001b[?2004l\r\u001b[?2004h> y = df['isFraud'].values\r\n\u001b[?2004l\r\u001b[?2004h> scaler = StandardScaler()\r\n\u001b[?2004l\r\u001b[?2004h> X = scaler.fit_transform(X)\r\n\u001b[?2004l\r\u001b[?2004h> split_idx = int(len(df) * 0.8)\r\n\u001b[?2004l\r\u001b[?2004h> X_train, X_val = X[:split_idx], X[split_idx:]\r\n\u001b[?2004l\r\u001b[?2004h> y_train, y_val = y[:split_idx], y[split_idx:]\r\n\u001b[?2004l\r\u001b[?2004h> model = xgb.XGBClassifier(objective='binary:logistic', eval_metric='rmse', n_estimators=300, max_depth=6, learning_rate=0.05, subsample=0.8, colsample_bytree=0.8, random_state=42, use_label_encoder=False, verbosity=0)\r\n\u001b[?2004l\r\u001b[?2004h> model.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=False)\r\n\u001b[?2004l\r\u001b[?2004h> probs = model.predict_proba(X_val)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> print('AUC:', roc_auc_score(y_val, probs))\r\n\u001b[?2004l\r\u001b[?2004h> \"\r\n\u001b[?2004l\r"]
