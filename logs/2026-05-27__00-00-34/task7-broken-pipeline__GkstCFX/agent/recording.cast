[55.764012, "o", "     1\t#!/usr/bin/env python3\r\r\n     2\t\"\"\"\r\r\n     3\tFraud Detection Pipeline — v1.2\r\r\n     4\tAuthor: junior_engineer@payments.co\r\r\n     5\t\"\"\"\r\r\n     6\timport pandas as pd\r\r\n     7\timport numpy as np\r\r\n     8\tfrom sklearn.model_selection import train_test_split\r\r\n     9\tfrom sklearn.preprocessing import StandardScaler\r\r\n    10\tfrom sklearn.metrics import roc_auc_score\r\r\n    11\timport xgboost as xgb\r\r\n    12\timport warnings\r\r\n    13\twarnings.filterwarnings(\"ignore\")\r\r\n    14\t\r\r\n    15\t# Load data\r\r\n    16\tprint(\"Loading data...\")\r\r\n    17\tdf = pd.read_csv(\"/data/train_transaction.csv\")\r\r\n    18\tprint(f\"Shape: {df.shape}\")\r\r\n    19\t\r\r\n    20\t# Features / target\r\r\n    21\tTARGET = \"isFraud\"\r\r\n    22\tDROP = [\"TransactionID\", TARGET, \"ProductCD\", \"card4\", \"card6\"]\r\r\n    23\tfeatures = [c for c in df.columns if c not in DROP]\r\r\n    24\t\r\r\n    25\tX = df[features].fillna(-999).values\r\r\n    26\ty = df[TARGET].values\r\r\n    27\t\r\r\n    28\t# Scale features for better model performance\r\r\n    29\tscaler = StandardScaler()\r\r\n    30\tX = scaler.fit_transform(X)\r\r\n    31\t\r\r\n    32\t# Split into train and validation\r\r\n    33\tX_train, X_val, y_train, y_val = train_test_split(\r\r\n    34\t    X, y, test_size=0.2, random_state=42\r\r\n    35\t)\r\r\n    36\tprint(f\"Train: {len(X_train)}, Val: {len(X_val)}\")\r\r\n    37\tprint(f\"Val fraud rate: {y_val.mean():.4f}\")\r\r\n    38\t\r\r\n    39\t# Train XGBoost\r\r\n    40\tmodel = xgb.XGBClassifier(\r\r\n    41\t    objective=\"binary:logistic\",\r\r\n    42\t    eval_metric=\"rmse\",\r\r\n    43\t    n_estimators=300,\r\r\n    44\t    max_depth=6,\r\r\n    45\t    learning_rate=0.05,\r\r\n    46\t    subsample=0.8,\r\r\n    47\t    colsample_bytree=0.8,\r\r\n    48\t    random_state=42,\r\r\n    49\t    use_label_encoder=False,\r\r\n    50\t    verbosity=0,\r\r\n    51\t)\r\r\n    52\tmodel.fit(\r\r\n    53\t    X_train, y_train,\r\r\n    54\t    eval_set=[(X_val, y_val)],\r\r\n    55\t    verbose=False,\r\r\n    56\t)\r\r\n    57\t\r\r\n    58\tprobs = model.predict_proba(X_val)[:, 1]\r\r\n    59\tauc   = roc_auc_score(y_val, probs)\r\r\n    60\tprint(f\"\\nValidation AUC: {auc:.4f}\")\r\r\n    61\tprint(\"Note: AUC seems low — unclear why model isn't learning better\")\r\r\n"]
