[?2004l[?2004h>         model = xgb.XGBClassifier(objective='binary:logistic', eval_metric='logloss', n_estimators=100, max_depth=6, learning_rate=0.05, random_state=42, use_label_encoder=False, verbosity=0)
[?2004l[?2004h>         model.fit(X_train, y_train)
[?2004l[?2004h>         probs = model.predict_proba(X_val)[:, 1]
[?2004l[?2004h>         aucs.append(roc_auc_score(y_val, probs))
[?2004l[?2004h>     print(f'Scaling={use_scaling}, Fill={fill_val} -> CV AUC: {np.mean(aucs):.4f}')
