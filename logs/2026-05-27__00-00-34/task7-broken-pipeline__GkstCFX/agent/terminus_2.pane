[?2004l[?2004h> 
[?2004l[?2004h> # Features / target
[?2004l[?2004h> TARGET = "isFraud"
[?2004l[?2004h> 
[?2004l[?2004h> # Keep and encode categorical features instead of dropping them
[?2004l[?2004h> cat_cols = ["ProductCD", "card4", "card6"]
