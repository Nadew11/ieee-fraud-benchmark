[?2004l[?2004h> df = pd.read_csv('/data/train_transaction.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Create a chronological train/val split first
[?2004l[?2004h> df_sorted = df.sort_values('TransactionDT').reset_index(drop=True)
[?2004l[?2004h> split_idx = int(len(df_sorted) * 0.8)
[?2004l[?2004h> train_df = df_sorted.iloc[:split_idx]
[?2004l[?2004h> val_df = df_sorted.iloc[split_idx:]
[?2004l[?2004h> 
[?2004l[?2004h> # Let's train using the junior engineer's exact method (random split of train_df, fillna -999, scaling, rmse)
[?2004l[?2004h> features = [c for c in train_df.columns if c not in ['TransactionID', 'isFraud', 'ProductCD', 'card4', 'card6']]
[?2004l[?2004h> X = train_df[features].fillna(-999).values
[?2004l[?2004h> y = train_df['isFraud'].values
[?2004l[?2004h> scaler = StandardScaler()
[?2004l[?2004h> X_scaled = scaler.fit_transform(X)
[?2004l[?2004h> 
[?2004l[?2004h> X_tr, X_va, y_tr, y_va = train_test_split(X_scaled, y, test_size=0.2, random_state=42)
[?2004l[?2004h> model = xgb.XGBClassifier(objective='binary:logistic', eval_metric='rmse', n_estimators=300, max_depth=6, learning_rate=0.05, subsample=0.8, colsample_bytree=0.8, random_state=42, use_label_encoder=False, verbosity=0)
[?2004l[?2004h> model.fit(X_tr, y_tr, eval_set=[(X_va, y_va)], verbose=False)
[?2004l[?2004h> 
[?2004l[?2004h> # Now evaluate on the chronological val_df
[?2004l[?2004h> X_test = val_df[features].fillna(-999).values
[?2004l[?2004h> y_test = val_df['isFraud'].values
[?2004l[?2004h> X_test_scaled = scaler.transform(X_test)
[?2004l[?2004h> probs = model.predict_proba(X_test_scaled)[:, 1]
