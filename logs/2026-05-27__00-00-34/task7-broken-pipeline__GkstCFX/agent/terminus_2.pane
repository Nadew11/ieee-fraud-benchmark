[?2004l[?2004h> X_train, X_val, y_train, y_val = train_test_split(
[?2004l[?2004h>     X, y, test_size=0.2, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> print(f"Train: {len(X_train)}, Val: {len(X_val)}")
[?2004l[?2004h> print(f"Val fraud rate: {y_val.mean():.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Train XGBoost with proper classification eval_metric and categorical support
[?2004l[?2004h> model = xgb.XGBClassifier(
[?2004l[?2004h>     objective="binary:logistic",
[?2004l[?2004h>     eval_metric="auc",
[?2004l[?2004h>     n_estimators=300,
[?2004l[?2004h>     max_depth=6,
[?2004l[?2004h>     learning_rate=0.05,
[?2004l[?2004h>     subsample=0.8,
[?2004l[?2004h>     colsample_bytree=0.8,
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     use_label_encoder=False,
[?2004l[?2004h>     verbosity=0,
[?2004l[?2004h>     enable_categorical=True,
[?2004l[?2004h> )
[?2004l[?2004h> model.fit(
[?2004l[?2004h>     X_train, y_train,
[?2004l[?2004h>     eval_set=[(X_val, y_val)],
[?2004l[?2004h>     verbose=False,
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> probs = model.predict_proba(X_val)[:, 1]
