Sending keys: ['python3 -c "\nimport pandas as pd, numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\ndf = pd.read_csv(\'/data/train_transaction.csv\')\n\n# Create a chronological train/val split first\ndf_sorted = df.sort_values(\'TransactionDT\').reset_index(drop=True)\nsplit_idx = int(len(df_sorted) * 0.8)\ntrain_df = df_sorted.iloc[:split_idx]\nval_df = df_sorted.iloc[split_idx:]\n\n# Let\'s train using the junior engineer\'s exact method (random split of train_df, fillna -999, scaling, rmse)\nfeatures = [c for c in train_df.columns if c not in [\'TransactionID\', \'isFraud\', \'ProductCD\', \'card4\', \'card6\']]\nX = train_df[features].fillna(-999).values\ny = train_df[\'isFraud\'].values\nscaler = StandardScaler()\nX_scaled = scaler.fit_transform(X)\n\nX_tr, X_va, y_tr, y_va = train_test_split(X_scaled, y, test_size=0.2, random_state=42)\nmodel = xgb.XGBClassifier(objective=\'binary:logistic\', eval_metric=\'rmse\', n_estimators=300, max_depth=6, learning_rate=0.05, subsample=0.8, colsample_bytree=0.8, random_state=42, use_label_encoder=False, verbosity=0)\nmodel.fit(X_tr, y_tr, eval_set=[(X_va, y_va)], verbose=False)\n\n# Now evaluate on the chronological val_df\nX_test = val_df[features].fillna(-999).values\ny_test = val_df[\'isFraud\'].values\nX_test_scaled = scaler.transform(X_test)\nprobs = model.predict_proba(X_test_scaled)[:, 1]\nprint(\'AUC on chronological validation set:\', roc_auc_score(y_test, probs))\n"\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
