[?2004hroot@9da0ecea1a80:/workspace# cat << 'EOF' > test_shift_expanding.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> data = pd.DataFrame({
[?2004l[?2004h>     'card1': [1, 1, 1, 2, 2],
[?2004l[?2004h>     'TransactionDT': [100, 200, 300, 150, 250],
[?2004l[?2004h>     'TransactionAmt': [10.0, 20.0, 30.0, 50.0, 100.0]
[?2004l[?2004h> })
[?2004l[?2004h> 
[?2004l[?2004h> # Sort
[?2004l[?2004h> data = data.sort_values('TransactionDT').reset_index(drop=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Cumulative count of previous transactions
[?2004l[?2004h> data['card1_cum_count'] = data.groupby('card1').cumcount()
[?2004l[?2004h> 
[?2004l[?2004h> # Time diff to previous transaction
[?2004l[?2004h> data['card1_time_diff'] = data.groupby('card1')['TransactionDT'].diff()
[?2004l[?2004h> 
[?2004l[?2004h> # Cumulative mean of previous transactions' amt
[?2004l[?2004h> data['card1_cum_amt_mean'] = data.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())
[?2004l[?2004h> 
[?2004l[?2004h> print(data)
[?2004l[?2004h> EOF
