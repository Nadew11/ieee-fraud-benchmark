[?2004hroot@9da0ecea1a80:/workspace# cat << 'EOF' > run_baseline.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> import xgboost as xgb
[?2004l[?2004h> 
[?2004l[?2004h> # 1. Load data
[?2004l[?2004h> df = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Sort chronologically
[?2004l[?2004h> df = df.sort_values('TransactionDT').reset_index(drop=True)
[?2004l[?2004h> 
[?2004l[?2004h> # 3. Feature Engineering: Historical pattern features
[?2004l[?2004h> print("Engineering historical features...")
[?2004l[?2004h> 
[?2004l[?2004h> # Client key 1: card1
[?2004l[?2004h> df['card1_cum_count'] = df.groupby('card1').cumcount()
[?2004l[?2004h> df['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff()
[?2004l[?2004h> # To handle NaN in time diff, we can use a large value or a flag
[?2004l[?2004h> df['card1_time_diff_nan'] = df['card1_time_diff'].isna().astype(int)
[?2004l[?2004h> df['card1_time_diff'] = df['card1_time_diff'].fillna(999999999) # large number
[?2004l[?2004h> 
[?2004l[?2004h> df['card1_cum_amt_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())
[?2004l[?2004h> df['card1_cum_amt_mean_nan'] = df['card1_cum_amt_mean'].isna().astype(int)
[?2004l[?2004h> df['card1_cum_amt_mean'] = df['card1_cum_amt_mean'].fillna(0)
[?2004l[?2004h> 
[?2004l[?2004h> # Ratio of current transaction amount to the average historical amount
[?2004l[?2004h> df['card1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_cum_amt_mean'] + 1e-5)
[?2004l[?2004h> 
[?2004l[?2004h> # Client key 2: card1 + addr1
[?2004l[?2004h> df['card1_addr1'] = df['card1'].astype(str) + '_' + df['addr1'].astype(str)
[?2004l[?2004h> df['card1_addr1_cum_count'] = df.groupby('card1_addr1').cumcount()
[?2004l[?2004h> df['card1_addr1_time_diff'] = df.groupby('card1_addr1')['TransactionDT'].diff()
[?2004l[?2004h> df['card1_addr1_time_diff_nan'] = df['card1_addr1_time_diff'].isna().astype(int)
[?2004l[?2004h> df['card1_addr1_time_diff'] = df['card1_addr1_time_diff'].fillna(999999999)
[?2004l[?2004h> 
[?2004l[?2004h> df['card1_addr1_cum_amt_mean'] = df.groupby('card1_addr1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())
[?2004l[?2004h> df['card1_addr1_cum_amt_mean_nan'] = df['card1_addr1_cum_amt_mean'].isna().astype(int)
[?2004l[?2004h> df['card1_addr1_cum_amt_mean'] = df['card1_addr1_cum_amt_mean'].fillna(0)
[?2004l[?2004h> 
[?2004l[?2004h> df['card1_addr1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_addr1_cum_amt_mean'] + 1e-5)
[?2004l[?2004h> 
[?2004l[?2004h> # 4. Standard features (categorical and numerical)
[?2004l[?2004h> # ProductCD - categorical target/label encoding or dummy
[?2004l[?2004h> df = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Drop helper string columns and target
[?2004l[?2004h> features_to_drop = ['TransactionID', 'TransactionDT', 'isFraud', 'card1_addr1']
[?2004l[?2004h> features = [c for c in df.columns if c not in features_to_drop]
[?2004l[?2004h> 
[?2004l[?2004h> # 5. Split train and test
[?2004l[?2004h> # Chronological split: 80% train, 20% test
[?2004l[?2004h> split_idx = int(len(df) * 0.8)
[?2004l[?2004h> train_df = df.iloc[:split_idx]
[?2004l[?2004h> test_df = df.iloc[split_idx:]
[?2004l[?2004h> 
[?2004l[?2004h> X_train = train_df[features]
[?2004l[?2004h> y_train = train_df['isFraud']
[?2004l[?2004h> X_test = test_df[features]
[?2004l[?2004h> y_test = test_df['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> print("Train shape:", X_train.shape, "Test shape:", X_test.shape)
[?2004l[?2004h> print("Train fraud rate:", y_train.mean(), "Test fraud rate:", y_test.mean())
[?2004l[?2004h> 
[?2004l[?2004h> # 6. Model Training
[?2004l[?2004h> model = xgb.XGBClassifier(n_estimators=100, max_depth=6, learning_rate=0.05, random_state=42, eval_metric='auc')
[?2004l[?2004h> model.fit(X_train, y_train)
[?2004l[?2004h> 
[?2004l[?2004h> # 7. Evaluation
[?2004l[?2004h> preds_train = model.predict_proba(X_train)[:, 1]
[?2004l[?2004h> preds_test = model.predict_proba(X_test)[:, 1]
[?2004l[?2004h> 
[?2004l[?2004h> auc_train = roc_auc_score(y_train, preds_train)
[?2004l[?2004h> auc_test = roc_auc_score(y_test, preds_test)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Train AUC: {auc_train:.5f}")
[?2004l[?2004h> print(f"Test AUC: {auc_test:.5f}")
[?2004l[?2004h> EOF
[?2004l[?2004hroot@9da0ecea1a80:/workspace# python3 run_baseline.py
[?2004lEngineering historical features...
Train shape: (24000, 21) Test shape: (6000, 21)
