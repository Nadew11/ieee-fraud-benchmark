[44.248999, "i", "cat << 'EOF' > test_perf.py\nimport pandas as pd\nimport numpy as np\nimport time\n\nt0 = time.time()\ndf = pd.read_csv('/data/transactions.csv')\ndf = df.sort_values('TransactionDT').reset_index(drop=True)\n\ndf['card1_cum_count'] = df.groupby('card1').cumcount()\ndf['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff()\ndf['card1_cum_amt_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())\n\nprint(\"Done in {:.2f}s\".format(time.time() - t0))\nprint(df[['card1', 'TransactionDT', 'TransactionAmt', 'card1_cum_count', 'card1_time_diff', 'card1_cum_amt_mean']].head(10))\nEOF\n"]
[44.268313, "o", "cat << 'EOF' > test_perf.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> import time\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> t0 = time.time()\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('TransactionDT').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['card1_cum_count'] = df.groupby('card1').cumcount()\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff()\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_cum_amt_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Done in {:.2f}s\".format(time.time() - t0))\r\n\u001b[?2004l\r\u001b[?2004h> print(df[['card1', 'TransactionDT', 'TransactionAmt', 'card1_cum_count', 'card1_time_diff', 'card1_cum_amt_mean']].head(10))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
