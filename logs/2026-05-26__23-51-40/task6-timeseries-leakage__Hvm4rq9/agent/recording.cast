[24.474262, "i", "cat << 'EOF' > inspect_data.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nprint(\"Shape:\", df.shape)\nprint(\"Columns:\", df.columns.tolist())\nprint(\"Missing values:\\n\", df.isnull().sum())\nprint(\"isFraud value counts:\\n\", df['isFraud'].value_counts(dropna=False))\nprint(\"TransactionDT range:\", df['TransactionDT'].min(), df['TransactionDT'].max())\nprint(\"ProductCD unique values:\", df['ProductCD'].unique())\nprint(\"card1 unique count:\", df['card1'].nunique())\nprint(\"addr1 unique count:\", df['addr1'].nunique())\nEOF\n"]
