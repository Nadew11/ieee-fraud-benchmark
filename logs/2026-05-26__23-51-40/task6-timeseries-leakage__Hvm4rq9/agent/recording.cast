[140.937606, "o", "            learning_rate=lr,\r\n\u001b[?2004l\r\u001b[?2004h>             subsample=0.9,\r\n\u001b[?2004l\r"]
[140.937674, "o", "\u001b[?2004h> "]
[140.937898, "o", "            colsample_bytree=0.8,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[140.938005, "o", "            random_state=42,\r\n\u001b[?2004l\r\u001b[?2004h"]
[140.938044, "o", ">             eval_metric='auc',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[140.938104, "o", "            early_stopping_rounds=50\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r"]
