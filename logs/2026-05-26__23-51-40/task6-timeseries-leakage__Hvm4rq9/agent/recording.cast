[115.423745, "i", "cat << 'EOF' > run_experiments.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\n# Load and sort\ndf = pd.read_csv('/data/transactions.csv')\ndf = df.sort_values('TransactionDT').reset_index(drop=True)\n\n# --- Feature Engineering ---\n\n# Cyclical/Temporal features\ndf['hour'] = (df['TransactionDT'] // 3600) % 24\ndf['day_of_week'] = (df['TransactionDT'] // 86400) % 7\n\n# Historical features per card1\ndf['card1_cum_count'] = df.groupby('card1').cumcount()\ndf['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff().fillna(999999999)\ndf['card1_cum_amt_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(0)\ndf['card1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_cum_amt_mean'] + 1e-5)\n\n# Historical features per card1 + addr1\ndf['card1_addr1'] = df['card1'].astype(str) + '_' + df['addr1'].astype(str)\ndf['card1_addr1_cum_count'] = df.groupby('card1_addr1').cumcount()\ndf['card1_addr1_time_diff'] = df.groupby('card1_addr1')['TransactionDT'].diff().fillna(999999999)\ndf['card1_addr1_cum_amt_mean'] = df.groupby('card1_addr1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(0)\ndf['card1_addr1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_addr1_cum_amt_mean'] + 1e-5)\n\n# Target encoding/frequency encoding of high cardinality features\n# Note: To prevent leakage, frequency of card1/addr1 can be calculated up to the transaction\ndf['card1_freq'] = df.groupby('card1')['TransactionDT'].transform('count')\ndf['addr1_freq'] = df.groupby('addr1')['TransactionDT'].transform('count')\n\n# Let's drop strings\ndf = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)\nfeatures_to_drop = ['TransactionID', 'TransactionDT', 'isFraud', 'card1_addr1']\nfeatures = [c for c in df.columns if c not in features_to_drop]\n\n# Train/Test Split\nsplit_idx = int(len(df) * 0.8)\ntrain_df = df.iloc[:split_idx]\ntest_df = df.iloc[split_idx:]\n\nX_train = train_df[features]\ny_train = train_df['isFraud']\nX_test = test_df[features]\ny_test = test_df['isFraud']\n\n# Let's perform a hyperparameter grid search\nprint(\"Features:\", features)\nprint(\"Number of features:\", len(features))\n\nfor max_depth in [4, 6, 8]:\n    for lr in [0.03, 0.05, 0.1]:\n        for subsample in [0.8, 1.0]:\n            model = xgb.XGBClassifier(\n                n_estimators=150,\n                max_depth=max_depth,\n                learning_rate=lr,\n                subsample=subsample,\n                colsample_bytree=0.8,\n                random_state=42,\n                eval_metric='auc'\n            )\n            model.fit(X_train, y_train)\n            preds_train = model.predict_proba(X_train)[:, 1]\n            preds_test = model.predict_proba(X_test)[:, 1]\n            \n            auc_train = roc_auc_score(y_train, preds_train)\n            auc_test = roc_auc_score(y_test, preds_test)\n            print(f\"depth={max_depth}, lr={lr}, sub={subsample} -> Train AUC: {auc_train:.5f}, Test AUC: {auc_test:.5f}\")\nEOF\n"]
[115.432264, "o", "cat << 'EOF' > run_experiments.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Load and sort\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('TransactionDT').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # --- Feature Engineering ---\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Cyclical/Temporal features\r\n\u001b[?2004l\r\u001b[?2004h> df['hour'] = (df['TransactionDT'] // 3600) % 24\r\n\u001b[?2004l\r\u001b[?2004h> df['day_of_week'] = (df['TransactionDT'] // 86400) % 7\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Historical features per card1\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_cum_count'] = df.groupby('card1').cumcount()\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff().fillna(999999999)\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_cum_amt_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_cum_amt_mean'] + 1e-5)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Historical features per card1 + addr1\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1'] = df['card1'].astype(str) + '_' + df['addr1'].astype(str)\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1_cum_count'] = df.groupby('card1_addr1').cumcount()\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1_time_diff'] = df.groupby('card1_addr1')['TransactionDT'].diff().fillna(999999999)\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1_cum_amt_mean'] = df.groupby('card1_addr1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_addr1_cum_amt_mean'] + 1e-5)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Target encoding/frequency encoding of high cardinality features\r\n\u001b[?2004l\r\u001b[?2004h> "]
