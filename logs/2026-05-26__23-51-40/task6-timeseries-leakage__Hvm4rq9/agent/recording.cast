[32.048251, "i", "cat << 'EOF' > test_fe.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\ndf = df.sort_values('TransactionDT').reset_index(drop=True)\n\n# Group by card1 frequency\nfreq = df['card1'].value_counts()\nprint(\"card1 transaction frequencies:\")\nprint(freq.describe())\nprint(\"Number of card1 with > 1 transaction:\", (freq > 1).sum())\nprint(\"Number of card1 with > 5 transactions:\", (freq > 5).sum())\n\n# Let's see ProductCD as well\nprint(\"ProductCD value counts:\")\nprint(df['ProductCD'].value_counts())\nEOF\n"]
