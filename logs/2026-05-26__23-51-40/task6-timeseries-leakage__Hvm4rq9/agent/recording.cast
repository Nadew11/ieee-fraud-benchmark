[66.39502, "i", "cat << 'EOF' > run_baseline.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\n# 1. Load data\ndf = pd.read_csv('/data/transactions.csv')\n\n# 2. Sort chronologically\ndf = df.sort_values('TransactionDT').reset_index(drop=True)\n\n# 3. Feature Engineering: Historical pattern features\nprint(\"Engineering historical features...\")\n\n# Client key 1: card1\ndf['card1_cum_count'] = df.groupby('card1').cumcount()\ndf['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff()\n# To handle NaN in time diff, we can use a large value or a flag\ndf['card1_time_diff_nan'] = df['card1_time_diff'].isna().astype(int)\ndf['card1_time_diff'] = df['card1_time_diff'].fillna(999999999) # large number\n\ndf['card1_cum_amt_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())\ndf['card1_cum_amt_mean_nan'] = df['card1_cum_amt_mean'].isna().astype(int)\ndf['card1_cum_amt_mean'] = df['card1_cum_amt_mean'].fillna(0)\n\n# Ratio of current transaction amount to the average historical amount\ndf['card1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_cum_amt_mean'] + 1e-5)\n\n# Client key 2: card1 + addr1\ndf['card1_addr1'] = df['card1'].astype(str) + '_' + df['addr1'].astype(str)\ndf['card1_addr1_cum_count'] = df.groupby('card1_addr1').cumcount()\ndf['card1_addr1_time_diff'] = df.groupby('card1_addr1')['TransactionDT'].diff()\ndf['card1_addr1_time_diff_nan'] = df['card1_addr1_time_diff'].isna().astype(int)\ndf['card1_addr1_time_diff'] = df['card1_addr1_time_diff'].fillna(999999999)\n\ndf['card1_addr1_cum_amt_mean'] = df.groupby('card1_addr1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())\ndf['card1_addr1_cum_amt_mean_nan'] = df['card1_addr1_cum_amt_mean'].isna().astype(int)\ndf['card1_addr1_cum_amt_mean'] = df['card1_addr1_cum_amt_mean'].fillna(0)\n\ndf['card1_addr1_amt_ratio_to_mean'] = df['TransactionAmt'] / (df['card1_addr1_cum_amt_mean'] + 1e-5)\n\n# 4. Standard features (categorical and numerical)\n# ProductCD - categorical target/label encoding or dummy\ndf = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)\n\n# Drop helper string columns and target\nfeatures_to_drop = ['TransactionID', 'TransactionDT', 'isFraud', 'card1_addr1']\nfeatures = [c for c in df.columns if c not in features_to_drop]\n\n# 5. Split train and test\n# Chronological split: 80% train, 20% test\nsplit_idx = int(len(df) * 0.8)\ntrain_df = df.iloc[:split_idx]\ntest_df = df.iloc[split_idx:]\n\nX_train = train_df[features]\ny_train = train_df['isFraud']\nX_test = test_df[features]\ny_test = test_df['isFraud']\n\nprint(\"Train shape:\", X_train.shape, \"Test shape:\", X_test.shape)\nprint(\"Train fraud rate:\", y_train.mean(), \"Test fraud rate:\", y_test.mean())\n\n# 6. Model Training\nmodel = xgb.XGBClassifier(n_estimators=100, max_depth=6, learning_rate=0.05, random_state=42, eval_metric='auc')\nmodel.fit(X_train, y_train)\n\n# 7. Evaluation\npreds_train = model.predict_proba(X_train)[:, 1]\npreds_test = model.predict_proba(X_test)[:, 1]\n\nauc_train = roc_auc_score(y_train, preds_train)\nauc_test = roc_auc_score(y_test, preds_test)\n\nprint(f\"Train AUC: {auc_train:.5f}\")\nprint(f\"Test AUC: {auc_test:.5f}\")\nEOF\n"]
[66.398577, "o", "cat << 'EOF' > run_baseline.py\r\n"]
