[40.20179, "i", "cat << 'EOF' > test_shift_expanding.py\nimport pandas as pd\nimport numpy as np\n\ndata = pd.DataFrame({\n    'card1': [1, 1, 1, 2, 2],\n    'TransactionDT': [100, 200, 300, 150, 250],\n    'TransactionAmt': [10.0, 20.0, 30.0, 50.0, 100.0]\n})\n\n# Sort\ndata = data.sort_values('TransactionDT').reset_index(drop=True)\n\n# Cumulative count of previous transactions\ndata['card1_cum_count'] = data.groupby('card1').cumcount()\n\n# Time diff to previous transaction\ndata['card1_time_diff'] = data.groupby('card1')['TransactionDT'].diff()\n\n# Cumulative mean of previous transactions' amt\ndata['card1_cum_amt_mean'] = data.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean())\n\nprint(data)\nEOF\n"]
