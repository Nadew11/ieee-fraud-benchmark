[275.327309, "i", "cat << 'EOF' > test_finetune.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\ndf = pd.read_csv('/data/transactions.csv')\ndf = df.sort_values('TransactionDT').reset_index(drop=True)\n\ndf['dt_diff_card1'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)\ndf['dt_diff_card1_addr1'] = df.groupby(['card1', 'addr1'])['TransactionDT'].diff().fillna(-1)\n\ndf['card1_cum_count'] = df.groupby('card1').cumcount()\ndf['card1_addr1_cum_count'] = df.groupby(['card1', 'addr1']).cumcount()\n\ndf['card1_amt_cum_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)\ndf['card1_addr1_amt_cum_mean'] = df.groupby(['card1', 'addr1'])['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)\n\ndf['card1_fraud_cum_mean'] = df.groupby('card1')['isFraud'].transform(lambda x: x.shift().expanding().mean()).fillna(0.0456)\ndf['card1_addr1_fraud_cum_mean'] = df.groupby(['card1', 'addr1'])['isFraud'].transform(lambda x: x.shift().expanding().mean()).fillna(0.0456)\n\ndf['hour'] = (df['TransactionDT'] // 3600) % 24\n\ndf['amt_to_mean_card1'] = df['TransactionAmt'] / (df['card1_amt_cum_mean'] + 1e-5)\ndf['amt_to_mean_card1_addr1'] = df['TransactionAmt'] / (df['card1_addr1_amt_cum_mean'] + 1e-5)\n\ndf['amt_diff_mean_card1'] = df['TransactionAmt'] - df['card1_amt_cum_mean']\ndf['amt_diff_mean_card1_addr1'] = df['TransactionAmt'] - df['card1_addr1_amt_cum_mean']\n\ndf['card1_amt_cum_std'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().std()).fillna(-1)\ndf['card1_addr1_amt_cum_std'] = df.groupby(['card1', 'addr1'])['TransactionAmt'].transform(lambda x: x.shift().expanding().std()).fillna(-1)\n\ndf['C1_diff_card1'] = df.groupby('card1')['C1'].diff().fillna(-1)\ndf['C2_diff_card1'] = df.groupby('card1')['C2'].diff().fillna(-1)\n\ndf = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)\n\nfeatures = [c for c in df.columns if c not in ['TransactionID', 'TransactionDT', 'isFraud']]\n\nn = len(df)\nsplit_idx = int(n * 0.8)\n\ntrain_df = df.iloc[:split_idx]\ntest_df = df.iloc[split_idx:]\n\nX_train, y_train = train_df[features], train_df['isFraud']\nX_test, y_test = test_df[features], test_df['isFraud']\n\nfor lr in [0.02, 0.03, 0.05]:\n    for n_est in [100, 120, 140, 160, 180, 200]:\n        model = xgb.XGBClassifier(n_estimators=n_est, max_depth=4, subsample=1.0, colsample_bytree=0.8, learning_rate=lr, random_state=42, eval_metric='auc')\n        model.fit(X_train, y_train)\n        preds = model.predict_proba(X_test)[:, 1]\n        auc = roc_auc_score(y_test, preds)\n        print(f'lr: {lr}, n_est: {n_est} -> Test AUC: {auc:.5f}')\nEOF\n"]
[275.351973, "o", "cat << 'EOF' > test_finetune.py"]
