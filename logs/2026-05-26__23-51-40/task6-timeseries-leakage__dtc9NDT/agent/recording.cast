[41.529659, "i", "cat << 'EOF' > test_features.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\ndf = pd.read_csv('/data/transactions.csv')\ndf = df.sort_values('TransactionDT').reset_index(drop=True)\n\ndf['dt_diff_card1'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)\ndf['dt_diff_card1_addr1'] = df.groupby(['card1', 'addr1'])['TransactionDT'].diff().fillna(-1)\ndf['card1_cum_count'] = df.groupby('card1').cumcount()\ndf['card1_addr1_cum_count'] = df.groupby(['card1', 'addr1']).cumcount()\ndf['card1_amt_cum_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)\ndf['card1_addr1_amt_cum_mean'] = df.groupby(['card1', 'addr1'])['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)\ndf['hour'] = (df['TransactionDT'] // 3600) % 24\ndf['amt_to_mean_card1'] = df['TransactionAmt'] / (df['card1_amt_cum_mean'] + 1e-5)\ndf = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)\n\nfeatures = [c for c in df.columns if c not in ['TransactionID', 'TransactionDT', 'isFraud']]\nsplit_idx = int(len(df) * 0.8)\ntrain_df = df.iloc[:split_idx]\ntest_df = df.iloc[split_idx:]\n\nX_train, y_train = train_df[features], train_df['isFraud']\nX_test, y_test = test_df[features], test_df['isFraud']\n\nmodel = xgb.XGBClassifier(n_estimators=100, max_depth=6, learning_rate=0.05, random_state=42, eval_metric='auc')\nmodel.fit(X_train, y_train, eval_set=[(X_test, y_test)], verbose=10)\npreds = model.predict_proba(X_test)[:, 1]\nprint(f'Test AUC: {roc_auc_score(y_test, preds):.5f}')\nEOF\n"]
[41.534472, "o", "cat << 'EOF' > test_features.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('TransactionDT').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['dt_diff_card1'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)\r\n\u001b[?2004l\r\u001b[?2004h> df['dt_diff_card1_addr1'] = df.groupby(['card1', 'addr1'])['TransactionDT'].diff().fillna(-1)\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_cum_count'] = df.groupby('card1').cumcount()\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1_cum_count'] = df.groupby(['card1', 'addr1']).cumcount()\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_amt_cum_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1_amt_cum_mean'] = df.groupby(['card1', 'addr1'])['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)\r\n\u001b[?2004l\r\u001b[?2004h> df['hour'] = (df['TransactionDT'] // 3600) % 24\r\n\u001b[?2004l\r\u001b[?2004h> df['amt_to_mean_card1'] = df['TransactionAmt'] / (df['card1_amt_cum_mean'] + 1e-5)\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df.columns if c not in ['TransactionID', 'TransactionDT', 'isFraud']]\r\n\u001b[?2004l\r\u001b[?2004h> split_idx = int(len(df) * 0.8)\r\n\u001b[?2004l\r\u001b[?2004h> train_df = df.iloc[:split_idx]\r\n\u001b[?2004l\r"]
[41.536946, "o", "\u001b[?2004h> test_df = df.iloc[split_idx:]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> X_train, y_train = train_df[features], train_df['isFraud']\r\n\u001b[?2004l\r\u001b[?2004h> X_test, y_test = test_df[features], test_df['isFraud']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[41.53863, "o", "\u001b[?2004h> model = xgb.XGBClassifier(n_estimators=100, max_depth=6, learning_rate=0.05, random_state=42, eval_metric='auc')\r\n\u001b[?2004l\r\u001b[?2004h> model.fit(X_train, y_train, eval_set=[(X_test, y_test)], verbose=10)\r\n\u001b[?2004l\r\u001b[?2004h> preds = model.predict_proba(X_test)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> print(f'Test AUC: {roc_auc_score(y_test, preds):.5f}')\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
