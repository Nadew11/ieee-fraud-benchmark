[275.404379, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> train_df = df.iloc[:split_idx]\r\n\u001b[?2004l\r\u001b[?2004h> test_df = df.iloc[split_idx:]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> X_train, y_train = train_df[features], train_df['isFraud']\r\n\u001b[?2004l\r\u001b[?2004h> X_test, y_test = test_df[features], test_df['isFraud']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for lr in [0.02, 0.03, 0.05]:\r\n\u001b[?2004l\r\u001b[?2004h>     for n_est in [100, 120, 140, 160, 180, 200]:\r\n\u001b[?2004l\r\u001b[?2004h>         model = xgb.XGBClassifier(n_estimators=n_est, max_depth=4, subsample=1.0, colsample_bytree=0.8, learning_rate=lr, random_state=42, eval_metric='auc')\r\n\u001b[?2004l\r\u001b[?2004h>         model.fit(X_train, y_train)\r\n\u001b[?2004l\r\u001b[?2004h>         preds = model.predict_proba(X_test)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h>         auc = roc_auc_score(y_test, preds)\r\n\u001b[?2004l\r\u001b[?2004h>         print(f'lr: {lr}, n_est: {n_est} -> Test AUC: {auc:.5f}')\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
