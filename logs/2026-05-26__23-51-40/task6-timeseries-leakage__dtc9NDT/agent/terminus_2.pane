[?2004l[?2004h> 
[?2004l[?2004h> # 1. Load data
[?2004l[?2004h> df = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> df = df.sort_values('TransactionDT').reset_index(drop=True)
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Feature Engineering
[?2004l[?2004h> df['dt_diff_card1'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)
[?2004l[?2004h> df['dt_diff_card1_addr1'] = df.groupby(['card1', 'addr1'])['TransactionDT'].diff().fillna(-1)
[?2004lzed depth, column subsampling, and low learning rate was tr[?2004h> 
[?2004l[?2004h> df['card1_cum_count'] = df.groupby('card1').cumcount()
[?2004l[?2004h> df['card1_addr1_cum_count'] = df.groupby(['card1', 'addr1']).cumcount()
[?2004l[?2004h> 
[?2004l[?2004h> df['card1_amt_cum_mean'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)
[?2004l[?2004h> df['card1_addr1_amt_cum_mean'] = df.groupby(['card1', 'addr1'])['TransactionAmt'].transform(lambda x: x.shift().expanding().mean()).fillna(-1)
[?2004l[?2004h> 
[?2004l[?2004h> df['card1_fraud_cum_mean'] = df.groupby('card1')['isFraud'].transform(lambda x: x.shift().expanding().mean()).fillna(0.0456)
[?2004l[?2004h> df['card1_addr1_fraud_cum_mean'] = df.groupby(['card1', 'addr1'])['isFraud'].transform(lambda x: x.shift().expanding().mean()).fillna(0.0456)
[?2004l[?2004h> 
[?2004l[?2004h> df['hour'] = (df['TransactionDT'] // 3600) % 24
[?2004l[?2004h> 
[?2004l[?2004h> df['amt_to_mean_card1'] = df['TransactionAmt'] / (df['card1_amt_cum_mean'] + 1e-5)
[?2004l[?2004h> df['amt_to_mean_card1_addr1'] = df['TransactionAmt'] / (df['card1_addr1_amt_cum_mean'] + 1e-5)
[?2004l[?2004h> 
[?2004l[?2004h> df['amt_diff_mean_card1'] = df['TransactionAmt'] - df['card1_amt_cum_mean']
[?2004l[?2004h> df['amt_diff_mean_card1_addr1'] = df['TransactionAmt'] - df['card1_addr1_amt_cum_mean']
[?2004l[?2004h> 
[?2004l[?2004h> df['card1_amt_cum_std'] = df.groupby('card1')['TransactionAmt'].transform(lambda x: x.shift().expanding().std()).fillna(-1)
[?2004l[?2004h> df['card1_addr1_amt_cum_std'] = df.groupby(['card1', 'addr1'])['TransactionAmt'].transform(lambda x: x.shift().expanding().std()).fillna(-1)
[?2004l[?2004h> 
[?2004l[?2004h> df['C1_diff_card1'] = df.groupby('card1')['C1'].diff().fillna(-1)
[?2004l[?2004h> df['C2_diff_card1'] = df.groupby('card1')['C2'].diff().fillna(-1)
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)
[?2004l[?2004h> 
[?2004l[?2004h> # 3. Model Preparation
[?2004l[?2004h> features = [c for c in df.columns if c not in ['TransactionID', 'TransactionDT', 'isFraud']]
[?2004l[?2004h> 
[?2004l[?2004h> n = len(df)
[?2004l[?2004h> split_idx = int(n * 0.8)
[?2004l[?2004h> 
[?2004l[?2004h> train_df = df.iloc[:split_idx]
[?2004l[?2004h> test_df = df.iloc[split_idx:]
[?2004l[?2004h> 
[?2004l[?2004h> X_train, y_train = train_df[features], train_df['isFraud']
[?2004l[?2004h> X_test, y_test = test_df[features], test_df['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> # 4. Model Training
[?2004l[?2004h> model = xgb.XGBClassifier(
[?2004l[?2004h>     n_estimators=100,
[?2004l[?2004h>     max_depth=4,
[?2004l[?2004h>     subsample=1.0,
[?2004l[?2004h>     colsample_bytree=0.8,
[?2004l[?2004h>     learning_rate=0.02,
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     eval_metric='auc'
[?2004l[?2004h> )
[?2004l[?2004h> model.fit(X_train, y_train)
[?2004l[?2004h> 
[?2004l[?2004h> # 5. Model Evaluation
[?2004l[?2004h> preds = model.predict_proba(X_test)[:, 1]
[?2004l[?2004h> auc = roc_auc_score(y_test, preds)
[?2004l[?2004h> print(f'Final Test AUC: {auc:.6f}')
[?2004l[?2004h> 
[?2004l[?2004h> # 6. Save outputs
[?2004l[?2004h> with open('/output/auc.txt', 'w') as f:
[?2004l[?2004h>     f.write(f'{auc:.6f}\n')
