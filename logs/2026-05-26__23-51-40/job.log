Sending keys: ['cat << \'EOF\' > train.py\nimport pandas as pd\nimport numpy as np\nfrom xgboost import XGBClassifier\nfrom sklearn.metrics import roc_auc_score\nimport os\n\n# Load dataset\ndf = pd.read_csv(\'/data/transactions.csv\')\n\n# Feature engineering\n# 1. Temporal features\ndf[\'hour\'] = (df[\'TransactionDT\'] // 3600) % 24\ndf[\'day_of_week\'] = (df[\'TransactionDT\'] // 86400) % 7\n\n# 2. Historical patterns for card1\ndf[\'card1_cum_count\'] = df.groupby(\'card1\').cumcount()\ndf[\'card1_time_diff\'] = df.groupby(\'card1\')[\'TransactionDT\'].diff().fillna(-1)\ncumsum_card1 = df.groupby(\'card1\')[\'TransactionAmt\'].cumsum()\ncumcount_card1 = df.groupby(\'card1\').cumcount() + 1\ndf[\'card1_cum_mean_amt\'] = cumsum_card1 / cumcount_card1\ndf[\'card1_amt_diff_mean\'] = df[\'TransactionAmt\'] - df[\'card1_cum_mean_amt\']\ndf[\'card1_amt_ratio_mean\'] = df[\'TransactionAmt\'] / (df[\'card1_cum_mean_amt\'] + 1e-5)\n\n# 3. Historical patterns for addr1\ndf[\'addr1_cum_count\'] = df.groupby(\'addr1\').cumcount()\ndf[\'addr1_time_diff\'] = df.groupby(\'addr1\')[\'TransactionDT\'].diff().fillna(-1)\ncumsum_addr1 = df.groupby(\'addr1\')[\'TransactionAmt\'].cumsum()\ncumcount_addr1 = df.groupby(\'addr1\').cumcount() + 1\ndf[\'addr1_cum_mean_amt\'] = cumsum_addr1 / cumcount_addr1\n\n# 4. ProductCD one-hot encoding\ndf = pd.get_dummies(df, columns=[\'ProductCD\'], drop_first=True)\n\n# Drop columns not used as features\n# TransactionID and TransactionDT are not direct predictors, but we can keep TransactionDT if useful.\n# We will drop TransactionID.\nfeatures = [col for col in df.columns if col not in [\'TransactionID\', \'isFraud\']]\n\n# Split into train and test temporally\nn_train = int(len(df) * 0.8)\ntrain = df.iloc[:n_train]\ntest = df.iloc[n_train:]\n\nX_train, y_train = train[features], train[\'isFraud\']\nX_test, y_test = test[features], test[\'isFraud\']\n\nprint("Features used:", list(X_train.columns))\n\n# Train Model\nmodel = XGBClassifier(\n    n_estimators=200,\n    learning_rate=0.05,\n    max_depth=6,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    eval_metric=\'auc\'\n)\n\nmodel.fit(X_train, y_train)\n\n# Predict probabilities\ny_pred_train = model.predict_proba(X_train)[:, 1]\ny_pred_test = model.predict_proba(X_test)[:, 1]\n\ntrain_auc = roc_auc_score(y_train, y_pred_train)\ntest_auc = roc_auc_score(y_test, y_pred_test)\n\nprint(f"Train AUC: {train_auc:.5f}")\nprint(f"Test AUC: {test_auc:.5f}")\n\n# Save outputs\nos.makedirs(\'/output\', exist_ok=True)\nwith open(\'/output/auc.txt\', \'w\') as f:\n    f.write(f"{test_auc:.6f}\\n")\n\n# Write methodology note\nwith open(\'/output/methodology.txt\', \'w\') as f:\n    f.write("Methodology Note - Fraud Detection Model with Engineered Features\\n")\n    f.write("===============================================================\\n\\n")\n    f.write("1. Feature Engineering Approach:\\n")\n    f.write("   To capture historical patterns in transaction behavior without introducing target leakage, ")\n    f.write("we engineered cumulative and difference-based features using vectorized cumulative operations:\\n")\n    f.write("   - card1_cum_count: Cumulative transaction count for each card1.\\n")\n    f.write("   - card1_time_diff: Time (seconds) since the previous transaction for the same card1 (filled with -1 for the first transaction).\\n")\n    f.write("   - card1_cum_mean_amt: Cumulative mean transaction amount for each card1.\\n")\n    f.write("   - card1_amt_diff_mean: Deviation of current TransactionAmt from the card1 cumulative mean.\\n")\n    f.write("   - card1_amt_ratio_mean: Ratio of current TransactionAmt to the card1 cumulative mean.\\n")\n    f.write("   - addr1_cum_count, addr1_time_diff, addr1_cum_mean_amt: Analogous cumulative features for the billing region addr1.\\n")\n    f.write("   - hour, day_of_week: Extracted temporal cyclic indicators from TransactionDT to reflect intra-day and intra-week patterns.\\n\\n")\n    f.write("2. Evaluation Strategy:\\n")\n    f.write("   We used a time-based split of 80% train / 20% test to properly evaluate the model\'s ability ")\n    f.write("to predict future unseen transactions, mimicking realistic production deployment scenarios. ")\n    f.write("Since the transactions are already ordered chronologically by TransactionDT, the split preserves the chronological sequence.\\n\\n")\n    f.write("3. Modeling Details:\\n")\n    f.write("   An XGBoost classifier was trained on the engineered feature set. AUC is monitored and reported on the test set.\\n")\n\nprint("Saved outputs successfully.")\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
