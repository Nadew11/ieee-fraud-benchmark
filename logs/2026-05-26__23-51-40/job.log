 = train[features], train[\'isFraud\']\nX_test, y_test = test[features], test[\'isFraud\']\n\n# Train on full train set\nmodel = XGBClassifier(\n    n_estimators=120,\n    learning_rate=0.05,\n    max_depth=4,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    eval_metric=\'auc\'\n)\n\nmodel.fit(X_train, y_train)\ny_pred_test = model.predict_proba(X_test)[:, 1]\ntest_auc = roc_auc_score(y_test, y_pred_test)\nprint(f"Final Test AUC: {test_auc:.5f}")\n\n# Save outputs\nos.makedirs(\'/output\', exist_ok=True)\nwith open(\'/output/auc.txt\', \'w\') as f:\n    f.write(f"{test_auc:.6f}\\n")\n\n# Write methodology note\nwith open(\'/output/methodology.txt\', \'w\') as f:\n    f.write("Methodology Note - Fraud Detection Model with Engineered Features\\n")\n    f.write("===============================================================\\n\\n")\n    f.write("1. Feature Engineering Approach:\\n")\n    f.write("   To capture historical patterns in transaction behavior without introducing target leakage, ")\n    f.write("we engineered cumulative and difference-based features using vectorized cumulative operations:\\n")\n    f.write("   - combo_cum_count, combo_time_diff, combo_cum_mean_amt, combo_amt_diff_mean: Cumulative patterns ")\n    f.write("based on unique card1 + addr1 combination to uniquely identify clients.\\n")\n    f.write("   - card1_cum_count, card1_time_diff, card1_cum_mean_amt: Cumulative patterns grouped by card1 alone.\\n")\n    f.write("   - card1_freq, addr1_freq: Frequency encoding mapped from training distribution for high-cardinality categorical IDs.\\n")\n    f.write("   - hour, day_of_week: Temporal cyclic patterns derived from TransactionDT.\\n\\n")\n    f.write("2. Evaluation Strategy:\\n")\n    f.write("   We used a temporal train/test split of 80% (first 24,000 samples) and 20% (last 6,000 samples). ")\n    f.write("To select model complexity and prevent overfitting, we performed cross-validation with early stopping ")\n    f.write("using a sub-validation set (the final 6,000 samples of the training portion).\\n\\n")\n    f.write("3. Hyperparameter Tuning and Final Training:\\n")\n    f.write("   The tuning process identified that a lower-complexity XGBoost model (max_depth=4, learning_rate=0.05) ")\n    f.write("substantially outperforms high-capacity models by preventing overfitting to the temporal distribution shift.\\n")\n    f.write("   We trained the final model on the full 80% training set using these parameters with 120 estimators, ")\n    f.write(f"yielding a final Test AUC of {test_auc:.5f}.\\n")\n\nprint("Saved all outputs successfully.")\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
