[?2004hroot@f9cb0064b676:/workspace# cat << 'EOF' > test_combo.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Grouping identifier
[?2004l[?2004h> df['card1_addr1'] = df['card1'].astype(str) + '_' + df['addr1'].astype(str)
[?2004l[?2004h> 
[?2004l[?2004h> # Features
[?2004l[?2004h> df['hour'] = (df['TransactionDT'] // 3600) % 24
[?2004l[?2004h> df['day_of_week'] = (df['TransactionDT'] // 86400) % 7
[?2004l[?2004h> 
[?2004l[?2004h> # Historical patterns for card1_addr1
[?2004l[?2004h> df['combo_cum_count'] = df.groupby('card1_addr1').cumcount()
[?2004l[?2004h> df['combo_time_diff'] = df.groupby('card1_addr1')['TransactionDT'].diff().fillna(-1)
[?2004l[?2004h> cumsum_combo = df.groupby('card1_addr1')['TransactionAmt'].cumsum()
[?2004l[?2004h> cumcount_combo = df.groupby('card1_addr1').cumcount() + 1
[?2004l[?2004h> df['combo_cum_mean_amt'] = cumsum_combo / cumcount_combo
[?2004l[?2004h> df['combo_amt_diff_mean'] = df['TransactionAmt'] - df['combo_cum_mean_amt']
[?2004l[?2004h> 
[?2004l[?2004h> # Historical patterns for card1 alone
[?2004l[?2004h> df['card1_cum_count'] = df.groupby('card1').cumcount()
[?2004l[?2004h> df['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)
[?2004l[?2004h> cumsum_card1 = df.groupby('card1')['TransactionAmt'].cumsum()
[?2004l[?2004h> cumcount_card1 = df.groupby('card1').cumcount() + 1
[?2004l[?2004h> df['card1_cum_mean_amt'] = cumsum_card1 / cumcount_card1
[?2004l[?2004h> 
[?2004l[?2004h> # Frequency encoding (based on train set to avoid target/future leakage)
[?2004l[?2004h> n_train = int(len(df) * 0.8)
[?2004l[?2004h> train_df = df.iloc[:n_train]
[?2004l[?2004h> card1_freq = train_df['card1'].value_counts(normalize=True)
[?2004l[?2004h> df['card1_freq'] = df['card1'].map(card1_freq).fillna(0)
[?2004l[?2004h> 
[?2004l[?2004h> # Categorical productCD
[?2004l[?2004h> df = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Drop non-feature columns
[?2004l[?2004h> features = [col for col in df.columns if col not in ['TransactionID', 'isFraud', 'card1_addr1']]
[?2004l[?2004h> 
[?2004l[?2004h> train = df.iloc[:n_train]
[?2004l[?2004h> test = df.iloc[n_train:]
[?2004l[?2004h> 
[?2004l[?2004h> X_train, y_train = train[features], train['isFraud']
[?2004l[?2004h> X_test, y_test = test[features], test['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> model = XGBClassifier(
[?2004l[?2004h>     n_estimators=200,
[?2004l[?2004h>     learning_rate=0.05,
[?2004l[?2004h>     max_depth=6,
[?2004l[?2004h>     subsample=0.8,
[?2004l[?2004h>     colsample_bytree=0.8,
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     use_label_encoder=False,
