[?2004hroot@f9cb0064b676:/workspace# cat << 'EOF' > train.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> import os
[?2004l[?2004h> 
[?2004l[?2004h> # Load dataset
[?2004l[?2004h> df = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Feature engineering
[?2004l[?2004h> # 1. Temporal features
[?2004l[?2004h> df['hour'] = (df['TransactionDT'] // 3600) % 24
[?2004l[?2004h> df['day_of_week'] = (df['TransactionDT'] // 86400) % 7
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Historical patterns for card1
[?2004l[?2004h> df['card1_cum_count'] = df.groupby('card1').cumcount()
[?2004l[?2004h> df['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)
[?2004l[?2004h> cumsum_card1 = df.groupby('card1')['TransactionAmt'].cumsum()
[?2004l[?2004h> cumcount_card1 = df.groupby('card1').cumcount() + 1
[?2004l[?2004h> df['card1_cum_mean_amt'] = cumsum_card1 / cumcount_card1
[?2004l[?2004h> df['card1_amt_diff_mean'] = df['TransactionAmt'] - df['card1_cum_mean_amt']
[?2004l[?2004h> df['card1_amt_ratio_mean'] = df['TransactionAmt'] / (df['card1_cum_mean_amt'] + 1e-5)
[?2004l[?2004h> 
[?2004l[?2004h> # 3. Historical patterns for addr1
[?2004l[?2004h> df['addr1_cum_count'] = df.groupby('addr1').cumcount()
[?2004l[?2004h> df['addr1_time_diff'] = df.groupby('addr1')['TransactionDT'].diff().fillna(-1)
[?2004l[?2004h> cumsum_addr1 = df.groupby('addr1')['TransactionAmt'].cumsum()
[?2004l[?2004h> cumcount_addr1 = df.groupby('addr1').cumcount() + 1
[?2004l[?2004h> df['addr1_cum_mean_amt'] = cumsum_addr1 / cumcount_addr1
[?2004l[?2004h> 
[?2004l[?2004h> # 4. ProductCD one-hot encoding
[?2004l[?2004h> df = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Drop columns not used as features
[?2004l[?2004h> # TransactionID and TransactionDT are not direct predictors, but we can keep TransactionDT if useful.
[?2004l[?2004h> # We will drop TransactionID.
[?2004l[?2004h> features = [col for col in df.columns if col not in ['TransactionID', 'isFraud']]
[?2004l[?2004h> 
[?2004l[?2004h> # Split into train and test temporally
[?2004l[?2004h> n_train = int(len(df) * 0.8)
[?2004l[?2004h> train = df.iloc[:n_train]
[?2004l[?2004h> test = df.iloc[n_train:]
[?2004l[?2004h> 
[?2004l[?2004h> X_train, y_train = train[features], train['isFraud']
[?2004l[?2004h> X_test, y_test = test[features], test['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> print("Features used:", list(X_train.columns))
[?2004l[?2004h> 
[?2004l[?2004h> # Train Model
[?2004l[?2004h> model = XGBClassifier(
[?2004l[?2004h>     n_estimators=200,
[?2004l[?2004h>     learning_rate=0.05,
[?2004l[?2004h>     max_depth=6,
[?2004l[?2004h>     subsample=0.8,
[?2004l[?2004h>     colsample_bytree=0.8,
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     use_label_encoder=False,
[?2004l[?2004h>     eval_metric='auc'
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> model.fit(X_train, y_train)
[?2004l[?2004h> 
[?2004l[?2004h> # Predict probabilities
[?2004l[?2004h> y_pred_train = model.predict_proba(X_train)[:, 1]
[?2004l[?2004h> y_pred_test = model.predict_proba(X_test)[:, 1]
[?2004l[?2004h> 
[?2004l[?2004h> train_auc = roc_auc_score(y_train, y_pred_train)
[?2004l[?2004h> test_auc = roc_auc_score(y_test, y_pred_test)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Train AUC: {train_auc:.5f}")
[?2004l[?2004h> print(f"Test AUC: {test_auc:.5f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save outputs
[?2004l[?2004h> os.makedirs('/output', exist_ok=True)
[?2004l[?2004h> with open('/output/auc.txt', 'w') as f:
[?2004l[?2004h>     f.write(f"{test_auc:.6f}\n")
[?2004l[?2004h> 
[?2004l[?2004h> # Write methodology note
[?2004l[?2004h> with open('/output/methodology.txt', 'w') as f:
[?2004l[?2004h>     f.write("Methodology Note - Fraud Detection Model with Engineered Features\n")
[?2004l[?2004h>     f.write("===============================================================\n\n")
[?2004l[?2004h>     f.write("1. Feature Engineering Approach:\n")
[?2004l[?2004h>     f.write("   To capture historical patterns in transaction behavior without introducing target leakage, ")
[?2004l[?2004h>     f.write("we engineered cumulative and difference-based features using vectorized cumulative operations:\n")
[?2004l[?2004h>     f.write("   - card1_cum_count: Cumulative transaction count for each card1.\n")
[?2004l[?2004h>     f.write("   - card1_time_diff: Time (seconds) since the previous transaction for the same card1 (filled with -1 for the first transaction).\n")
[?2004l[?2004h>     f.write("   - card1_cum_mean_amt: Cumulative mean transaction amount for each card1.\n")
[?2004l[?2004h>     f.write("   - card1_amt_diff_mean: Deviation of current TransactionAmt from the card1 cumulative mean.\n")
[?2004l[?2004h>     f.write("   - card1_amt_ratio_mean: Ratio of current TransactionAmt to the card1 cumulative mean.\n")
[?2004l[?2004h>     f.write("   - addr1_cum_count, addr1_time_diff, addr1_cum_mean_amt: Analogous cumulative features for the billing region addr1.\n")
[?2004l[?2004h>     f.write("   - hour, day_of_week: Extracted temporal cyclic indicators from TransactionDT to reflect intra-day and intra-week patterns.\n\n")
[?2004l[?2004h>     f.write("2. Evaluation Strategy:\n")
[?2004l[?2004h>     f.write("   We used a time-based split of 80% train / 20% test to properly evaluate the model's ability ")
[?2004l[?2004h>     f.write("to predict future unseen transactions, mimicking realistic production deployment scenarios. ")
[?2004l[?2004h>     f.write("Since the transactions are already ordered chronologically by TransactionDT, the split preserves the chronological sequence.\n\n")
[?2004l[?2004h>     f.write("3. Modeling Details:\n")
[?2004l[?2004h>     f.write("   An XGBoost classifier was trained on the engineered feature set. AUC is monitored and reported on the test set.\n")
[?2004l[?2004h> 
[?2004l[?2004h> print("Saved outputs successfully.")
[?2004l[?2004h> EOF
[?2004l[?2004hroot@f9cb0064b676:/workspace# python3 train.py
[?2004lFeatures used: ['TransactionDT', 'TransactionAmt', 'card1', 'addr1', 'C1', 'C2', 'hour', 'day_of_week', 'card1_cum_count', 'card1_time_diff', 'card1_cum_mean_amt', 'card1_amt_diff_mean', 'card1_amt_ratio_mean', 'addr1_cum_count', 'addr1_time_diff', 'addr1_cum_mean_amt', 'ProductCD_H', 'ProductCD_R', 'ProductCD_S', 'ProductCD_W']
