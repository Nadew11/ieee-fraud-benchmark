[51.25813, "i", "cat << 'EOF' > test_split.py\nimport pandas as pd\ndf = pd.read_csv('/data/transactions.csv')\nn_train = int(len(df) * 0.8)\ntrain = df.iloc[:n_train]\ntest = df.iloc[n_train:]\nprint('Train shape:', train.shape, 'Fraud rate:', train['isFraud'].mean(), 'Fraud count:', train['isFraud'].sum())\nprint('Test shape:', test.shape, 'Fraud rate:', test['isFraud'].mean(), 'Fraud count:', test['isFraud'].sum())\nEOF\n"]
[51.271051, "o", "cat << 'EOF' > test_split.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> n_train = int(len(df) * 0.8)\r\n\u001b[?2004l\r\u001b[?2004h> train = df.iloc[:n_train]\r\n\u001b[?2004l\r\u001b[?2004h> test = df.iloc[n_train:]\r\n\u001b[?2004l\r\u001b[?2004h> print('Train shape:', train.shape, 'Fraud rate:', train['isFraud'].mean(), 'Fraud count:', train['isFraud'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> print('Test shape:', test.shape, 'Fraud rate:', test['isFraud'].mean(), 'Fraud count:', test['isFraud'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
