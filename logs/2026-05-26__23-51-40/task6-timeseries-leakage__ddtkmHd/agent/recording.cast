[40.617921, "i", "cat << 'EOF' > test_feat_fast.py\nimport pandas as pd\nimport time\nstart = time.time()\ndf = pd.read_csv('/data/transactions.csv')\ndf['card1_cum_count'] = df.groupby('card1').cumcount()\ndf['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)\n# Fast vectorized cumulative mean\ncumsum = df.groupby('card1')['TransactionAmt'].cumsum()\ncumcount = df.groupby('card1').cumcount() + 1\ndf['card1_cum_mean_amt'] = cumsum / cumcount\nprint(f'Done in {time.time() - start:.3f} seconds')\nprint(df[['card1', 'TransactionDT', 'TransactionAmt', 'card1_cum_count', 'card1_time_diff', 'card1_cum_mean_amt']].head(20))\nEOF\n"]
[40.618996, "o", "cat << 'EOF' > test_feat_fast.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import time\r\n\u001b[?2004l\r\u001b[?2004h> start = time.time()\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> "]
