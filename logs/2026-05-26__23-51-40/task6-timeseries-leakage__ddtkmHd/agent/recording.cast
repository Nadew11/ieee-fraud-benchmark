[86.18458, "i", "cat << 'EOF' > test_combo.py\nimport pandas as pd\nimport numpy as np\nfrom xgboost import XGBClassifier\nfrom sklearn.metrics import roc_auc_score\n\ndf = pd.read_csv('/data/transactions.csv')\n\n# Grouping identifier\ndf['card1_addr1'] = df['card1'].astype(str) + '_' + df['addr1'].astype(str)\n\n# Features\ndf['hour'] = (df['TransactionDT'] // 3600) % 24\ndf['day_of_week'] = (df['TransactionDT'] // 86400) % 7\n\n# Historical patterns for card1_addr1\ndf['combo_cum_count'] = df.groupby('card1_addr1').cumcount()\ndf['combo_time_diff'] = df.groupby('card1_addr1')['TransactionDT'].diff().fillna(-1)\ncumsum_combo = df.groupby('card1_addr1')['TransactionAmt'].cumsum()\ncumcount_combo = df.groupby('card1_addr1').cumcount() + 1\ndf['combo_cum_mean_amt'] = cumsum_combo / cumcount_combo\ndf['combo_amt_diff_mean'] = df['TransactionAmt'] - df['combo_cum_mean_amt']\n\n# Historical patterns for card1 alone\ndf['card1_cum_count'] = df.groupby('card1').cumcount()\ndf['card1_time_diff'] = df.groupby('card1')['TransactionDT'].diff().fillna(-1)\ncumsum_card1 = df.groupby('card1')['TransactionAmt'].cumsum()\ncumcount_card1 = df.groupby('card1').cumcount() + 1\ndf['card1_cum_mean_amt'] = cumsum_card1 / cumcount_card1\n\n# Frequency encoding (based on train set to avoid target/future leakage)\nn_train = int(len(df) * 0.8)\ntrain_df = df.iloc[:n_train]\ncard1_freq = train_df['card1'].value_counts(normalize=True)\ndf['card1_freq'] = df['card1'].map(card1_freq).fillna(0)\n\n# Categorical productCD\ndf = pd.get_dummies(df, columns=['ProductCD'], drop_first=True)\n\n# Drop non-feature columns\nfeatures = [col for col in df.columns if col not in ['TransactionID', 'isFraud', 'card1_addr1']]\n\ntrain = df.iloc[:n_train]\ntest = df.iloc[n_train:]\n\nX_train, y_train = train[features], train['isFraud']\nX_test, y_test = test[features], test['isFraud']\n\nmodel = XGBClassifier(\n    n_estimators=200,\n    learning_rate=0.05,\n    max_depth=6,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    eval_metric='auc'\n)\n\nmodel.fit(X_train, y_train)\ny_pred_test = model.predict_proba(X_test)[:, 1]\ntest_auc = roc_auc_score(y_test, y_pred_test)\nprint(f\"Test AUC with combo features: {test_auc:.5f}\")\nEOF\n"]
[86.191628, "o", "cat << 'EOF' > test_combo.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from xgboost import XGBClassifier\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Grouping identifier\r\n\u001b[?2004l\r\u001b[?2004h> df['card1_addr1'] = df['card1'].astype(str) + '_' + df['addr1'].astype(str)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Features\r\n\u001b[?2004l\r\u001b[?2004h> df['hour'] = (df['TransactionDT'] // 3600) % 24\r\n\u001b[?2004l\r\u001b[?2004h> df['day_of_week'] = (df['TransactionDT'] // 86400) % 7\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Historical patterns for card1_addr1\r\n\u001b[?2004l\r\u001b[?2004h> df['combo_cum_count'] = df.groupby('card1_addr1').cumcount()\r\n\u001b[?2004l\r\u001b[?2004h> df['combo_time_diff'] = df.groupby('card1_addr1')['TransactionDT'].diff().fillna(-1)"]
