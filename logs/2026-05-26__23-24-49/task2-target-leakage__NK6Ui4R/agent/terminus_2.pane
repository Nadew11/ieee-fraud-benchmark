[?2004hroot@f6fdec80eb9d:/workspace# cat << 'EOF' > test_clean_models.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.compose import ColumnTransformer
[?2004l[?2004h> from sklearn.pipeline import Pipeline
[?2004l[?2004h> from sklearn.impute import SimpleImputer
[?2004l[?2004h> from sklearn.preprocessing import OneHotEncoder, StandardScaler
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> 
[?2004l[?2004h> # Load
[?2004l[?2004h> df = pd.read_csv('/data/train_transaction.csv')
[?2004l[?2004h> target = 'isFraud'
[?2004l[?2004h> 
[?2004l[?2004h> # Exclude target, ID, and leaky features
[?2004l[?2004h> exclude_features = ['TransactionID', target, 'chargeback_amount', 'days_to_chargeback', 'fraud_score']
[?2004l[?2004h> features = [c for c in df.columns if c not in exclude_features]
[?2004l[?2004h> 
[?2004l[?2004h> # Split
[?2004l[?2004h> train_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])
[?2004l[?2004h> 
[?2004l[?2004h> # Preprocessing
[?2004l[?2004h> cat_cols = df[features].select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> num_cols = [c for c in features if c not in cat_cols]
[?2004l[?2004h> 
[?2004l[?2004h> # 1. Pipeline with HistGradientBoostingClassifier (using native categorical or OneHot)
[?2004l[?2004h> # HistGB natively supports missing values, so we can just convert categorical to categories or use OneHot
[?2004l[?2004h> # Let's test HistGB with OneHot
[?2004l[?2004h> num_transformer = SimpleImputer(strategy='median')
[?2004l[?2004h> cat_transformer = Pipeline(steps=[
[?2004l[?2004h>     ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),
[?2004l[?2004h>     ('onehot', OneHotEncoder(handle_unknown='ignore', sparse_output=False))
[?2004l[?2004h> ])
[?2004l[?2004h> preprocessor = ColumnTransformer(transformers=[
[?2004l[?2004h>     ('num', num_transformer, num_cols),
[?2004l[?2004h>     ('cat', cat_transformer, cat_cols)
[?2004l[?2004h> ])
[?2004l[?2004h> 
[?2004l[?2004h> pipeline_hgb = Pipeline(steps=[
[?2004l[?2004h>     ('preprocessor', preprocessor),
[?2004l[?2004h>     ('classifier', HistGradientBoostingClassifier(random_state=42))
[?2004l[?2004h> ])
[?2004l[?2004h> pipeline_hgb.fit(train_df[features], train_df[target])
[?2004l[?2004h> preds_hgb = pipeline_hgb.predict_proba(val_df[features])[:, 1]
[?2004l[?2004h> print("HistGB (OneHot) AUC:", roc_auc_score(val_df[target], preds_hgb))
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Pipeline with XGBoost (enable_categorical=True, handle missing natively)
[?2004l[?2004h> # XGBoost can handle categorical features natively if they are category dtype and enable_categorical=True
[?2004l[?2004h> xgb_train = train_df[features].copy()
[?2004l[?2004h> xgb_val = val_df[features].copy()
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     xgb_train[col] = xgb_train[col].astype('category')
[?2004l[?2004h>     xgb_val[col] = xgb_val[col].astype('category')
[?2004l[?2004h> 
[?2004l[?2004h> # XGBoost handles missing numeric values natively, but let's see if we should impute
[?2004l[?2004h> xgb = XGBClassifier(enable_categorical=True, random_state=42, eval_metric='auc')
[?2004l[?2004h> xgb.fit(xgb_train, train_df[target])
[?2004l[?2004h> preds_xgb = xgb.predict_proba(xgb_val)[:, 1]
[?2004l[?2004h> print("XGBoost (native categorical & missing) AUC:", roc_auc_score(val_df[target], preds_xgb))
[?2004l[?2004h> 
[?2004l[?2004h> # 3. XGBoost with explicit Imputation + OneHot
[?2004l[?2004h> # Let's see if pre-imputing and one-hot encoding improves XGBoost
[?2004l[?2004h> pipeline_xgb = Pipeline(steps=[
[?2004l[?2004h>     ('preprocessor', preprocessor),
[?2004l[?2004h>     ('classifier', XGBClassifier(random_state=42, eval_metric='auc'))
[?2004l[?2004h> ])
[?2004l[?2004h> pipeline_xgb.fit(train_df[features], train_df[target])
[?2004l[?2004h> preds_xgb_pipe = pipeline_xgb.predict_proba(val_df[features])[:, 1]
[?2004l[?2004h> print("XGBoost (Pipeline with OneHot & Imputation) AUC:", roc_auc_score(val_df[target], preds_xgb_pipe))
