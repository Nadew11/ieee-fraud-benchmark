[?2004hroot@f6fdec80eb9d:/workspace# cat << 'EOF' > test_xgb.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from xgboost import XGBClassifier
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.read_csv('/data/train_transaction.csv')
[?2004l[?2004h> target = 'isFraud'
[?2004l[?2004h> 
[?2004l[?2004h> # Convert categorical columns to category dtypes
[?2004l[?2004h> cat_cols = df.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     df[col] = df[col].astype('category')
[?2004l[?2004h> 
[?2004l[?2004h> # Split
[?2004l[?2004h> train_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])
[?2004l[?2004h> 
[?2004l[?2004h> # Exclude leakage features
[?2004l[?2004h> features_no_leak = [c for c in df.columns if c not in ['TransactionID', target, 'chargeback_amount', 'days_to_chargeback']]
[?2004l[?2004h> 
[?2004l[?2004h> # Train XGBoost with categorical support
[?2004l[?2004h> xgb = XGBClassifier(enable_categorical=True, random_state=42, eval_metric='auc')
[?2004l[?2004h> xgb.fit(train_df[features_no_leak], train_df[target])
[?2004l[?2004h> preds_xgb = xgb.predict_proba(val_df[features_no_leak])[:, 1]
[?2004l[?2004h> auc_xgb = roc_auc_score(val_df[target], preds_xgb)
[?2004l[?2004h> print(f"XGB AUC without explicit chargeback leaks: {auc_xgb:.6f}")
[?2004l[?2004h> 
[?2004l[?2004h> # What if we also exclude fraud_score?
[?2004l[?2004h> features_no_score = [c for c in features_no_leak if c != 'fraud_score']
[?2004l[?2004h> xgb2 = XGBClassifier(enable_categorical=True, random_state=42, eval_metric='auc')
[?2004l[?2004h> xgb2.fit(train_df[features_no_score], train_df[target])
[?2004l[?2004h> preds_xgb2 = xgb2.predict_proba(val_df[features_no_score])[:, 1]
[?2004l[?2004h> auc_xgb2 = roc_auc_score(val_df[target], preds_xgb2)
[?2004l[?2004h> print(f"XGB AUC without fraud_score or chargeback: {auc_xgb2:.6f}")
[?2004l[?2004h> EOF
