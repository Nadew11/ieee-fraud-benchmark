[?2004hroot@f6fdec80eb9d:/workspace# cat << 'EOF' > test_model.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> 
[?2004l[?2004h> # Load data
[?2004l[?2004h> df = pd.read_csv('/data/train_transaction.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Separate features and target
[?2004l[?2004h> target = 'isFraud'
[?2004l[?2004h> 
[?2004l[?2004h> # Let's inspect categorical columns
[?2004l[?2004h> cat_cols = df.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> print("Categorical columns:", cat_cols)
[?2004l[?2004h> 
[?2004l[?2004h> # Convert categorical columns to category dtypes for HistGradientBoostingClassifier
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     df[col] = df[col].astype('category')
[?2004l[?2004h> 
[?2004l[?2004h> # Split
[?2004l[?2004h> train_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])
[?2004l[?2004h> 
[?2004l[?2004h> # Define feature sets
[?2004l[?2004h> # 1. All features (excluding TransactionID and isFraud)
[?2004l[?2004h> features_all = [c for c in df.columns if c not in ['TransactionID', target]]
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Features excluding potential leakage: 'chargeback_amount', 'days_to_chargeback', 'fraud_score'
[?2004l[?2004h> features_no_leak = [c for c in features_all if c not in ['chargeback_amount', 'days_to_chargeback', 'fraud_score']]
[?2004l[?2004h> 
[?2004l[?2004h> # Train model 1 (all features)
[?2004l[?2004h> clf1 = HistGradientBoostingClassifier(categorical_features=[features_all.index(c) for c in cat_cols if c in features_all], random_state=42)
[?2004l[?2004h> clf1.fit(train_df[features_all], train_df[target])
[?2004l[?2004h> preds1 = clf1.predict_proba(val_df[features_all])[:, 1]
[?2004l[?2004h> auc1 = roc_auc_score(val_df[target], preds1)
[?2004l[?2004h> print(f"AUC with all features: {auc1:.6f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Train model 2 (no leak)
[?2004l[?2004h> clf2 = HistGradientBoostingClassifier(categorical_features=[features_no_leak.index(c) for c in cat_cols if c in features_no_leak], random_state=42)
[?2004l[?2004h> clf2.fit(train_df[features_no_leak], train_df[target])
[?2004l[?2004h> preds2 = clf2.predict_proba(val_df[features_no_leak])[:, 1]
[?2004l[?2004h> auc2 = roc_auc_score(val_df[target], preds2)
[?2004l[?2004h> print(f"AUC without leaky features: {auc2:.6f}")
[?2004l[?2004h> EOF
