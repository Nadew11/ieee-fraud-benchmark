_score(val_df[target], preds)\r\n\u001b[?2004l\r\u001b[?2004h>     return auc\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"AUC excluding chargeback leaks:\", run_pipeline(['chargeback_amount', 'days_to_chargeback']))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"AUC excluding chargeback leaks & fraud_score:\", run_pipeline(['chargeback_amount', 'days_to_chargeback', 'fraud_score']))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"AUC with ALL features:\", run_pipeline([]))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@f6fdec80eb9d:/workspace# python3 pipeline_test.py\r\n\u001b[?2004l\r"]
