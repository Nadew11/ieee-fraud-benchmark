[298.037556, "o", "\u001b[?2004h> from sklearn.model_selection import train_test_split\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.compose import ColumnTransformer\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.pipeline import Pipeline\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.impute import SimpleImputer\r\n\u001b[?2004l\r"]
[298.037749, "o", "\u001b[?2004h> from sklearn.preprocessing import OneHotEncoder\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.037971, "o", "from sklearn.ensemble import HistGradientBoostingClassifier\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.038168, "o", "# 1. Load data\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.038481, "o", "target = 'isFraud'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 2. Exclude target, ID, and leaky features\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.038595, "o", "exclude_features = ['TransactionID', target, 'chargeback_amount', 'days_to_chargeback', 'fraud_score']\r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df.columns if c not in exclude_features]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.038861, "o", "# 3. 80/20 train/validation split\r\n\u001b[?2004l\r\u001b[?2004h> train_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 4. Define feature columns\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.038917, "o", "cat_cols = df[features].select_dtypes(include=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.039119, "o", "num_cols = [c for c in features if c not in cat_cols]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 5. Pipeline with imputation and one-hot encoding\r\n\u001b[?2004l\r\u001b[?2004h> num_transformer = SimpleImputer(strategy='median')\r\n"]
[298.039147, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[298.039333, "o", "cat_transformer = Pipeline(steps=[\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.039488, "o", "    ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),\r\n\u001b[?2004l\r\u001b[?2004h>     ('onehot', OneHotEncoder(handle_unknown='ignore', sparse_output=False))\r\n\u001b[?2004l\r"]
[298.039535, "o", "\u001b[?2004h> ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.039775, "o", "preprocessor = ColumnTransformer(transformers=[\r\n\u001b[?2004l\r\u001b[?2004h>     ('num', num_transformer, num_cols),\r\n\u001b[?2004l\r\u001b[?2004h>     ('cat', cat_transformer, cat_cols)\r\n\u001b[?2004l\r\u001b[?2004h> ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.039839, "o", "# 6. Fit best model\r\n\u001b[?2004l\r\u001b[?2004h> model = Pipeline(steps=[\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.039924, "o", "    ('preprocessor', preprocessor),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.039939, "o", "    ('classifier', HistGradientBoostingClassifier(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.04011, "o", "        learning_rate=0.05,\r\n\u001b[?2004l\r\u001b[?2004h>         max_iter=100,\r\n\u001b[?2004l\r\u001b[?2004h>         max_leaf_nodes=31,\r\n\u001b[?2004l\r\u001b[?2004h>         random_state=42\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.040134, "o", "    ))\r\n\u001b[?2004l\r\u001b[?2004h> ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.040235, "o", "model.fit(train_df[features], train_df[target])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 7. Predict validation probabilities\r\n\u001b[?2004l\r"]
[298.040253, "o", "\u001b[?2004h> "]
[298.040396, "o", "val_preds = model.predict_proba(val_df[features])[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Recalculate and print AUC to double check\r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.040471, "o", "auc = roc_auc_score(val_df[target], val_preds)\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Validation AUC: {auc:.6f}\")\r\n\u001b[?2004l\r"]
[298.040588, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.040611, "o", "# 8. Create /output directory if not exists\r\n\u001b[?2004l\r\u001b[?2004h> os.makedirs('/output', exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[298.041712, "o", "# 9. Save predictions: columns must be TransactionID and fraud_prob\r\n\u001b[?2004l\r\u001b[?2004h> preds_df = pd.DataFrame({\r\n\u001b[?2004l\r\u001b[?2004h>     'TransactionID': val_df['TransactionID'],\r\n\u001b[?2004l\r\u001b[?2004h>     'fraud_prob': val_preds\r\n\u001b[?2004l\r\u001b[?2004h> })\r\n\u001b[?2004l\r\u001b[?2004h> preds_df.to_csv('/output/predictions.csv', index=False)\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Predictions saved to /output/predictions.csv successfully. Shape:\", preds_df.shape)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 10. Save AUC score\r\n\u001b[?2004l\r\u001b[?2004h> with open('/output/auc.txt', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     f.write(f\"{auc:.6f}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"AUC saved to /output/auc.txt successfully.\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[298.047674, "o", "\u001b[?2004hroot@f6fdec80eb9d:/workspace# "]
[298.0478, "o", "python3 train_and_save.py\r\n\u001b[?2004l\r"]
[301.292193, "o", "Validation AUC: 0.900803\r\n"]
[301.31249, "o", "Predictions saved to /output/predictions.csv successfully. Shape: (3000, 2)\r\n"]
[301.31292, "o", "AUC saved to /output/auc.txt successfully.\r\n"]
[301.517981, "o", "\u001b[?2004hroot@f6fdec80eb9d:/workspace# "]
[307.827677, "i", "cat /output/auc.txt\n"]
[307.830613, "o", "cat /output/auc.txt\r\n\u001b[?2004l\r"]
[307.837085, "o", "0.900803\r\n\u001b[?2004hroot@f6fdec80eb9d:/workspace# "]
[308.25448, "i", "head -n 5 /output/predictions.csv\n"]
[308.254648, "o", "head -n 5 /output/predictions.csv\r\n\u001b[?2004l\r"]
[308.258442, "o", "TransactionID,fraud_prob\r\n3476394,0.02922378936302175\r\n3053569,0.005270258892182082\r\n3353921,0.004754205349301189\r\n3516024,0.004783394252933903\r\n\u001b[?2004hroot@f6fdec80eb9d:/workspace# "]
