[176.54497, "o", "> "]
[176.545167, "o", "    xgb_train[col] = xgb_train[col].astype('category')\r\n\u001b[?2004l\r\u001b[?2004h>     xgb_val[col] = xgb_val[col].astype('category')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[176.545199, "o", "\u001b[?2004h> "]
[176.546275, "o", "# XGBoost handles missing numeric values natively, but let's see if we should impute\r\n\u001b[?2004l\r\u001b[?2004h> xgb = XGBClassifier(enable_categorical=True, random_state=42, eval_metric='auc')\r\n\u001b[?2004l\r\u001b[?2004h> xgb.fit(xgb_train, train_df[target])\r\n\u001b[?2004l\r\u001b[?2004h> preds_xgb = xgb.predict_proba(xgb_val)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> print(\"XGBoost (native categorical & missing) AUC:\", roc_auc_score(val_df[target], preds_xgb))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[176.546359, "o", "# 3. XGBoost with explicit Imputation + OneHot\r\n\u001b[?2004l\r\u001b[?2004h> # Let's see if pre-imputing and one-hot encoding improves XGBoost\r\n\u001b[?2004l\r\u001b[?2004h> pipeline_xgb = Pipeline(steps=[\r\n\u001b[?2004l\r\u001b[?2004h"]
[176.546396, "o", "> "]
[176.546468, "o", "    ('preprocessor', preprocessor),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[176.546825, "o", "    ('classifier', XGBClassifier(random_state=42, eval_metric='auc'))\r\n\u001b[?2004l\r\u001b[?2004h> ])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[176.547232, "o", "pipeline_xgb.fit(train_df[features], train_df[target])\r\n"]
[176.547274, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[176.547918, "o", "preds_xgb_pipe = pipeline_xgb.predict_proba(val_df[features])[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[176.547989, "o", "print(\"XGBoost (Pipeline with OneHot & Imputation) AUC:\", roc_auc_score(val_df[target], preds_xgb_pipe))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
