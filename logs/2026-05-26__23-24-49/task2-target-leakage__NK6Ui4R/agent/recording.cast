[176.542699, "o", "    ('onehot', OneHotEncoder(handle_unknown='ignore', sparse_output=False))\r\n\u001b[?2004l\r\u001b[?2004h> ])\r\n\u001b[?2004l\r\u001b[?2004h> "]
