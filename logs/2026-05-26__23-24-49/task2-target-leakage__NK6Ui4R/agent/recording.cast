[220.46173, "i", "cat << 'EOF' > tune_model.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.compose import ColumnTransformer\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.preprocessing import OneHotEncoder\nfrom sklearn.ensemble import HistGradientBoostingClassifier\nfrom sklearn.metrics import roc_auc_score\n\n# Load\ndf = pd.read_csv('/data/train_transaction.csv')\ntarget = 'isFraud'\n\n# Clean feature set\nexclude_features = ['TransactionID', target, 'chargeback_amount', 'days_to_chargeback', 'fraud_score']\nfeatures = [c for c in df.columns if c not in exclude_features]\n\n# Split\ntrain_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])\n\ncat_cols = df[features].select_dtypes(include=['object']).columns.tolist()\nnum_cols = [c for c in features if c not in cat_cols]\n\n# Preprocessor\nnum_transformer = SimpleImputer(strategy='median')\ncat_transformer = Pipeline(steps=[\n    ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),\n    ('onehot', OneHotEncoder(handle_unknown='ignore', sparse_output=False))\n])\npreprocessor = ColumnTransformer(transformers=[\n    ('num', num_transformer, num_cols),\n    ('cat', cat_transformer, cat_cols)\n])\n\n# Let's try different hyperparameters for HistGB\nresults = []\nfor lr in [0.03, 0.05, 0.1]:\n    for max_iter in [100, 150, 200]:\n        for max_leaf_nodes in [31, 63]:\n            model = Pipeline(steps=[\n                ('preprocessor', preprocessor),\n                ('classifier', HistGradientBoostingClassifier(\n                    learning_rate=lr,\n                    max_iter=max_iter,\n                    max_leaf_nodes=max_leaf_nodes,\n                    random_state=42\n                ))\n            ])\n            model.fit(train_df[features], train_df[target])\n            preds = model.predict_proba(val_df[features])[:, 1]\n            auc = roc_auc_score(val_df[target], preds)\n            results.append((lr, max_iter, max_leaf_nodes, auc))\n            print(f\"lr={lr}, max_iter={max_iter}, max_leaf_nodes={max_leaf_nodes} -> AUC={auc:.6f}\")\n\nbest_res = max(results, key=lambda x: x[3])\nprint(\"Best Hyperparameters:\", best_res)\nEOF\npython3 tune_model.py\n"]
[220.764064, "o", "cat << 'EOF' > tune_model.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.model_selection import train_test_split\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.compose import ColumnTransformer\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.pipeline import Pipeline\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.impute import SimpleImputer\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.preprocessing import OneHotEncoder\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.ensemble import HistGradientBoostingClassifier\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Load\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv')\r\n\u001b[?2004l\r\u001b[?2004h> target = 'isFraud'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Clean feature set\r\n\u001b[?2004l\r\u001b[?2004h> exclude_features = ['TransactionID', target, 'chargeback_amount', 'days_to_chargeback', 'fraud_score']\r\n\u001b[?2004l\r\u001b[?2004h> features = [c for c in df.columns if c not in exclude_features]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Split\r\n\u001b[?2004l\r\u001b[?2004h> train_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> cat_cols = df[features].select_dtypes(include=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h> num_cols = [c for c in features if c not in cat_cols]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Preprocessor\r\n\u001b[?2004l\r\u001b[?2004h> num_transformer = SimpleImputer(strategy='median')\r\n\u001b[?2004l\r\u001b[?2004h> cat_transformer = Pipeline(steps=[\r\n\u001b[?2004l\r\u001b[?2004h>     ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),\r\n\u001b[?2004l\r\u001b[?2004h>     ('onehot', OneHotEncoder(handle_unknown='ignore', sparse_output=False))\r\n\u001b[?2004l\r\u001b[?2004h> ])\r\n\u001b[?2004l\r\u001b[?2004h> preprocessor = ColumnTransformer(transformers=[\r\n\u001b[?2004l\r\u001b[?2004h>     ('num', num_transformer, num_cols),\r\n\u001b[?2004l\r\u001b[?2004h>     ('cat', cat_transformer, cat_cols)\r\n\u001b[?2004l\r\u001b[?2004h> ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's try different hyperparameters for HistGB\r\n\u001b[?2004l\r\u001b[?2004h> results = []\r\n\u001b[?2004l\r\u001b[?2004h> for lr in [0.03, 0.05, 0.1]:\r\n\u001b[?2004l\r\u001b[?2004h>     for max_iter in [100, 150, 200]:\r\n\u001b[?2004l\r\u001b[?2004h>         for max_leaf_nodes in [31, 63]:\r\n\u001b[?2004l\r\u001b[?2004h>             model = Pipeline(steps=[\r\n\u001b[?2004l\r\u001b[?2004h>                 ('preprocessor', preprocessor),\r\n\u001b[?2004l\r\u001b[?2004h>                 ('classifier', HistGradientBoostingClassifier(\r\n\u001b[?2004l\r\u001b[?2004h>                     learning_rate=lr,\r\n\u001b[?2004l\r\u001b[?2004h>                     max_iter=max_iter,\r\n\u001b[?2004l\r\u001b[?2004h>                     max_leaf_nodes=max_leaf_nodes,\r\n\u001b[?2004l\r\u001b[?2004h>                     random_state=42\r\n\u001b[?2004l\r\u001b[?2004h>                 ))\r\n\u001b[?2004l\r\u001b[?2004h>             ])\r\n\u001b[?2004l\r\u001b[?2004h>             model.fit(train_df[features], train_df[target])\r\n\u001b[?2004l\r\u001b[?2004h>             preds = model.predict_proba(val_df[features])[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h>             auc = roc_auc_score(val_df[target], preds)\r\n\u001b[?2004l\r\u001b[?2004h>             results.append((lr, max_iter, max_leaf_nodes, auc))\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"lr={lr}, max_iter={max_iter}, max_leaf_nodes={max_leaf_nodes} -> AUC={auc:.6f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> best_res = max(results, key=lambda x: x[3])\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Best Hyperparameters:\", best_res)\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
