[121.901624, "i", "cat << 'EOF' > pipeline_test.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.compose import ColumnTransformer\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.preprocessing import OneHotEncoder\nfrom sklearn.ensemble import HistGradientBoostingClassifier\nfrom sklearn.metrics import roc_auc_score\n\n# Load\ndf = pd.read_csv('/data/train_transaction.csv')\ntarget = 'isFraud'\n\n# 80/20 train/val split\ntrain_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])\n\n# Identify column types\ncat_cols = df.select_dtypes(include=['object']).columns.tolist()\n\ndef run_pipeline(exclude_cols):\n    features = [c for c in df.columns if c not in ['TransactionID', target] + exclude_cols]\n    \n    num_features = [c for c in features if c not in cat_cols]\n    cat_features = [c for c in features if c in cat_cols]\n    \n    # Preprocessing\n    num_transformer = SimpleImputer(strategy='median')\n    cat_transformer = Pipeline(steps=[\n        ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),\n        ('onehot', OneHotEncoder(handle_unknown='ignore', sparse_output=False))\n    ])\n    \n    preprocessor = ColumnTransformer(transformers=[\n        ('num', num_transformer, num_features),\n        ('cat', cat_transformer, cat_features)\n    ])\n    \n    # Pipeline\n    model = Pipeline(steps=[\n        ('preprocessor', preprocessor),\n        ('classifier', HistGradientBoostingClassifier(random_state=42))\n    ])\n    \n    model.fit(train_df[features], train_df[target])\n    preds = model.predict_proba(val_df[features])[:, 1]\n    auc = roc_auc_score(val_df[target], preds)\n    return auc\n\nprint(\"AUC excluding chargeback leaks:\", run_pipeline(['chargeback_amount', 'days_to_chargeback']))\nprint(\"AUC excluding chargeback leaks & fraud_score:\", run_pipeline(['chargeback_amount', 'days_to_chargeback', 'fraud_score']))\nprint(\"AUC with ALL features:\", run_pipeline([]))\nEOF\npython3 pipeline_test.py\n"]
