[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> import xgboost as xgb
[?2004l[?2004h> 
[?2004l[?2004h> # 1. Load data
[?2004l[?2004h> df = pd.read_csv('/data/train_transaction.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Identify targets and features
[?2004l[?2004h> target_col = 'isFraud'
[?2004l[?2004h> id_col = 'TransactionID'
[?2004l[?2004h> 
[?2004l[?2004h> # Separate features and target
[?2004l[?2004h> X = df.drop(columns=[target_col])
[?2004l[?2004h> y = df[target_col]
[?2004l[?2004h> 
[?2004l[?2004h> # For categorical columns, convert them to category type
[?2004l[?2004h> cat_cols = X.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     X[col] = X[col].astype('category')
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Train/validation split (80/20)
[?2004l[?2004h> X_train, X_val, y_train, y_val = train_test_split(
[?2004l[?2004h>     X, y, test_size=0.20, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare output paths
[?2004l[?2004h> os.makedirs('/output', exist_ok=True)
[?2004l[?2004h> 
[?2004l[?2004h> # We need TransactionID in predictions.csv, so let's keep track of validation set TransactionIDs
[?2004l[?2004h> val_ids = X_val[id_col]
[?2004l[?2004h> 
[?2004l[?2004h> # Let's drop TransactionID from training features so the model doesn't overfit on it
[?2004l[?2004h> X_train_feat = X_train.drop(columns=[id_col])
[?2004l[?2004h> X_val_feat = X_val.drop(columns=[id_col])
[?2004l[?2004h> 
[?2004l[?2004h> # 3. Train XGBoost classifier
[?2004l[?2004h> # enable_categorical=True allows XGBoost to handle category columns directly
[?2004l[?2004h> model = xgb.XGBClassifier(
[?2004l[?2004h>     n_estimators=200,
[?2004l[?2004h>     learning_rate=0.05,
[?2004l[?2004h>     max_depth=6,
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     enable_categorical=True,
[?2004l[?2004h>     tree_method='hist'
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> model.fit(X_train_feat, y_train)
[?2004l[?2004h> 
[?2004l[?2004h> # 4. Predict probabilities
[?2004l[?2004h> # Predict prob of class 1
[?2004l[?2004h> val_probs = model.predict_proba(X_val_feat)[:, 1]
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate AUC
[?2004l[?2004h> auc = roc_auc_score(y_val, val_probs)
[?2004l[?2004h> print(f"Validation AUC: {auc:.6f}")
[?2004l[?2004h> 
[?2004l[?2004h> # 5. Save predictions
