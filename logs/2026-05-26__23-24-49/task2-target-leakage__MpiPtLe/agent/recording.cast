[154.948703, "o", "\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Train shape:\", X_train.shape)\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Validation shape:\", X_val.shape)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Train tuned XGBoost Classifier\r\n\u001b[?2004l\r\u001b[?2004h> clf = xgb.XGBClassifier(\r\n\u001b[?2004l\r\u001b[?2004h>     n_estimators=300,\r\n\u001b[?2004l\r\u001b[?2004h>     learning_rate=0.03,\r\n\u001b[?2004l\r\u001b[?2004h>     max_depth=6,\r\n\u001b[?2004l\r\u001b[?2004h>     subsample=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     colsample_bytree=0.8,\r\n\u001b[?2004l\r\u001b[?2004h>     random_state=42,\r\n\u001b[?2004l\r\u001b[?2004h>     use_label_encoder=False,\r\n\u001b[?2004l\r\u001b[?2004h>     eval_metric='auc'\r\n\u001b[?2004l\r\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> clf.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=50)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Predict probabilities\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.948829, "o", "val_preds = clf.predict_proba(X_val)[:, 1]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Calculate and report Validation AUC\r\n\u001b[?2004l\r"]
[154.948891, "o", "\u001b[?2004h> "]
[154.948995, "o", "auc_score = roc_auc_score(y_val, val_preds)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.949223, "o", "print(f\"Validation ROC-AUC: {auc_score:.6f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Save predictions to /output/predictions.csv\r\n\u001b[?2004l\r\u001b[?2004h> predictions_df = pd.DataFrame({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.949278, "o", "    'TransactionID': idx_val,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.949396, "o", "    'fraud_prob': val_preds\r\n\u001b[?2004l\r\u001b[?2004h> })\r\n\u001b[?2004l\r\u001b[?2004h> "]
[154.94989, "o", "predictions_df.to_csv('/output/predictions.csv', index=False)\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Saved validation predictions to /output/predictions.csv\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Save AUC to /output/auc.txt\r\n\u001b[?2004l\r\u001b[?2004h> with open('/output/auc.txt', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     f.write(f\"{auc_score:.6f}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Saved validation AUC to /output/auc.txt\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
