[74.111992, "i", "cat << 'EOF' > tune.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\n# Load data\ndf = pd.read_csv('/data/train_transaction.csv')\n\n# Drop leakage\nleakage_cols = ['chargeback_amount', 'days_to_chargeback', 'fraud_score']\nexisting_leaks = [col for col in leakage_cols if col in df.columns]\ndf_clean = df.drop(columns=existing_leaks)\n\nX = df_clean.drop(columns=['isFraud', 'TransactionID'])\ny = df_clean['isFraud']\n\ncat_cols = X.select_dtypes(include=['object']).columns.tolist()\nfrom sklearn.preprocessing import LabelEncoder\nfor col in cat_cols:\n    X[col] = X[col].fillna('Missing').astype(str)\n    le = LabelEncoder()\n    X[col] = le.fit_transform(X[col])\n\nX_train, X_val, y_train, y_val = train_test_split(\n    X, y, test_size=0.20, random_state=42, stratify=y\n)\n\n# Let's try a few combinations of max_depth, learning_rate, subsample, and colsample_bytree\nbest_auc = 0\nbest_params = {}\n\nfor max_depth in [4, 6, 8]:\n    for lr in [0.03, 0.05, 0.1]:\n        for sub in [0.8, 1.0]:\n            clf = xgb.XGBClassifier(\n                n_estimators=300,\n                learning_rate=lr,\n                max_depth=max_depth,\n                subsample=sub,\n                colsample_bytree=0.8,\n                random_state=42,\n                use_label_encoder=False,\n                eval_metric='auc'\n            )\n            clf.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=False)\n            preds = clf.predict_proba(X_val)[:, 1]\n            auc = roc_auc_score(y_val, preds)\n            print(f\"depth={max_depth}, lr={lr}, sub={sub} -> AUC: {auc:.6f}\")\n            if auc > best_auc:\n                best_auc = auc\n                best_params = {'max_depth': max_depth, 'learning_rate': lr, 'subsample': sub}\n\nprint(\"Best AUC:\", best_auc)\nprint(\"Best params:\", best_params)\nEOF\npython3 tune.py\n"]
