[37.085006, "i", "cat << 'EOF' > train.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\n# Load data\ndf = pd.read_csv('/data/train_transaction.csv')\nprint(\"Loaded shape:\", df.shape)\n\n# Separate features and target\nX = df.drop(columns=['isFraud'])\ny = df['isFraud']\n\n# Keep track of TransactionID for predictions\ntrans_id = X['TransactionID']\n# Drop TransactionID from features as it's an identifier\nX = X.drop(columns=['TransactionID'])\n\n# Let's identify categorical columns\ncat_cols = X.select_dtypes(include=['object']).columns.tolist()\nprint(\"Categorical columns:\", cat_cols)\n\n# For categorical columns, let's fillna with 'Missing' and convert to category type\nfor col in cat_cols:\n    X[col] = X[col].fillna('Missing').astype('category')\n\n# For numerical columns, XGBoost handles missing values natively, but let's be sure. \n# If we convert categories to codes or use XGBoost's enable_categorical=True:\n# Let's use enable_categorical=True since modern XGBoost supports categorical features.\n# Alternatively, we can use label encoding or one-hot encoding.\n# Let's write a robust script that encodes categorical features using label encoding to avoid any environment compatibility issues.\nfrom sklearn.preprocessing import LabelEncoder\nlabel_encoders = {}\nfor col in cat_cols:\n    le = LabelEncoder()\n    X[col] = le.fit_transform(X[col].astype(str))\n\n# Split 80/20\n# The prompt says: \"Use an 80/20 train/validation split.\"\n# Let's use a fixed random state for reproducibility.\nX_train, X_val, y_train, y_val, idx_train, idx_val = train_test_split(\n    X, y, trans_id, test_size=0.20, random_state=42, stratify=y\n)\n\nprint(\"Train shape:\", X_train.shape)\nprint(\"Val shape:\", X_val.shape)\n\n# Train XGBoost Classifier\nclf = xgb.XGBClassifier(\n    n_estimators=500,\n    learning_rate=0.05,\n    max_depth=6,\n    subsample=0.8,\n    colsample_bytree=0.8,\n    random_state=42,\n    use_label_encoder=False,\n    eval_metric='auc'\n)\n\nclf.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=50)\n\n# Predict\nval_preds = clf.predict_proba(X_val)[:, 1]\n\n# Calculate AUC\nauc_score = roc_auc_score(y_val, val_preds)\nprint(\"Validation AUC:\", auc_score)\n\n# Save predictions\npredictions_df = pd.DataFrame({\n    'TransactionID': idx_val,\n    'fraud_prob': val_preds\n})\npredictions_df.to_csv('/output/predictions.csv', index=False)\nprint(\"Saved predictions to /output/predictions.csv\")\n\n# Save AUC to /output/auc.txt\nwith open('/output/auc.txt', 'w') as f:\n    f.write(f\"{auc_score:.6f}\")\nprint(\"Saved AUC to /output/auc.txt\")\n\nEOF\npython3 train.py\n"]
[37.087527, "o", "cat << 'EOF' > train.py\r\n\u001b[?2004l\r"]
[37.090326, "o", "\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.model_selection import train_test_split\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> import xgboost as xgb\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Load data\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/train_transaction.csv')\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Loaded shape:\", df.shape)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Separate features and target\r\n\u001b[?2004l\r\u001b[?2004h> X = df.drop(columns=['isFraud'])\r\n\u001b[?2004l\r\u001b[?2004h> y = df['isFraud']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Keep track of TransactionID for predictions\r\n\u001b[?2004l\r\u001b[?2004h> trans_id = X['TransactionID']\r\n\u001b[?2004l\r\u001b[?2004h> # Drop TransactionID from features as it's an identifier\r\n\u001b[?2004l\r\u001b[?2004h> X = X.drop(columns=['TransactionID'])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's identify categorical columns\r\n\u001b[?2004l\r\u001b[?2004h> cat_cols = X.select_dtypes(include=['object']).columns.tolist()\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Categorical columns:\", cat_cols)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # For categorical columns, let's fillna with 'Missing' and convert to category type\r\n\u001b[?2004l\r\u001b[?2004h> for col in cat_cols:\r\n\u001b[?2004l\r\u001b[?2004h>     X[col] = X[col].fillna('Missing').astype('category')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
