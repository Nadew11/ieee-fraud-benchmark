[?2004hroot@d8276d655354:/workspace# cat << 'EOF' > train.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.model_selection import train_test_split
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> import xgboost as xgb
[?2004l[?2004h> 
[?2004l[?2004h> # Load data
[?2004l[?2004h> df = pd.read_csv('/data/train_transaction.csv')
[?2004l[?2004h> print("Loaded shape:", df.shape)
[?2004l[?2004h> 
[?2004l[?2004h> # Separate features and target
[?2004l[?2004h> X = df.drop(columns=['isFraud'])
[?2004l[?2004h> y = df['isFraud']
[?2004l[?2004h> 
[?2004l[?2004h> # Keep track of TransactionID for predictions
[?2004l[?2004h> trans_id = X['TransactionID']
[?2004l[?2004h> # Drop TransactionID from features as it's an identifier
[?2004l[?2004h> X = X.drop(columns=['TransactionID'])
[?2004l[?2004h> 
[?2004l[?2004h> # Let's identify categorical columns
[?2004l[?2004h> cat_cols = X.select_dtypes(include=['object']).columns.tolist()
[?2004l[?2004h> print("Categorical columns:", cat_cols)
[?2004l[?2004h> 
[?2004l[?2004h> # For categorical columns, let's fillna with 'Missing' and convert to category type
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     X[col] = X[col].fillna('Missing').astype('category')
[?2004l[?2004h> 
[?2004l[?2004h> # For numerical columns, XGBoost handles missing values natively, but let's be sure. 
[?2004l[?2004h> # If we convert categories to codes or use XGBoost's enable_categorical=True:
[?2004l[?2004h> # Let's use enable_categorical=True since modern XGBoost supports categorical features.
[?2004l[?2004h> # Alternatively, we can use label encoding or one-hot encoding.
[?2004l[?2004h> # Let's write a robust script that encodes categorical features using label encoding to avoid any environment compatibility issues.
[?2004l[?2004h> from sklearn.preprocessing import LabelEncoder
[?2004l[?2004h> label_encoders = {}
[?2004l[?2004h> for col in cat_cols:
[?2004l[?2004h>     le = LabelEncoder()
[?2004l[?2004h>     X[col] = le.fit_transform(X[col].astype(str))
[?2004l[?2004h> 
[?2004l[?2004h> # Split 80/20
[?2004l[?2004h> # The prompt says: "Use an 80/20 train/validation split."
[?2004l[?2004h> # Let's use a fixed random state for reproducibility.
[?2004l[?2004h> X_train, X_val, y_train, y_val, idx_train, idx_val = train_test_split(
[?2004l[?2004h>     X, y, trans_id, test_size=0.20, random_state=42, stratify=y
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> print("Train shape:", X_train.shape)
[?2004l[?2004h> print("Val shape:", X_val.shape)
[?2004l[?2004h> 
[?2004l[?2004h> # Train XGBoost Classifier
[?2004l[?2004h> clf = xgb.XGBClassifier(
[?2004l[?2004h>     n_estimators=500,
[?2004l[?2004h>     learning_rate=0.05,
[?2004l[?2004h>     max_depth=6,
[?2004l[?2004h>     subsample=0.8,
[?2004l[?2004h>     colsample_bytree=0.8,
[?2004l[?2004h>     random_state=42,
[?2004l[?2004h>     use_label_encoder=False,
[?2004l[?2004h>     eval_metric='auc'
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> clf.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=50)
[?2004l[?2004h> 
[?2004l[?2004h> # Predict
[?2004l[?2004h> val_preds = clf.predict_proba(X_val)[:, 1]
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate AUC
[?2004l[?2004h> auc_score = roc_auc_score(y_val, val_preds)
[?2004l[?2004h> print("Validation AUC:", auc_score)
[?2004l[?2004h> 
[?2004l[?2004h> # Save predictions
[?2004l[?2004h> predictions_df = pd.DataFrame({
[?2004l[?2004h>     'TransactionID': idx_val,
[?2004l[?2004h>     'fraud_prob': val_preds
[?2004l[?2004h> })
[?2004l[?2004h> predictions_df.to_csv('/output/predictions.csv', index=False)
[?2004l[?2004h> print("Saved predictions to /output/predictions.csv")
[?2004l[?2004h> 
[?2004l[?2004h> # Save AUC to /output/auc.txt
[?2004l[?2004h> with open('/output/auc.txt', 'w') as f:
[?2004l[?2004h>     f.write(f"{auc_score:.6f}")
[?2004l[?2004h> print("Saved AUC to /output/auc.txt")
[?2004l[?2004h> 
[?2004l[?2004h> EOF
