score(val_df[target], preds_hgb))\n\n# 2. Pipeline with XGBoost (enable_categorical=True, handle missing natively)\n# XGBoost can handle categorical features natively if they are category dtype and enable_categorical=True\nxgb_train = train_df[features].copy()\nxgb_val = val_df[features].copy()\nfor col in cat_cols:\n    xgb_train[col] = xgb_train[col].astype(\'category\')\n    xgb_val[col] = xgb_val[col].astype(\'category\')\n\n# XGBoost handles missing numeric values natively, but let\'s see if we should impute\nxgb = XGBClassifier(enable_categorical=True, random_state=42, eval_metric=\'auc\')\nxgb.fit(xgb_train, train_df[target])\npreds_xgb = xgb.predict_proba(xgb_val)[:, 1]\nprint("XGBoost (native categorical & missing) AUC:", roc_auc_score(val_df[target], preds_xgb))\n\n# 3. XGBoost with explicit Imputation + OneHot\n# Let\'s see if pre-imputing and one-hot encoding improves XGBoost\npipeline_xgb = Pipeline(steps=[\n    (\'preprocessor\', preprocessor),\n    (\'classifier\', XGBClassifier(random_state=42, eval_metric=\'auc\'))\n])\npipeline_xgb.fit(train_df[features], train_df[target])\npreds_xgb_pipe = pipeline_xgb.predict_proba(val_df[features])[:, 1]\nprint("XGBoost (Pipeline with OneHot & Imputation) AUC:", roc_auc_score(val_df[target], preds_xgb_pipe))\n\nEOF\npython3 test_clean_models.py\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
