Sending keys: ['cat << \'EOF\' > train_and_save.py\nimport os\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.compose import ColumnTransformer\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.preprocessing import OneHotEncoder\nfrom sklearn.ensemble import HistGradientBoostingClassifier\nfrom sklearn.metrics import roc_auc_score\n\n# 1. Load data\ndf = pd.read_csv(\'/data/train_transaction.csv\')\ntarget = \'isFraud\'\n\n# 2. Exclude target, ID, and leaky features\nexclude_features = [\'TransactionID\', target, \'chargeback_amount\', \'days_to_chargeback\', \'fraud_score\']\nfeatures = [c for c in df.columns if c not in exclude_features]\n\n# 3. 80/20 train/validation split\ntrain_df, val_df = train_test_split(df, test_size=0.2, random_state=42, stratify=df[target])\n\n# 4. Define feature columns\ncat_cols = df[features].select_dtypes(include=[\'object\']).columns.tolist()\nnum_cols = [c for c in features if c not in cat_cols]\n\n# 5. Pipeline with imputation and one-hot encoding\nnum_transformer = SimpleImputer(strategy=\'median\')\ncat_transformer = Pipeline(steps=[\n    (\'imputer\', SimpleImputer(strategy=\'constant\', fill_value=\'missing\')),\n    (\'onehot\', OneHotEncoder(handle_unknown=\'ignore\', sparse_output=False))\n])\n\npreprocessor = ColumnTransformer(transformers=[\n    (\'num\', num_transformer, num_cols),\n    (\'cat\', cat_transformer, cat_cols)\n])\n\n# 6. Fit best model\nmodel = Pipeline(steps=[\n    (\'preprocessor\', preprocessor),\n    (\'classifier\', HistGradientBoostingClassifier(\n        learning_rate=0.05,\n        max_iter=100,\n        max_leaf_nodes=31,\n        random_state=42\n    ))\n])\n\nmodel.fit(train_df[features], train_df[target])\n\n# 7. Predict validation probabilities\nval_preds = model.predict_proba(val_df[features])[:, 1]\n\n# Recalculate and print AUC to double check\nauc = roc_auc_score(val_df[target], val_preds)\nprint(f"Validation AUC: {auc:.6f}")\n\n# 8. Create /output directory if not exists\nos.makedirs(\'/output\', exist_ok=True)\n\n# 9. Save predictions: columns must be TransactionID and fraud_prob\npreds_df = pd.DataFrame({\n    \'TransactionID\': val_df[\'TransactionID\'],\n    \'fraud_prob\': val_preds\n})\npreds_df.to_csv(\'/output/predictions.csv\', index=False)\nprint("Predictions saved to /output/predictions.csv successfully. Shape:", preds_df.shape)\n\n# 10. Save AUC score\nwith open(\'/output/auc.txt\', \'w\') as f:\n    f.write(f"{auc:.6f}\\n")\nprint("AUC saved to /output/auc.txt successfully.")\nEOF\npython3 train_and_save.py\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
