Sending keys: ['cat << \'EOF\' > /workspace/train.py\nimport os\nimport pandas as pd\nimport numpy as np\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import roc_auc_score\nimport xgboost as xgb\n\n# 1. Load data\ndf = pd.read_csv(\'/data/train_transaction.csv\')\n\n# Identify targets and features\ntarget_col = \'isFraud\'\nid_col = \'TransactionID\'\n\n# Leaky columns to drop\nleaky_cols = [\'chargeback_amount\', \'fraud_score\', \'days_to_chargeback\']\n\n# Separate features and target\nX = df.drop(columns=[target_col] + leaky_cols)\ny = df[target_col]\n\n# For categorical columns, convert them to category type\ncat_cols = X.select_dtypes(include=[\'object\']).columns.tolist()\nfor col in cat_cols:\n    X[col] = X[col].astype(\'category\')\n\n# 2. Train/validation split (80/20)\nX_train, X_val, y_train, y_val = train_test_split(\n    X, y, test_size=0.20, random_state=42, stratify=y\n)\n\n# Prepare output paths\nos.makedirs(\'/output\', exist_ok=True)\n\n# We need TransactionID in predictions.csv, so let\'s keep track of validation set TransactionIDs\nval_ids = X_val[id_col]\n\n# Drop TransactionID from features\nX_train_feat = X_train.drop(columns=[id_col])\nX_val_feat = X_val.drop(columns=[id_col])\n\n# 3. Train XGBoost classifier\n# Use enable_categorical=True to let XGBoost handle categorical features natively\nmodel = xgb.XGBClassifier(\n    n_estimators=100,\n    learning_rate=0.05,\n    max_depth=6,\n    random_state=42,\n    enable_categorical=True,\n    tree_method=\'hist\'\n)\n\nmodel.fit(X_train_feat, y_train)\n\n# 4. Predict probabilities\n# Predict prob of class 1\nval_probs = model.predict_proba(X_val_feat)[:, 1]\n\n# Calculate AUC\nauc = roc_auc_score(y_val, val_probs)\nprint(f"Validation AUC: {auc:.6f}")\n\n# 5. Save predictions\npredictions_df = pd.DataFrame({\n    \'TransactionID\': val_ids,\n    \'fraud_prob\': val_probs\n})\npredictions_df.to_csv(\'/output/predictions.csv\', index=False)\nprint("Saved predictions to /output/predictions.csv")\n\n# 6. Save AUC\nwith open(\'/output/auc.txt\', \'w\') as f:\n    f.write(f"{auc:.6f}\\n")\nprint("Saved AUC to /output/auc.txt")\n\nEOF\n'] min_timeout_sec: 1.5 max_timeout_sec: 180.0
