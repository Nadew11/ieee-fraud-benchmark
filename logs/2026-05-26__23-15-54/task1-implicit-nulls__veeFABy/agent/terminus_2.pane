[?2004hroot@803b650a44b8:/workspace# cat << 'EOF' > clean.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> # Load dataset
[?2004l[?2004h> df = pd.read_csv('/data/train_identity.csv')
[?2004l[?2004h> print("Original shape:", df.shape)
[?2004l[?2004h> 
[?2004l[?2004h> # Remove duplicate records based on TransactionID, keeping the first occurrence
[?2004l[?2004h> df_clean = df.drop_duplicates(subset=['TransactionID'], keep='first').copy()
[?2004l[?2004h> print("Shape after deduplication:", df_clean.shape)
[?2004l[?2004h> 
[?2004l[?2004h> # Handle missing values and ensure correct data types
[?2004l[?2004h> for col in df_clean.columns:
[?2004l[?2004h>     if df_clean[col].dtype == 'object':
[?2004l[?2004h>         # Categorical columns: fill missing with 'Unknown'
[?2004l[?2004h>         df_clean[col] = df_clean[col].fillna('Unknown').astype(str)
[?2004l[?2004h>     else:
[?2004l[?2004h>         # Numeric columns: fill missing with median
[?2004l[?2004h>         median_val = df_clean[col].median()
[?2004l[?2004h>         df_clean[col] = df_clean[col].fillna(median_val)
[?2004l[?2004h>         
[?2004l[?2004h>         # Cast integer-valued columns to int64
[?2004l[?2004h>         # (We check if all values are integers after filling)
[?2004l[?2004h>         if (df_clean[col] % 1 == 0).all():
[?2004l[?2004h>             df_clean[col] = df_clean[col].astype('int64')
[?2004l[?2004h>         else:
[?2004l[?2004h>             df_clean[col] = df_clean[col].astype('float64')
[?2004l[?2004h> 
[?2004l[?2004h> # Verify types and missing values
[?2004l[?2004h> print("Null counts:", df_clean.isnull().sum().sum())
[?2004l[?2004h> print("Column data types:")
[?2004l[?2004h> for col in df_clean.columns:
[?2004l[?2004h>     print(f"{col}: {df_clean[col].dtype}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save cleaned dataset
[?2004l[?2004h> import os
[?2004l[?2004h> os.makedirs('/output', exist_ok=True)
[?2004l[?2004h> df_clean.to_csv('/output/cleaned.csv', index=False)
[?2004l[?2004h> print("Saved cleaned dataset to /output/cleaned.csv")
[?2004l[?2004h> EOF
