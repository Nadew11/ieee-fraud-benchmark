Sending keys: ['cat << \'EOF\' > clean.py\nimport pandas as pd\nimport numpy as np\n\n# Load dataset\ndf = pd.read_csv(\'/data/train_identity.csv\')\nprint("Original shape:", df.shape)\n\n# Remove duplicate records based on TransactionID, keeping the first occurrence\ndf_clean = df.drop_duplicates(subset=[\'TransactionID\'], keep=\'first\').copy()\nprint("Shape after deduplication:", df_clean.shape)\n\n# Handle missing values and ensure correct data types\nfor col in df_clean.columns:\n    if df_clean[col].dtype == \'object\':\n        # Categorical columns: fill missing with \'Unknown\'\n        df_clean[col] = df_clean[col].fillna(\'Unknown\').astype(str)\n    else:\n        # Numeric columns: fill missing with median\n        median_val = df_clean[col].median()\n        df_clean[col] = df_clean[col].fillna(median_val)\n        \n        # Cast integer-valued columns to int64\n        # (We check if all values are integers after filling)\n        if (df_clean[col] % 1 == 0).all():\n            df_clean[col] = df_clean[col].astype(\'int64\')\n        else:\n            df_clean[col] = df_clean[col].astype(\'float64\')\n\n# Verify types and missing values\nprint("Null counts:", df_clean.isnull().sum().sum())\nprint("Column data types:")\nfor col in df_clean.columns:\n    print(f"{col}: {df_clean[col].dtype}")\n\n# Save cleaned dataset\nimport os\nos.makedirs(\'/output\', exist_ok=True)\ndf_clean.to_csv(\'/output/cleaned.csv\', index=False)\nprint("Saved cleaned dataset to /output/cleaned.csv")\nEOF\npython3 clean.py\n'] min_timeout_sec: 3.0 max_timeout_sec: 180.0
