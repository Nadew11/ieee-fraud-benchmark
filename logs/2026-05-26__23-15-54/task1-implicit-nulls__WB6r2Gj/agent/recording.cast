[271.606788, "i", "python3 -c \"\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/train_identity.csv', keep_default_na=False)\nprint('Before clean:')\nprint('id_01 == -999:', (df['id_01'].astype(str).str.startswith('-999')).sum())\nprint('id_12 == unknown:', (df['id_12'] == 'unknown').sum())\nprint('id_15 == empty:', (df['id_15'] == '').sum())\n\n# Let's clean it\ndf_clean = df.drop_duplicates(subset=['TransactionID'], keep='first').copy()\n# Cast TransactionID to int\ndf_clean['TransactionID'] = df_clean['TransactionID'].astype(float).astype(int)\n\n# Replace sentinels\n# For id_01, let's replace '-999' or '-999.0' with empty string\ndf_clean.loc[df_clean['id_01'].astype(str).str.startswith('-999'), 'id_01'] = ''\ndf_clean.loc[df_clean['id_12'] == 'unknown', 'id_12'] = ''\n# df_clean['id_15'] empty string remains empty string for missing representation\n\nprint('After clean:')\nprint('id_01 == -999:', (df_clean['id_01'].astype(str).str.startswith('-999')).sum())\nprint('id_12 == unknown:', (df_clean['id_12'] == 'unknown').sum())\nprint('id_15 == empty:', (df_clean['id_15'] == '').sum())\n\"\n"]
