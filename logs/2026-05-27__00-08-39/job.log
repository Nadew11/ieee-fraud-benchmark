ows():\n    if abs(row[\'amt_usd\'] - diff_gross) < 5.0 and abs(row[\'processing_fee\'] - diff_fees) < 1.0:\n        print("Potential single row:", row[\'TransactionID\'], row[\'TransactionAmt\'], row[\'currency\'], row[\'amt_usd\'], row[\'processing_fee\'], row[\'merchant_category\'])\n\nrecoveries = df_no_declined[(df_no_declined.isFraud == 1) & (df_no_declined.transaction_type.isin([\'refund\', \'chargeback_reversal\']))]\nprint("Number of recoveries:", len(recoveries))\nprint("Total USD of recoveries:", recoveries[\'amt_usd\'].sum())\ndiff_rec = recoveries[\'amt_usd\'].sum() - 2435.89\nprint("Difference in recoveries:", diff_rec)\n\nprint(recoveries[[\'TransactionID\', \'transaction_type\', \'amt_usd\', \'settlement_status\']])\n\nEOF\npython3 find_exact_excluded.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
