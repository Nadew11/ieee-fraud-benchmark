Sending keys: ['cat << \'EOF\' > test_rounding.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\nfees = pd.read_csv(\'/data/fee_schedule.csv\')\n\ndf[\'transaction_date\'] = pd.to_datetime(df[\'transaction_date\'])\nfx[\'date\'] = pd.to_datetime(fx[\'date\'])\n\nall_dates = pd.date_range(start=min(df[\'transaction_date\'].min(), fx[\'date\'].min()), \n                          end=max(df[\'transaction_date\'].max(), fx[\'date\'].max()))\n\nfx_lookup = {\'USD\': pd.Series(1.0, index=all_dates)}\nfor cur in fx[\'currency\'].unique():\n    cur_rates = fx[fx[\'currency\'] == cur].set_index(\'date\')[\'rate_to_usd\'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf[\'fx_rate\'] = df.apply(lambda r: fx_lookup[r[\'currency\']].loc[r[\'transaction_date\']], axis=1)\n\n# Let\'s test different rounding strategies!\n# Strategy 1: Round amount_usd to 2 decimal places first, then fee_usd is calculated and rounded to 2 decimal places.\n# Strategy 2: Do not round amount_usd, but round fee_usd to 2 decimal places.\n# Strategy 3: Round both to 2 decimal places.\n# Let\'s see!\n\nfor round_amt in [False, True]:\n    for round_fee in [False, True]:\n        df_c = df.copy()\n        if round_amt:\n            df_c[\'amount_usd\'] = (df_c[\'TransactionAmt\'] * df_c[\'fx_rate\']).round(2)\n        else:\n            df_c[\'amount_usd\'] = df_c[\'TransactionAmt\'] * df_c[\'fx_rate\']\n        \n        fee_dict = fees.set_index(\'merchant_category\')[\'fee_rate\'].to_dict()\n        df_c[\'fee_rate\'] = df_c[\'merchant_category\'].map(fee_dict)\n        \n        if round_fee:\n            df_c[\'processing_fee_usd\'] = (df_c[\'amount_usd\'] * df_c[\'fee_rate\']).round(2)\n        else:\n            df_c[\'processing_fee_usd\'] = df_c[\'amount_usd\'] * df_c[\'fee_rate\']\n            \n        # Now, drop duplicates using \'first\'\n        df_dedup = df_c.drop_duplicates(subset=[\'TransactionID\'], keep=\'first\')\n        df_q4 = df_dedup[(df_dedup[\'transaction_date\'] >= \'2023-10-01\') & (df_dedup[\'transaction_date\'] <= \'2023-12-31\')]\n        df_q4 = df_q4[df_q4[\'settlement_status\'] != \'declined\']\n        \n        purchases = df_q4[(df_q4[\'isFraud\'] == 1) & (df_q4[\'transaction_type\'] == \'purchase\')]\n        \n        print(f"round_amt: {round_amt}, round_fee: {round_fee} -> "\n              f"count: {len(purchases)}, "\n              f"gross_sum: {purchases[\'amount_usd\'].sum():.4f}, "\n              f"fees_sum: {purchases[\'processing_fee_usd\'].sum():.4f}")\n\nEOF\npython3 test_rounding.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
