\n# Let\'s write a search over all single-row exclusions from settled_purchases + pending_purchases to see if any has sum close to target\nall_non_declined_purchases = purchases[purchases[\'settlement_status\'] != \'declined\']\nprint("Total non-declined purchases:", len(all_non_declined_purchases))\n\n# Let\'s see: if we exclude some transactions, can we match the targets?\n# Let\'s print the sum of all settled purchases\nprint("Settled purchases sum:", settled_purchases[\'amt_usd\'].sum(), "fee sum:", settled_purchases[\'processing_fee\'].sum())\n\n# Let\'s write a python search over all subsets of settled_purchases or non-declined purchases\n# Since there are 264 settled purchases, and we want 263, we can just exclude 1 transaction from settled_purchases\nprint("\\nSearching for 1-row exclusion from settled_purchases:")\nfor idx, row in settled_purchases.iterrows():\n    gross = settled_purchases[\'amt_usd\'].sum() - row[\'amt_usd\']\n    fee_sum = settled_purchases[\'processing_fee\'].sum() - row[\'processing_fee\']\n    if abs(gross - 30212.56) < 10.0:\n        print(f"Excluding {row[\'TransactionID\']}: Gross: {gross:.2f}, Fee: {fee_sum:.2f}, Row Amt: {row[\'amt_usd\']:.2f}, Row Fee: {row[\'processing_fee\']:.2f}")\n\nEOF\npython3 find_matching_subset.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
