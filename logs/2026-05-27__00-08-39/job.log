e\', \'refund\'], [\'purchase\', \'chargeback_reversal\', \'refund\']]:\n        sub = frauds[(frauds[\'settlement_status\'].isin(status)) & (frauds[\'transaction_type\'].isin(t_type))]\n        gross_sum = sub[\'amt_usd\'].sum()\n        fee_sum = sub[\'processing_fee\'].sum()\n        print(f"Status: {status}, Type: {t_type}, Count: {len(sub)}, Gross: {gross_sum:.2f}, Fee: {fee_sum:.2f}")\n\nEOF\npython3 search_subset.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
