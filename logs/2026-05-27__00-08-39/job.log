Sending keys: ['cat << \'EOF\' > search_logic.py\nimport pandas as pd\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\nfees = pd.read_csv(\'/data/fee_schedule.csv\')\n\nrates_dict = {}\nfor idx, row in fx.iterrows():\n    rates_dict[(row[\'currency\'], row[\'date\'])] = row[\'rate_to_usd\']\n\ndef get_rate(currency, date_str):\n    if currency == \'USD\':\n        return 1.0\n    if (currency, date_str) in rates_dict:\n        return rates_dict[(currency, date_str)]\n    currency_rates = fx[fx[\'currency\'] == currency]\n    prior_rates = currency_rates[currency_rates[\'date\'] <= date_str]\n    if len(prior_rates) == 0:\n        return currency_rates.sort_values(\'date\').iloc[0][\'rate_to_usd\']\n    return prior_rates.sort_values(\'date\', ascending=False).iloc[0][\'rate_to_usd\']\n\nrates = []\nfor idx, row in df.iterrows():\n    rates.append(get_rate(row[\'currency\'], row[\'transaction_date\']))\ndf[\'fx_rate\'] = rates\ndf[\'amt_usd\'] = df[\'TransactionAmt\'] * df[\'fx_rate\']\n\nfee_dict = dict(zip(fees[\'merchant_category\'], fees[\'fee_rate\']))\ndf[\'fee_rate\'] = df[\'merchant_category\'].map(fee_dict)\ndf[\'processing_fee\'] = df[\'amt_usd\'] * df[\'fee_rate\']\n\nall_fraud = df[df.isFraud == 1]\nprint("Total fraud transactions in entire file:", len(all_fraud))\nprint(all_fraud[\'settlement_status\'].value_counts())\nprint(all_fraud[\'transaction_type\'].value_counts())\nprint(all_fraud[\'transaction_date\'].min(), all_fraud[\'transaction_date\'].max())\n\nEOF\npython3 search_logic.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
