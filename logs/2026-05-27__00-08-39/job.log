rauds_no_dup[\'transaction_type\'] == \'purchase\']\nrefunds = frauds_no_dup[frauds_no_dup[\'transaction_type\'] == \'refund\']\n\n# Let\'s group purchases by region\np_gp = purchases.groupby(\'region\').agg(\n    gross_fraud_usd=(\'amt_usd\', \'sum\'),\n    processing_fees=(\'processing_fee\', \'sum\'),\n    q4_fraud_count=(\'TransactionID\', \'count\')\n).reset_index()\n\n# Group refunds by region\nr_gp = refunds.groupby(\'region\').agg(\n    recoveries=(\'amt_usd\', \'sum\')\n).reset_index()\n\nregions_list = [\'Africa\', \'Europe\', \'North America\', \'Other\']\ngrid = pd.DataFrame({\'region\': regions_list})\n\nreg_summary = pd.merge(grid, p_gp, on=\'region\', how=\'left\')\nreg_summary = pd.merge(reg_summary, r_gp, on=\'region\', how=\'left\')\nreg_summary = reg_summary.fillna(0)\n\nreg_summary[\'q4_net_fraud_usd\'] = (reg_summary[\'gross_fraud_usd\'] - reg_summary[\'recoveries\'] - reg_summary[\'processing_fees\']).round(2)\nreg_summary[\'q4_avg_ticket_usd\'] = np.where(reg_summary[\'q4_fraud_count\'] > 0, (reg_summary[\'gross_fraud_usd\'] / reg_summary[\'q4_fraud_count\']).round(2), 0.0)\n\ntotal_net_fraud = reg_summary[\'q4_net_fraud_usd\'].sum()\nreg_summary[\'pct_of_total\'] = (reg_summary[\'q4_net_fraud_usd\'] / total_net_fraud).round(4)\n\nprint("Regional Summary table:")\nprint(reg_summary[[\'region\', \'q4_net_fraud_usd\', \'q4_fraud_count\', \'q4_avg_ticket_usd\', \'pct_of_total\']])\n\nprint("\\nTotal net fraud check:", total_net_fraud)\nprint("Total fraud count check:", reg_summary[\'q4_fraud_count\'].sum())\n\nEOF\npython3 test_regional_summary.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
