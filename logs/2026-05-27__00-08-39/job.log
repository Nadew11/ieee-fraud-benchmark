ell.border = thin_border\n        if c_idx == 1:\n            cell.alignment = Alignment(horizontal="center")\n        elif c_idx in [2, 4]:\n            cell.number_format = "$#,##0.00"\n            cell.alignment = Alignment(horizontal="right")\n        elif c_idx == 3:\n            cell.number_format = "#,##0"\n            cell.alignment = Alignment(horizontal="right")\n        elif c_idx == 5:\n            cell.number_format = "0.00%"\n            cell.alignment = Alignment(horizontal="right")\n\n# Auto-fit columns for Regional Summary\nfor col in ws_regional.columns:\n    max_len = max(len(str(cell.value or \'\')) for cell in col)\n    col_letter = get_column_letter(col[0].column)\n    ws_regional.column_dimensions[col_letter].width = max(max_len + 3, 12)\n\n# 3. Write Executive Summary\n# Executive Summary requirements:\n# A1 = q4_net_fraud_total_usd, B1 = numeric total\n# A2 = q4_gross_fraud_total_usd, B2 = numeric total\n# A3 = total_processing_fees, B3 = numeric total\n# A4 = total_recoveries, B4 = numeric total\n# Row 6 header = assumption_number, decision, rationale\n# Starting at row 7, list each business decision you made with a brief rationale.\n\nnet_total = regional_df[\'q4_net_fraud_usd\'].sum()\ngross_total = regional_df[\'gross_fraud_usd\'].sum()\nfees_total = regional_df[\'processing_fees\'].sum()\nrecov_total = summary[\'recoveries\'].sum()\n\nws_exec.cell(row=1, column=1, value="q4_net_fraud_total_usd").font = bold_font\ncell_b1 = ws_exec.cell(row=1, column=2, value=float(net_total))\ncell_b1.font = bold_font\ncell_b1.number_format = "$#,##0.00"\n\nws_exec.cell(row=2, column=1, value="q4_gross_fraud_total_usd").font = regular_font\ncell_b2 = ws_exec.cell(row=2, column=2, value=float(gross_total))\ncell_b2.font = regular_font\ncell_b2.number_format = "$#,##0.00"\n\nws_exec.cell(row=3, column=1, value="total_processing_fees").font = regular_font\ncell_b3 = ws_exec.cell(row=3, column=2, value=float(fees_total))\ncell_b3.font = regular_font\ncell_b