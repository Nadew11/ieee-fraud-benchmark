Sending keys: ['cat << \'EOF\' > test_logic.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\nfee = pd.read_csv(\'/data/fee_schedule.csv\')\nregion = pd.read_csv(\'/data/region_map.csv\')\n\n# Convert dates to datetime objects\ndf[\'transaction_date_dt\'] = pd.to_datetime(df[\'transaction_date\'])\nfx[\'date_dt\'] = pd.to_datetime(fx[\'date\'])\n\n# Sort fx by date\nfx = fx.sort_values(\'date_dt\')\n\n# Let\'s write a function to get the USD rate for a given (currency, date_dt)\n# To do this efficiently, we can pivot fx rates or do an asof merge.\n# USD rate is always 1.0\n\n# Let\'s prepare a dataframe of dates and currencies\n# We have currencies: GBP, ETB, NGN, EUR, USD\n# For USD, rate is 1.0. Let\'s append USD rates to fx for all dates\nunique_dates = pd.concat([df[\'transaction_date_dt\'], fx[\'date_dt\']]).unique()\nusd_rates = pd.DataFrame({\'date_dt\': unique_dates, \'currency\': \'USD\', \'rate_to_usd\': 1.0})\nfx_all = pd.concat([fx[[\'date_dt\', \'currency\', \'rate_to_usd\']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values(\'date_dt\')\n\n# We can use pd.merge_asof to match\n# For pd.merge_asof, we must sort both dataframes by the key on which we merge\ndf = df.sort_values(\'transaction_date_dt\')\n\n# merge_asof matches on transaction_date_dt <= date_dt? No, we want matching or most recent prior rate.\n# So df[\'transaction_date_dt\'] >= fx_all[\'date_dt\'].\n# In pandas merge_asof: \n# merge_asof(df, fx_all, on=\'transaction_date_dt\', by=\'currency\', direction=\'backward\')\n# This matches the transaction_date_dt with the largest date_dt in fx_all that is less than or equal to transaction_date_dt.\n\ndf_merged = pd.merge_asof(df, fx_all, left_on=\'transaction_date_dt\', right_on=\'date_dt\', by=\'currency\', direction=\'backward\')\n\n# Let\'s verify if there are any missing rates\nmissing_rates = df_merged[df_merged[\'rate_to_usd\'].isna()]\nprint("Missing rates count:", len(missing_rates))\nif len(missing_rates) > 0:\n    print(missing_rates[[\'transaction_date\', \'currency\']].drop_duplicates())\n\n# Calculate TransactionAmt in USD\ndf_merged[\'amt_usd\'] = df_merged[\'TransactionAmt\'] * df_merged[\'rate_to_usd\']\n\nprint("Total rows:", len(df_merged))\nEOF\npython3 test_logic.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
Sending keys: ['cat << \'EOF\' > match_gt.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\nfees = pd.read_csv(\'/data/fee_schedule.csv\')\nregions = pd.read_csv(\'/data/region_map.csv\')\n\n# Convert dates\ndf[\'transaction_date\'] = pd.to_datetime(df[\'transaction_date\'])\nfx[\'date\'] = pd.to_datetime(fx[\'date\'])\n\n# Build FX rates lookup\nall_dates = pd.date_range(start=min(df[\'transaction_date\'].min(), fx[\'date\'].min()), \n                          end=max(df[\'transaction_date\'].max(), fx[\'date\'].max()))\n\nfx_lookup = {\'USD\': pd.Series(1.0, index=all_dates)}\nfor cur in fx[\'currency\'].unique():\n    cur_rates = fx[fx[\'currency\'] == cur].set_index(\'date\')[\'rate_to_usd\'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf[\'fx_rate\'] = df.apply(lambda r: fx_lookup[r[\'currency\']].loc[r[\'transaction_date\']], axis=1)\ndf[\'amount_usd\'] = df[\'TransactionAmt\'] * df[\'fx_rate\']\n\n# Join fee schedules\nfee_dict = fees.set_index(\'merchant_category\')[\'fee_rate\'].to_dict()\ndf[\'fee_rate\'] = df[\'merchant_category\'].map(fee_dict)\n# Wait, let\'s verify if there are any missing fee rates\nprint("Missing fee rates:", df[\'fee_rate\'].isna().sum())\n\ndf[\'processing_fee_usd\'] = df[\'amount_usd\'] * df[\'fee_rate\']\n\n# Join regions\nregion_dict = regions.set_index(\'country_code\')[\'region\'].to_dict()\ndf[\'region\'] = df[\'country_code\'].map(region_dict).fillna(\'Other\')\n\n# Filter for Q4 2023\ndf_q4 = df[(df[\'transaction_date\'] >= \'2023-10-01\') & (df[\'transaction_date\'] <= \'2023-12-31\')]\n\n# Filter out declined transactions\ndf_q4_not_declined = df_q4[df_q4[\'settlement_status\'] != \'declined\']\n\n# Now, let\'s look at isFraud == 1 transactions in Q4\nfraud_txs = df_q4_not_declined[df_q4_not_declined[\'isFraud\'] == 1]\n\nprint("Total fraud txs (excluding declined) in Q4:", len(fraud_txs))\nprint("By transaction type:")\nprint(fraud_txs.groupby(\'transaction_type\').size())\nprint("Gross fraud usd by type:")\nprint(fraud_txs.groupby(\'transaction_type\')[\'amount_usd\'].sum())\nprint("Processing fee usd by type:")\nprint(fraud_txs.groupby(\'transaction_type\')[\'processing_fee_usd\'].sum())\n\nEOF\npython3 match_gt.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
