   d2 = q4_df.drop_duplicates(subset=[\'TransactionID\'], keep=keep_strat)\n    d2 = d2[d2[\'settlement_status\'] != \'declined\']\n    purchases = d2[(d2[\'isFraud\'] == 1) & (d2[\'transaction_type\'] == \'purchase\')]\n    print(f"Dedup Q4 df ({keep_strat}) -> count: {len(purchases)}, gross: {purchases[\'amount_usd\'].sum():.4f}, fees: {purchases[\'processing_fee_usd\'].sum():.4f}")\n\nEOF\npython3 test_dedup_all.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
