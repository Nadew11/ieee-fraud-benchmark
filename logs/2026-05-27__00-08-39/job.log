e\')[\'amt_usd\'].sum())\n\n# Let\'s see if we just take \'refund\' without dropping duplicates or with dropping duplicates\nrefunds = frauds_all[frauds_all[\'transaction_type\'] == \'refund\']\nprint("\\nRefunds only, no dup dropping:")\nprint("Count:", len(refunds), "Sum:", refunds[\'amt_usd\'].sum())\nprint("Refunds only, keep first dup:")\nrefunds_no_dup = refunds.drop_duplicates(subset=[\'TransactionID\'], keep=\'first\')\nprint("Count:", len(refunds_no_dup), "Sum:", refunds_no_dup[\'amt_usd\'].sum())\n\n# Let\'s print unique types for frauds_no_dup\nprint("\\nAll types in frauds_no_dup:", frauds_no_dup[\'transaction_type\'].unique())\n\nEOF\npython3 test_recoveries.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
