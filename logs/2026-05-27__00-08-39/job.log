Sending keys: ['cat << \'EOF\' > test_fx.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\nfees = pd.read_csv(\'/data/fee_schedule.csv\')\nregions = pd.read_csv(\'/data/region_map.csv\')\n\n# Dates to datetime\ndf[\'transaction_date\'] = pd.to_datetime(df[\'transaction_date\'])\nfx[\'date\'] = pd.to_datetime(fx[\'date\'])\n\n# Build the FX rate dictionary\n# For each currency, we want a complete date index from fx[\'date\'].min() to max transaction_date\nall_dates = pd.date_range(start=min(df[\'transaction_date\'].min(), fx[\'date\'].min()), \n                          end=max(df[\'transaction_date\'].max(), fx[\'date\'].max()))\n\nfx_lookup = {}\n# For USD, rate is always 1.0\nfx_lookup[\'USD\'] = pd.Series(1.0, index=all_dates)\n\nfor cur in fx[\'currency\'].unique():\n    cur_rates = fx[fx[\'currency\'] == cur].set_index(\'date\')[\'rate_to_usd\']\n    # Reindex to all_dates, ffill\n    # Note: we must sort index to ffill properly\n    cur_rates = cur_rates.sort_index()\n    # We reindex to all_dates\n    cur_rates_reindexed = cur_rates.reindex(all_dates)\n    # ffill\n    cur_rates_ffilled = cur_rates_reindexed.ffill()\n    fx_lookup[cur] = cur_rates_ffilled\n\n# Add rate column to transactions\ndef get_rate(row):\n    curr = row[\'currency\']\n    dt = row[\'transaction_date\']\n    return fx_lookup[curr].loc[dt]\n\ndf[\'fx_rate\'] = df.apply(get_rate, axis=1)\ndf[\'amount_usd\'] = df[\'TransactionAmt\'] * df[\'fx_rate\']\n\nprint("Done fx rate mapping. Checking some NGN rates:")\nprint(df[df[\'currency\'] == \'NGN\'][[\'transaction_date\', \'currency\', \'TransactionAmt\', \'fx_rate\', \'amount_usd\']].head())\nEOF\npython3 test_fx.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
