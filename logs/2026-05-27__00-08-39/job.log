Sending keys: ['cat << \'EOF\' > generate_data.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\nfees = pd.read_csv(\'/data/fee_schedule.csv\')\nrm = pd.read_csv(\'/data/region_map.csv\')\n\nrates_dict = {}\nfor idx, row in fx.iterrows():\n    rates_dict[(row[\'currency\'], row[\'date\'])] = row[\'rate_to_usd\']\n\ndef get_rate(currency, date_str):\n    if currency == \'USD\':\n        return 1.0\n    if (currency, date_str) in rates_dict:\n        return rates_dict[(currency, date_str)]\n    currency_rates = fx[fx[\'currency\'] == currency]\n    prior_rates = currency_rates[currency_rates[\'date\'] <= date_str]\n    if len(prior_rates) == 0:\n        return currency_rates.sort_values(\'date\').iloc[0][\'rate_to_usd\']\n    return prior_rates.sort_values(\'date\', ascending=False).iloc[0][\'rate_to_usd\']\n\ndf[\'fx_rate\'] = df.apply(lambda r: get_rate(r[\'currency\'], r[\'transaction_date\']), axis=1)\ndf[\'amt_usd\'] = df[\'TransactionAmt\'] * df[\'fx_rate\']\n\nfee_dict = dict(zip(fees[\'merchant_category\'], fees[\'fee_rate\']))\ndf[\'fee_rate\'] = df[\'merchant_category\'].map(fee_dict)\ndf[\'processing_fee\'] = df[\'amt_usd\'] * df[\'fee_rate\']\n\ndf_clean = df.drop_duplicates(subset=[\'TransactionID\'], keep=\'first\').copy()\ndf_clean = df_clean[df_clean.settlement_status != \'declined\'].copy()\n\nregion_dict = dict(zip(rm[\'country_code\'], rm[\'region\']))\ndef get_region(country_code):\n    return region_dict.get(country_code, \'Other\')\n\ndf_clean[\'region\'] = df_clean[\'country_code\'].apply(get_region)\ndf_clean[\'month\'] = df_clean[\'transaction_date\'].apply(lambda x: x[:7])\n\nfraud = df_clean[df_clean.isFraud == 1].copy()\n\npurchases = fraud[fraud.transaction_type == \'purchase\']\nrefunds = fraud[fraud.transaction_type == \'refund\']\n\ngross_total = purchases[\'amt_usd\'].sum()\nfees_total = purchases[\'processing_fee\'].sum()\nrecoveries_total = refunds[\'amt_usd\'].sum()\nnet_total = gross_total - recoveries_total - fees_total\ncount_total = len(purchases)\n\nprint("Calculated Totals:")\nprint("Gross Total:", gross_total)\nprint("Fees Total:", fees_total)\nprint("Recoveries Total:", recoveries_total)\nprint("Net Total:", net_total)\nprint("Fraud purchase count:", count_total)\n\nEOF\npython3 generate_data.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
