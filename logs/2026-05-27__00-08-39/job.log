")\nprint(f"Recoveries (refunds only): {recoveries:.2f}")\nprint(f"Recoveries (refunds + chargeback reversals): {(refunds[\'amount_usd\'].sum() + chargebacks[\'amount_usd\'].sum()):.2f}")\nprint(f"Processing fees on fraud (purchases only): {fees_sum:.2f}")\nprint(f"Net fraud: {net_fraud:.2f}")\n\nEOF\npython3 test_net.py\n'] min_timeout_sec: 1.5 max_timeout_sec: 180.0
