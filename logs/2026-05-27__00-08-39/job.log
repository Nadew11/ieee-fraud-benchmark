Sending keys: ['cat << \'EOF\' > test_dedup.py\nimport pandas as pd\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\n\n# Convert dates\ndf[\'transaction_date\'] = pd.to_datetime(df[\'transaction_date\'])\nfx[\'date\'] = pd.to_datetime(fx[\'date\'])\n\n# Build FX rates lookup\nall_dates = pd.date_range(start=min(df[\'transaction_date\'].min(), fx[\'date\'].min()), \n                          end=max(df[\'transaction_date\'].max(), fx[\'date\'].max()))\nfx_lookup = {\'USD\': pd.Series(1.0, index=all_dates)}\nfor cur in fx[\'currency\'].unique():\n    cur_rates = fx[fx[\'currency\'] == cur].set_index(\'date\')[\'rate_to_usd\'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf[\'fx_rate\'] = df.apply(lambda r: fx_lookup[r[\'currency\']].loc[r[\'transaction_date\']], axis=1)\ndf[\'amount_usd\'] = df[\'TransactionAmt\'] * df[\'fx_rate\']\n\n# Let\'s test different dedup strategies\n# Strategy A: Dedup the entire df first on TransactionID, keeping first or last\nfor keep_strat in [\'first\', \'last\']:\n    df_dedup = df.drop_duplicates(subset=[\'TransactionID\'], keep=keep_strat)\n    df_q4 = df_dedup[(df_dedup[\'transaction_date\'] >= \'2023-10-01\') & (df_dedup[\'transaction_date\'] <= \'2023-12-31\')]\n    \n    # Settled purchase fraud\n    purchases = df_q4[(df_q4[\'isFraud\'] == 1) & (df_q4[\'transaction_type\'] == \'purchase\') & (df_q4[\'settlement_status\'] == \'settled\')]\n    print(f"Keep: {keep_strat} -> count: {len(purchases)}, sum: {purchases[\'amount_usd\'].sum():.2f}")\n\n# Let\'s check other status_filter combinations or sorting before dedup?\nEOF\npython3 test_dedup.py\n'] min_timeout_sec: 1.5 max_timeout_sec: 180.0
