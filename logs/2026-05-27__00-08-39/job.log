aud.settlement_status == \'settled\')][\'amt_usd\'].sum()\ngross_purchase_all = fraud[fraud.transaction_type == \'purchase\'][\'amt_usd\'].sum()\nprint("Gross Purchase settled:", gross_purchase_settled)\nprint("Gross Purchase all:", gross_purchase_all)\n\nrecoveries_settled = fraud[fraud.transaction_type.isin([\'refund\', \'chargeback_reversal\']) & (fraud.settlement_status == \'settled\')][\'amt_usd\'].sum()\nrecoveries_all = fraud[fraud.transaction_type.isin([\'refund\', \'chargeback_reversal\'])][\'amt_usd\'].sum()\nprint("Recoveries settled:", recoveries_settled)\nprint("Recoveries all:", recoveries_all)\n\nfees_settled = fraud[(fraud.transaction_type == \'purchase\') & (fraud.settlement_status == \'settled\')][\'processing_fee\'].sum()\nfees_all = fraud[fraud.transaction_type == \'purchase\'][\'processing_fee\'].sum()\nprint("Fees settled:", fees_settled)\nprint("Fees all:", fees_all)\n\nEOF\npython3 find_logic.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
