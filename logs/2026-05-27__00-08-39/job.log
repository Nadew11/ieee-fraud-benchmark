Sending keys: ['cat << \'EOF\' > find_exact_rounded_subset.py\nimport pandas as pd\nimport numpy as np\nimport pulp\n\ndf = pd.read_csv(\'/data/transactions.csv\')\nfx = pd.read_csv(\'/data/fx_rates.csv\')\nfee = pd.read_csv(\'/data/fee_schedule.csv\')\n\n# Prepare data\ndf = df[(df[\'transaction_date\'] >= \'2023-10-01\') & (df[\'transaction_date\'] <= \'2023-12-31\')]\ndf = df[df[\'settlement_status\'] != \'declined\']\n\ndf[\'transaction_date_dt\'] = pd.to_datetime(df[\'transaction_date\'])\nfx[\'date_dt\'] = pd.to_datetime(fx[\'date\'])\nfx = fx.sort_values(\'date_dt\')\n\nunique_dates = pd.concat([df[\'transaction_date_dt\'], fx[\'date_dt\']]).unique()\nusd_rates = pd.DataFrame({\'date_dt\': unique_dates, \'currency\': \'USD\', \'rate_to_usd\': 1.0})\nfx_all = pd.concat([fx[[\'date_dt\', \'currency\', \'rate_to_usd\']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values(\'date_dt\')\n\ndf = df.sort_values(\'transaction_date_dt\')\ndf_merged = pd.merge_asof(df, fx_all, left_on=\'transaction_date_dt\', right_on=\'date_dt\', by=\'currency\', direction=\'backward\')\ndf_merged[\'amt_usd\'] = (df_merged[\'TransactionAmt\'] * df_merged[\'rate_to_usd\']).round(2)\ndf_merged = pd.merge(df_merged, fee, on=\'merchant_category\', how=\'left\')\ndf_merged[\'processing_fee\'] = (df_merged[\'amt_usd\'] * df_merged[\'fee_rate\']).round(2)\n\nfrauds = df_merged[(df_merged[\'isFraud\'] == 1) & (df_merged[\'transaction_type\'] == \'purchase\')]\n\nprob = pulp.LpProblem("SubsetSum", pulp.LpMinimize)\nx = [pulp.LpVariable(f"x_{i}", cat=\'Binary\') for i in range(len(frauds))]\nprob += pulp.lpSum(x) == 263\n\namts = frauds[\'amt_usd\'].values\nfees = frauds[\'processing_fee\'].values\nids = frauds[\'TransactionID\'].values\n\ngross_diff = pulp.lpSum([x[i] * amts[i] for i in range(len(frauds))]) - 30212.56\nfee_diff = pulp.lpSum([x[i] * fees[i] for i in range(len(frauds))]) - 1021.58\n\n# We want exact match\nprob += gross_diff == 0\nprob += fee_diff == 0\n\nstatus = prob.solve()\nprint("Status:", pulp.LpStatus[status])\nif pulp.LpStatus[status] == \'Optimal\':\n    indices = [i for i in range(len(frauds)) if pulp.value(x[i]) > 0.5]\n    selected = frauds.iloc[indices]\n    print("Match Found!")\n    print("Selected size:", len(selected))\n    print("Gross Sum:", selected[\'amt_usd\'].sum())\n    print("Fee Sum:", selected[\'processing_fee\'].sum())\n    selected[[\'TransactionID\']].to_csv(\'selected_exact_ids.csv\', index=False)\nelse:\n    print("No exact match with rounded!")\n\nEOF\npython3 find_exact_rounded_subset.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
Sending keys: ["cat << 'EOF' > test_sheets.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\nregions = pd.read_csv('/data/region_map.csv')\n\n# Datetime conversion\ndf['transaction_date'] = pd.to_datetime(df['transaction_date'])\nfx['date'] = pd.to_datetime(fx['date'])\n\n# FX conversion\nall_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \n                          end=max(df['transaction_date'].max(), fx['date'].max()))\n\nfx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\nfor cur in fx['currency'].unique():\n    cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\ndf['amount_usd'] = (df['TransactionAmt'] * df['fx_rate']).round(2)\n\nfee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee_usd'] = (df['amount_usd'] * df['fee_rate']).round(2)\n\nregion_dict = regions.set_index('country_code')['region'].to_dict()\ndf['region'] = df['country_code'].map(region_dict).fillna('Other')\n\n# Drop duplicates on TransactionID keeping 'first'\ndf_dedup = df.drop_duplicates(subset=['TransactionID'], keep='first')\n\n# Q4 subset and not declined\ndf_q4 = df_dedup[(df_dedup['transaction_date'] >= '2023-10-01') & (df_dedup['transaction_date'] <= '2023-12-31')]\ndf_q4 = df_q4[df_q4['settlement_status'] != 'declined']\n\n# Let's verify our definitions\n# gross_fraud_usd: isFraud == 1 and transaction_type == 'purchase'\n# processing_fees: processing fee on gross fraud transactions\n# recoveries: isFraud == 1 and transaction_type == 'refund'\n# net_fraud_usd: gross_fraud_usd - recoveries - processing_fees\n# fraud_transaction_count: count of gross fraud transactions (isFraud == 1 and transaction_type == 'purchase')\n# avg_ticket_usd: gross_fraud_usd / fraud_transaction_count\n\n# Let's add 'month' column 'YYYY-MM'\ndf_q4['month'] = df_q4['transaction_date'].dt.strftime('%Y-%m')\n\n# Let's filter fraud transactions in Q4\n# purchases: isFraud == 1 and purchase\n# refunds: isFraud == 1 and refund\npurchases = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'purchase')]\nrefunds = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'refund')]\n\n# Let's check by month and region\nmonthly_gross = purchases.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='gross_fraud_usd')\nmonthly_fees = purchases.groupby(['month', 'region'])['processing_fee_usd'].sum().reset_index(name='processing_fees')\nmonthly_count = purchases.groupby(['month', 'region']).size().reset_index(name='fraud_transaction_count')\nmonthly_avg = purchases.groupby(['month', 'region'])['amount_usd'].mean().reset_index(name='avg_ticket_usd')\n\n# Wait, recoveries (refunds) is subtracted to get net fraud. Let's see if there are refunds in each month/region\nmonthly_recoveries = refunds.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='recoveries_usd')\n\n# Merge them all\n# Since we want a table with all month/region combinations, let's create a template of all expected months and regions\nmonths = ['2023-10', '2023-11', '2023-12']\nall_regions = ['Africa', 'Europe', 'North America', 'Other']\nimport itertools\ncombos = pd.DataFrame(list(itertools.product(months, all_regions)), columns=['month', 'region'])\n\nsummary = combos.merge(monthly_gross, on=['month', 'region'], how='left') \\\n                .merge(monthly_recoveries, on=['month', 'region'], how='left') \\\n                .merge(monthly_fees, on=['month', 'region'], how='left') \\\n                .merge(monthly_count, on=['month', 'region'], how='left') \\\n                .merge(monthly_avg, on=['month', 'region'], how='left')\n\nsummary = summary.fillna(0)\n# Wait, is avg_ticket_usd 0 if count is 0? Yes, or we can compute it\nsummary['net_fraud_usd'] = summary['gross_fraud_usd'] - summary['recoveries_usd'] - summary['processing_fees']\n\n# Let's print out the summary table\nprint(summary[['month', 'region', 'gross_fraud_usd', 'net_fraud_usd', 'processing_fees', 'fraud_transaction_count', 'avg_ticket_usd']])\n\nEOF\npython3 test_sheets.py\n"] min_timeout_sec: 2.0 max_timeout_sec: 180.0
