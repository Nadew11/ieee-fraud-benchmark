[151.488759, "i", "cat << 'EOF' > check_fx.py\nimport pandas as pd\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\n\ntrans_cd = set(zip(df.currency, df.transaction_date))\nfx_cd = set(zip(fx.currency, fx.date))\n\nmissing = trans_cd - fx_cd\nprint(\"Missing direct matches:\", len(missing))\nfor c, d in sorted(list(missing))[:15]:\n    print(f\"{c} on {d}\")\nEOF\npython3 check_fx.py\n"]
