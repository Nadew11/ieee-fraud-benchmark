[588.000696, "o", "rates = dict(zip(zip(fx.currency, fx.date), fx.rate_to_usd))\r\n\u001b[?2004l\r"]
[588.000865, "o", "\u001b[?2004h> def get_rate(c, d):\r\n\u001b[?2004l\r\u001b[?2004h>     if c == 'USD': return 1.0\r\n\u001b[?2004l\r\u001b[?2004h>     if (c, d) in rates: return rates[(c, d)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[588.001124, "o", "    sub = fx[fx.currency == c][fx.date <= d]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[588.002065, "o", "    return sub.sort_values('date').iloc[-1]['rate_to_usd'] if not sub.empty else fx[fx.currency==c].sort_values('date').iloc[0]['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['r'] = df.apply(lambda row: get_rate(row['currency'], row['transaction_date']), axis=1)\r\n\u001b[?2004l\r\u001b[?2004h> df['amt'] = (df['TransactionAmt'] * df['r']).round(2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Merchant categories count in df:\", df.merchant_category.value_counts())\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
