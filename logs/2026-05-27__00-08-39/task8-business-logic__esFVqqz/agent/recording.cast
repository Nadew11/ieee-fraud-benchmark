[568.288888, "o", "\u001b[?2004h>     if r_type == 'round_both':\r\n\u001b[?2004l\r\u001b[?2004h>         df['fee'] = df['fee'].round(2)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     clean = df.drop_duplicates(subset=['TransactionID'], keep='first')\r\n\u001b[?2004l\r\u001b[?2004h>     clean = clean[clean.settlement_status != 'declined']\r\n\u001b[?2004l\r\u001b[?2004h>     fraud = clean[clean.isFraud == 1]\r\n\u001b[?2004l\r\u001b[?2004h>     purchases = fraud[fraud.transaction_type == 'purchase']\r\n\u001b[?2004l\r\u001b[?2004h>     refunds = fraud[fraud.transaction_type == 'refund']\r\n\u001b[?2004l\r\u001b[?2004h>     print(r_type, \"Gross:\", purchases['amt'].sum(), \"Fees:\", purchases['fee'].sum(), \"Recoveries:\", refunds['amt'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
