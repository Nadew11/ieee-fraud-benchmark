[567.992696, "i", "cat << 'EOF' > test_rounding.py\nimport pandas as pd\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nrates = dict(zip(zip(fx.currency, fx.date), fx.rate_to_usd))\ndef get_rate(c, d):\n    if c == 'USD': return 1.0\n    if (c, d) in rates: return rates[(c, d)]\n    sub = fx[fx.currency == c]\n    sub = sub[sub.date <= d]\n    return sub.sort_values('date').iloc[-1]['rate_to_usd'] if not sub.empty else fx[fx.currency==c].sort_values('date').iloc[0]['rate_to_usd']\n\ndf['r'] = df.apply(lambda row: get_rate(row['currency'], row['transaction_date']), axis=1)\nfor r_type in ['none', 'round_both']:\n    df['amt'] = df['TransactionAmt'] * df['r']\n    if r_type == 'round_both':\n        df['amt'] = df['amt'].round(2)\n    # fee category rates\n    f_map = {'retail':0.025, 'travel':0.03, 'digital_goods':0.035, 'gambling':0.045}\n    df['fee'] = df['amt'] * df['merchant_category'].map(f_map)\n    if r_type == 'round_both':\n        df['fee'] = df['fee'].round(2)\n    \n    clean = df.drop_duplicates(subset=['TransactionID'], keep='first')\n    clean = clean[clean.settlement_status != 'declined']\n    fraud = clean[clean.isFraud == 1]\n    purchases = fraud[fraud.transaction_type == 'purchase']\n    refunds = fraud[fraud.transaction_type == 'refund']\n    print(r_type, \"Gross:\", purchases['amt'].sum(), \"Fees:\", purchases['fee'].sum(), \"Recoveries:\", refunds['amt'].sum())\nEOF\npython3 test_rounding.py\n"]
[568.197735, "o", "cat << 'EOF' > test_rounding.py\r\n\u001b[?2004l\r"]
[568.198854, "o", "\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> rates = dict(zip(zip(fx.currency, fx.date), fx.rate_to_usd))\r\n\u001b[?2004l\r\u001b[?2004h> def get_rate(c, d):\r\n\u001b[?2004l\r\u001b[?2004h>     if c == 'USD': return 1.0\r\n\u001b[?2004l\r\u001b[?2004h>     if (c, d) in rates: return rates[(c, d)]\r\n\u001b[?2004l\r\u001b[?2004h>     sub = fx[fx.currency == c]\r\n\u001b[?2004l\r\u001b[?2004h>     sub = sub[sub.date <= d]\r\n\u001b[?2004l\r\u001b[?2004h>     return sub.sort_values('date').iloc[-1]['rate_to_usd'] if not sub.empty else fx[fx.currency==c].sort_values('date').iloc[0]['rate_to_usd']\r\n\u001b[?2004l\r"]
[568.266289, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['r'] = df.apply(lambda row: get_rate(row['currency'], row['transaction_date']), axis=1)\r\n\u001b[?2004l\r\u001b[?2004h> for r_type in ['none', 'round_both']:\r\n\u001b[?2004l\r\u001b[?2004h>     df['amt'] = df['TransactionAmt'] * df['r']\r\n\u001b[?2004l\r\u001b[?2004h>     if r_type == 'round_both':\r\n\u001b[?2004l\r\u001b[?2004h>         df['amt'] = df['amt'].round(2)\r\n\u001b[?2004l\r\u001b[?2004h>     # fee category rates\r\n\u001b[?2004l\r\u001b[?2004h>     f_map = {'retail':0.025, 'travel':0.03, 'digital_goods':0.035, 'gambling':0.045}\r\n\u001b[?2004l\r"]
