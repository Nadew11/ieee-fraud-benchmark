[207.104087, "i", "cat << 'EOF' > test_dups_strategy.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\n\nrates_dict = {}\nfor idx, row in fx.iterrows():\n    rates_dict[(row['currency'], row['date'])] = row['rate_to_usd']\n\ndef get_rate(currency, date_str):\n    if currency == 'USD':\n        return 1.0\n    if (currency, date_str) in rates_dict:\n        return rates_dict[(currency, date_str)]\n    currency_rates = fx[fx['currency'] == currency]\n    prior_rates = currency_rates[currency_rates['date'] <= date_str]\n    if len(prior_rates) == 0:\n        return currency_rates.sort_values('date').iloc[0]['rate_to_usd']\n    return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']\n\nrates = []\nfor idx, row in df.iterrows():\n    rates.append(get_rate(row['currency'], row['transaction_date']))\ndf['fx_rate'] = rates\ndf['amt_usd'] = df['TransactionAmt'] * df['fx_rate']\n\nfee_dict = dict(zip(fees['merchant_category'], fees['fee_rate']))\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee'] = df['amt_usd'] * df['fee_rate']\n\nfor keep_strat in ['first', 'last', 'none']:\n    print(f\"\\n--- Strategy: Keep {keep_strat} ---\")\n    if keep_strat == 'none':\n        df_clean = df.drop_duplicates(subset=['TransactionID'], keep=False)\n    else:\n        df_clean = df.drop_duplicates(subset=['TransactionID'], keep=keep_strat)\n    \n    df_clean_no_declined = df_clean[df_clean.settlement_status != 'declined'].copy()\n    \n    fraud = df_clean_no_declined[df_clean_no_declined.isFraud == 1]\n    fraud_purchases = fraud[fraud.transaction_type == 'purchase']\n    \n    print(\"Fraud purchase count:\", len(fraud_purchases))\n    \n    gross_fraud = fraud_purchases['amt_usd'].sum()\n    proc_fees = fraud_purchases['processing_fee'].sum()\n    recoveries = fraud[fraud.transaction_type.isin(['refund', 'chargeback_reversal'])]['amt_usd'].sum()\n    \n    print(\"Gross fraud:\", gross_fraud)\n    print(\"Processing fees:\", proc_fees)\n    print(\"Recoveries:\", recoveries)\n    print(\"Net fraud:\", gross_fraud - recoveries - proc_fees)\n\nEOF\npython3 test_dups_strategy.py\n"]
