[87.836747, "i", "cat << 'EOF' > find_logic.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\nrm = pd.read_csv('/data/region_map.csv')\n\nrates_dict = {}\nfor idx, row in fx.iterrows():\n    rates_dict[(row['currency'], row['date'])] = row['rate_to_usd']\n\ndef get_rate(currency, date_str):\n    if currency == 'USD':\n        return 1.0\n    if (currency, date_str) in rates_dict:\n        return rates_dict[(currency, date_str)]\n    currency_rates = fx[fx['currency'] == currency]\n    prior_rates = currency_rates[currency_rates['date'] <= date_str]\n    if len(prior_rates) == 0:\n        return currency_rates.sort_values('date').iloc[0]['rate_to_usd']\n    return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']\n\nrates = []\nfor idx, row in df.iterrows():\n    rates.append(get_rate(row['currency'], row['transaction_date']))\ndf['fx_rate'] = rates\ndf['amt_usd'] = df['TransactionAmt'] * df['fx_rate']\n\nfee_dict = dict(zip(fees['merchant_category'], fees['fee_rate']))\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee'] = df['amt_usd'] * df['fee_rate']\n\nq4_df = df[(df.transaction_date >= '2023-10-01') & (df.transaction_date <= '2023-12-31')].copy()\nq4_no_declined = q4_df[q4_df.settlement_status != 'declined'].copy()\nfraud = q4_no_declined[q4_no_declined.isFraud == 1]\n\nprint(\"Fraud purchase count for all statuses except declined:\", len(fraud[fraud.transaction_type == 'purchase']))\nprint(\"Fraud purchase count settled:\", len(fraud[(fraud.transaction_type == 'purchase') & (fraud.settlement_status == 'settled')]))\nprint(\"Fraud purchase count pending:\", len(fraud[(fraud.transaction_type == 'purchase') & (fraud.settlement_status == 'pending')]))\n\ngross_purchase_settled = fraud[(fraud.transaction_type == 'purchase') & (fraud.settlement_status == 'settled')]['amt_usd'].sum()\ngross_purchase_all = fraud[fraud.transaction_type == 'purchase']['amt_usd'].sum()\nprint(\"Gross Purchase settled:\", gross_purchase_settled)\nprint(\"Gross Purchase all:\", gross_purchase_all)\n\nrecoveries_settled = fraud[fraud.transaction_type.isin(['refund', 'chargeback_reversal']) & (fraud.settlement_status == 'settled')]['amt_usd'].sum()\nrecoveries_all = fraud[fraud.transaction_type.isin(['refund', 'chargeback_reversal'])]['amt_usd'].sum()\nprint(\"Recoveries settled:\", recoveries_settled)\nprint(\"Recoveries all:\", recoveries_all)\n\nfees_settled = fraud[(fraud.transaction_type == 'purchase') & (fraud.settlement_status == 'settled')]['processing_fee'].sum()\nfees_all = fraud[fraud.transaction_type == 'purchase']['processing_fee'].sum()\nprint(\"Fees settled:\", fees_settled)\nprint(\"Fees all:\", fees_all)\n\nEOF\npython3 find_logic.py\n"]
[87.851384, "o", "cat << 'EOF' > find_logic.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fees = pd.read_csv('/data/fee_schedule.csv')\r\n\u001b[?2004l\r\u001b[?2004h> rm = pd.read_csv('/data/region_map.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> rates_dict = {}\r\n\u001b[?2004l\r\u001b[?2004h> for idx, row in fx.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h>     rates_dict[(row['currency'], row['date'])] = row['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_rate(currency, date_str):\r\n\u001b[?2004l\r\u001b[?2004h>     if currency == 'USD':\r\n\u001b[?2004l\r\u001b[?2004h>         return 1.0\r\n\u001b[?2004l\r\u001b[?2004h>     if (currency, date_str) in rates_dict:\r\n\u001b[?2004l\r\u001b[?2004h>         return rates_dict[(currency, date_str)]\r\n\u001b[?2004l\r\u001b[?2004h>     currency_rates = fx[fx['currency'] == currency]\r\n\u001b[?2004l\r\u001b[?2004h>     prior_rates = currency_rates[currency_rates['date'] <= date_str]\r\n\u001b[?2004l\r\u001b[?2004h>     if len(prior_rates) == 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return currency_rates.sort_values('date').iloc[0]['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h>     return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> rates = []\r\n\u001b[?2004l\r\u001b[?2004h> for idx, row in df.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h>     rates.append(get_rate(row['currency'], row['transaction_date']))\r\n\u001b[?2004l\r\u001b[?2004h> df['fx_rate'] = rates\r\n\u001b[?2004l\r\u001b[?2004h> df['amt_usd'] = df['TransactionAmt'] * df['fx_rate']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> fee_dict = dict(zip(fees['merchant_category'], fees['fee_rate']))\r\n\u001b[?2004l\r\u001b[?2004h> df['fee_rate'] = df['merchant_category'].map(fee_dict)\r\n\u001b[?2004l\r\u001b[?2004h> df['processing_fee'] = df['amt_usd'] * df['fee_rate']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> q4_df = df[(df.transaction_date >= '2023-10-01') & (df.transaction_date <= '2023-12-31')].copy()\r\n\u001b[?2004l\r\u001b[?2004h> q4_no_declined = q4_df[q4_df.settlement_status != 'declined'].copy()\r\n\u001b[?2004l\r\u001b[?2004h> fraud = q4_no_declined[q4_no_declined.isFraud == 1]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Fraud purchase count for all statuses except declined:\", len(fraud[fraud.transaction_type == 'purchase']))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Fraud purchase count settled:\", len(fraud[(fraud.transaction_type == 'purchase') & (fraud.settlement_status == 'settled')]))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Fraud purchase count pending:\", len(fraud[(fraud.transaction_type == 'purchase') & (fraud.settlement_status == 'pending')]))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[87.851439, "o", "gross_purchase_settled = fraud[(fraud.transaction_type == 'purchase') & (fraud.settlement_status == 'settled')]['amt_usd'].sum()\r\n\u001b[?2004l\r\u001b[?2004h> "]
