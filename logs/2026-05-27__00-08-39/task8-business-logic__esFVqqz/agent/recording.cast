[360.927087, "i", "cat << 'EOF' > get_breakdowns.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\nrm = pd.read_csv('/data/region_map.csv')\n\nrates_dict = {}\nfor idx, row in fx.iterrows():\n    rates_dict[(row['currency'], row['date'])] = row['rate_to_usd']\n\ndef get_rate(currency, date_str):\n    if currency == 'USD':\n        return 1.0\n    if (currency, date_str) in rates_dict:\n        return rates_dict[(currency, date_str)]\n    currency_rates = fx[fx['currency'] == currency]\n    prior_rates = currency_rates[currency_rates['date'] <= date_str]\n    if len(prior_rates) == 0:\n        return currency_rates.sort_values('date').iloc[0]['rate_to_usd']\n    return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']\n\ndf['fx_rate'] = df.apply(lambda r: get_rate(r['currency'], r['transaction_date']), axis=1)\ndf['amt_usd'] = df['TransactionAmt'] * df['fx_rate']\n\nfee_dict = dict(zip(fees['merchant_category'], fees['fee_rate']))\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee'] = df['amt_usd'] * df['fee_rate']\n\ndf_clean = df.drop_duplicates(subset=['TransactionID'], keep='first').copy()\ndf_clean = df_clean[df_clean.settlement_status != 'declined'].copy()\n\nregion_dict = dict(zip(rm['country_code'], rm['region']))\ndef get_region(country_code):\n    return region_dict.get(country_code, 'Other')\n\ndf_clean['region'] = df_clean['country_code'].apply(get_region)\ndf_clean['month'] = df_clean['transaction_date'].apply(lambda x: x[:7])\n\nfraud = df_clean[df_clean.isFraud == 1].copy()\n\npurchases = fraud[fraud.transaction_type == 'purchase']\nrefunds = fraud[fraud.transaction_type == 'refund']\n\nmonthly_gross = purchases.groupby(['month', 'region'])['amt_usd'].sum().reset_index(name='gross_fraud_usd')\nmonthly_fees = purchases.groupby(['month', 'region'])['processing_fee'].sum().reset_index(name='processing_fees')\nmonthly_count = purchases.groupby(['month', 'region']).size().reset_index(name='fraud_transaction_count')\nmonthly_avg = purchases.groupby(['month', 'region'])['amt_usd'].mean().reset_index(name='avg_ticket_usd')\n\nmonthly_recoveries = refunds.groupby(['month', 'region'])['amt_usd'].sum().reset_index(name='recoveries')\n\nfrom functools import reduce\ndata_frames = [monthly_gross, monthly_fees, monthly_count, monthly_avg, monthly_recoveries]\nmonthly_breakdown = reduce(lambda left, right: pd.merge(left, right, on=['month', 'region'], how='outer'), data_frames)\nmonthly_breakdown.fillna(0, inplace=True)\n\nmonthly_breakdown['net_fraud_usd'] = monthly_breakdown['gross_fraud_usd'] - monthly_breakdown['recoveries'] - monthly_breakdown['processing_fees']\n\nmonthly_breakdown = monthly_breakdown[['month', 'region', 'gross_fraud_usd', 'net_fraud_usd', 'processing_fees', 'fraud_transaction_count', 'avg_ticket_usd']]\nprint(\"Monthly Breakdown Rows:\")\nprint(monthly_breakdown.to_string())\nprint(\"\\nSum of Columns:\")\nprint(monthly_breakdown.sum(numeric_only=True))\n\nEOF\npython3 get_breakdowns.py\n"]
[360.93957, "o", "cat << 'EOF' > get_breakdowns.py"]
[360.942618, "o", "\r\n"]
