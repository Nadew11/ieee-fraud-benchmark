[227.810404, "i", "cat << 'EOF' > search_recoveries.py\nimport pandas as pd\nimport itertools\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\n\nrates_dict = {}\nfor idx, row in fx.iterrows():\n    rates_dict[(row['currency'], row['date'])] = row['rate_to_usd']\n\ndef get_rate(currency, date_str):\n    if currency == 'USD':\n        return 1.0\n    if (currency, date_str) in rates_dict:\n        return rates_dict[(currency, date_str)]\n    currency_rates = fx[fx['currency'] == currency]\n    prior_rates = currency_rates[currency_rates['date'] <= date_str]\n    if len(prior_rates) == 0:\n        return currency_rates.sort_values('date').iloc[0]['rate_to_usd']\n    return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']\n\ndf['fx_rate'] = df.apply(lambda r: get_rate(r['currency'], r['transaction_date']), axis=1)\ndf['amt_usd'] = df['TransactionAmt'] * df['fx_rate']\n\ndf_clean = df.drop_duplicates(subset=['TransactionID'], keep='first')\ndf_clean_no_declined = df_clean[df_clean.settlement_status != 'declined'].copy()\n\nfraud = df_clean_no_declined[df_clean_no_declined.isFraud == 1]\nrecoveries = fraud[fraud.transaction_type.isin(['refund', 'chargeback_reversal'])]\n\nprint(\"Recoveries found (total =\", recoveries['amt_usd'].sum(), \"):\")\nfor idx, r in recoveries.iterrows():\n    print(f\"{r['TransactionID']} | {r['transaction_type']} | {r['TransactionAmt']} {r['currency']} | {r['amt_usd']} USD | status: {r['settlement_status']}\")\n\nrec_list = list(recoveries.itertuples())\ntarget = 2435.89\nprint(\"Searching for subsets...\")\nfor r_size in range(1, len(rec_list) + 1):\n    found = False\n    for comb in itertools.combinations(rec_list, r_size):\n        s = sum(x.amt_usd for x in comb)\n        if abs(s - target) < 2.0:\n            print(f\"Subset of size {r_size} sums to {s}: {[x.TransactionID for x in comb]}\")\n            if abs(s - target) < 1.0:\n                found = True\n    if found:\n        print(\"Found subset matching target!\")\n        break\nEOF\npython3 search_recoveries.py\n"]
[227.825174, "o", "cat << 'EOF' > search_recoveries.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import itertools\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fees = pd.read_csv('/data/fee_schedule.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> rates_dict = {}\r\n\u001b[?2004l\r\u001b[?2004h> for idx, row in fx.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h>     rates_dict[(row['currency'], row['date'])] = row['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_rate(currency, date_str):\r\n\u001b[?2004l\r\u001b[?2004h>     if currency == 'USD':\r\n\u001b[?2004l\r\u001b[?2004h>         return 1.0\r\n\u001b[?2004l\r\u001b[?2004h>     if (currency, date_str) in rates_dict:\r\n\u001b[?2004l\r\u001b[?2004h>         return rates_dict[(currency, date_str)]\r\n\u001b[?2004l\r\u001b[?2004h>     currency_rates = fx[fx['currency'] == currency]\r\n\u001b[?2004l\r\u001b[?2004h>     prior_rates = currency_rates[currency_rates['date'] <= date_str]\r\n\u001b[?2004l\r\u001b[?2004h>     if len(prior_rates) == 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return currency_rates.sort_values('date').iloc[0]['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h>     return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['fx_rate'] = df.apply(lambda r: get_rate(r['currency'], r['transaction_date']), axis=1)\r\n\u001b[?2004l\r\u001b[?2004h> df['amt_usd'] = df['TransactionAmt'] * df['fx_rate']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[227.827635, "o", "df_clean = df.drop_duplicates(subset=['TransactionID'], keep='first')\r\n\u001b[?2004l\r\u001b[?2004h> df_clean_no_declined = df_clean[df_clean.settlement_status != 'declined'].copy()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> fraud = df_clean_no_declined[df_clean_no_declined.isFraud == 1]\r\n\u001b[?2004l\r\u001b[?2004h> recoveries = fraud[fraud.transaction_type.isin(['refund', 'chargeback_reversal'])]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Recoveries found (total =\", recoveries['amt_usd'].sum(), \"):\")\r\n\u001b[?2004l\r\u001b[?2004h> for idx, r in recoveries.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"{r['TransactionID']} | {r['transaction_type']} | {r['TransactionAmt']} {r['currency']} | {r['amt_usd']} USD | status: {r['settlement_status']}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> rec_list = list(recoveries.itertuples())\r\n\u001b[?2004l\r\u001b[?2004h> target = 2435.89\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Searching for subsets...\")\r\n\u001b[?2004l\r\u001b[?2004h> for r_size in range(1, len(rec_list) + 1):\r\n\u001b[?2004l\r\u001b[?2004h>     found = False\r\n\u001b[?2004l\r\u001b[?2004h>     for comb in itertools.combinations(rec_list, r_size):\r\n\u001b[?2004l\r\u001b[?2004h>         s = sum(x.amt_usd for x in comb)\r\n\u001b[?2004l\r\u001b[?2004h>         if abs(s - target) < 2.0:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"Subset of size {r_size} sums to {s}: {[x.TransactionID for x in comb]}\")\r\n\u001b[?2004l\r\u001b[?2004h>             if abs(s - target) < 1.0:\r\n\u001b[?2004l\r\u001b[?2004h>                 found = True\r\n\u001b[?2004l\r\u001b[?2004h>     if found:\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"Found subset matching target!\")\r\n\u001b[?2004l\r"]
