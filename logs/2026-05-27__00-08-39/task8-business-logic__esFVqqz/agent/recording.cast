[112.884062, "i", "cat << 'EOF' > check_fraud.py\nimport pandas as pd\ndf = pd.read_csv('/data/transactions.csv')\n\ndf = df[df.settlement_status != 'declined']\n\nfraud_purchases = df[(df.isFraud == 1) & (df.transaction_type == 'purchase')]\nprint(\"Total non-declined fraud purchases:\", len(fraud_purchases))\nprint(fraud_purchases.isnull().sum())\nprint(fraud_purchases.card4.value_counts(dropna=False))\nprint(fraud_purchases.card6.value_counts(dropna=False))\nprint(fraud_purchases.settlement_status.value_counts(dropna=False))\n\nfor col in fraud_purchases.columns:\n    if fraud_purchases[col].nunique() < 10:\n        print(col, \":\", fraud_purchases[col].value_counts(dropna=False))\nEOF\npython3 check_fraud.py\n"]
[112.887239, "o", "cat << 'EOF' > check_fraud.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = df[df.settlement_status != 'declined']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> fraud_purchases = df[(df.isFraud == 1) & (df.transaction_type == 'purchase')]\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Total non-declined fraud purchases:\", len(fraud_purchases))\r\n\u001b[?2004l\r\u001b[?2004h> print(fraud_purchases.isnull().sum())\r\n\u001b[?2004l\r\u001b[?2004h> print(fraud_purchases.card4.value_counts(dropna=False))\r\n\u001b[?2004l\r\u001b[?2004h> print(fraud_purchases.card6.value_counts(dropna=False))\r\n\u001b[?2004l\r\u001b[?2004h> print(fraud_purchases.settlement_status.value_counts(dropna=False))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for col in fraud_purchases.columns:\r\n\u001b[?2004l\r\u001b[?2004h"]
[112.887785, "o", ">     if fraud_purchases[col].nunique() < 10:\r\n\u001b[?2004l\r\u001b[?2004h>         print(col, \":\", fraud_purchases[col].value_counts(dropna=False))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
