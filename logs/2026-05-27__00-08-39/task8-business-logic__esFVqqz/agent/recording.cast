[139.526117, "i", "cat << 'EOF' > find_exact_excluded.py\nimport pandas as pd\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\n\nrates_dict = {}\nfor idx, row in fx.iterrows():\n    rates_dict[(row['currency'], row['date'])] = row['rate_to_usd']\n\ndef get_rate(currency, date_str):\n    if currency == 'USD':\n        return 1.0\n    if (currency, date_str) in rates_dict:\n        return rates_dict[(currency, date_str)]\n    currency_rates = fx[fx['currency'] == currency]\n    prior_rates = currency_rates[currency_rates['date'] <= date_str]\n    if len(prior_rates) == 0:\n        return currency_rates.sort_values('date').iloc[0]['rate_to_usd']\n    return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']\n\nrates = []\nfor idx, row in df.iterrows():\n    rates.append(get_rate(row['currency'], row['transaction_date']))\ndf['fx_rate'] = rates\ndf['amt_usd'] = df['TransactionAmt'] * df['fx_rate']\n\nfee_dict = dict(zip(fees['merchant_category'], fees['fee_rate']))\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee'] = df['amt_usd'] * df['fee_rate']\n\ndf_no_declined = df[df.settlement_status != 'declined'].copy()\n\nsettled_fp = df_no_declined[(df_no_declined.isFraud == 1) & (df_no_declined.transaction_type == 'purchase') & (df_no_declined.settlement_status == 'settled')].copy()\n\nprint(\"Number of settled fraud purchases:\", len(settled_fp))\nprint(\"Total USD of settled fraud purchases:\", settled_fp['amt_usd'].sum())\nprint(\"Total Fees of settled fraud purchases:\", settled_fp['processing_fee'].sum())\n\ntarget_gross = 30212.56\ntarget_fees = 1021.58\n\ndiff_gross = settled_fp['amt_usd'].sum() - target_gross\ndiff_fees = settled_fp['processing_fee'].sum() - target_fees\nprint(f\"Difference in gross: {diff_gross}, Difference in fees: {diff_fees}\")\n\nfor idx, row in settled_fp.iterrows():\n    if abs(row['amt_usd'] - diff_gross) < 5.0 and abs(row['processing_fee'] - diff_fees) < 1.0:\n        print(\"Potential single row:\", row['TransactionID'], row['TransactionAmt'], row['currency'], row['amt_usd'], row['processing_fee'], row['merchant_category'])\n\nrecoveries = df_no_declined[(df_no_declined.isFraud == 1) & (df_no_declined.transaction_type.isin(['refund', 'chargeback_reversal']))]\nprint(\"Number of recoveries:\", len(recoveries))\nprint(\"Total USD of recoveries:\", recoveries['amt_usd'].sum())\ndiff_rec = recoveries['amt_usd'].sum() - 2435.89\nprint(\"Difference in recoveries:\", diff_rec)\n\nprint(recoveries[['TransactionID', 'transaction_type', 'amt_usd', 'settlement_status']])\n\nEOF\npython3 find_exact_excluded.py\n"]
[139.529034, "o", "cat << 'EOF' > find_exact_excluded.py\r\n\u001b[?2004l\r"]
