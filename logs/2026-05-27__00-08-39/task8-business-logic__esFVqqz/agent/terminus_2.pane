[?2004l[?2004h>         return rates_dict[(currency, date_str)]
[?2004l[?2004h>     currency_rates = fx[fx['currency'] == currency]
[?2004l[?2004h>     prior_rates = currency_rates[currency_rates['date'] <= date_str]
[?2004l[?2004h>     if len(prior_rates) == 0:
[?2004l[?2004h>         return currency_rates.sort_values('date').iloc[0]['rate_to_usd']
[?2004l[?2004h>     return prior_rates.sort_values('date', ascending=False).iloc[0]['rate_to_usd']
