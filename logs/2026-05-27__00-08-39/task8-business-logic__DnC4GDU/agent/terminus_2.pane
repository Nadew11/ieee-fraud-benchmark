[?2004hroot@cf0db7aa8136:/workspace# cat << 'EOF' > test_logic.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> fx = pd.read_csv('/data/fx_rates.csv')
[?2004l[?2004h> fee = pd.read_csv('/data/fee_schedule.csv')
[?2004l[?2004h> region = pd.read_csv('/data/region_map.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Convert dates to datetime objects
[?2004l[?2004h> df['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])
[?2004l[?2004h> fx['date_dt'] = pd.to_datetime(fx['date'])
[?2004l[?2004h> 
[?2004l[?2004h> # Sort fx by date
[?2004l[?2004h> fx = fx.sort_values('date_dt')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's write a function to get the USD rate for a given (currency, date_dt)
[?2004l[?2004h> # To do this efficiently, we can pivot fx rates or do an asof merge.
[?2004l[?2004h> # USD rate is always 1.0
[?2004l[?2004h> 
[?2004l[?2004h> # Let's prepare a dataframe of dates and currencies
[?2004l[?2004h> # We have currencies: GBP, ETB, NGN, EUR, USD
[?2004l[?2004h> # For USD, rate is 1.0. Let's append USD rates to fx for all dates
[?2004l[?2004h> unique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()
[?2004l[?2004h> usd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})
[?2004l[?2004h> fx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)
[?2004l[?2004h> fx_all = fx_all.sort_values('date_dt')
[?2004l[?2004h> 
[?2004l[?2004h> # We can use pd.merge_asof to match
[?2004l[?2004h> # For pd.merge_asof, we must sort both dataframes by the key on which we merge
[?2004l[?2004h> df = df.sort_values('transaction_date_dt')
[?2004l[?2004h> 
[?2004l[?2004h> # merge_asof matches on transaction_date_dt <= date_dt? No, we want matching or most recent prior rate.
[?2004l[?2004h> # So df['transaction_date_dt'] >= fx_all['date_dt'].
[?2004l[?2004h> # In pandas merge_asof: 
[?2004l[?2004h> # merge_asof(df, fx_all, on='transaction_date_dt', by='currency', direction='backward')
[?2004l[?2004h> # This matches the transaction_date_dt with the largest date_dt in fx_all that is less than or equal to transaction_date_dt.
[?2004l[?2004h> 
[?2004l[?2004h> df_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's verify if there are any missing rates
[?2004l[?2004h> missing_rates = df_merged[df_merged['rate_to_usd'].isna()]
[?2004l[?2004h> print("Missing rates count:", len(missing_rates))
[?2004l[?2004h> if len(missing_rates) > 0:
[?2004l[?2004h>     print(missing_rates[['transaction_date', 'currency']].drop_duplicates())
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate TransactionAmt in USD
[?2004l[?2004h> df_merged['amt_usd'] = df_merged['TransactionAmt'] * df_merged['rate_to_usd']
[?2004l[?2004h> 
[?2004l[?2004h> print("Total rows:", len(df_merged))
[?2004l[?2004h> EOF
