[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> df_orig = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> fx = pd.read_csv('/data/fx_rates.csv')
[?2004l[?2004h> fee = pd.read_csv('/data/fee_schedule.csv')
[?2004l[?2004h> region_map = pd.read_csv('/data/region_map.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare data
[?2004l[?2004h> df_orig['original_index'] = df_orig.index
[?2004l[?2004h> df = df_orig[(df_orig['transaction_date'] >= '2023-10-01') & (df_orig['transaction_date'] <= '2023-12-31')].copy()
[?2004l[?2004h> df = df[df['settlement_status'] != 'declined']
[?2004l[?2004h> 
[?2004l[?2004h> df['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])
[?2004l[?2004h> fx['date_dt'] = pd.to_datetime(fx['date'])
[?2004l[?2004h> fx = fx.sort_values('date_dt')
[?2004l[?2004h> 
[?2004l[?2004h> unique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()
[?2004l[?2004h> usd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})
[?2004l[?2004h> fx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)
[?2004l[?2004h> fx_all = fx_all.sort_values('date_dt')
[?2004l[?2004h> 
[?2004l[?2004h> df = df.sort_values('transaction_date_dt')
[?2004l[?2004h> df_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')
[?2004l[?2004h> df_merged = df_merged.sort_values('original_index')
[?2004l[?2004h> df_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)
[?2004l[?2004h> df_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')
[?2004l[?2004h> df_merged = df_merged.sort_values('original_index')
[?2004l[?2004h> df_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)
[?2004l[?2004h> 
[?2004l[?2004h> # Map region
[?2004l[?2004h> df_merged = pd.merge(df_merged, region_map, on='country_code', how='left')
[?2004l[?2004h> df_merged['region'] = df_merged['region'].fillna('Other')
[?2004l[?2004h> 
[?2004l[?2004h> # Deduplicate based on TransactionID, keeping first occurrence in original order
[?2004l[?2004h> frauds_all = df_merged[df_merged['isFraud'] == 1]
[?2004l[?2004h> frauds_no_dup = frauds_all.drop_duplicates(subset=['TransactionID'], keep='first').copy()
[?2004l[?2004h> 
[?2004l[?2004h> # Extract month
[?2004l[?2004h> frauds_no_dup['month'] = frauds_no_dup['transaction_date'].str[:7]
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate by month and region
[?2004l[?2004h> # For gross fraud and processing fees, we use transaction_type == 'purchase'
[?2004l[?2004h> # For recoveries, we use transaction_type == 'refund'
[?2004l[?2004h> 
[?2004l[?2004h> purchases = frauds_no_dup[frauds_no_dup['transaction_type'] == 'purchase']
[?2004l[?2004h> refunds = frauds_no_dup[frauds_no_dup['transaction_type'] == 'refund']
[?2004l[?2004h> 
[?2004l[?2004h> print("Purchases count:", len(purchases))
[?2004l[?2004h> print("Refunds count:", len(refunds))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's group purchases by month and region
[?2004l[?2004h> p_gp = purchases.groupby(['month', 'region']).agg(
[?2004l[?2004h>     gross_fraud_usd=('amt_usd', 'sum'),
[?2004l[?2004h>     processing_fees=('processing_fee', 'sum'),
[?2004l[?2004h>     fraud_transaction_count=('TransactionID', 'count')
[?2004l[?2004h> ).reset_index()
[?2004l[?2004h> 
[?2004l[?2004h> # Group refunds by month and region
[?2004l[?2004h> r_gp = refunds.groupby(['month', 'region']).agg(
[?2004l[?2004h>     recoveries=('amt_usd', 'sum')
[?2004l[?2004h> ).reset_index()
[?2004l[?2004h> 
[?2004l[?2004h> # Merge them together on month and region
[?2004l[?2004h> # We want all combinations of expected months and expected regions
[?2004l[?2004h> months = ['2023-10', '2023-11', '2023-12']
[?2004l[?2004h> regions = ['Africa', 'Europe', 'North America', 'Other']
[?2004l[?2004h> 
[?2004l[?2004h> # Create a cartesian product of months and regions
[?2004l[?2004h> grid = pd.MultiIndex.from_product([months, regions], names=['month', 'region']).to_frame().reset_index(drop=True)
[?2004l[?2004h> 
[?2004l[?2004h> summary = pd.merge(grid, p_gp, on=['month', 'region'], how='left')
[?2004l[?2004h> summary = pd.merge(summary, r_gp, on=['month', 'region'], how='left')
