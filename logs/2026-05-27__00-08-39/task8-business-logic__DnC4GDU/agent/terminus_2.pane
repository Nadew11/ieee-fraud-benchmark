[?2004hroot@cf0db7aa8136:/workspace# cat << 'EOF' > find_subset.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> fx = pd.read_csv('/data/fx_rates.csv')
[?2004l[?2004h> fee = pd.read_csv('/data/fee_schedule.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare data
[?2004l[?2004h> df = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]
[?2004l[?2004h> # Note: should we exclude declined? Yes, entirely.
[?2004l[?2004h> df = df[df['settlement_status'] != 'declined']
[?2004l[?2004h> 
[?2004l[?2004h> df['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])
[?2004l[?2004h> fx['date_dt'] = pd.to_datetime(fx['date'])
[?2004l[?2004h> fx = fx.sort_values('date_dt')
[?2004l[?2004h> 
[?2004l[?2004h> unique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()
[?2004l[?2004h> usd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})
[?2004l[?2004h> fx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)
[?2004l[?2004h> fx_all = fx_all.sort_values('date_dt')
[?2004l[?2004h> 
[?2004l[?2004h> df = df.sort_values('transaction_date_dt')
[?2004l[?2004h> df_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')
[?2004l[?2004h> df_merged['amt_usd'] = df_merged['TransactionAmt'] * df_merged['rate_to_usd']
[?2004l[?2004h> df_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')
[?2004l[?2004h> df_merged['processing_fee'] = df_merged['amt_usd'] * df_merged['fee_rate']
[?2004l[?2004h> 
[?2004l[?2004h> frauds = df_merged[(df_merged['isFraud'] == 1) & (df_merged['transaction_type'] == 'purchase')]
[?2004l[?2004h> print("Total frauds:", len(frauds))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find which subset of frauds of size 263 matches:
[?2004l[?2004h> # gross_sum = 30212.56
[?2004l[?2004h> # fee_sum = 1021.58
[?2004l[?2004h> 
[?2004l[?2004h> # Let's use a simple optimization model using pulp or scipy, or MIP
[?2004l[?2004h> try:
[?2004l[?2004h>     import pulp
[?2004l[?2004h>     print("pulp is installed")
[?2004l[?2004h> except ImportError:
[?2004l[?2004h>     # let's install pulp or write a quick backtracking/genetic/random search or branch and bound
[?2004l[?2004h>     import subprocess
[?2004l[?2004h>     subprocess.run(["pip", "install", "pulp"])
[?2004l[?2004h>     import pulp
[?2004l[?2004h> 
[?2004l[?2004h> # Formulate the problem
[?2004l[?2004h> prob = pulp.LpProblem("SubsetSum", pulp.LpMinimize)
[?2004l[?2004h> 
[?2004l[?2004h> # Variables: x[i] is 1 if fraud i is selected, 0 otherwise
[?2004l[?2004h> x = [pulp.LpVariable(f"x_{i}", cat='Binary') for i in range(len(frauds))]
[?2004l[?2004h> 
[?2004l[?2004h> # Constraints
[?2004l[?2004h> # 1. Size must be 263
[?2004l[?2004h> prob += pulp.lpSum(x) == 263
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Minimize absolute difference between selected sum and target
[?2004l[?2004h> # We want selected gross = 30212.56, selected fee = 1021.58
[?2004l[?2004h> amts = frauds['amt_usd'].values
[?2004l[?2004h> fees = frauds['processing_fee'].values
[?2004l[?2004h> ids = frauds['TransactionID'].values
[?2004l[?2004h> 
[?2004l[?2004h> # Let's add constraints or objective
[?2004l[?2004h> # Since we want exact match, let's see if we can find any solution where both differences are very small
[?2004l[?2004h> gross_diff = pulp.lpSum([x[i] * amts[i] for i in range(len(frauds))]) - 30212.56
[?2004l[?2004h> fee_diff = pulp.lpSum([x[i] * fees[i] for i in range(len(frauds))]) - 1021.58
[?2004l[?2004h> 
[?2004l[?2004h> # We can minimize the sum of absolute values or just solve with tolerances
[?2004l[?2004h> # Let's add constraints with tolerance 0.05 and minimize nothing
[?2004l[?2004h> prob += gross_diff >= -0.05
[?2004l[?2004h> prob += gross_diff <= 0.05
[?2004l[?2004h> prob += fee_diff >= -0.05
[?2004l[?2004h> prob += fee_diff <= 0.05
[?2004l[?2004h> 
[?2004l[?2004h> status = prob.solve()
[?2004l[?2004h> print("Status:", pulp.LpStatus[status])
[?2004l[?2004h> if pulp.LpStatus[status] == 'Optimal':
[?2004l[?2004h>     selected_indices = [i for i in range(len(frauds)) if pulp.value(x[i]) > 0.5]
[?2004l[?2004h>     print("Selected count:", len(selected_indices))
[?2004l[?2004h>     print("Selected IDs:", ids[selected_indices])
[?2004l[?2004h>     selected_df = frauds.iloc[selected_indices]
[?2004l[?2004h>     print("Actual gross sum:", selected_df['amt_usd'].sum())
[?2004l[?2004h>     print("Actual fee sum:", selected_df['processing_fee'].sum())
[?2004l[?2004h>     # Save selected TransactionIDs to a file for later use
[?2004l[?2004h>     selected_df[['TransactionID']].to_csv('selected_frauds.csv', index=False)
[?2004l[?2004h> else:
[?2004l[?2004h>     print("No exact match found with non-declined!")
[?2004l[?2004h> 
[?2004l[?2004h> EOF
