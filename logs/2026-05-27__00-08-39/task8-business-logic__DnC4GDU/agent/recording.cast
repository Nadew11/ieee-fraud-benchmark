[191.006122, "i", "cat << 'EOF' > check_exclusions.py\nimport pandas as pd\n\ndf_selected = pd.read_csv('selected_exact_ids.csv')\ndf_all = pd.read_csv('/data/transactions.csv')\n\n# Filter df_all to Q4 non-declined fraud purchases\ndf_q4 = df_all[(df_all['transaction_date'] >= '2023-10-01') & (df_all['transaction_date'] <= '2023-12-31')]\ndf_q4 = df_q4[df_q4['settlement_status'] != 'declined']\nfrauds = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'purchase')]\n\n# Let's find which ones are NOT in selected\nexcluded = frauds[~frauds['TransactionID'].isin(df_selected['TransactionID'])]\nprint(\"Excluded transactions count:\", len(excluded))\nprint(excluded[['TransactionID', 'TransactionAmt', 'settlement_status', 'transaction_date', 'currency', 'country_code']])\n\nEOF\npython3 check_exclusions.py\n"]
[191.009819, "o", "cat << 'EOF' > check_exclusions.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df_selected = pd.read_csv('selected_exact_ids.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df_all = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Filter df_all to Q4 non-declined fraud purchases\r\n\u001b[?2004l\r\u001b[?2004h> df_q4 = df_all[(df_all['transaction_date'] >= '2023-10-01') & (df_all['transaction_date'] <= '2023-12-31')]\r\n\u001b[?2004l\r\u001b[?2004h> df_q4 = df_q4[df_q4['settlement_status'] != 'declined']\r\n\u001b[?2004l\r\u001b[?2004h> frauds = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'purchase')]\r\n\u001b[?2004l\r\u001b[?2004h"]
