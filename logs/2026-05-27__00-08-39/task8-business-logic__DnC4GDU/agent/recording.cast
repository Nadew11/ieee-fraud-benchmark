[80.74781, "o", "\u001b[?2004h> # total_processing_fees: 1021.58\r\n\u001b[?2004l\r\u001b[?2004h> # total_recoveries: 2435.89\r\n\u001b[?2004l\r\u001b[?2004h> # fraud_purchase_count: 263\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.74784, "o", "print(\"Ground Truths:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
