[287.503593, "i", "cat << 'EOF' > test_recoveries.py\nimport pandas as pd\nimport numpy as np\n\ndf_orig = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\n\ndf_orig['original_index'] = df_orig.index\ndf = df_orig[(df_orig['transaction_date'] >= '2023-10-01') & (df_orig['transaction_date'] <= '2023-12-31')].copy()\ndf = df[df['settlement_status'] != 'declined']\n\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\ndf_merged = df_merged.sort_values('original_index')\ndf_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\ndf_merged = df_merged.sort_values('original_index')\ndf_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\n\n# Let's inspect recoveries\n# Prompt: \"recoveries (refunds, chargebacks reversed)\"\n# Let's see if we drop duplicates for all frauds first, and then look at transaction types\nfrauds_all = df_merged[df_merged['isFraud'] == 1]\nfrauds_no_dup = frauds_all.drop_duplicates(subset=['TransactionID'], keep='first')\n\nprint(\"Frauds with duplicate TransactionIDs dropped (keep first):\")\nprint(frauds_no_dup.groupby('transaction_type').size())\nprint(frauds_no_dup.groupby('transaction_type')['amt_usd'].sum())\n\n# Let's see if we just take 'refund' without dropping duplicates or with dropping duplicates\nrefunds = frauds_all[frauds_all['transaction_type'] == 'refund']\nprint(\"\\nRefunds only, no dup dropping:\")\nprint(\"Count:\", len(refunds), \"Sum:\", refunds['amt_usd'].sum())\nprint(\"Refunds only, keep first dup:\")\nrefunds_no_dup = refunds.drop_duplicates(subset=['TransactionID'], keep='first')\nprint(\"Count:\", len(refunds_no_dup), \"Sum:\", refunds_no_dup['amt_usd'].sum())\n\n# Let's print unique types for frauds_no_dup\nprint(\"\\nAll types in frauds_no_dup:\", frauds_no_dup['transaction_type'].unique())\n\nEOF\npython3 test_recoveries.py\n"]
[287.522172, "o", "cat << 'EOF' > test_recoveries.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df_orig = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fee = pd.read_csv('/data/fee_schedule.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df_orig['original_index'] = df_orig.index\r\n\u001b[?2004l\r\u001b[?2004h> df = df_orig[(df_orig['transaction_date'] >= '2023-10-01') & (df_orig['transaction_date'] <= '2023-12-31')].copy()\r\n\u001b[?2004l\r\u001b[?2004h> df = df[df['settlement_status'] != 'declined']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx['date_dt'] = pd.to_datetime(fx['date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx = fx.sort_values('date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> unique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\r\n\u001b[?2004l\r\u001b[?2004h> usd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\r\n\u001b[?2004l\r\u001b[?2004h> fx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\r\n\u001b[?2004l\r\u001b[?2004h> fx_all = fx_all.sort_values('date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('transaction_date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = df_merged.sort_values('original_index')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = df_merged.sort_values('original_index')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's inspect recoveries\r\n\u001b[?2004l\r\u001b[?2004h> # Prompt: \"recoveries (refunds, chargebacks reversed)\"\r\n\u001b[?2004l\r\u001b[?2004h> # Let's see if we drop duplicates for all frauds first, and then look at transaction types\r\n\u001b[?2004l\r\u001b[?2004h> frauds_all = df_merged[df_merged['isFraud'] == 1]\r\n\u001b[?2004l\r\u001b[?2004h> frauds_no_dup = frauds_all.drop_duplicates(subset=['TransactionID'], keep='first')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Frauds with duplicate TransactionIDs dropped (keep first):\")\r\n\u001b[?2004l\r\u001b[?2004h> print(frauds_no_dup.groupby('transaction_type').size())\r\n\u001b[?2004l\r\u001b[?2004h> print(frauds_no_dup.groupby('transaction_type')['amt_usd'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's see if we just take 'refund' without dropping duplicates or with dropping duplicates\r\n\u001b[?2004l\r\u001b[?2004h> refunds = frauds_all[frauds_all['transaction_type'] == 'refund']\r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\nRefunds only, no dup dropping:\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Count:\", len(refunds), \"Sum:\", refunds['amt_usd'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Refunds only, keep first dup:\")\r\n\u001b[?2004l\r\u001b[?2004h> refunds_no_dup = refunds.drop_duplicates(subset=['TransactionID'], keep='first')\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Count:\", len(refunds_no_dup), \"Sum:\", refunds_no_dup['amt_usd'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's print unique types for frauds_no_dup\r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\nAll types in frauds_no_dup:\", frauds_no_dup['transaction_type'].unique())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
