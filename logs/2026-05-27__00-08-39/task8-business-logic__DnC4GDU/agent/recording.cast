[315.48978, "i", "cat << 'EOF' > test_summaries.py\nimport pandas as pd\nimport numpy as np\n\ndf_orig = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\nregion_map = pd.read_csv('/data/region_map.csv')\n\n# Prepare data\ndf_orig['original_index'] = df_orig.index\ndf = df_orig[(df_orig['transaction_date'] >= '2023-10-01') & (df_orig['transaction_date'] <= '2023-12-31')].copy()\ndf = df[df['settlement_status'] != 'declined']\n\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\ndf_merged = df_merged.sort_values('original_index')\ndf_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\ndf_merged = df_merged.sort_values('original_index')\ndf_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\n\n# Map region\ndf_merged = pd.merge(df_merged, region_map, on='country_code', how='left')\ndf_merged['region'] = df_merged['region'].fillna('Other')\n\n# Deduplicate based on TransactionID, keeping first occurrence in original order\nfrauds_all = df_merged[df_merged['isFraud'] == 1]\nfrauds_no_dup = frauds_all.drop_duplicates(subset=['TransactionID'], keep='first').copy()\n\n# Extract month\nfrauds_no_dup['month'] = frauds_no_dup['transaction_date'].str[:7]\n\n# Calculate by month and region\n# For gross fraud and processing fees, we use transaction_type == 'purchase'\n# For recoveries, we use transaction_type == 'refund'\n\npurchases = frauds_no_dup[frauds_no_dup['transaction_type'] == 'purchase']\nrefunds = frauds_no_dup[frauds_no_dup['transaction_type'] == 'refund']\n\nprint(\"Purchases count:\", len(purchases))\nprint(\"Refunds count:\", len(refunds))\n\n# Let's group purchases by month and region\np_gp = purchases.groupby(['month', 'region']).agg(\n    gross_fraud_usd=('amt_usd', 'sum'),\n    processing_fees=('processing_fee', 'sum'),\n    fraud_transaction_count=('TransactionID', 'count')\n).reset_index()\n\n# Group refunds by month and region\nr_gp = refunds.groupby(['month', 'region']).agg(\n    recoveries=('amt_usd', 'sum')\n).reset_index()\n\n# Merge them together on month and region\n# We want all combinations of expected months and expected regions\nmonths = ['2023-10', '2023-11', '2023-12']\nregions = ['Africa', 'Europe', 'North America', 'Other']\n\n# Create a cartesian product of months and regions\ngrid = pd.MultiIndex.from_product([months, regions], names=['month', 'region']).to_frame().reset_index(drop=True)\n\nsummary = pd.merge(grid, p_gp, on=['month', 'region'], how='left')\nsummary = pd.merge(summary, r_gp, on=['month', 'region'], how='left')\n\nsummary = summary.fillna(0)\nsummary['gross_fraud_usd'] = summary['gross_fraud_usd'].round(2)\nsummary['processing_fees'] = summary['processing_fees'].round(2)\nsummary['recoveries'] = summary['recoveries'].round(2)\nsummary['net_fraud_usd'] = (summary['gross_fraud_usd'] - summary['recoveries'] - summary['processing_fees']).round(2)\nsummary['avg_ticket_usd'] = np.where(summary['fraud_transaction_count'] > 0, (summary['gross_fraud_usd'] / summary['fraud_transaction_count']).round(2), 0.0)\n\nprint(\"\\nMonthly Breakdown table:\")\nprint(summary[['month', 'region', 'gross_fraud_usd', 'net_fraud_usd', 'processing_fees', 'fraud_transaction_count', 'avg_ticket_usd']])\n\nprint(\"\\nMonthly Breakdown sums:\")\nprint(\"Gross:\", summary['gross_fraud_usd'].sum())\nprint(\"Fees:\", summary['processing_fees'].sum())\nprint(\"Recoveries:\", summary['recoveries'].sum())\nprint(\"Net:\", summary['net_fraud_usd'].sum())\nprint(\"Frau"]
[315.493485, "i", "d Count:\", summary['fraud_transaction_count'].sum())\n\nEOF\npython3 test_summaries.py\n"]
[315.494257, "o", "cat << 'EOF' > test_summaries.py\r\n"]
