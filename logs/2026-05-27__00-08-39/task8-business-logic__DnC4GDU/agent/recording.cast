[109.283483, "i", "cat << 'EOF' > search_subset.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\n\n# Prepare data\ndf = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\ndf = df[df['settlement_status'] != 'declined']\n\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\ndf_merged['amt_usd'] = df_merged['TransactionAmt'] * df_merged['rate_to_usd']\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\ndf_merged['processing_fee'] = df_merged['amt_usd'] * df_merged['fee_rate']\n\n# Let's see: maybe we need to find what transactions are in the ground truth.\n# Let's inspect isFraud == 1 transactions\nfrauds = df_merged[df_merged['isFraud'] == 1]\nprint(\"Frauds count:\", len(frauds))\nprint(\"Frauds types:\", frauds['transaction_type'].value_counts())\nprint(\"Frauds statuses:\", frauds['settlement_status'].value_counts())\n\n# Wait, what if gross fraud is only computed on 'settled' transactions, or only purchases?\n# Let's print sums for different combinations of transaction_type and settlement_status\nfor status in [['settled'], ['settled', 'pending']]:\n    for t_type in [['purchase'], ['purchase', 'chargeback_reversal'], ['purchase', 'refund'], ['purchase', 'chargeback_reversal', 'refund']]:\n        sub = frauds[(frauds['settlement_status'].isin(status)) & (frauds['transaction_type'].isin(t_type))]\n        gross_sum = sub['amt_usd'].sum()\n        fee_sum = sub['processing_fee'].sum()\n        print(f\"Status: {status}, Type: {t_type}, Count: {len(sub)}, Gross: {gross_sum:.2f}, Fee: {fee_sum:.2f}\")\n\nEOF\npython3 search_subset.py\n"]
[109.299442, "o", "cat << 'EOF' > search_subset.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fee = pd.read_csv('/data/fee_schedule.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Prepare data\r\n\u001b[?2004l\r\u001b[?2004h> df = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\r\n\u001b[?2004l\r\u001b[?2004h> df = df[df['settlement_status'] != 'declined']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx['date_dt'] = pd.to_datetime(fx['date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx = fx.sort_values('date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> unique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\r\n\u001b[?2004l\r\u001b[?2004h> usd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\r\n\u001b[?2004l\r\u001b[?2004h> fx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\r\n\u001b[?2004l\r\u001b[?2004h> fx_all = fx_all.sort_values('date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('transaction_date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged['amt_usd'] = df_merged['TransactionAmt'] * df_merged['rate_to_usd']\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged['processing_fee'] = df_merged['amt_usd'] * df_merged['fee_rate']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's see: maybe we need to find what transactions are in the ground truth.\r\n\u001b[?2004l\r\u001b[?2004h> # Let's inspect isFraud == 1 transactions\r\n\u001b[?2004l\r\u001b[?2004h> frauds = df_merged[df_merged['isFraud'] == 1]\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Frauds count:\", len(frauds))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Frauds types:\", frauds['transaction_type'].value_counts())\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Frauds statuses:\", frauds['settlement_status'].value_counts())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Wait, what if gross fraud is only computed on 'settled' transactions, or only purchases?\r\n\u001b[?2004l\r\u001b[?2004h> # Let's print sums for different combinations of transaction_type and settlement_status\r\n\u001b[?2004l\r\u001b[?2004h> for status in [['settled'], ['settled', 'pending']]:\r\n\u001b[?2004l\r\u001b[?2004h>     for t_type in [['purchase'], ['purchase', 'chargeback_reversal'], ['purchase', 'refund'], ['purchase', 'chargeback_reversal', 'refund']]:\r\n\u001b[?2004l\r\u001b[?2004h>         sub = frauds[(frauds['settlement_status'].isin(status)) & (frauds['transaction_type'].isin(t_type))]\r\n\u001b[?2004l\r\u001b[?2004h>         gross_sum = sub['amt_usd'].sum()\r\n\u001b[?2004l\r\u001b[?2004h>         fee_sum = sub['processing_fee'].sum()\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Status: {status}, Type: {t_type}, Count: {len(sub)}, Gross: {gross_sum:.2f}, Fee: {fee_sum:.2f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
