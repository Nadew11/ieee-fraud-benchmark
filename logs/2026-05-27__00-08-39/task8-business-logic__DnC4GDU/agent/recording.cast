[330.149454, "i", "cat << 'EOF' > test_regional_summary.py\nimport pandas as pd\nimport numpy as np\n\n# We have the monthly breakdown in summary dataframe\n# Let's sum by region\nsummary = pd.read_csv('test_summaries.py') # wait, summary is not a csv yet, let's just write the code to compute it from scratch!\nEOF\n"]
[330.153154, "o", "cat << 'EOF' > test_regional_summary.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # We have the monthly breakdown in summary dataframe\r\n\u001b[?2004l\r\u001b[?2004h> # Let's sum by region\r\n\u001b[?2004l\r\u001b[?2004h> summary = pd.read_csv('test_summaries.py') # wait, summary is not a csv yet, let's just write the code to compute it from scratch!\r\n\u001b[?2004l\r"]
