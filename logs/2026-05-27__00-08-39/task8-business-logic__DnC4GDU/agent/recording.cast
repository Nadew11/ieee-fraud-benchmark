[330.158218, "o", "\u001b[?2004hroot@cf0db7aa8136:/workspace# "]
[330.6583, "i", "cat << 'EOF' > test_regional_summary.py\nimport pandas as pd\nimport numpy as np\n\ndf_orig = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\nregion_map = pd.read_csv('/data/region_map.csv')\n\n# Prepare data\ndf_orig['original_index'] = df_orig.index\ndf = df_orig[(df_orig['transaction_date'] >= '2023-10-01') & (df_orig['transaction_date'] <= '2023-12-31')].copy()\ndf = df[df['settlement_status'] != 'declined']\n\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\ndf_merged = df_merged.sort_values('original_index')\ndf_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\ndf_merged = df_merged.sort_values('original_index')\ndf_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\n\n# Map region\ndf_merged = pd.merge(df_merged, region_map, on='country_code', how='left')\ndf_merged['region'] = df_merged['region'].fillna('Other')\n\n# Deduplicate based on TransactionID, keeping first occurrence in original order\nfrauds_all = df_merged[df_merged['isFraud'] == 1]\nfrauds_no_dup = frauds_all.drop_duplicates(subset=['TransactionID'], keep='first').copy()\n\npurchases = frauds_no_dup[frauds_no_dup['transaction_type'] == 'purchase']\nrefunds = frauds_no_dup[frauds_no_dup['transaction_type'] == 'refund']\n\n# Let's group purchases by region\np_gp = purchases.groupby('region').agg(\n    gross_fraud_usd=('amt_usd', 'sum'),\n    processing_fees=('processing_fee', 'sum'),\n    q4_fraud_count=('TransactionID', 'count')\n).reset_index()\n\n# Group refunds by region\nr_gp = refunds.groupby('region').agg(\n    recoveries=('amt_usd', 'sum')\n).reset_index()\n\nregions_list = ['Africa', 'Europe', 'North America', 'Other']\ngrid = pd.DataFrame({'region': regions_list})\n\nreg_summary = pd.merge(grid, p_gp, on='region', how='left')\nreg_summary = pd.merge(reg_summary, r_gp, on='region', how='left')\nreg_summary = reg_summary.fillna(0)\n\nreg_summary['q4_net_fraud_usd'] = (reg_summary['gross_fraud_usd'] - reg_summary['recoveries'] - reg_summary['processing_fees']).round(2)\nreg_summary['q4_avg_ticket_usd'] = np.where(reg_summary['q4_fraud_count'] > 0, (reg_summary['gross_fraud_usd'] / reg_summary['q4_fraud_count']).round(2), 0.0)\n\ntotal_net_fraud = reg_summary['q4_net_fraud_usd'].sum()\nreg_summary['pct_of_total'] = (reg_summary['q4_net_fraud_usd'] / total_net_fraud).round(4)\n\nprint(\"Regional Summary table:\")\nprint(reg_summary[['region', 'q4_net_fraud_usd', 'q4_fraud_count', 'q4_avg_ticket_usd', 'pct_of_total']])\n\nprint(\"\\nTotal net fraud check:\", total_net_fraud)\nprint(\"Total fraud count check:\", reg_summary['q4_fraud_count'].sum())\n\nEOF\npython3 test_regional_summary.py\n"]
