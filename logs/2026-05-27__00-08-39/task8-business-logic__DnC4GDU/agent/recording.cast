[80.748326, "o", "\u001b[?2004h> # Let's see if we can match fraud_purchase_count first\r\n\u001b[?2004l\r\u001b[?2004h> # Is it possible some transactions are excluded or have different statuses?\r\n\u001b[?2004l\r\u001b[?2004h> # What if we only consider settlement_status == 'settled'?\r\n\u001b[?2004l\r\u001b[?2004h> for status_filter in ['all_except_declined', 'settled_only']:\r\n\u001b[?2004l\r\u001b[?2004h>     if status_filter == 'all_except_declined':\r\n\u001b[?2004l\r\u001b[?2004h>         sub_df = df_merged\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.74837, "o", ">     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.748466, "o", "        sub_df = df_merged[df_merged['settlement_status'] == 'settled']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.748492, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.748593, "o", "    purchase_count = len(sub_df[(sub_df['isFraud'] == 1) & (sub_df['transaction_type'] == 'purchase')])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.748695, "o", "    print(f\"{status_filter}: fraud_purchase_count = {purchase_count}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
