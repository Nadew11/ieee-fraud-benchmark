[168.920719, "i", "cat << 'EOF' > test_rounding.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\n\n# Prepare data\ndf = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\ndf = df[df['settlement_status'] != 'declined']\n\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\n\n# Let's see: if we round amt_usd to 2 decimal places first\ndf_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\n# And round processing_fee to 2 decimal places first\ndf_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\n\n# Now let's see what happens to the sums for settled-only fraud purchases!\npurchases = df_merged[(df_merged['isFraud'] == 1) & (df_merged['transaction_type'] == 'purchase')]\nsettled_purchases = purchases[purchases['settlement_status'] == 'settled']\nprint(\"Total settled purchases with rounding:\", len(settled_purchases))\nprint(\"Settled purchases gross sum with rounding:\", settled_purchases['amt_usd'].sum())\nprint(\"Settled purchases fee sum with rounding:\", settled_purchases['processing_fee'].sum())\n\nEOF\npython3 test_rounding.py\n"]
[168.931177, "o", "cat << 'EOF' > test_rounding.py"]
[168.93296, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fee = pd.read_csv('/data/fee_schedule.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Prepare data\r\n\u001b[?2004l\r\u001b[?2004h> df = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\r\n\u001b[?2004l\r\u001b[?2004h> df = df[df['settlement_status'] != 'declined']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx['date_dt'] = pd.to_datetime(fx['date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx = fx.sort_values('date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[168.93449, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> unique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\r\n\u001b[?2004l\r\u001b[?2004h> usd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[168.938875, "o", "fx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\r\n\u001b[?2004l\r\u001b[?2004h> fx_all = fx_all.sort_values('date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('transaction_date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[168.942444, "o", "# Let's see: if we round amt_usd to 2 decimal places first\r\n\u001b[?2004l\r\u001b[?2004h> df_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\r\n\u001b[?2004l\r\u001b[?2004h> df_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\r\n\u001b[?2004l\r\u001b[?2004h> # And round processing_fee to 2 decimal places first\r\n\u001b[?2004l\r\u001b[?2004h> df_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[168.944259, "o", "# Now let's see what happens to the sums for settled-only fraud purchases!\r\n\u001b[?2004l\r\u001b[?2004h> purchases = df_merged[(df_merged['isFraud'] == 1) & (df_merged['transaction_type'] == 'purchase')]\r\n\u001b[?2004l\r\u001b[?2004h> settled_purchases = purchases[purchases['settlement_status'] == 'settled']\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Total settled purchases with rounding:\", len(settled_purchases))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Settled purchases gross sum with rounding:\", settled_purchases['amt_usd'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Settled purchases fee sum with rounding:\", settled_purchases['processing_fee'].sum())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
