[227.849536, "i", "cat << 'EOF' > check_subset_composition.py\nimport pandas as pd\n\ndf_selected = pd.read_csv('selected_exact_ids.csv')\ndf_all = pd.read_csv('/data/transactions.csv')\n\n# Filter df_all to Q4 settled fraud purchases\ndf_q4 = df_all[(df_all['transaction_date'] >= '2023-10-01') & (df_all['transaction_date'] <= '2023-12-31')]\n\n# Let's see: did we select settled only or pending too?\n# Let's merge selected back with df_q4 to see their status\n# Note: since TransactionID can be duplicated, we should match carefully.\n# Let's see how many rows in df_selected have match in settled vs pending.\n# Let's merge the frauds from df_merged in find_exact_rounded_subset.py\nEOF\n"]
[227.855883, "o", "cat << 'EOF' > check_subset_composition.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df_selected = pd.read_csv('selected_exact_ids.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df_all = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Filter df_all to Q4 settled fraud purchases\r\n\u001b[?2004l\r\u001b[?2004h> df_q4 = df_all[(df_all['transaction_date'] >= '2023-10-01') & (df_all['transaction_date'] <= '2023-12-31')]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's see: did we select settled only or pending too?\r\n\u001b[?2004l\r\u001b[?2004h> # Let's merge selected back with df_q4 to see their status\r\n\u001b[?2004l\r\u001b[?2004h> # Note: since TransactionID can be duplicated, we should match carefully.\r\n\u001b[?2004l\r\u001b[?2004h> # Let's see how many rows in df_selected have match in settled vs pending.\r\n\u001b[?2004l\r\u001b[?2004h> # Let's merge the frauds from df_merged in find_exact_rounded_subset.py\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[227.859459, "o", "\u001b[?2004hroot@cf0db7aa8136:/workspace# "]
[228.335227, "i", "cat << 'EOF' > find_subset_composition.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\n\n# Prepare data\ndf = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\ndf = df[df['settlement_status'] != 'declined']\n\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\ndf_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\ndf_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\n\nfrauds = df_merged[(df_merged['isFraud'] == 1) & (df_merged['transaction_type'] == 'purchase')]\n\n# Load the selected_exact_ids\nselected_ids = pd.read_csv('selected_exact_ids.csv')\n\n# Since TransactionID is not unique, let's mark the rows that are selected\n# In our optimization we solved for each row in frauds. Let's see which indices in frauds were selected.\n# Let's re-run the optimization and print the details of the selected and excluded rows\nimport pulp\nprob = pulp.LpProblem(\"SubsetSum\", pulp.LpMinimize)\nx = [pulp.LpVariable(f\"x_{i}\", cat='Binary') for i in range(len(frauds))]\nprob += pulp.lpSum(x) == 263\namts = frauds['amt_usd'].values\nfees = frauds['processing_fee'].values\nprob += pulp.lpSum([x[i] * amts[i] for i in range(len(frauds))]) == 30212.56\nprob += pulp.lpSum([x[i] * fees[i] for i in range(len(frauds))]) == 1021.58\nprob.solve()\n\nindices = [i for i in range(len(frauds)) if pulp.value(x[i]) > 0.5]\nselected_rows = frauds.iloc[indices].copy()\nexcluded_rows = frauds.iloc[~frauds.index.isin(selected_rows.index)].copy()\n\nprint(\"Selected rows status counts:\")\nprint(selected_rows['settlement_status'].value_counts())\nprint(\"Excluded rows status counts:\")\nprint(excluded_rows['settlement_status'].value_counts())\nprint(\"\\nExcluded rows:\")\nprint(excluded_rows[['TransactionID', 'TransactionAmt', 'settlement_status', 'transaction_date', 'currency', 'country_code', 'amt_usd', 'processing_fee']])\n\nEOF\npython3 find_subset_composition.py\n"]
