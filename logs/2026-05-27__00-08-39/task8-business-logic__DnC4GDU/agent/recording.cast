[254.878637, "i", "cat << 'EOF' > check_duplicates.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\n\n# Prepare data\ndf = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\ndf = df[df['settlement_status'] != 'declined']\n\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\ndf_merged['amt_usd'] = (df_merged['TransactionAmt'] * df_merged['rate_to_usd']).round(2)\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\ndf_merged['processing_fee'] = (df_merged['amt_usd'] * df_merged['fee_rate']).round(2)\n\nfrauds = df_merged[(df_merged['isFraud'] == 1) & (df_merged['transaction_type'] == 'purchase')]\n\nprint(\"Total frauds:\", len(frauds))\nprint(\"Unique TransactionID frauds:\", frauds['TransactionID'].nunique())\n\n# Let's see what happens if we drop duplicates based on TransactionID\nfrauds_no_dup = frauds.drop_duplicates(subset=['TransactionID'])\nprint(\"Frauds with duplicates dropped:\", len(frauds_no_dup))\nprint(\"Gross Sum (no dup):\", frauds_no_dup['amt_usd'].sum())\nprint(\"Fee Sum (no dup):\", frauds_no_dup['processing_fee'].sum())\n\n# Let's check other ways of dropping duplicates. What if we keep first vs last?\nfrauds_dup_last = frauds.drop_duplicates(subset=['TransactionID'], keep='last')\nprint(\"Gross Sum (keep last):\", frauds_dup_last['amt_usd'].sum())\nprint(\"Fee Sum (keep last):\", frauds_dup_last['processing_fee'].sum())\n\nEOF\npython3 check_duplicates.py\n"]
