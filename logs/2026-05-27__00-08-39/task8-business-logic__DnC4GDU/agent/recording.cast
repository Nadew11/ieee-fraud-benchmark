[57.26844, "o", "\u001b[?2004h> unique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\r\n\u001b[?2004l\r\u001b[?2004h> usd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\r\n\u001b[?2004l\r\u001b[?2004h> fx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\r\n\u001b[?2004l\r\u001b[?2004h> fx_all = fx_all.sort_values('date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # We can use pd.merge_asof to match\r\n\u001b[?2004l\r\u001b[?2004h> # For pd.merge_asof, we must sort both dataframes by the key on which we merge\r\n\u001b[?2004l\r\u001b[?2004h> df = df.sort_values('transaction_date_dt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # merge_asof matches on transaction_date_dt <= date_dt? No, we want matching or most recent prior rate.\r\n\u001b[?2004l\r\u001b[?2004h> # So df['transaction_date_dt'] >= fx_all['date_dt'].\r\n\u001b[?2004l\r\u001b[?2004h> # In pandas merge_asof: \r\n\u001b[?2004l\r\u001b[?2004h> # merge_asof(df, fx_all, on='transaction_date_dt', by='currency', direction='backward')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.269507, "o", "# This matches the transaction_date_dt with the largest date_dt in fx_all that is less than or equal to transaction_date_dt.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's verify if there are any missing rates\r\n\u001b[?2004l\r\u001b[?2004h> missing_rates = df_merged[df_merged['rate_to_usd'].isna()]\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Missing rates count:\", len(missing_rates))\r\n\u001b[?2004l\r\u001b[?2004h> if len(missing_rates) > 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.269646, "o", "    print(missing_rates[['transaction_date', 'currency']].drop_duplicates())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
