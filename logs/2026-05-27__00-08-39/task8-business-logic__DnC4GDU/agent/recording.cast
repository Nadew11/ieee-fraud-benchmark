[80.740243, "i", "cat << 'EOF' > test_logic.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfee = pd.read_csv('/data/fee_schedule.csv')\nregion = pd.read_csv('/data/region_map.csv')\n\n# Filter to Q4 2023\ndf = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\n\n# Exclude declined\ndf = df[df['settlement_status'] != 'declined']\n\n# Convert dates\ndf['transaction_date_dt'] = pd.to_datetime(df['transaction_date'])\nfx['date_dt'] = pd.to_datetime(fx['date'])\nfx = fx.sort_values('date_dt')\n\nunique_dates = pd.concat([df['transaction_date_dt'], fx['date_dt']]).unique()\nusd_rates = pd.DataFrame({'date_dt': unique_dates, 'currency': 'USD', 'rate_to_usd': 1.0})\nfx_all = pd.concat([fx[['date_dt', 'currency', 'rate_to_usd']], usd_rates], ignore_index=True)\nfx_all = fx_all.sort_values('date_dt')\n\ndf = df.sort_values('transaction_date_dt')\ndf_merged = pd.merge_asof(df, fx_all, left_on='transaction_date_dt', right_on='date_dt', by='currency', direction='backward')\ndf_merged['amt_usd'] = df_merged['TransactionAmt'] * df_merged['rate_to_usd']\ndf_merged = pd.merge(df_merged, fee, on='merchant_category', how='left')\ndf_merged['processing_fee'] = df_merged['amt_usd'] * df_merged['fee_rate']\n\n# Ground truth numbers:\n# q4_net_fraud_total_usd: 26755.09\n# q4_gross_fraud_total_usd: 30212.56\n# total_processing_fees: 1021.58\n# total_recoveries: 2435.89\n# fraud_purchase_count: 263\n\nprint(\"Ground Truths:\")\nprint(\"net fraud: 26755.09, gross: 30212.56, fees: 1021.58, recoveries: 2435.89, purchase count: 263\\n\")\n\n# Let's see if we can match fraud_purchase_count first\n# Is it possible some transactions are excluded or have different statuses?\n# What if we only consider settlement_status == 'settled'?\nfor status_filter in ['all_except_declined', 'settled_only']:\n    if status_filter == 'all_except_declined':\n        sub_df = df_merged\n    else:\n        sub_df = df_merged[df_merged['settlement_status'] == 'settled']\n        \n    purchase_count = len(sub_df[(sub_df['isFraud'] == 1) & (sub_df['transaction_type'] == 'purchase')])\n    print(f\"{status_filter}: fraud_purchase_count = {purchase_count}\")\n\nEOF\npython3 test_logic.py\n"]
[80.744599, "o", "cat << 'EOF' > test_logic.py\r\n\u001b[?2004l\r\u001b[?2004h> "]
