[?2004l[?2004h> fees = pd.read_csv('/data/fee_schedule.csv')
[?2004l[?2004h> regions = pd.read_csv('/data/region_map.csv')
[?2004l[?2004h> 
[?2004l[?2004h> df['transaction_date'] = pd.to_datetime(df['transaction_date'])
[?2004l[?2004h> fx['date'] = pd.to_datetime(fx['date'])
[?2004l[?2004h> 
[?2004l[?2004h> all_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), 
[?2004l[?2004h>                           end=max(df['transaction_date'].max(), fx['date'].max()))
[?2004l[?2004h> 
[?2004l[?2004h> fx_lookup = {'USD': pd.Series(1.0, index=all_dates)}
[?2004l[?2004h> for cur in fx['currency'].unique():
[?2004l[?2004h>     cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()
[?2004l[?2004h>     fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()
[?2004l[?2004h> 
[?2004l[?2004h> df['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)
[?2004l[?2004h> df['amount_usd'] = df['TransactionAmt'] * df['fx_rate']
[?2004l[?2004h> 
[?2004l[?2004h> fee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()
[?2004l[?2004h> df['fee_rate'] = df['merchant_category'].map(fee_dict)
[?2004l[?2004h> df['processing_fee_usd'] = df['amount_usd'] * df['fee_rate']
[?2004l[?2004h> 
[?2004l[?2004h> # Join regions
[?2004l[?2004h> region_dict = regions.set_index('country_code')['region'].to_dict()
[?2004l[?2004h> df['region'] = df['country_code'].map(region_dict).fillna('Other')
[?2004l[?2004h> 
[?2004l[?2004h> df_q4 = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]
[?2004l[?2004h> settled_p_sf = df_q4[(df_q4['settlement_status'] == 'settled') & (df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'purchase')]
[?2004l[?2004h> 
[?2004l[?2004h> target_gross = 30212.56
[?2004l[?2004h> target_fees = 1021.58
[?2004l[?2004h> 
[?2004l[?2004h> # Let's see if we can find a single row that matches
[?2004l[?2004h> for idx, row in settled_p_sf.iterrows():
[?2004l[?2004h>     rem_gross = settled_p_sf['amount_usd'].sum() - row['amount_usd']
[?2004l[?2004h>     rem_fees = settled_p_sf['processing_fee_usd'].sum() - row['processing_fee_usd']
[?2004l[?2004h>     
[?2004l[?2004h>     if abs(rem_gross - target_gross) < 0.1 and abs(rem_fees - target_fees) < 0.1:
[?2004l[?2004h>         print(f"MATCH FOUND! Row index: {idx}")
[?2004l[?2004h>         print(row)
