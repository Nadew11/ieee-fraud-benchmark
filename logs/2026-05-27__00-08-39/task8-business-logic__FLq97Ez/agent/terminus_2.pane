[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> fx = pd.read_csv('/data/fx_rates.csv')
[?2004l[?2004h> fees = pd.read_csv('/data/fee_schedule.csv')
[?2004l[?2004h> regions = pd.read_csv('/data/region_map.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Dates to datetime
[?2004l[?2004h> df['transaction_date'] = pd.to_datetime(df['transaction_date'])
[?2004l[?2004h> fx['date'] = pd.to_datetime(fx['date'])
[?2004l[?2004h> 
[?2004l[?2004h> # Build the FX rate dictionary
[?2004l[?2004h> # For each currency, we want a complete date index from fx['date'].min() to max transaction_date
[?2004l[?2004h> all_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), 
[?2004l[?2004h>                           end=max(df['transaction_date'].max(), fx['date'].max()))
[?2004l[?2004h> 
[?2004l[?2004h> fx_lookup = {}
[?2004l[?2004h> # For USD, rate is always 1.0
[?2004l[?2004h> fx_lookup['USD'] = pd.Series(1.0, index=all_dates)
[?2004l[?2004h> 
[?2004l[?2004h> for cur in fx['currency'].unique():
[?2004l[?2004h>     cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd']
[?2004l[?2004h>     # Reindex to all_dates, ffill
[?2004l[?2004h>     # Note: we must sort index to ffill properly
[?2004l[?2004h>     cur_rates = cur_rates.sort_index()
[?2004l[?2004h>     # We reindex to all_dates
[?2004l[?2004h>     cur_rates_reindexed = cur_rates.reindex(all_dates)
[?2004l[?2004h>     # ffill
[?2004l[?2004h>     cur_rates_ffilled = cur_rates_reindexed.ffill()
[?2004l[?2004h>     fx_lookup[cur] = cur_rates_ffilled
[?2004l[?2004h> 
[?2004l[?2004h> # Add rate column to transactions
[?2004l[?2004h> def get_rate(row):
[?2004l[?2004h>     curr = row['currency']
[?2004l[?2004h>     dt = row['transaction_date']
[?2004l[?2004h>     return fx_lookup[curr].loc[dt]
[?2004l[?2004h> 
[?2004l[?2004h> df['fx_rate'] = df.apply(get_rate, axis=1)
[?2004l[?2004h> df['amount_usd'] = df['TransactionAmt'] * df['fx_rate']
[?2004l[?2004h> 
[?2004l[?2004h> print("Done fx rate mapping. Checking some NGN rates:")
