[?2004l[?2004h>         
[?2004l[?2004h>         if round_fee:
[?2004l[?2004h>             df_c['processing_fee_usd'] = (df_c['amount_usd'] * df_c['fee_rate']).round(2)
[?2004l[?2004h>         else:
[?2004l[?2004h>             df_c['processing_fee_usd'] = df_c['amount_usd'] * df_c['fee_rate']
