[230.283453, "i", "cat << 'EOF' > create_report.py\nimport pandas as pd\nimport numpy as np\nimport openpyxl\nfrom openpyxl.utils.dataframe import dataframe_to_rows\n\n# 1. Load data\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\nregions = pd.read_csv('/data/region_map.csv')\n\n# 2. Parse dates\ndf['transaction_date'] = pd.to_datetime(df['transaction_date'])\nfx['date'] = pd.to_datetime(fx['date'])\n\n# 3. Build FX rate lookup table\n# Index covers all possible transaction and FX dates to allow forward fill\nall_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \n                          end=max(df['transaction_date'].max(), fx['date'].max()))\n\nfx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\nfor cur in fx['currency'].unique():\n    cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\n# 4. Map exchange rate and convert transaction amount to USD\ndf['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\ndf['amount_usd'] = (df['TransactionAmt'] * df['fx_rate']).round(2)\n\n# 5. Map processing fee schedule\nfee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee_usd'] = (df['amount_usd'] * df['fee_rate']).round(2)\n\n# 6. Map regions\nregion_dict = regions.set_index('country_code')['region'].to_dict()\ndf['region'] = df['country_code'].map(region_dict).fillna('Other')\n\n# 7. Apply deduplication (keep first transaction for duplicate TransactionIDs)\ndf_dedup = df.drop_duplicates(subset=['TransactionID'], keep='first')\n\n# 8. Filter for Q4 2023 and exclude declined\ndf_q4 = df_dedup[(df_dedup['transaction_date'] >= '2023-10-01') & (df_dedup['transaction_date'] <= '2023-12-31')]\ndf_q4 = df_q4[df_q4['settlement_status'] != 'declined']\ndf_q4['month'] = df_q4['transaction_date'].dt.strftime('%Y-%m')\n\n# 9. Extract fraud purchases (gross fraud) and fraud refunds (recoveries)\npurchases = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'purchase')]\nrefunds = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'refund')]\n\n# --- Sheet 1: Monthly Breakdown ---\nmonths = ['2023-10', '2023-11', '2023-12']\nall_regions = ['Africa', 'Europe', 'North America', 'Other']\nimport itertools\ncombos = pd.DataFrame(list(itertools.product(months, all_regions)), columns=['month', 'region'])\n\nmonthly_gross = purchases.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='gross_fraud_usd')\nmonthly_fees = purchases.groupby(['month', 'region'])['processing_fee_usd'].sum().reset_index(name='processing_fees')\nmonthly_count = purchases.groupby(['month', 'region']).size().reset_index(name='fraud_transaction_count')\nmonthly_avg = purchases.groupby(['month', 'region'])['amount_usd'].mean().reset_index(name='avg_ticket_usd')\nmonthly_recoveries = refunds.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='recoveries_usd')\n\nmb_df = combos.merge(monthly_gross, on=['month', 'region'], how='left') \\\n              .merge(monthly_recoveries, on=['month', 'region'], how='left') \\\n              .merge(monthly_fees, on=['month', 'region'], how='left') \\\n              .merge(monthly_count, on=['month', 'region'], how='left') \\\n              .merge(monthly_avg, on=['month', 'region'], how='left')\n\nmb_df = mb_df.fillna(0)\nmb_df['net_fraud_usd'] = (mb_df['gross_fraud_usd'] - mb_df['recoveries_usd'] - mb_df['processing_fees']).round(2)\n\n# Ensure clean datatypes\nmb_df['gross_fraud_usd'] = mb_df['gross_fraud_usd'].astype(float)\nmb_df['net_fraud_usd'] = mb_df['net_fraud_usd'].astype(float)\nmb_df['processing_fees'] = mb_df['processing_fees'].astype(float)\nmb_df['fraud_transaction_count'] = mb_df['fraud_transaction_count'].astype(int)\nmb_df['avg_ticket_usd'] = mb_df['avg_ticket_usd'].round(2).astype(float)\n\n# Final columns for Monthly Breakdown\nmonthly_breakdown_cols = ['month', 'region', 'gross_fraud_usd', 'net_fraud_usd', 'processing_fees', 'fraud_tra"]
[230.286163, "i", "nsaction_count', 'avg_ticket_usd']\nmonthly_breakdown_df = mb_df[monthly_breakdown_cols]\n\n# --- Sheet 2: Regional Summary ---\nreg_gross = purchases.groupby('region')['amount_usd'].sum().reset_index(name='gross_fraud_usd')\nreg_fees = purchases.groupby('region')['processing_fee_usd'].sum().reset_index(name='processing_fees')\nreg_count = purchases.groupby('region').size().reset_index(name='q4_fraud_count')\nreg_avg = purchases.groupby('region')['amount_usd'].mean().reset_index(name='q4_avg_ticket_usd')\nreg_recoveries = refunds.groupby('region')['amount_usd'].sum().reset_index(name='recoveries_usd')\n\nreg_df = pd.DataFrame(all_regions, columns=['region'])\nreg_df = reg_df.merge(reg_gross, on='region', how='left') \\\n               .merge(reg_recoveries, on='region', how='left') \\\n               .merge(reg_fees, on='region', how='left') \\\n               .merge(reg_count, on='region', how='left') \\\n               .merge(reg_avg, on='region', how='left')\n\nreg_df = reg_df.fillna(0)\nreg_df['q4_net_fraud_usd'] = (reg_df['gross_fraud_usd'] - reg_df['recoveries_usd'] - reg_df['processing_fees']).round(2)\ntotal_net_fraud = reg_df['q4_net_fraud_usd'].sum()\nreg_df['pct_of_total'] = (reg_df['q4_net_fraud_usd'] / total_net_fraud).astype(float)\n\nreg_df['q4_net_fraud_usd'] = reg_df['q4_net_fraud_usd'].astype(float)\nreg_df['q4_fraud_count'] = reg_df['q4_fraud_count'].astype(int)\nreg_df['q4_avg_ticket_usd'] = reg_df['q4_avg_ticket_usd'].round(2).astype(float)\n\nregional_summary_cols = ['region', 'q4_net_fraud_usd', 'q4_fraud_count', 'q4_avg_ticket_usd', 'pct_of_total']\nregional_summary_df = reg_df[regional_summary_cols]\n\n# --- Sheet 3: Executive Summary ---\nq4_net_fraud_total_usd = float(purchases['amount_usd'].sum() - refunds['amount_usd'].sum() - purchases['processing_fee_usd'].sum())\nq4_gross_fraud_total_usd = float(purchases['amount_usd'].sum())\ntotal_processing_fees = float(purchases['processing_fee_usd'].sum())\ntotal_recoveries = float(refunds['amount_usd'].sum())\n\n# Create openpyxl Workbook\nwb = openpyxl.Workbook()\n\n# 1. Monthly Breakdown Sheet\nws1 = wb.active\nws1.title = \"Monthly Breakdown\"\nfor r in dataframe_to_rows(monthly_breakdown_df, index=False, header=True):\n    ws1.append(r)\n\n# 2. Regional Summary Sheet\nws2 = wb.create_sheet(title=\"Regional Summary\")\nfor r in dataframe_to_rows(regional_summary_df, index=False, header=True):\n    ws2.append(r)\n\n# 3. Executive Summary Sheet\nws3 = wb.create_sheet(title=\"Executive Summary\")\n# Row 1-4 layout\nws3['A1'] = 'q4_net_fraud_total_usd'\nws3['B1'] = round(q4_net_fraud_total_usd, 2)\nws3['A2'] = 'q4_gross_fraud_total_usd'\nws3['B2'] = round(q4_gross_fraud_total_usd, 2)\nws3['A3'] = 'total_processing_fees'\nws3['B3'] = round(total_processing_fees, 2)\nws3['A4'] = 'total_recoveries'\nws3['B4'] = round(total_recoveries, 2)\n\n# Row 6 header\nws3.append([]) # Row 5 is empty\nws3.append(['assumption_number', 'decision', 'rationale']) # Row 6\n\n# Decisions list\ndecisions = [\n    [1, 'Deduplication', \"Kept only the first occurrence for duplicate TransactionIDs in the raw transactions data to avoid double counting, which matches the target ledger metrics.\"],\n    [2, 'Excluded Declined', \"Excluded transactions with settlement_status = 'declined' from all fraud loss calculations as declined transactions never settled and represent no actual loss.\"],\n    [3, 'Exchange Rates Lookup', \"Where no exact date match exists in fx_rates.csv, used the most recent prior rate (forward fill) to determine USD converted transaction values.\"],\n    [4, 'Recoveries Calculation', \"Calculated recoveries solely based on refund transactions (transaction_type = 'refund') with isFraud = 1 as they represent the actual recovery of fraud amounts.\"],\n    [5, 'Rounding Strategy', \"Transaction USD amounts and processing fees were rounded to 2 decimal places per transaction to align with accounting principles and exactly match company targets.\"]\n]\n\nfor d in decisions:\n    ws3.append(d)\n\n# Save the workbook\nwb.save('/output/fraud_report.xlsx')\nprint(\"Workbook saved successfully!\")\n\nEOF\npython3 create_report.py\n"]
