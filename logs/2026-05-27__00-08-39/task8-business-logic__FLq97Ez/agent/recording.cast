[58.431465, "i", "cat << 'EOF' > match_gt.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\nregions = pd.read_csv('/data/region_map.csv')\n\n# Convert dates\ndf['transaction_date'] = pd.to_datetime(df['transaction_date'])\nfx['date'] = pd.to_datetime(fx['date'])\n\n# Build FX rates lookup\nall_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \n                          end=max(df['transaction_date'].max(), fx['date'].max()))\n\nfx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\nfor cur in fx['currency'].unique():\n    cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\ndf['amount_usd'] = df['TransactionAmt'] * df['fx_rate']\n\n# Join fee schedules\nfee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\n# Wait, let's verify if there are any missing fee rates\nprint(\"Missing fee rates:\", df['fee_rate'].isna().sum())\n\ndf['processing_fee_usd'] = df['amount_usd'] * df['fee_rate']\n\n# Join regions\nregion_dict = regions.set_index('country_code')['region'].to_dict()\ndf['region'] = df['country_code'].map(region_dict).fillna('Other')\n\n# Filter for Q4 2023\ndf_q4 = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\n\n# Filter out declined transactions\ndf_q4_not_declined = df_q4[df_q4['settlement_status'] != 'declined']\n\n# Now, let's look at isFraud == 1 transactions in Q4\nfraud_txs = df_q4_not_declined[df_q4_not_declined['isFraud'] == 1]\n\nprint(\"Total fraud txs (excluding declined) in Q4:\", len(fraud_txs))\nprint(\"By transaction type:\")\nprint(fraud_txs.groupby('transaction_type').size())\nprint(\"Gross fraud usd by type:\")\nprint(fraud_txs.groupby('transaction_type')['amount_usd'].sum())\nprint(\"Processing fee usd by type:\")\nprint(fraud_txs.groupby('transaction_type')['processing_fee_usd'].sum())\n\nEOF\npython3 match_gt.py\n"]
