[120.026969, "i", "cat << 'EOF' > match_exact.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\nregions = pd.read_csv('/data/region_map.csv')\n\n# Convert dates\ndf['transaction_date'] = pd.to_datetime(df['transaction_date'])\nfx['date'] = pd.to_datetime(fx['date'])\n\n# Build FX rates lookup\nall_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \n                          end=max(df['transaction_date'].max(), fx['date'].max()))\n\nfx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\nfor cur in fx['currency'].unique():\n    cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\ndf['amount_usd'] = df['TransactionAmt'] * df['fx_rate']\n\nfee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee_usd'] = df['amount_usd'] * df['fee_rate']\n\nregion_dict = regions.set_index('country_code')['region'].to_dict()\ndf['region'] = df['country_code'].map(region_dict).fillna('Other')\n\n# Let's filter for Q4 and exclude declined\ndf_q4 = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\ndf_q4 = df_q4[df_q4['settlement_status'] != 'declined']\n\n# Let's examine different subsets of df_q4 to see if we can get:\n# q4_gross_fraud_total_usd = 30212.56\n# total_processing_fees = 1021.58\n# total_recoveries = 2435.89\n# fraud_purchase_count = 263\n\n# Let's try only keeping 'settled' transactions first\nprint(\"--- ONLY SETTLED ---\")\nsettled = df_q4[df_q4['settlement_status'] == 'settled']\n# Let's check fraud\nsf = settled[settled['isFraud'] == 1]\np_sf = sf[sf['transaction_type'] == 'purchase']\nprint(\"Count:\", len(p_sf), \"Gross sum:\", p_sf['amount_usd'].sum(), \"Fees:\", p_sf['processing_fee_usd'].sum())\n# Let's print recoveries\nr_sf = sf[sf['transaction_type'] == 'refund']\nprint(\"Recoveries count:\", len(r_sf), \"Recoveries sum:\", r_sf['amount_usd'].sum())\nc_sf = sf[sf['transaction_type'] == 'chargeback_reversal']\nprint(\"Chargebacks count:\", len(c_sf), \"Chargebacks sum:\", c_sf['amount_usd'].sum())\n\n# Wait, what if we keep both settled and pending?\nprint(\"--- SETTLED AND PENDING ---\")\npending_or_settled = df_q4[df_q4['settlement_status'].isin(['settled', 'pending'])]\nsf = pending_or_settled[pending_or_settled['isFraud'] == 1]\np_sf = sf[sf['transaction_type'] == 'purchase']\nprint(\"Count:\", len(p_sf), \"Gross sum:\", p_sf['amount_usd'].sum(), \"Fees:\", p_sf['processing_fee_usd'].sum())\n\nEOF\npython3 match_exact.py\n"]
