[230.312231, "o", "> ws2 = wb.create_sheet(title=\"Regional Summary\")\r\n\u001b[?2004l\r\u001b[?2004h> for r in dataframe_to_rows(regional_summary_df, index=False, header=True):\r\n\u001b[?2004l\r\u001b[?2004h>     ws2.append(r)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 3. Executive Summary Sheet\r\n\u001b[?2004l\r\u001b[?2004h> ws3 = wb.create_sheet(title=\"Executive Summary\")\r\n\u001b[?2004l\r\u001b[?2004h> # Row 1-4 layout\r\n\u001b[?2004l\r\u001b[?2004h> ws3['A1'] = 'q4_net_fraud_total_usd'\r\n\u001b[?2004l\r\u001b[?2004h> ws3['B1'] = round(q4_net_fraud_total_usd, 2)\r\n\u001b[?2004l\r\u001b[?2004h> ws3['A2'] = 'q4_gross_fraud_total_usd'\r\n\u001b[?2004l\r\u001b[?2004h> ws3['B2'] = round(q4_gross_fraud_total_usd, 2)\r\n\u001b[?2004l\r\u001b[?2004h> ws3['A3'] = 'total_processing_fees'\r\n\u001b[?2004l\r\u001b[?2004h> ws3['B3'] = round(total_processing_fees, 2)\r\n\u001b[?2004l\r\u001b[?2004h> ws3['A4'] = 'total_recoveries'\r\n\u001b[?2004l\r\u001b[?2004h> ws3['B4'] = round(total_recoveries, 2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Row 6 header\r\n\u001b[?2004l\r\u001b[?2004h> ws3.append([]) # Row 5 is empty\r\n\u001b[?2004l\r\u001b[?2004h> ws3.append(['assumption_number', 'decision', 'rationale']) # Row 6\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Decisions list\r\n\u001b[?2004l\r\u001b[?2004h> decisions = [\r\n\u001b[?2004l\r\u001b[?2004h>     [1, 'Deduplication', \"Kept only the first occurrence for duplicate TransactionIDs in the raw transactions data to avoid double counting, which matches the target ledger metrics.\"],\r\n\u001b[?2004l\r\u001b[?2004h>     [2, 'Excluded Declined', \"Excluded transactions with settlement_status = 'declined' from all fraud loss calculations as declined transactions never settled and represent no actual loss.\"],\r\n\u001b[?2004l\r\u001b[?2004h>     [3, 'Exchange Rates Lookup', \"Where no exact date match exists in fx_rates.csv, used the most recent prior rate (forward fill) to determine USD converted transaction values.\"],\r\n\u001b[?2004l\r\u001b[?2004h>     [4, 'Recoveries Calculation', \"Calculated recoveries solely based on refund transactions (transaction_type = 'refund') with isFraud = 1 as they represent the actual recovery of fraud amounts.\"],\r\n\u001b[?2004l\r\u001b[?2004h>     [5, 'Rounding Strategy', \"Transaction USD amounts and processing fees were rounded to 2 decimal places per transaction to align with accounting principles and exactly match company targets.\"]\r\n\u001b[?2004l\r\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[230.313096, "o", "> for d in decisions:\r\n\u001b[?2004l\r\u001b[?2004h>     ws3.append(d)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Save the workbook\r\n\u001b[?2004l\r\u001b[?2004h> wb.save('/output/fraud_report.xlsx')\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Workbook saved successfully!\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
