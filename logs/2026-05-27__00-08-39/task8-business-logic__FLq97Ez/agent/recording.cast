[141.80856, "i", "cat << 'EOF' >> find_subset.py\n# Test keeping 'first' or 'last' for duplicates within 'purchases'\nfor keep_strat in ['first', 'last']:\n    purchases_dedup = purchases.drop_duplicates(subset=['TransactionID'], keep=keep_strat)\n    print(f\"Keep: {keep_strat} -> count: {len(purchases_dedup)}, gross: {purchases_dedup['amount_usd'].sum():.4f}, fees: {purchases_dedup['processing_fee_usd'].sum():.4f}\")\n\nEOF\npython3 find_subset.py\n"]
