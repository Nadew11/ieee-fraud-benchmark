[151.265196, "i", "cat << 'EOF' > test_dedup_all.py\nimport pandas as pd\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\n\ndf['transaction_date'] = pd.to_datetime(df['transaction_date'])\nfx['date'] = pd.to_datetime(fx['date'])\n\nall_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \n                          end=max(df['transaction_date'].max(), fx['date'].max()))\n\nfx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\nfor cur in fx['currency'].unique():\n    cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\ndf['amount_usd'] = df['TransactionAmt'] * df['fx_rate']\n\nfee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee_usd'] = df['amount_usd'] * df['fee_rate']\n\n# Let's test different dedup stages\n# 1. Dedup on entire df\nfor keep_strat in ['first', 'last']:\n    d1 = df.drop_duplicates(subset=['TransactionID'], keep=keep_strat)\n    d1_q4 = d1[(d1['transaction_date'] >= '2023-10-01') & (d1['transaction_date'] <= '2023-12-31')]\n    # Filter out declined\n    d1_q4 = d1_q4[d1_q4['settlement_status'] != 'declined']\n    purchases = d1_q4[(d1_q4['isFraud'] == 1) & (d1_q4['transaction_type'] == 'purchase')]\n    print(f\"Dedup entire df ({keep_strat}) -> count: {len(purchases)}, gross: {purchases['amount_usd'].sum():.4f}, fees: {purchases['processing_fee_usd'].sum():.4f}\")\n\n# 2. Dedup on df_q4 (before or after filtering out declined?)\nfor keep_strat in ['first', 'last']:\n    q4_df = df[(df['transaction_date'] >= '2023-10-01') & (df['transaction_date'] <= '2023-12-31')]\n    d2 = q4_df.drop_duplicates(subset=['TransactionID'], keep=keep_strat)\n    d2 = d2[d2['settlement_status'] != 'declined']\n    purchases = d2[(d2['isFraud'] == 1) & (d2['transaction_type'] == 'purchase')]\n    print(f\"Dedup Q4 df ({keep_strat}) -> count: {len(purchases)}, gross: {purchases['amount_usd'].sum():.4f}, fees: {purchases['processing_fee_usd'].sum():.4f}\")\n\nEOF\npython3 test_dedup_all.py\n"]
