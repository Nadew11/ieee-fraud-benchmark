[180.142046, "o", "# gross_fraud_usd: isFraud == 1 and transaction_type == 'purchase'\r\n\u001b[?2004l\r\u001b[?2004h> # processing_fees: processing fee on gross fraud transactions\r\n\u001b[?2004l\r\u001b[?2004h> # recoveries: isFraud == 1 and transaction_type == 'refund'\r\n\u001b[?2004l\r\u001b[?2004h> # net_fraud_usd: gross_fraud_usd - recoveries - processing_fees\r\n\u001b[?2004l\r\u001b[?2004h> # fraud_transaction_count: count of gross fraud transactions (isFraud == 1 and transaction_type == 'purchase')\r\n\u001b[?2004l\r\u001b[?2004h> # avg_ticket_usd: gross_fraud_usd / fraud_transaction_count\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's add 'month' column 'YYYY-MM'\r\n\u001b[?2004l\r\u001b[?2004h> df_q4['month'] = df_q4['transaction_date'].dt.strftime('%Y-%m')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's filter fraud transactions in Q4\r\n\u001b[?2004l\r\u001b[?2004h> # purchases: isFraud == 1 and purchase\r\n\u001b[?2004l\r\u001b[?2004h> # refunds: isFraud == 1 and refund\r\n\u001b[?2004l\r\u001b[?2004h> purchases = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'purchase')]\r\n\u001b[?2004l\r\u001b[?2004h> refunds = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'refund')]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's check by month and region\r\n\u001b[?2004l\r\u001b[?2004h> monthly_gross = purchases.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='gross_fraud_usd')\r\n\u001b[?2004l\r\u001b[?2004h> monthly_fees = purchases.groupby(['month', 'region'])['processing_fee_usd'].sum().reset_index(name='processing_fees')\r\n\u001b[?2004l\r\u001b[?2004h> monthly_count = purchases.groupby(['month', 'region']).size().reset_index(name='fraud_transaction_count')\r\n\u001b[?2004l\r\u001b[?2004h> monthly_avg = purchases.groupby(['month', 'region'])['amount_usd'].mean().reset_index(name='avg_ticket_usd')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Wait, recoveries (refunds) is subtracted to get net fraud. Let's see if there are refunds in each month/region\r\n\u001b[?2004l\r\u001b[?2004h> monthly_recoveries = refunds.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='recoveries_usd')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Merge them all\r\n\u001b[?2004l\r\u001b[?2004h> # Since we want a table with all month/region combinations, let's create a template of all expected months and regions\r\n\u001b[?2004l\r\u001b[?2004h> months = ['2023-10', '2023-11', '2023-12']\r\n\u001b[?2004l\r\u001b[?2004h> all_regions = ['Africa', 'Europe', 'North America', 'Other']\r\n\u001b[?2004l\r\u001b[?2004h> import itertools\r\n\u001b[?2004l\r\u001b[?2004h> combos = pd.DataFrame(list(itertools.product(months, all_regions)), columns=['month', 'region'])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> summary = combos.merge(monthly_gross, on=['month', 'region'], how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                 .merge(monthly_recoveries, on=['month', 'region'], how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                 .merge(monthly_fees, on=['month', 'region'], how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                 .merge(monthly_count, on=['month', 'region'], how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                 .merge(monthly_avg, on=['month', 'region'], how='left')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> summary = summary.fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h> # Wait, is avg_ticket_usd 0 if count is 0? Yes, or we can compute it\r\n\u001b[?2004l\r\u001b[?2004h> summary['net_fraud_usd'] = summary['gross_fraud_usd'] - summary['recoveries_usd'] - summary['processing_fees']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's print out the summary table\r\n\u001b[?2004l\r\u001b[?2004h> print(summary[['month', 'region', 'gross_fraud_usd', 'net_fraud_usd', 'processing_fees', 'fraud_transaction_count', 'avg_ticket_usd']])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[180.146986, "o", "\u001b[?2004hroot@474ebd5bd0a4:/workspace# python3 test_sheets.py\r\n\u001b[?2004l\r"]
