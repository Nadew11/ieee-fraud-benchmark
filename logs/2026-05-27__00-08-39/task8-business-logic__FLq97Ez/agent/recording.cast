[168.189609, "i", "cat << 'EOF' > test_net.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\n\ndf['transaction_date'] = pd.to_datetime(df['transaction_date'])\nfx['date'] = pd.to_datetime(fx['date'])\n\nall_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \n                          end=max(df['transaction_date'].max(), fx['date'].max()))\n\nfx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\nfor cur in fx['currency'].unique():\n    cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\ndf['amount_usd'] = (df['TransactionAmt'] * df['fx_rate']).round(2)\n\nfee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee_usd'] = (df['amount_usd'] * df['fee_rate']).round(2)\n\n# Drop duplicates on TransactionID keeping 'first'\ndf_dedup = df.drop_duplicates(subset=['TransactionID'], keep='first')\n\n# Q4 subset and not declined\ndf_q4 = df_dedup[(df_dedup['transaction_date'] >= '2023-10-01') & (df_dedup['transaction_date'] <= '2023-12-31')]\ndf_q4 = df_q4[df_q4['settlement_status'] != 'declined']\n\n# Let's inspect isFraud == 1\nfraud = df_q4[df_q4['isFraud'] == 1]\n\npurchases = fraud[fraud['transaction_type'] == 'purchase']\nrefunds = fraud[fraud['transaction_type'] == 'refund']\nchargebacks = fraud[fraud['transaction_type'] == 'chargeback_reversal']\n\ngross = purchases['amount_usd'].sum()\nrecoveries = refunds['amount_usd'].sum()\nfees_sum = purchases['processing_fee_usd'].sum()\n\nnet_fraud = gross - recoveries - fees_sum\nprint(f\"Gross: {gross:.2f}\")\nprint(f\"Recoveries (refunds only): {recoveries:.2f}\")\nprint(f\"Recoveries (refunds + chargeback reversals): {(refunds['amount_usd'].sum() + chargebacks['amount_usd'].sum()):.2f}\")\nprint(f\"Processing fees on fraud (purchases only): {fees_sum:.2f}\")\nprint(f\"Net fraud: {net_fraud:.2f}\")\n\nEOF\npython3 test_net.py\n"]
[168.196412, "o", "cat << 'EOF' > test_net.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fees = pd.read_csv('/data/fee_schedule.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['transaction_date'] = pd.to_datetime(df['transaction_date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx['date'] = pd.to_datetime(fx['date'])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> all_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \r\n\u001b[?2004l\r\u001b[?2004h>                           end=max(df['transaction_date'].max(), fx['date'].max()))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> fx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\r\n\u001b[?2004l\r\u001b[?2004h> for cur in fx['currency'].unique():\r\n\u001b[?2004l\r\u001b[?2004h>     cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\r\n\u001b[?2004l\r\u001b[?2004h>     fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\r\n\u001b[?2004l\r\u001b[?2004h> df['amount_usd'] = (df['TransactionAmt'] * df['fx_rate']).round(2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> fee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\r\n\u001b[?2004l\r\u001b[?2004h> df['fee_rate'] = df['merchant_category'].map(fee_dict)\r\n\u001b[?2004l\r"]
