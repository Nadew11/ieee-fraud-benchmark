[43.474652, "i", "cat << 'EOF' >> search_filters.py\n# Check fx rate min/max dates for each currency\nfor cur in ['GBP', 'ETB', 'NGN', 'EUR']:\n    cur_fx = fx[fx['currency'] == cur]\n    print(f\"{cur}: min_date={cur_fx['date'].min()}, max_date={cur_fx['date'].max()}, count={len(cur_fx)}\")\nEOF\npython3 search_filters.py\n"]
[43.477454, "o", "cat << 'EOF' >> search_filters.py\r\n\u001b[?2004l\r\u001b[?2004h> # Check fx rate min/max dates for each currency\r\n\u001b[?2004l\r\u001b[?2004h> for cur in ['GBP', 'ETB', 'NGN', 'EUR']:\r\n\u001b[?2004l\r\u001b[?2004h>     cur_fx = fx[fx['currency'] == cur]\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"{cur}: min_date={cur_fx['date'].min()}, max_date={cur_fx['date'].max()}, count={len(cur_fx)}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
