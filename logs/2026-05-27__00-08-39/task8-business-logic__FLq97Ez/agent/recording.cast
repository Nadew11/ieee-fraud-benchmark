[230.306659, "o", "reg_gross = purchases.groupby('region')['amount_usd'].sum().reset_index(name='gross_fraud_usd')\r\n\u001b[?2004l\r\u001b[?2004h> reg_fees = purchases.groupby('region')['processing_fee_usd'].sum().reset_index(name='processing_fees')\r\n\u001b[?2004l\r\u001b[?2004h> reg_count = purchases.groupby('region').size().reset_index(name='q4_fraud_count')\r\n\u001b[?2004l\r\u001b[?2004h> reg_avg = purchases.groupby('region')['amount_usd'].mean().reset_index(name='q4_avg_ticket_usd')\r\n\u001b[?2004l\r\u001b[?2004h> reg_recoveries = refunds.groupby('region')['amount_usd'].sum().reset_index(name='recoveries_usd')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> reg_df = pd.DataFrame(all_regions, columns=['region'])\r\n\u001b[?2004l\r\u001b[?2004h> reg_df = reg_df.merge(reg_gross, on='region', how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                .merge(reg_recoveries, on='region', how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                .merge(reg_fees, on='region', how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                .merge(reg_count, on='region', how='left') \\\r\n\u001b[?2004l\r\u001b[?2004h>                .merge(reg_avg, on='region', how='left')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> reg_df = reg_df.fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h> reg_df['q4_net_fraud_usd'] = (reg_df['gross_fraud_usd'] - reg_df['recoveries_usd'] - reg_df['processing_fees']).round(2)\r\n\u001b[?2004l\r\u001b[?2004h> total_net_fraud = reg_df['q4_net_fraud_usd'].sum()\r\n\u001b[?2004l\r\u001b[?2004h> reg_df['pct_of_total'] = (reg_df['q4_net_fraud_usd'] / total_net_fraud).astype(float)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> reg_df['q4_net_fraud_usd'] = reg_df['q4_net_fraud_usd'].astype(float)\r\n\u001b[?2004l\r\u001b[?2004h> reg_df['q4_fraud_count'] = reg_df['q4_fraud_count'].astype(int)\r\n\u001b[?2004l\r\u001b[?2004h> reg_df['q4_avg_ticket_usd'] = reg_df['q4_avg_ticket_usd'].round(2).astype(float)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> regional_summary_cols = ['region', 'q4_net_fraud_usd', 'q4_fraud_count', 'q4_avg_ticket_usd', 'pct_of_total']\r\n\u001b[?2004l\r\u001b[?2004h> regional_summary_df = reg_df[regional_summary_cols]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
