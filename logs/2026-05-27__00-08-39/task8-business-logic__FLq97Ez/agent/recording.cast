[254.528415, "o", "for r in dataframe_to_rows(monthly_breakdown_df, index=False, header=True):\r\n\u001b[?2004l\r\u001b[?2004h>     ws1.append(r)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[254.528433, "o", "> "]
[254.528544, "o", "# 2. Regional Summary Sheet\r\n\u001b[?2004l\r"]
[254.528695, "o", "\u001b[?2004h> "]
[254.528866, "o", "ws2 = wb.create_sheet(title=\"Regional Summary\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.528965, "o", "for r in dataframe_to_rows(regional_summary_df, index=False, header=True):"]
[254.528995, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.529144, "o", "    ws2.append(r)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # 3. Executive Summary Sheet\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.529269, "o", "ws3 = wb.create_sheet(title=\"Executive Summary\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.529284, "o", "ws3['A1'] = 'q4_net_fraud_total_usd'"]
[254.529422, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> ws3['B1'] = round(q4_net_fraud_total_usd, 2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.529536, "o", "ws3['A2'] = 'q4_gross_fraud_total_usd'\r\n\u001b[?2004l\r\u001b[?2004h> ws3['B2'] = round(q4_gross_fraud_total_usd, 2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.529595, "o", "ws3['A3'] = 'total_processing_fees'\r\n\u001b[?2004l\r"]
[254.529754, "o", "\u001b[?2004h> "]
[254.529826, "o", "ws3['B3'] = round(total_processing_fees, 2)"]
[254.529992, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.530163, "o", "ws3['A4'] = 'total_recoveries'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.530244, "o", "ws3['B4'] = round(total_recoveries, 2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> ws3.append([])\r\n"]
[254.530317, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[254.530462, "o", "ws3.append(['assumption_number', 'decision', 'rationale'])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.530477, "o", "decisions = [\r\n\u001b[?2004l\r"]
[254.530495, "o", "\u001b[?2004h> "]
[254.530722, "o", "    [1, 'Deduplication', \"Kept only the first occurrence for duplicate TransactionIDs in the raw transactions data to avoid double counting, which matches the target ledger metrics.\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.530976, "o", "    [2, 'Excluded Declined', \"Excluded transactions with settlement_status = 'declined' from all fraud loss calculations as declined transactions never settled and represent no actual loss.\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.531167, "o", "    [3, 'Exchange Rates Lookup', \"Where no exact date match exists in fx_rates.csv, used the most recent prior rate (forward fill) to determine USD converted transaction values.\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.531409, "o", "    [4, 'Recoveries Calculation', \"Calculated recoveries solely based on refund transactions (transaction_type = 'refund') with isFraud = 1 as they represent the actual recovery of fraud amounts.\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.531725, "o", "    [5, 'Rounding Strategy', \"Transaction USD amounts and processing fees were rounded to 2 decimal places per transaction to align with accounting principles and exactly match company targets.\"]\r\n\u001b[?2004l\r"]
[254.531827, "o", "\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.531872, "o", "for d in decisions:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[254.532065, "o", "    ws3.append(d)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> wb.save('/output/fraud_report.xlsx')\r\n\u001b[?2004l\r\u001b[?2004h> "]
