[180.129562, "i", "cat << 'EOF' > test_sheets.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/transactions.csv')\nfx = pd.read_csv('/data/fx_rates.csv')\nfees = pd.read_csv('/data/fee_schedule.csv')\nregions = pd.read_csv('/data/region_map.csv')\n\n# Datetime conversion\ndf['transaction_date'] = pd.to_datetime(df['transaction_date'])\nfx['date'] = pd.to_datetime(fx['date'])\n\n# FX conversion\nall_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \n                          end=max(df['transaction_date'].max(), fx['date'].max()))\n\nfx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\nfor cur in fx['currency'].unique():\n    cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\n    fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\n\ndf['fx_rate'] = df.apply(lambda r: fx_lookup[r['currency']].loc[r['transaction_date']], axis=1)\ndf['amount_usd'] = (df['TransactionAmt'] * df['fx_rate']).round(2)\n\nfee_dict = fees.set_index('merchant_category')['fee_rate'].to_dict()\ndf['fee_rate'] = df['merchant_category'].map(fee_dict)\ndf['processing_fee_usd'] = (df['amount_usd'] * df['fee_rate']).round(2)\n\nregion_dict = regions.set_index('country_code')['region'].to_dict()\ndf['region'] = df['country_code'].map(region_dict).fillna('Other')\n\n# Drop duplicates on TransactionID keeping 'first'\ndf_dedup = df.drop_duplicates(subset=['TransactionID'], keep='first')\n\n# Q4 subset and not declined\ndf_q4 = df_dedup[(df_dedup['transaction_date'] >= '2023-10-01') & (df_dedup['transaction_date'] <= '2023-12-31')]\ndf_q4 = df_q4[df_q4['settlement_status'] != 'declined']\n\n# Let's verify our definitions\n# gross_fraud_usd: isFraud == 1 and transaction_type == 'purchase'\n# processing_fees: processing fee on gross fraud transactions\n# recoveries: isFraud == 1 and transaction_type == 'refund'\n# net_fraud_usd: gross_fraud_usd - recoveries - processing_fees\n# fraud_transaction_count: count of gross fraud transactions (isFraud == 1 and transaction_type == 'purchase')\n# avg_ticket_usd: gross_fraud_usd / fraud_transaction_count\n\n# Let's add 'month' column 'YYYY-MM'\ndf_q4['month'] = df_q4['transaction_date'].dt.strftime('%Y-%m')\n\n# Let's filter fraud transactions in Q4\n# purchases: isFraud == 1 and purchase\n# refunds: isFraud == 1 and refund\npurchases = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'purchase')]\nrefunds = df_q4[(df_q4['isFraud'] == 1) & (df_q4['transaction_type'] == 'refund')]\n\n# Let's check by month and region\nmonthly_gross = purchases.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='gross_fraud_usd')\nmonthly_fees = purchases.groupby(['month', 'region'])['processing_fee_usd'].sum().reset_index(name='processing_fees')\nmonthly_count = purchases.groupby(['month', 'region']).size().reset_index(name='fraud_transaction_count')\nmonthly_avg = purchases.groupby(['month', 'region'])['amount_usd'].mean().reset_index(name='avg_ticket_usd')\n\n# Wait, recoveries (refunds) is subtracted to get net fraud. Let's see if there are refunds in each month/region\nmonthly_recoveries = refunds.groupby(['month', 'region'])['amount_usd'].sum().reset_index(name='recoveries_usd')\n\n# Merge them all\n# Since we want a table with all month/region combinations, let's create a template of all expected months and regions\nmonths = ['2023-10', '2023-11', '2023-12']\nall_regions = ['Africa', 'Europe', 'North America', 'Other']\nimport itertools\ncombos = pd.DataFrame(list(itertools.product(months, all_regions)), columns=['month', 'region'])\n\nsummary = combos.merge(monthly_gross, on=['month', 'region'], how='left') \\\n                .merge(monthly_recoveries, on=['month', 'region'], how='left') \\\n                .merge(monthly_fees, on=['month', 'region'], how='left') \\\n                .merge(monthly_count, on=['month', 'region'], how='left') \\\n                .merge(monthly_avg, on=['month', 'region'], how='left')\n\nsummary = summary.fillna(0)\n# Wait, is avg_ticket_usd 0 if count is 0? Yes, or we can compute it\nsummary['net_fraud_usd'] = summary['gross_fraud_usd'] - summary['recoveries_usd'] - summary['processi"]
[180.13021, "i", "ng_fees']\n\n# Let's print out the summary table\nprint(summary[['month', 'region', 'gross_fraud_usd', 'net_fraud_usd', 'processing_fees', 'fraud_transaction_count', 'avg_ticket_usd']])\n\nEOF\npython3 test_sheets.py\n"]
[180.133031, "o", "cat << 'EOF' > test_sheets.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/transactions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fx = pd.read_csv('/data/fx_rates.csv')\r\n\u001b[?2004l\r\u001b[?2004h> fees = pd.read_csv('/data/fee_schedule.csv')\r\n\u001b[?2004l\r\u001b[?2004h> regions = pd.read_csv('/data/region_map.csv')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Datetime conversion\r\n\u001b[?2004l\r\u001b[?2004h> df['transaction_date'] = pd.to_datetime(df['transaction_date'])\r\n\u001b[?2004l\r\u001b[?2004h> fx['date'] = pd.to_datetime(fx['date'])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # FX conversion\r\n\u001b[?2004l\r\u001b[?2004h> all_dates = pd.date_range(start=min(df['transaction_date'].min(), fx['date'].min()), \r\n\u001b[?2004l\r\u001b[?2004h>                           end=max(df['transaction_date'].max(), fx['date'].max()))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> fx_lookup = {'USD': pd.Series(1.0, index=all_dates)}\r\n\u001b[?2004l\r\u001b[?2004h> for cur in fx['currency'].unique():\r\n\u001b[?2004l\r\u001b[?2004h>     cur_rates = fx[fx['currency'] == cur].set_index('date')['rate_to_usd'].sort_index()\r\n\u001b[?2004l\r\u001b[?2004h>     fx_lookup[cur] = cur_rates.reindex(all_dates).ffill()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
