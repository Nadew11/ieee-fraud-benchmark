[15.789154, "i", "cat << 'EOF' > inspect_data.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score\n\ndf = pd.read_csv('/data/predictions.csv')\nprint(\"Columns:\", df.columns.tolist())\nprint(\"Shape:\", df.shape)\nprint(\"True class distribution:\")\nprint(df['y_true'].value_counts())\n\n# Confusion matrix at 0.5\ndf['y_pred'] = (df['y_pred_prob'] >= 0.5).astype(int)\ntn, fp, fn, tp = confusion_matrix(df['y_true'], df['y_pred']).ravel()\nprint(f\"TN: {tn}, FP: {fp}, FN: {fn}, TP: {tp}\")\nprint(f\"Accuracy: {accuracy_score(df['y_true'], df['y_pred']):.4f}\")\nprint(f\"AUC-ROC: {roc_auc_score(df['y_true'], df['y_pred_prob']):.4f}\")\n\n# Check dates\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\nprint(\"Min date:\", df['scored_at'].min())\nprint(\"Max date:\", df['scored_at'].max())\n\n# Look for dates after April 30, 2026\nout_of_period = df[df['scored_at'] > '2026-04-30 23:59:59']\nprint(\"Records outside January 15 - April 30, 2026:\", len(out_of_period))\nprint(out_of_period.head(10))\nEOF\npython3 inspect_data.py\n"]
[15.795285, "o", "cat << 'EOF' > inspect_data.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/predictions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Columns:\", df.columns.tolist())\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Shape:\", df.shape)\r\n\u001b[?2004l\r\u001b[?2004h> print(\"True class distribution:\")\r\n\u001b[?2004l\r\u001b[?2004h> print(df['y_true'].value_counts())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Confusion matrix at 0.5\r\n\u001b[?2004l\r\u001b[?2004h> df['y_pred'] = (df['y_pred_prob'] >= 0.5).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h> tn, fp, fn, tp = confusion_matrix(df['y_true'], df['y_pred']).ravel()\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"TN: {tn}, FP: {fp}, FN: {fn}, TP: {tp}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Accuracy: {accuracy_score(df['y_true'], df['y_pred']):.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"AUC-ROC: {roc_auc_score(df['y_true'], df['y_pred_prob']):.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Check dates\r\n\u001b[?2004l\r\u001b[?2004h> df['scored_at'] = pd.to_datetime(df['scored_at'])\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Min date:\", df['scored_at'].min())\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Max date:\", df['scored_at'].max())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Look for dates after April 30, 2026\r\n\u001b[?2004l\r\u001b[?2004h> out_of_period = df[df['scored_at'] > '2026-04-30 23:59:59']\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Records outside January 15 - April 30, 2026:\", len(out_of_period))\r\n\u001b[?2004l\r\u001b[?2004h> print(out_of_period.head(10))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
