[122.162292, "i", "cat << 'EOF' > compute_metrics.py\nimport pandas as pd\nimport json\nfrom sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score\n\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\n\n# Clean data\ndf_clean = df[(df['batch_id'] != 99) & (df['scored_at'] <= '2026-04-30 23:59:59')].copy()\n\n# Compute metrics at threshold 0.5\ny_true = df_clean['y_true']\ny_pred_prob = df_clean['y_pred_prob']\ny_pred_05 = (y_pred_prob >= 0.5).astype(int)\n\ntn, fp, fn, tp = confusion_matrix(y_true, y_pred_05).ravel()\naccuracy_05 = accuracy_score(y_true, y_pred_05)\nauc_roc = roc_auc_score(y_true, y_pred_prob)\nprecision_05 = tp / (tp + fp)\nrecall_05 = tp / (tp + fn)\nf1_05 = 2 * precision_05 * recall_05 / (precision_05 + recall_05)\n\n# Let's also compute metrics at recommended threshold 0.63\ny_pred_063 = (y_pred_prob >= 0.63).astype(int)\ntn_63, fp_63, fn_63, tp_63 = confusion_matrix(y_true, y_pred_063).ravel()\naccuracy_063 = accuracy_score(y_true, y_pred_063)\nprecision_063 = tp_63 / (tp_63 + fp_63)\nrecall_063 = tp_63 / (tp_63 + fn_63)\nf1_063 = 2 * precision_063 * recall_063 / (precision_063 + recall_063)\n\nmetrics = {\n    \"auc_roc\": float(round(auc_roc, 4)),\n    \"accuracy_at_0.5\": float(round(accuracy_05, 4)),\n    \"precision_at_0.5\": float(round(precision_05, 4)),\n    \"recall_at_0.5\": float(round(recall_05, 4)),\n    \"f1_score_at_0.5\": float(round(f1_05, 4)),\n    \"accuracy_at_0.63\": float(round(accuracy_063, 4)),\n    \"precision_at_0.63\": float(round(precision_063, 4)),\n    \"recall_at_0.63\": float(round(recall_063, 4)),\n    \"f1_score_at_0.63\": float(round(f1_063, 4))\n}\n\nwith open('/output/metrics.json', 'w') as f:\n    json.dump(metrics, f, indent=4)\n\nprint(\"Saved metrics:\")\nprint(json.dumps(metrics, indent=4))\nEOF\npython3 compute_metrics.py\n"]
