[97.924089, "o", "from sklearn.metrics import confusion_matrix, roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/predictions.csv')\r\n\u001b[?2004l\r"]
