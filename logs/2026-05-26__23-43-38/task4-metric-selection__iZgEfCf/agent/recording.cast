[78.22, "i", "cat << 'EOF' > inspect_b99.py\nimport pandas as pd\nfrom sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score\n\ndf = pd.read_csv('/data/predictions.csv')\ndf_b99 = df[df['batch_id'] == 99]\n\nprint(\"Batch 99 performance:\")\nprint(\"Count:\", len(df_b99))\nprint(\"Class balance:\", df_b99['y_true'].value_counts().to_dict())\ny_pred_b99 = (df_b99['y_pred_prob'] >= 0.5).astype(int)\ntn, fp, fn, tp = confusion_matrix(df_b99['y_true'], y_pred_b99).ravel()\nprint(f\"TN: {tn}, FP: {fp}, FN: {fn}, TP: {tp}\")\nprint(f\"Accuracy: {accuracy_score(df_b99['y_true'], y_pred_b99):.4f}\")\nprint(f\"AUC-ROC: {roc_auc_score(df_b99['y_true'], df_b99['y_pred_prob']):.4f}\")\nEOF\npython3 inspect_b99.py\n"]
[78.221696, "o", "cat << 'EOF' > inspect_b99.py\r\n\u001b[?2004l\r"]
[78.226301, "o", "\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/predictions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df_b99 = df[df['batch_id'] == 99]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Batch 99 performance:\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Count:\", len(df_b99))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Class balance:\", df_b99['y_true'].value_counts().to_dict())\r\n\u001b[?2004l\r\u001b[?2004h> y_pred_b99 = (df_b99['y_pred_prob'] >= 0.5).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h> tn, fp, fn, tp = confusion_matrix(df_b99['y_true'], y_pred_b99).ravel()\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"TN: {tn}, FP: {fp}, FN: {fn}, TP: {tp}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Accuracy: {accuracy_score(df_b99['y_true'], y_pred_b99):.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"AUC-ROC: {roc_auc_score(df_b99['y_true'], df_b99['y_pred_prob']):.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
