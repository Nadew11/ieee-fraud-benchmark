[54.424435, "i", "cat << 'EOF' > evaluate_filters.py\nimport pandas as pd\nfrom sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score\n\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\n\ndef show_metrics(data, desc):\n    print(f\"=== {desc} ===\")\n    print(f\"Count: {len(data)}\")\n    print(f\"Class balance: {data['y_true'].value_counts().to_dict()}\")\n    y_pred = (data['y_pred_prob'] >= 0.5).astype(int)\n    tn, fp, fn, tp = confusion_matrix(data['y_true'], y_pred).ravel()\n    acc = accuracy_score(data['y_true'], y_pred)\n    auc = roc_auc_score(data['y_true'], data['y_pred_prob'])\n    print(f\"TN: {tn}, FP: {fp}, FN: {fn}, TP: {tp}\")\n    print(f\"Accuracy: {acc:.4f}, AUC: {auc:.4f}\")\n    # Precision, Recall, F1\n    precision = tp / (tp + fp) if (tp + fp) > 0 else 0\n    recall = tp / (tp + fn) if (tp + fn) > 0 else 0\n    f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0\n    print(f\"Precision: {precision:.4f}, Recall: {recall:.4f}, F1: {f1:.4f}\")\n\nshow_metrics(df, \"Raw Data (As-Is)\")\n\n# Filter 1: Exclude batch 99\ndf_no_b99 = df[df['batch_id'] != 99]\nshow_metrics(df_no_b99, \"Exclude Batch 99\")\n\n# Filter 2: Date <= April 30\ndf_date = df[df['scored_at'] <= '2026-04-30 23:59:59']\nshow_metrics(df_date, \"Date <= April 30\")\n\n# Filter 3: Exclude Batch 99 AND Date <= April 30\ndf_both = df[(df['batch_id'] != 99) & (df['scored_at'] <= '2026-04-30 23:59:59')]\nshow_metrics(df_both, \"Exclude Batch 99 AND Date <= April 30\")\n\nEOF\npython3 evaluate_filters.py\n"]
[54.430215, "o", "cat << 'EOF' > evaluate_filters.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('/data/predictions.csv')\r\n\u001b[?2004l\r\u001b[?2004h> df['scored_at'] = pd.to_datetime(df['scored_at'])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def show_metrics(data, desc):\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"=== {desc} ===\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Count: {len(data)}\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Class balance: {data['y_true'].value_counts().to_dict()}\")\r\n\u001b[?2004l\r\u001b[?2004h>     y_pred = (data['y_pred_prob'] >= 0.5).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h>     tn, fp, fn, tp = confusion_matrix(data['y_true'], y_pred).ravel()\r\n\u001b[?2004l\r\u001b[?2004h>     acc = accuracy_score(data['y_true'], y_pred)\r\n\u001b[?2004l\r\u001b[?2004h>     auc = roc_auc_score(data['y_true'], data['y_pred_prob'])\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"TN: {tn}, FP: {fp}, FN: {fn}, TP: {tp}\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Accuracy: {acc:.4f}, AUC: {auc:.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h>     # Precision, Recall, F1\r\n\u001b[?2004l\r\u001b[?2004h>     precision = tp / (tp + fp) if (tp + fp) > 0 else 0\r\n\u001b[?2004l\r\u001b[?2004h>     recall = tp / (tp + fn) if (tp + fn) > 0 else 0\r\n\u001b[?2004l\r\u001b[?2004h>     f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Precision: {precision:.4f}, Recall: {recall:.4f}, F1: {f1:.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> show_metrics(df, \"Raw Data (As-Is)\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Filter 1: Exclude batch 99\r\n\u001b[?2004l\r\u001b[?2004h> df_no_b99 = df[df['batch_id'] != 99]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[54.431043, "o", "show_metrics(df_no_b99, \"Exclude Batch 99\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Filter 2: Date <= April 30\r\n\u001b[?2004l\r\u001b[?2004h> df_date = df[df['scored_at'] <= '2026-04-30 23:59:59']\r\n\u001b[?2004l\r\u001b[?2004h> show_metrics(df_date, \"Date <= April 30\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Filter 3: Exclude Batch 99 AND Date <= April 30\r\n\u001b[?2004l\r\u001b[?2004h> df_both = df[(df['batch_id'] != 99) & (df['scored_at'] <= '2026-04-30 23:59:59')]\r\n\u001b[?2004l\r\u001b[?2004h> show_metrics(df_both, \"Exclude Batch 99 AND Date <= April 30\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
