[28.91289, "i", "cat << 'EOF' > inspect_anomalies.py\nimport pandas as pd\ndf = pd.read_csv('/data/predictions.csv')\n\n# Look at TransactionID patterns\ndf['id_prefix'] = df['TransactionID'].astype(str).str[:4]\nprint(\"TransactionID prefixes:\")\nprint(df['id_prefix'].value_counts())\n\n# Let's filter by prefixes and see scored_at and batch_id\nfor prefix in df['id_prefix'].unique():\n    sub = df[df['id_prefix'] == prefix]\n    print(f\"\\nPrefix: {prefix}\")\n    print(f\"Count: {len(sub)}\")\n    print(f\"Batch IDs: {sub['batch_id'].unique()}\")\n    print(f\"Min Date: {sub['scored_at'].min()}\")\n    print(f\"Max Date: {sub['scored_at'].max()}\")\n    print(f\"True Class Balance: {sub['y_true'].value_counts().to_dict()}\")\n\n# Let's see the batch_id distribution\nprint(\"\\nBatch ID distribution:\")\nprint(df['batch_id'].value_counts().sort_index())\nEOF\npython3 inspect_anomalies.py\n"]
