[36.280515, "i", "cat << 'EOF' > inspect_dates_batches.py\nimport pandas as pd\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\n\nprint(\"Total records:\", len(df))\nprint(\"Records <= 2026-04-30:\", len(df[df['scored_at'] <= '2026-04-30 23:59:59']))\nprint(\"Records > 2026-04-30:\", len(df[df['scored_at'] > '2026-04-30 23:59:59']))\n\n# Let's see count by batch_id and whether they are > April 30\ndf['after_apr30'] = df['scored_at'] > '2026-04-30 23:59:59'\nprint(\"\\nBatch and After April 30 breakdown:\")\nprint(df.groupby(['batch_id', 'after_apr30']).size().unstack(fill_value=0))\n\n# Let's see count by prefix and whether they are > April 30\ndf['prefix'] = df['TransactionID'].astype(str).str[:4]\nprint(\"\\nPrefix and After April 30 breakdown:\")\nprint(df.groupby(['prefix', 'after_apr30']).size().unstack(fill_value=0))\nEOF\npython3 inspect_dates_batches.py\n"]
