[97.918371, "i", "cat << 'EOF' > optimize_threshold.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import confusion_matrix, roc_auc_score\n\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\n\n# Clean dataset\ndf_clean = df[(df['batch_id'] != 99) & (df['scored_at'] <= '2026-04-30 23:59:59')].copy()\n\nprint(\"Clean dataset count:\", len(df_clean))\nprint(\"Clean dataset fraud count:\", (df_clean['y_true'] == 1).sum())\n\n# Cost parameters\nloss_per_fn = 4200\ncost_per_alert = 35\nquarterly_volume = 2800000\nholdout_volume = len(df_clean)\nscale_factor = quarterly_volume / holdout_volume\ndays_in_quarter = 90\ncapacity = 1500\n\nresults = []\nthresholds = np.linspace(0.0, 1.0, 101)\n\nfor t in thresholds:\n    df_clean['y_pred'] = (df_clean['y_pred_prob'] >= t).astype(int)\n    tn, fp, fn, tp = confusion_matrix(df_clean['y_true'], df_clean['y_pred']).ravel()\n    \n    # Holdout costs\n    holdout_fn_cost = fn * loss_per_fn\n    holdout_alert_cost = (tp + fp) * cost_per_alert\n    holdout_total_cost = holdout_fn_cost + holdout_alert_cost\n    \n    # Projected quarterly costs\n    proj_fn_cost = holdout_fn_cost * scale_factor\n    proj_alert_cost = holdout_alert_cost * scale_factor\n    proj_total_cost = holdout_total_cost * scale_factor\n    \n    # Alert volume\n    proj_quarterly_alerts = (tp + fp) * scale_factor\n    proj_daily_alerts = proj_quarterly_alerts / days_in_quarter\n    \n    # Metrics\n    recall = tp / (tp + fn) if (tp + fn) > 0 else 0\n    precision = tp / (tp + fp) if (tp + fp) > 0 else 0\n    f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0\n    acc = (tp + tn) / holdout_volume\n    \n    results.append({\n        'threshold': t,\n        'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,\n        'recall': recall, 'precision': precision, 'f1': f1, 'accuracy': acc,\n        'proj_total_cost': proj_total_cost,\n        'proj_fn_cost': proj_fn_cost,\n        'proj_alert_cost': proj_alert_cost,\n        'proj_quarterly_alerts': proj_quarterly_alerts,\n        'proj_daily_alerts': proj_daily_alerts\n    })\n\nres_df = pd.DataFrame(results)\n# Sort by projected total cost\nprint(\"Top 10 thresholds by lowest cost:\")\nprint(res_df.sort_values(by='proj_total_cost').head(10)[['threshold', 'tp', 'fp', 'fn', 'tn', 'precision', 'recall', 'f1', 'proj_daily_alerts', 'proj_total_cost']])\n\n# Let's see results where daily alerts <= capacity\nprint(\"\\nTop 10 thresholds by lowest cost within capacity (<= 1500 daily alerts):\")\nwithin_cap = res_df[res_df['proj_daily_alerts'] <= capacity]\nprint(within_cap.sort_values(by='proj_total_cost').head(10)[['threshold', 'tp', 'fp', 'fn', 'tn', 'precision', 'recall', 'f1', 'proj_daily_alerts', 'proj_total_cost']])\nEOF\npython3 optimize_threshold.py\n"]
[97.923324, "o", "cat << 'EOF' > optimize_threshold.py\r\n\u001b[?2004l\r"]
[97.923614, "o", "\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r"]
