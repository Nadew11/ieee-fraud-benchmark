[97.924423, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> # Clean dataset\r\n\u001b[?2004l\r\u001b[?2004h> df_clean = df[(df['batch_id'] != 99) & (df['scored_at'] <= '2026-04-30 23:59:59')].copy()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[97.929329, "o", "print(\"Clean dataset count:\", len(df_clean))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Clean dataset fraud count:\", (df_clean['y_true'] == 1).sum())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Cost parameters\r\n\u001b[?2004l\r\u001b[?2004h> loss_per_fn = 4200\r\n\u001b[?2004l\r\u001b[?2004h> cost_per_alert = 35\r\n\u001b[?2004l\r\u001b[?2004h> quarterly_volume = 2800000\r\n\u001b[?2004l\r\u001b[?2004h> holdout_volume = len(df_clean)\r\n\u001b[?2004l\r\u001b[?2004h> scale_factor = quarterly_volume / holdout_volume\r\n\u001b[?2004l\r\u001b[?2004h> days_in_quarter = 90\r\n\u001b[?2004l\r\u001b[?2004h> capacity = 1500\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> results = []\r\n\u001b[?2004l\r\u001b[?2004h> thresholds = np.linspace(0.0, 1.0, 101)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for t in thresholds:\r\n\u001b[?2004l\r\u001b[?2004h>     df_clean['y_pred'] = (df_clean['y_pred_prob'] >= t).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h>     tn, fp, fn, tp = confusion_matrix(df_clean['y_true'], df_clean['y_pred']).ravel()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Holdout costs\r\n\u001b[?2004l\r\u001b[?2004h>     holdout_fn_cost = fn * loss_per_fn\r\n\u001b[?2004l\r\u001b[?2004h>     holdout_alert_cost = (tp + fp) * cost_per_alert\r\n\u001b[?2004l\r\u001b[?2004h>     holdout_total_cost = holdout_fn_cost + holdout_alert_cost\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Projected quarterly costs\r\n\u001b[?2004l\r\u001b[?2004h>     proj_fn_cost = holdout_fn_cost * scale_factor\r\n\u001b[?2004l\r\u001b[?2004h>     proj_alert_cost = holdout_alert_cost * scale_factor\r\n\u001b[?2004l\r\u001b[?2004h>     proj_total_cost = holdout_total_cost * scale_factor\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Alert volume\r\n\u001b[?2004l\r\u001b[?2004h>     proj_quarterly_alerts = (tp + fp) * scale_factor\r\n\u001b[?2004l\r\u001b[?2004h>     proj_daily_alerts = proj_quarterly_alerts / days_in_quarter\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Metrics\r\n\u001b[?2004l\r\u001b[?2004h>     recall = tp / (tp + fn) if (tp + fn) > 0 else 0\r\n\u001b[?2004l\r\u001b[?2004h>     precision = tp / (tp + fp) if (tp + fp) > 0 else 0\r\n\u001b[?2004l\r\u001b[?2004h>     f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0\r\n\u001b[?2004l\r\u001b[?2004h>     acc = (tp + tn) / holdout_volume\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     results.append({\r\n\u001b[?2004l\r\u001b[?2004h>         'threshold': t,\r\n\u001b[?2004l\r\u001b[?2004h>         'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,\r\n\u001b[?2004l\r\u001b[?2004h>         'recall': recall, 'precision': precision, 'f1': f1, 'accuracy': acc,\r\n\u001b[?2004l\r\u001b[?2004h>         'proj_total_cost': proj_total_cost,\r\n\u001b[?2004l\r\u001b[?2004h>         'proj_fn_cost': proj_fn_cost,\r\n\u001b[?2004l\r\u001b[?2004h>         'proj_alert_cost': proj_alert_cost,\r\n\u001b[?2004l\r\u001b[?2004h>         'proj_quarterly_alerts': proj_quarterly_alerts,\r\n\u001b[?2004l\r\u001b[?2004h>         'proj_daily_alerts': proj_daily_alerts\r\n\u001b[?2004l\r\u001b[?2004h>     })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> res_df = pd.DataFrame(results)\r\n\u001b[?2004l\r\u001b[?2004h> # Sort by projected total cost\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Top 10 thresholds by lowest cost:\")\r\n\u001b[?2004l\r\u001b[?2004h> print(res_df.sort_values(by='proj_total_cost').head(10)[['threshold', 'tp', 'fp', 'fn', 'tn', 'precision', 'recall', 'f1', 'proj_daily_alerts', 'proj_total_cost']])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's see results where daily alerts <= capacity\r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\nTop 10 thresholds by lowest cost within capacity (<= 1500 daily alerts):\")\r\n\u001b[?2004l\r\u001b[?2004h> within_cap = res_df[res_df['proj_daily_alerts'] <= capacity]\r\n\u001b[?2004l\r\u001b[?2004h> print(within_cap.sort_values(by='proj_total_cost').head(10)[['threshold', 'tp', 'fp', 'fn', 'tn', 'precision', 'recall', 'f1', 'proj_daily_alerts', 'proj_total_cost']])\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
