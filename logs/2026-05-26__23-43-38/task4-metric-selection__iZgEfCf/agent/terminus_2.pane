[?2004l[?2004hroot@58fc9c5bb0bf:/workspace# cat << 'EOF' > compute_metrics.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import json
[?2004l[?2004h> from sklearn.metrics import confusion_matrix, accuracy_score, roc_auc_score
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.read_csv('/data/predictions.csv')
[?2004l[?2004h> df['scored_at'] = pd.to_datetime(df['scored_at'])
[?2004l[?2004h> 
[?2004l[?2004h> # Clean data
[?2004l[?2004h> df_clean = df[(df['batch_id'] != 99) & (df['scored_at'] <= '2026-04-30 23:59:59')].copy()
[?2004l[?2004h> 
[?2004l[?2004h> # Compute metrics at threshold 0.5
[?2004l[?2004h> y_true = df_clean['y_true']
[?2004l[?2004h> y_pred_prob = df_clean['y_pred_prob']
[?2004l[?2004h> y_pred_05 = (y_pred_prob >= 0.5).astype(int)
[?2004l[?2004h> 
[?2004l[?2004h> tn, fp, fn, tp = confusion_matrix(y_true, y_pred_05).ravel()
[?2004l[?2004h> accuracy_05 = accuracy_score(y_true, y_pred_05)
[?2004l[?2004h> auc_roc = roc_auc_score(y_true, y_pred_prob)
[?2004l[?2004h> precision_05 = tp / (tp + fp)
[?2004l[?2004h> recall_05 = tp / (tp + fn)
[?2004l[?2004h> f1_05 = 2 * precision_05 * recall_05 / (precision_05 + recall_05)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's also compute metrics at recommended threshold 0.63
[?2004l[?2004h> y_pred_063 = (y_pred_prob >= 0.63).astype(int)
[?2004l[?2004h> tn_63, fp_63, fn_63, tp_63 = confusion_matrix(y_true, y_pred_063).ravel()
[?2004l[?2004h> accuracy_063 = accuracy_score(y_true, y_pred_063)
[?2004l[?2004h> precision_063 = tp_63 / (tp_63 + fp_63)
[?2004l[?2004h> recall_063 = tp_63 / (tp_63 + fn_63)
[?2004l[?2004h> f1_063 = 2 * precision_063 * recall_063 / (precision_063 + recall_063)
[?2004l[?2004h> 
[?2004l[?2004h> metrics = {
[?2004l[?2004h>     "auc_roc": float(round(auc_roc, 4)),
[?2004l[?2004h>     "accuracy_at_0.5": float(round(accuracy_05, 4)),
[?2004l[?2004h>     "precision_at_0.5": float(round(precision_05, 4)),
[?2004l[?2004h>     "recall_at_0.5": float(round(recall_05, 4)),
[?2004l[?2004h>     "f1_score_at_0.5": float(round(f1_05, 4)),
[?2004l[?2004h>     "accuracy_at_0.63": float(round(accuracy_063, 4)),
[?2004l[?2004h>     "precision_at_0.63": float(round(precision_063, 4)),
[?2004l[?2004h>     "recall_at_0.63": float(round(recall_063, 4)),
[?2004l[?2004h>     "f1_score_at_0.63": float(round(f1_063, 4))
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> with open('/output/metrics.json', 'w') as f:
[?2004l[?2004h>     json.dump(metrics, f, indent=4)
[?2004l[?2004h> 
[?2004l[?2004h> print("Saved metrics:")
[?2004l[?2004h> print(json.dumps(metrics, indent=4))
