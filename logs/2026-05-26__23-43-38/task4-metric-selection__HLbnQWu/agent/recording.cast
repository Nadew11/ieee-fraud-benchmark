[92.67288, "i", "cat << 'EOF' > print_details.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score, accuracy_score, confusion_matrix\n\n# Load and clean\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\nstart_date = pd.to_datetime('2026-01-15 00:00:00')\nend_date = pd.to_datetime('2026-04-30 23:59:59')\nclean_df = df[(df['scored_at'] >= start_date) & (df['scored_at'] <= end_date)].copy()\n\nprint(f\"--- DATASET SIZES ---\")\nprint(f\"Raw dataset: {len(df)} rows\")\nprint(f\"Cleaned dataset (scoring period only): {len(clean_df)} rows\")\nprint(f\"Excluded (out-of-period): {len(df) - len(clean_df)} rows\")\n\n# Baseline (No deployment)\ntp_b, fp_b, fn_b, tn_b = 0, 0, 193, 4872\n\n# Threshold 0.5 (Uncleaned)\ny_true_raw = df['y_true']\ny_pred_prob_raw = df['y_pred_prob']\ny_pred_05_raw = (y_pred_prob_raw >= 0.5).astype(int)\nauc_raw = roc_auc_score(y_true_raw, y_pred_prob_raw)\nacc_raw = accuracy_score(y_true_raw, y_pred_05_raw)\ntn_raw, fp_raw, fn_raw, tp_raw = confusion_matrix(y_true_raw, y_pred_05_raw).ravel()\n\nprint(f\"\\n--- ANALYST UNCLEANED METRICS (Threshold 0.5) ---\")\nprint(f\"AUC-ROC: {auc_raw:.6f} (reported: 0.9182)\")\nprint(f\"Accuracy: {acc_raw*100:.2f}% (reported: 88.3%)\")\nprint(f\"TP: {tp_raw}, FP: {fp_raw}, FN: {fn_raw}, TN: {tn_raw}\")\n\n# Threshold 0.5 (Cleaned)\ny_true_clean = clean_df['y_true']\ny_pred_prob_clean = clean_df['y_pred_prob']\ny_pred_05_clean = (y_pred_prob_clean >= 0.5).astype(int)\nauc_clean = roc_auc_score(y_true_clean, y_pred_prob_clean)\nacc_clean = accuracy_score(y_true_clean, y_pred_05_clean)\ntn_clean, fp_clean, fn_clean, tp_clean = confusion_matrix(y_true_clean, y_pred_05_clean).ravel()\n\nprint(f\"\\n--- CLEANED METRICS (Threshold 0.5) ---\")\nprint(f\"AUC-ROC: {auc_clean:.6f}\")\nprint(f\"Accuracy: {acc_clean*100:.2f}%\")\nprint(f\"TP: {tp_clean}, FP: {fp_clean}, FN: {fn_clean}, TN: {tn_clean}\")\n\n# Optimal Constrained Threshold (0.644 or similar)\n# Let's verify if there is a slightly different optimal threshold or if 0.644 is indeed the one\n# Let's print out a range of thresholds around 0.644\nprint(f\"\\n--- DETAILED LOOK AROUND 0.644 ---\")\nfor t in [0.64, 0.641, 0.642, 0.643, 0.644, 0.645, 0.65, 0.66]:\n    flagged = clean_df['y_pred_prob'] >= t\n    fc = flagged.sum()\n    tp = ((flagged) & (clean_df['y_true'] == 1)).sum()\n    fp = ((flagged) & (clean_df['y_true'] == 0)).sum()\n    fn = ((~flagged) & (clean_df['y_true'] == 1)).sum()\n    tn = ((~flagged) & (clean_df['y_true'] == 0)).sum()\n    \n    q_flagged = fc * (2800000 / len(clean_df))\n    daily_alerts = q_flagged / 90.0\n    q_cost = q_flagged * 35.0 + fn * (2800000 / len(clean_df)) * 4200.0\n    \n    print(f\"t={t:.3f}: flagged={fc}, tp={tp}, fp={fp}, fn={fn}, daily={daily_alerts:.1f}, cost=${q_cost:,.2f}\")\n\nEOF\n"]
