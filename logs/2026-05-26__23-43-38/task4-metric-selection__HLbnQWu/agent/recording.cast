[111.413996, "o", "\u001b[?2004h>     \"precision_at_recommended_threshold_0.644\": round(precision_rec, 6),\r\n\u001b[?2004l\r\u001b[?2004h>     \"recall_at_recommended_threshold_0.644\": round(recall_rec, 6),\r\n\u001b[?2004l\r\u001b[?2004h>     \"f1_score_at_recommended_threshold_0.644\": round(f1_rec, 6),\r\n\u001b[?2004l\r\u001b[?2004h>     \"accuracy_at_recommended_threshold_0.644\": round(accuracy_rec, 6),\r\n\u001b[?2004l\r\u001b[?2004h>     \"holdout_dataset_size\": int(len(clean_df)),\r\n\u001b[?2004l\r"]
