[111.412809, "o", "precision_05 = float(precision_score(y_true, y_pred_05))\r\n\u001b[?2004l\r\u001b[?2004h> recall_05 = float(recall_score(y_true, y_pred_05))\r\n\u001b[?2004l\r\u001b[?2004h> f1_05 = float(f1_score(y_true, y_pred_05))\r\n\u001b[?2004l\r\u001b[?2004h> accuracy_05 = float(accuracy_score(y_true, y_pred_05))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Metrics at 0.644\r\n\u001b[?2004l\r\u001b[?2004h> y_pred_rec = (y_pred_prob >= 0.644).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h> precision_rec = float(precision_score(y_true, y_pred_rec))\r\n\u001b[?2004l\r\u001b[?2004h"]
