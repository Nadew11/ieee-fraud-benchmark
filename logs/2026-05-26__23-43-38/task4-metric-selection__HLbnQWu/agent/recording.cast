[92.683685, "o", "# Optimal Constrained Threshold (0.644 or similar)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.683811, "o", "# Let's verify if there is a slightly different optimal threshold or if 0.644 is indeed the one\r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.684078, "o", "# Let's print out a range of thresholds around 0.644\r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.684149, "o", "print(f\"\\n--- DETAILED LOOK AROUND 0.644 ---\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.684282, "o", "for t in [0.64, 0.641, 0.642, 0.643, 0.644, 0.645, 0.65, 0.66]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.684415, "o", "    flagged = clean_df['y_pred_prob'] >= t\r\n\u001b[?2004l\r\u001b[?2004h>     fc = flagged.sum()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.684728, "o", "    tp = ((flagged) & (clean_df['y_true'] == 1)).sum()\r\n\u001b[?2004l\r\u001b[?2004h>     fp = ((flagged) & (clean_df['y_true'] == 0)).sum()\r\n\u001b[?2004l\r\u001b[?2004h>     fn = ((~flagged) & (clean_df['y_true'] == 1)).sum()\r\n\u001b[?2004l\r"]
[92.688508, "o", "\u001b[?2004h>     tn = ((~flagged) & (clean_df['y_true'] == 0)).sum()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     q_flagged = fc * (2800000 / len(clean_df))\r\n\u001b[?2004l\r\u001b[?2004h>     daily_alerts = q_flagged / 90.0\r\n\u001b[?2004l\r\u001b[?2004h>     q_cost = q_flagged * 35.0 + fn * (2800000 / len(clean_df)) * 4200.0\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"t={t:.3f}: flagged={fc}, tp={tp}, fp={fp}, fn={fn}, daily={daily_alerts:.1f}, cost=${q_cost:,.2f}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
