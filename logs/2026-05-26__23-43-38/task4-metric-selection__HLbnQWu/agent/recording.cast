[27.826886, "i", "cat << 'EOF' > analyze_dates.py\nimport pandas as pd\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\n\nstart_date = pd.to_datetime('2026-01-15 00:00:00')\nend_date = pd.to_datetime('2026-04-30 23:59:59')\n\nin_period = df[(df['scored_at'] >= start_date) & (df['scored_at'] <= end_date)]\nout_period = df[(df['scored_at'] < start_date) | (df['scored_at'] > end_date)]\n\nprint(f\"Total records: {len(df)}\")\nprint(f\"Records inside evaluation period (Jan 15 - Apr 30): {len(in_period)}\")\nprint(f\"Records outside evaluation period: {len(out_period)}\")\n\nif len(out_period) > 0:\n    print(f\"Outside period date range: {out_period['scored_at'].min()} to {out_period['scored_at'].max()}\")\n    print(f\"Outside period y_true value counts:\\n{out_period['y_true'].value_counts()}\")\n    \nprint(f\"\\nInside period unique TransactionID count: {in_period['TransactionID'].nunique()}\")\nprint(f\"Inside period total records: {len(in_period)}\")\nprint(f\"Inside period duplicate TransactionIDs: {in_period.duplicated(subset=['TransactionID']).sum()}\")\nEOF\n"]
