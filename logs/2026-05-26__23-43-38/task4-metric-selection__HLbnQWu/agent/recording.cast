[15.702987, "i", "cat << 'EOF' > analyze.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import roc_auc_score, confusion_matrix, accuracy_score\n\n# Load dataset\ndf = pd.read_csv('/data/predictions.csv')\nprint(f\"Dataset shape: {df.shape}\")\nprint(f\"Unique TransactionIDs: {df['TransactionID'].nunique()}\")\nprint(f\"Missing values:\\n{df.isnull().sum()}\")\nprint(f\"y_true counts:\\n{df['y_true'].value_counts()}\")\n\n# Compute metrics at threshold 0.5\ny_true = df['y_true']\ny_pred_prob = df['y_pred_prob']\ny_pred_05 = (y_pred_prob >= 0.5).astype(int)\n\nauc = roc_auc_score(y_true, y_pred_prob)\nacc = accuracy_score(y_true, y_pred_05)\ncm = confusion_matrix(y_true, y_pred_05)\ntn, fp, fn, tp = cm.ravel()\n\nprint(f\"\\nAt 0.5 threshold:\")\nprint(f\"AUC-ROC: {auc:.4f}\")\nprint(f\"Accuracy: {acc:.4f}\")\nprint(f\"Confusion Matrix:\")\nprint(f\"TP: {tp}, FP: {fp}, FN: {fn}, TN: {tn}\")\n\n# Let's check duplicates of TransactionID\ndup = df[df.duplicated(subset=['TransactionID'], keep=False)]\nprint(f\"\\nNumber of duplicate TransactionID rows: {len(dup)}\")\nif len(dup) > 0:\n    print(dup.sort_values(by='TransactionID').head(10))\nEOF\n"]
[15.705307, "o", "cat << 'EOF' > analyze.py\r\n\u001b[?2004l\r"]
