[92.680531, "o", "print(f\"Raw dataset: {len(df)} rows\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Cleaned dataset (scoring period only): {len(clean_df)} rows\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Excluded (out-of-period): {len(df) - len(clean_df)} rows\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Baseline (No deployment)\r\n\u001b[?2004l\r\u001b[?2004h> tp_b, fp_b, fn_b, tn_b = 0, 0, 193, 4872\r\n\u001b[?2004l\r"]
[92.682607, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Threshold 0.5 (Uncleaned)\r\n\u001b[?2004l\r\u001b[?2004h> y_true_raw = df['y_true']\r\n\u001b[?2004l\r\u001b[?2004h> y_pred_prob_raw = df['y_pred_prob']\r\n\u001b[?2004l\r\u001b[?2004h> y_pred_05_raw = (y_pred_prob_raw >= 0.5).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h> auc_raw = roc_auc_score(y_true_raw, y_pred_prob_raw)\r\n\u001b[?2004l\r\u001b[?2004h> acc_raw = accuracy_score(y_true_raw, y_pred_05_raw)\r\n\u001b[?2004l\r\u001b[?2004h> tn_raw, fp_raw, fn_raw, tp_raw = confusion_matrix(y_true_raw, y_pred_05_raw).ravel()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(f\"\\n--- ANALYST UNCLEANED METRICS (Threshold 0.5) ---\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"AUC-ROC: {auc_raw:.6f} (reported: 0.9182)\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Accuracy: {acc_raw*100:.2f}% (reported: 88.3%)\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"TP: {tp_raw}, FP: {fp_raw}, FN: {fn_raw}, TN: {tn_raw}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Threshold 0.5 (Cleaned)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.682847, "o", "y_true_clean = clean_df['y_true']\r\n\u001b[?2004l\r\u001b[?2004h> y_pred_prob_clean = clean_df['y_pred_prob']\r\n\u001b[?2004l\r\u001b[?2004h> y_pred_05_clean = (y_pred_prob_clean >= 0.5).astype(int)\r\n\u001b[?2004l\r\u001b[?2004h> auc_clean = roc_auc_score(y_true_clean, y_pred_prob_clean)\r\n\u001b[?2004l\r"]
[92.683055, "o", "\u001b[?2004h> acc_clean = accuracy_score(y_true_clean, y_pred_05_clean)\r\n\u001b[?2004l\r\u001b[?2004h> tn_clean, fp_clean, fn_clean, tp_clean = confusion_matrix(y_true_clean, y_pred_05_clean).ravel()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[92.683282, "o", "print(f\"\\n--- CLEANED METRICS (Threshold 0.5) ---\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"AUC-ROC: {auc_clean:.6f}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Accuracy: {acc_clean*100:.2f}%\")\r\n\u001b[?2004l\r\u001b[?2004h"]
