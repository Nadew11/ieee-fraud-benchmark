[69.71578, "i", "cat << 'EOF' > analyze_constrained.py\nimport pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\nstart_date = pd.to_datetime('2026-01-15 00:00:00')\nend_date = pd.to_datetime('2026-04-30 23:59:59')\nclean_df = df[(df['scored_at'] >= start_date) & (df['scored_at'] <= end_date)].copy()\n\nloss_per_undetected = 4200.0\ncost_per_investigation = 35.0\ndaily_review_capacity = 1500  # alerts/day\nquarterly_volume = 2800000\nnum_days_quarter = 90  # Standard quarter is 90 days\n\nholdout_size = len(clean_df)\nextrap_ratio = quarterly_volume / holdout_size\n\nresults = []\nthresholds = np.linspace(0.0, 1.0, 10001)  # Fine-grained search\n\nfor t in thresholds:\n    flagged = clean_df['y_pred_prob'] >= t\n    flagged_count = flagged.sum()\n    \n    # Projected metrics\n    q_flagged = flagged_count * extrap_ratio\n    daily_alerts = q_flagged / num_days_quarter\n    \n    tp = ((flagged) & (clean_df['y_true'] == 1)).sum()\n    fp = ((flagged) & (clean_df['y_true'] == 0)).sum()\n    fn = ((~flagged) & (clean_df['y_true'] == 1)).sum()\n    tn = ((~flagged) & (clean_df['y_true'] == 0)).sum()\n    \n    q_investigation_cost = q_flagged * cost_per_investigation\n    q_fraud_loss = fn * extrap_ratio * loss_per_undetected\n    q_total_cost = q_investigation_cost + q_fraud_loss\n    \n    results.append({\n        'threshold': t,\n        'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,\n        'flagged': flagged_count,\n        'q_flagged': q_flagged,\n        'daily_alerts': daily_alerts,\n        'q_investigation_cost': q_investigation_cost,\n        'q_fraud_loss': q_fraud_loss,\n        'q_total_cost': q_total_cost\n    })\n\nres_df = pd.DataFrame(results)\n\n# Filter to those within capacity\nconstrained_df = res_df[res_df['daily_alerts'] <= daily_review_capacity]\n\nprint(f\"Number of thresholds satisfying capacity: {len(constrained_df)}\")\nif not constrained_df.empty:\n    best_constrained = constrained_df.loc[constrained_df['q_total_cost'].idxmin()]\n    print(\"\\nBest Constrained Threshold:\")\n    print(best_constrained)\nelse:\n    print(\"No threshold satisfies the capacity constraint!\")\n\n# Let's check what the baseline cost is if we do NO deployment (i.e. threshold = 1.0, meaning we flag nothing and investigate nothing)\nbaseline_row = res_df.iloc[res_df['threshold'].idxmax()] # t = 1.0\nprint(\"\\nBaseline (No Model deployed, t=1.0) metrics:\")\nprint(baseline_row)\n\n# Let's check what the cost is if we deploy with threshold = 0.5 (unconstrained but proposed by junior analyst)\nrow_05 = res_df.iloc[(res_df['threshold'] - 0.5).abs().idxmin()]\nprint(\"\\nJunior Analyst's proposed threshold (0.5) metrics:\")\nprint(row_05)\n\nEOF\n"]
