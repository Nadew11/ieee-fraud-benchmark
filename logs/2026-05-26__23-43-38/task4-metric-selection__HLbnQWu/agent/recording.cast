[111.409479, "i", "cat << 'EOF' > make_metrics_json.py\nimport pandas as pd\nimport json\nfrom sklearn.metrics import roc_auc_score, precision_score, recall_score, f1_score, accuracy_score\n\n# Load and clean\ndf = pd.read_csv('/data/predictions.csv')\ndf['scored_at'] = pd.to_datetime(df['scored_at'])\nstart_date = pd.to_datetime('2026-01-15 00:00:00')\nend_date = pd.to_datetime('2026-04-30 23:59:59')\nclean_df = df[(df['scored_at'] >= start_date) & (df['scored_at'] <= end_date)].copy()\n\ny_true = clean_df['y_true']\ny_pred_prob = clean_df['y_pred_prob']\n\n# Metrics at 0.5\ny_pred_05 = (y_pred_prob >= 0.5).astype(int)\nprecision_05 = float(precision_score(y_true, y_pred_05))\nrecall_05 = float(recall_score(y_true, y_pred_05))\nf1_05 = float(f1_score(y_true, y_pred_05))\naccuracy_05 = float(accuracy_score(y_true, y_pred_05))\n\n# Metrics at 0.644\ny_pred_rec = (y_pred_prob >= 0.644).astype(int)\nprecision_rec = float(precision_score(y_true, y_pred_rec))\nrecall_rec = float(recall_score(y_true, y_pred_rec))\nf1_rec = float(f1_score(y_true, y_pred_rec))\naccuracy_rec = float(accuracy_score(y_true, y_pred_rec))\n\nauc_roc = float(roc_auc_score(y_true, y_pred_prob))\n\nmetrics = {\n    \"auc_roc\": round(auc_roc, 6),\n    \"precision_at_0.5\": round(precision_05, 6),\n    \"recall_at_0.5\": round(recall_05, 6),\n    \"f1_score_at_0.5\": round(f1_05, 6),\n    \"accuracy_at_0.5\": round(accuracy_05, 6),\n    \"precision_at_recommended_threshold_0.644\": round(precision_rec, 6),\n    \"recall_at_recommended_threshold_0.644\": round(recall_rec, 6),\n    \"f1_score_at_recommended_threshold_0.644\": round(f1_rec, 6),\n    \"accuracy_at_recommended_threshold_0.644\": round(accuracy_rec, 6),\n    \"holdout_dataset_size\": int(len(clean_df)),\n    \"holdout_fraud_cases\": int(y_true.sum()),\n    \"holdout_non_fraud_cases\": int((y_true == 0).sum())\n}\n\n# Save to /output/metrics.json\nwith open('/output/metrics.json', 'w') as f:\n    json.dump(metrics, f, indent=2)\n\nprint(\"Successfully created /output/metrics.json:\")\nprint(json.dumps(metrics, indent=2))\nEOF\n"]
[111.411379, "o", "cat << 'EOF' > make_metrics_json.py\r\n\u001b[?2004l\r\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> "]
