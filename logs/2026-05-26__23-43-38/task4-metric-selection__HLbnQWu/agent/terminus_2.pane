[?2004hroot@831ed0f33a44:/workspace# cat << 'EOF' > analyze_financials.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.metrics import roc_curve
[?2004l[?2004h> 
[?2004l[?2004h> # Load and clean dataset
[?2004l[?2004h> df = pd.read_csv('/data/predictions.csv')
[?2004l[?2004h> df['scored_at'] = pd.to_datetime(df['scored_at'])
[?2004l[?2004h> start_date = pd.to_datetime('2026-01-15 00:00:00')
[?2004l[?2004h> end_date = pd.to_datetime('2026-04-30 23:59:59')
[?2004l[?2004h> clean_df = df[(df['scored_at'] >= start_date) & (df['scored_at'] <= end_date)].copy()
[?2004l[?2004h> 
[?2004l:[?2004h> # Parameters from cost_assumptions.txt
[?2004l[?2004h> loss_per_undetected = 4200.0
[?2004l[?2004h> cost_per_investigation = 35.0
[?2004l[?2004h> daily_review_capacity = 1500  # alerts/day
[?2004l[?2004h> quarterly_volume = 2800000
[?2004l[?2004h> 
[?2004l[?2004h> # The clean_df represents the holdout set. How many days are in this evaluation period?
[?2004l[?2004h> min_date = clean_df['scored_at'].min()
[?2004l[?2004h> max_date = clean_df['scored_at'].max()
[?2004l[?2004h> num_days = (max_date - min_date).total_seconds() / (24 * 3600)
[?2004l[?2004h> print(f"Evaluation period: {min_date} to {max_date} ({num_days:.2f} days)")
[?2004l[?2004h> 
[?2004l[?2004h> # Let's count how many days of data we actually have
[?2004l[?2004h> unique_days = clean_df['scored_at'].dt.date.nunique()
[?2004l[?2004h> print(f"Unique days in dataset: {unique_days}")
[?2004l[?2004h> 
[?2004l[?2004h> # Let's calculate costs for different thresholds
[?2004l[?2004h> # A threshold 't' means: if y_pred_prob >= t, we flag/alert (Positive), else we pass (Negative).
[?2004l[?2004h> # If y_true == 1 and we don't flag (Negative, which is FN), we lose $4,200.
[?2004l[?2004h> # If we flag (Positive, which is TP + FP), we spend $35 to investigate.
[?2004l[?2004h> # Let's verify: does a TP still cost $35 to investigate, and do we save the $4,200 loss? Yes, manual investigation prevents the fraud loss, but costs $35. Undetected fraud (FN) costs $4200. FPs cost $35.
[?2004l[?2004h> # Let's write down the cost formulas:
[?2004l[?2004h> # Total cost on holdout set = (TP + FP) * 35.0 + FN * 4200.0
[?2004l[?2004h> # Let's evaluate this cost for all thresholds from 0.0 to 1.0
[?2004l[?2004h> 
[?2004l[?2004h> thresholds = np.linspace(0.0, 1.0, 1001)
[?2004l[?2004h> results = []
[?2004l[?2004h> 
[?2004l[?2004h> for t in thresholds:
[?2004l[?2004h>     # Flagged transactions
[?2004l[?2004h>     flagged = clean_df['y_pred_prob'] >= t
[?2004l[?2004h>     tp = ((flagged) & (clean_df['y_true'] == 1)).sum()
[?2004l[?2004h>     fp = ((flagged) & (clean_df['y_true'] == 0)).sum()
[?2004l[?2004h>     fn = ((~flagged) & (clean_df['y_true'] == 1)).sum()
[?2004l[?2004h>     tn = ((~flagged) & (clean_df['y_true'] == 0)).sum()
[?2004l[?2004h>     
[?2004l[?2004h>     # Holdout metrics
[?2004l[?2004h>     holdout_size = len(clean_df)
[?2004l[?2004h>     flagged_count = flagged.sum()
[?2004l[?2004h>     
[?2004l[?2004h>     # Extrapolate to quarterly volume
[?2004l[?2004h>     # Ratio of quarterly volume to holdout size
[?2004l[?2004h>     extrap_ratio = quarterly_volume / holdout_size
[?2004l[?2004h>     
[?2004l[?2004h>     # Quarterly estimates
[?2004l[?2004h>     q_flagged = flagged_count * extrap_ratio
[?2004l[?2004h>     q_tp = tp * extrap_ratio
[?2004l[?2004h>     # Daily flagged
[?2004l[?2004h>     # Assuming 90 days per quarter? Let's check.
[?2004l[?2004h>     # Let's write the daily alert rate. Is it q_flagged / 90?
[?2004l[?2004h>     # Or let's see: how many daily alerts based on the actual holdout daily density?
[?2004l[?2004h>     # Let's check how many days are in a quarter. Usually 90, 91, or 92 days. Let's see if we should use 90 days, 91 days, or based on holdout dataset's daily average.
[?2004l[?2004h>     # Let's print both.
[?2004l[?2004h>     daily_alerts_by_holdout = flagged_count / (num_days)
[?2004l[?2004h>     daily_alerts_by_quarter = q_flagged / 90.0  # standard quarter is 90 days, or we can use the holdout day density
[?2004l[?2004h>     
[?2004l[?2004h>     # Quarterly costs
[?2004l[?2004h>     q_investigation_cost = q_flagged * cost_per_investigation
[?2004l[?2004h>     q_fraud_loss = fn * extrap_ratio * loss_per_undetected
[?2004l[?2004h>     q_total_cost = q_investigation_cost + q_fraud_loss
[?2004l[?2004h>     
[?2004l[?2004h>     results.append({
[?2004l[?2004h>         'threshold': t,
[?2004l[?2004h>         'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,
[?2004l[?2004h>         'flagged': flagged_count,
[?2004l[?2004h>         'q_flagged': q_flagged,
[?2004l[?2004h>         'daily_alerts_by_holdout': daily_alerts_by_holdout,
[?2004l[?2004h>         'daily_alerts_by_quarter': daily_alerts_by_quarter,
[?2004l[?2004h>         'q_investigation_cost': q_investigation_cost,
[?2004l[?2004h>         'q_fraud_loss': q_fraud_loss,
[?2004l[?2004h>         'q_total_cost': q_total_cost
[?2004l[?2004h>     })
[?2004l[?2004h> 
[?2004l[?2004h> res_df = pd.DataFrame(results)
[?2004l[?2004h> best_row = res_df.loc[res_df['q_total_cost'].idxmin()]
[?2004l[?2004h> print("\nBest Threshold based on Total Quarterly Cost (unconstrained):")
[?2004l[?2004h> print(best_row)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at threshold 0.5 for comparison
[?2004l[?2004h> row_05 = res_df.iloc[(res_df['threshold'] - 0.5).abs().idxmin()]
[?2004l[?2004h> print("\nMetrics at threshold 0.5:")
[?2004l[?2004h> print(row_05)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at what threshold we need to fit within daily review capacity of 1,500 alerts/day
[?2004l[?2004h> # Wait, is the daily review capacity 1,500 alerts/day?
[?2004l[?2004h> # Let's check what the daily alert rate is at different thresholds and find the best threshold that satisfies daily_alerts <= 1500.
[?2004l[?2004h> # Is 'daily_alerts' calculated as q_flagged / 90, or holdout flagged / num_days?
[?2004l[?2004h> # Let's see. The holdout period is from Jan 15 to Apr 30, which is:
[?2004l[?2004h> # Jan 15-31: 17 days
[?2004l[?2004h> # Feb: 28 days (or 29? 2026 is not a leap year. 2024 is, so 2026 has 28 days)
[?2004l[?2004h> # Mar: 31 days
[?2004l[?2004h> # Apr: 30 days
[?2004l[?2004h> # Total holdout days: 17 + 28 + 31 + 30 = 106 days. Let's verify the exact days of the dataset.
[?2004l[?2004h> EOF
[?2004l[?2004hroot@831ed0f33a44:/workspace# python3 analyze_financials.py
