[?2004hroot@831ed0f33a44:/workspace# cat << 'EOF' > analyze_constrained.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> df = pd.read_csv('/data/predictions.csv')
[?2004l[?2004h> df['scored_at'] = pd.to_datetime(df['scored_at'])
[?2004l[?2004h> start_date = pd.to_datetime('2026-01-15 00:00:00')
[?2004l[?2004h> end_date = pd.to_datetime('2026-04-30 23:59:59')
[?2004l[?2004h> clean_df = df[(df['scored_at'] >= start_date) & (df['scored_at'] <= end_date)].copy()
[?2004l[?2004h> 
[?2004l[?2004h> loss_per_undetected = 4200.0
[?2004l[?2004h> cost_per_investigation = 35.0
[?2004l[?2004h> daily_review_capacity = 1500  # alerts/day
[?2004l[?2004h> quarterly_volume = 2800000
[?2004l[?2004h> num_days_quarter = 90  # Standard quarter is 90 days
[?2004l[?2004h> 
[?2004l[?2004h> holdout_size = len(clean_df)
[?2004l[?2004h> extrap_ratio = quarterly_volume / holdout_size
[?2004l[?2004h> 
[?2004l[?2004h> results = []
[?2004l[?2004h> thresholds = np.linspace(0.0, 1.0, 10001)  # Fine-grained search
[?2004l[?2004h> 
[?2004l[?2004h> for t in thresholds:
[?2004l[?2004h>     flagged = clean_df['y_pred_prob'] >= t
[?2004l[?2004h>     flagged_count = flagged.sum()
[?2004l[?2004h>     
[?2004l[?2004h>     # Projected metrics
[?2004l[?2004h>     q_flagged = flagged_count * extrap_ratio
[?2004l[?2004h>     daily_alerts = q_flagged / num_days_quarter
[?2004l[?2004h>     
[?2004l[?2004h>     tp = ((flagged) & (clean_df['y_true'] == 1)).sum()
[?2004l[?2004h>     fp = ((flagged) & (clean_df['y_true'] == 0)).sum()
[?2004l[?2004h>     fn = ((~flagged) & (clean_df['y_true'] == 1)).sum()
[?2004l[?2004h>     tn = ((~flagged) & (clean_df['y_true'] == 0)).sum()
[?2004l[?2004h>     
[?2004l[?2004h>     q_investigation_cost = q_flagged * cost_per_investigation
[?2004l[?2004h>     q_fraud_loss = fn * extrap_ratio * loss_per_undetected
[?2004l[?2004h>     q_total_cost = q_investigation_cost + q_fraud_loss
[?2004l[?2004h>     
[?2004l[?2004h>     results.append({
[?2004l[?2004h>         'threshold': t,
[?2004l[?2004h>         'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,
[?2004l[?2004h>         'flagged': flagged_count,
[?2004l[?2004h>         'q_flagged': q_flagged,
[?2004l[?2004h>         'daily_alerts': daily_alerts,
[?2004l[?2004h>         'q_investigation_cost': q_investigation_cost,
[?2004l[?2004h>         'q_fraud_loss': q_fraud_loss,
[?2004l[?2004h>         'q_total_cost': q_total_cost
[?2004l[?2004h>     })
[?2004l[?2004h> 
[?2004l[?2004h> res_df = pd.DataFrame(results)
[?2004l[?2004h> 
[?2004l[?2004h> # Filter to those within capacity
[?2004l[?2004h> constrained_df = res_df[res_df['daily_alerts'] <= daily_review_capacity]
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Number of thresholds satisfying capacity: {len(constrained_df)}")
[?2004l[?2004h> if not constrained_df.empty:
[?2004l[?2004h>     best_constrained = constrained_df.loc[constrained_df['q_total_cost'].idxmin()]
[?2004l[?2004h>     print("\nBest Constrained Threshold:")
[?2004l[?2004h>     print(best_constrained)
[?2004l[?2004h> else:
[?2004l[?2004h>     print("No threshold satisfies the capacity constraint!")
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check what the baseline cost is if we do NO deployment (i.e. threshold = 1.0, meaning we flag nothing and investigate nothing)
[?2004l[?2004h> baseline_row = res_df.iloc[res_df['threshold'].idxmax()] # t = 1.0
[?2004l[?2004h> print("\nBaseline (No Model deployed, t=1.0) metrics:")
[?2004l[?2004h> print(baseline_row)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check what the cost is if we deploy with threshold = 0.5 (unconstrained but proposed by junior analyst)
[?2004l[?2004h> row_05 = res_df.iloc[(res_df['threshold'] - 0.5).abs().idxmin()]
[?2004l[?2004h> print("\nJunior Analyst's proposed threshold (0.5) metrics:")
[?2004l[?2004h> print(row_05)
