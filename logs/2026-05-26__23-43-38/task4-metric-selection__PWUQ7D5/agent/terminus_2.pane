[?2004l[?2004h>     print(f"Threshold: {res['threshold']:.3f} | TP: {res['tp']}, FP: {res['fp']}, FN: {res['fn']}, TN: {res['tn']} | Daily Alerts: {res['alerts_daily']:.1f} | Cost FN: ${res['cost_fn']:,.2f} | Cost Alert: ${res['cost_alert']:,.2f} | Total: ${res['total_cost']:,.2f}")
