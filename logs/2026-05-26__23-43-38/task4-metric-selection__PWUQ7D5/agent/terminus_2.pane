[?2004hroot@a7f99ad36897:/workspace# cat << 'EOF' > optimize_threshold.py
[?2004l[?2004h> import csv
[?2004l[?2004h> from datetime import datetime
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> with open('/data/predictions.csv', 'r') as f:
[?2004l[?2004h>     reader = csv.reader(f)
[?2004l[?2004h>     header = next(reader)
[?2004l[?2004h>     rows = [r for r in reader]
[?2004l[?2004h> 
[?2004l[?2004h> # Filter to scoring period: before May 1, 2026
[?2004l[?2004h> filtered_rows = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') < datetime(2026, 5, 1)]
[?2004l[?2004h> 
[?2004l[?2004h> y_true = np.array([int(r[1]) for r in filtered_rows])
[?2004l[?2004h> y_prob = np.array([float(r[2]) for r in filtered_rows])
[?2004l[?2004h> 
[?2004l[?2004h> N = len(filtered_rows)
[?2004l[?2004h> num_pos = sum(y_true)
[?2004l[?2004h> num_neg = N - num_pos
[?2004l[?2004h> 
[?2004l[?2004h> print("Filtered dataset length:", N)
[?2004l[?2004h> print("Positives:", num_pos)
[?2004l[?2004h> print("Negatives:", num_neg)
[?2004l[?2004h> 
[?2004l[?2004h> # Cost parameters
[?2004l[?2004h> loss_per_fn = 4200.0
[?2004l[?2004h> cost_per_alert = 35.0
[?2004l[?2004h> capacity_daily = 1500.0
[?2004l[?2004h> quarterly_volume = 2800000.0
[?2004l[?2004h> 
[?2004l[?2004h> daily_volume = quarterly_volume / 90.0
[?2004l[?2004h> print(f"Daily transaction volume: {daily_volume:.2f}")
[?2004l[?2004h> 
[?2004l[?2004h> best_overall_cost = float('inf')
[?2004l[?2004h> best_overall_t = None
[?2004l[?2004h> best_overall_metrics = {}
[?2004l[?2004h> 
[?2004l[?2004h> best_feas_cost = float('inf')
[?2004l[?2004h> best_feas_t = None
[?2004l[?2004h> best_feas_metrics = {}
[?2004l[?2004h> 
[?2004l[?2004h> # Scan thresholds from 0 to 1
[?2004l[?2004h> for t in np.linspace(0.0, 1.0, 1001):
[?2004l[?2004h>     y_pred = (y_prob >= t).astype(int)
[?2004l[?2004h>     tp = int(sum((y_true == 1) & (y_pred == 1)))
[?2004l[?2004h>     fp = int(sum((y_true == 0) & (y_pred == 1)))
[?2004l[?2004h>     fn = int(sum((y_true == 1) & (y_pred == 0)))
[?2004l[?2004h>     tn = int(sum((y_true == 0) & (y_pred == 0)))
[?2004l[?2004h>     
[?2004l[?2004h>     tp_rate = tp / N
[?2004l[?2004h>     fp_rate = fp / N
[?2004l[?2004h>     fn_rate = fn / N
[?2004l[?2004h>     tn_rate = tn / N
[?2004l[?2004h>     
[?2004l[?2004h>     tp_q = tp_rate * quarterly_volume
[?2004l[?2004h>     fp_q = fp_rate * quarterly_volume
[?2004l[?2004h>     fn_q = fn_rate * quarterly_volume
[?2004l[?2004h>     tn_q = tn_rate * quarterly_volume
[?2004l[?2004h>     
[?2004l[?2004h>     alerts_q = tp_q + fp_q
[?2004l[?2004h>     alerts_daily = alerts_q / 90.0
[?2004l[?2004h>     
[?2004l[?2004h>     cost_fn = fn_q * loss_per_fn
[?2004l[?2004h>     cost_alert = alerts_q * cost_per_alert
[?2004l[?2004h>     total_cost = cost_fn + cost_alert
[?2004l[?2004h>     
[?2004l[?2004h>     # Check overall
[?2004l[?2004h>     if total_cost < best_overall_cost:
[?2004l[?2004h>         best_overall_cost = total_cost
[?2004l[?2004h>         best_overall_t = t
[?2004l[?2004h>         best_overall_metrics = {
[?2004l[?2004h>             'threshold': t,
[?2004l[?2004h>             'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,
[?2004l[?2004h>             'alerts_daily': alerts_daily,
[?2004l[?2004h>             'total_cost': total_cost
[?2004l[?2004h>         }
[?2004l[?2004h>     
[?2004l[?2004h>     # Check feasible
[?2004l[?2004h>     if alerts_daily <= capacity_daily:
[?2004l[?2004h>         if total_cost < best_feas_cost:
[?2004l[?2004h>             best_feas_cost = total_cost
[?2004l[?2004h>             best_feas_t = t
[?2004l[?2004h>             best_feas_metrics = {
[?2004l[?2004h>                 'threshold': t,
[?2004l[?2004h>                 'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,
[?2004l[?2004h>                 'alerts_daily': alerts_daily,
[?2004l[?2004h>                 'total_cost': total_cost
[?2004l[?2004h>             }
[?2004l[?2004h> 
[?2004l[?2004h> print("Unconstrained:")
[?2004l[?2004h> print(best_overall_metrics)
[?2004l[?2004h> print("Feasible:")
[?2004l[?2004h> print(best_feas_metrics)
