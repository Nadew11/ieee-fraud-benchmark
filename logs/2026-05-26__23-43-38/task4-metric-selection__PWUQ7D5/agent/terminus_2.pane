[?2004hroot@a7f99ad36897:/workspace# cat << 'EOF' > test_analyst.py
[?2004l[?2004h> import csv
[?2004l[?2004h> 
[?2004l[?2004h> with open('/data/predictions.csv', 'r') as f:
[?2004l[?2004h>     reader = csv.reader(f)
[?2004l[?2004h>     header = next(reader)
[?2004l[?2004h>     rows = [r for r in reader]
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate confusion matrix for threshold = 0.5
[?2004l[?2004h> tp, fp, fn, tn = 0, 0, 0, 0
[?2004l[?2004h> for r in rows:
[?2004l[?2004h>     y_true = int(r[1])
[?2004l[?2004h>     y_prob = float(r[2])
[?2004l[?2004h>     y_pred = 1 if y_prob >= 0.5 else 0
[?2004l[?2004h>     if y_true == 1 and y_pred == 1:
[?2004l[?2004h>         tp += 1
[?2004l[?2004h>     elif y_true == 0 and y_pred == 1:
[?2004l[?2004h>         fp += 1
[?2004l[?2004h>     elif y_true == 1 and y_pred == 0:
[?2004l[?2004h>         fn += 1
[?2004l[?2004h>     elif y_true == 0 and y_pred == 0:
[?2004l[?2004h>         tn += 1
[?2004l[?2004h> 
[?2004l[?2004h> print(f"TP: {tp}, FP: {fp}, FN: {fn}, TN: {tn}")
[?2004l[?2004h> print("Accuracy:", (tp + tn) / len(rows))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's import roc_auc_score to verify AUC on the full dataset
[?2004l[?2004h> # Using standard sklearn
[?2004l[?2004h> from sklearn.metrics import roc_auc_score
[?2004l[?2004h> y_true_all = [int(r[1]) for r in rows]
[?2004l[?2004h> y_prob_all = [float(r[2]) for r in rows]
