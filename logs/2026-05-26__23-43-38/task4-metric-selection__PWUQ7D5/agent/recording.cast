[58.158519, "i", "cat << 'EOF' > test_analyst.py\nimport csv\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\n# Calculate confusion matrix for threshold = 0.5\ntp, fp, fn, tn = 0, 0, 0, 0\nfor r in rows:\n    y_true = int(r[1])\n    y_prob = float(r[2])\n    y_pred = 1 if y_prob >= 0.5 else 0\n    if y_true == 1 and y_pred == 1:\n        tp += 1\n    elif y_true == 0 and y_pred == 1:\n        fp += 1\n    elif y_true == 1 and y_pred == 0:\n        fn += 1\n    elif y_true == 0 and y_pred == 0:\n        tn += 1\n\nprint(f\"TP: {tp}, FP: {fp}, FN: {fn}, TN: {tn}\")\nprint(\"Accuracy:\", (tp + tn) / len(rows))\n\n# Let's import roc_auc_score to verify AUC on the full dataset\n# Using standard sklearn\nfrom sklearn.metrics import roc_auc_score\ny_true_all = [int(r[1]) for r in rows]\ny_prob_all = [float(r[2]) for r in rows]\nprint(\"AUC:\", roc_auc_score(y_true_all, y_prob_all))\nEOF\npython3 test_analyst.py\n"]
[58.162335, "o", "cat << 'EOF' > test_analyst.py\r\n\u001b[?2004l\r\u001b[?2004h> import csv\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open('/data/predictions.csv', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     reader = csv.reader(f)\r\n\u001b[?2004l\r\u001b[?2004h>     header = next(reader)\r\n\u001b[?2004l\r\u001b[?2004h>     rows = [r for r in reader]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Calculate confusion matrix for threshold = 0.5\r\n\u001b[?2004l\r\u001b[?2004h> tp, fp, fn, tn = 0, 0, 0, 0\r\n\u001b[?2004l\r\u001b[?2004h> for r in rows:\r\n\u001b[?2004l\r\u001b[?2004h>     y_true = int(r[1])\r\n\u001b[?2004l\r\u001b[?2004h>     y_prob = float(r[2])\r\n\u001b[?2004l\r\u001b[?2004h>     y_pred = 1 if y_prob >= 0.5 else 0\r\n\u001b[?2004l\r\u001b[?2004h>     if y_true == 1 and y_pred == 1:\r\n\u001b[?2004l\r\u001b[?2004h>         tp += 1\r\n\u001b[?2004l\r\u001b[?2004h>     elif y_true == 0 and y_pred == 1:\r\n\u001b[?2004l\r\u001b[?2004h>         fp += 1\r\n\u001b[?2004l\r\u001b[?2004h>     elif y_true == 1 and y_pred == 0:\r\n\u001b[?2004l\r\u001b[?2004h>         fn += 1\r\n\u001b[?2004l\r\u001b[?2004h>     elif y_true == 0 and y_pred == 0:\r\n\u001b[?2004l\r\u001b[?2004h>         tn += 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(f\"TP: {tp}, FP: {fp}, FN: {fn}, TN: {tn}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Accuracy:\", (tp + tn) / len(rows))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's import roc_auc_score to verify AUC on the full dataset\r\n\u001b[?2004l\r\u001b[?2004h> # Using standard sklearn\r\n\u001b[?2004l\r\u001b[?2004h> from sklearn.metrics import roc_auc_score\r\n\u001b[?2004l\r\u001b[?2004h> y_true_all = [int(r[1]) for r in rows]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[58.162425, "o", "y_prob_all = [float(r[2]) for r in rows]\r\n\u001b[?2004l\r\u001b[?2004h> print(\"AUC:\", roc_auc_score(y_true_all, y_prob_all))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
