[24.84645, "i", "cat << 'EOF' > fast_analyze.py\nimport csv\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    print(\"Header:\", header)\n    \n    # Count rows, duplicates, unique IDs\n    ids = []\n    rows = []\n    for r in reader:\n        # r: TransactionID,y_true,y_pred_prob,scored_at,batch_id\n        ids.append(r[0])\n        rows.append(r)\n        \nprint(\"Total rows:\", len(rows))\nprint(\"Unique IDs:\", len(set(ids)))\nprint(\"Duplicated IDs:\", len(ids) - len(set(ids)))\nEOF\npython3 fast_analyze.py\n"]
