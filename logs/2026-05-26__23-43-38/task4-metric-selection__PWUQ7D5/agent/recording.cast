[28.678401, "i", "cat << 'EOF' > fast_analyze.py\nimport csv\nfrom collections import Counter\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [tuple(r) for r in reader]\n\nprint(\"Total rows:\", len(rows))\nunique_rows = set(rows)\nprint(\"Unique rows:\", len(unique_rows))\n\n# Let's see some duplicates\ntrans_counts = Counter([r[0] for r in rows])\ndup_ids = [tid for tid, count in trans_counts.items() if count > 1]\nprint(\"Number of duplicate IDs:\", len(dup_ids))\n\n# Look at some examples\nprint(\"Examples of duplicates:\")\ncount = 0\nfor tid in dup_ids:\n    matching = [r for r in rows if r[0] == tid]\n    print(f\"ID {tid}:\")\n    for m in matching:\n        print(\"  \", m)\n    count += 1\n    if count >= 5:\n        break\nEOF\npython3 fast_analyze.py\n"]
