[65.880125, "i", "cat << 'EOF' > filter_check.py\nimport csv\nfrom datetime import datetime\nfrom collections import Counter\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\nfiltered_rows = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') < datetime(2026, 5, 1)]\nprint(\"Filtered rows (scored before May 1):\", len(filtered_rows))\n\ntids = [r[0] for r in filtered_rows]\ncounts = Counter(tids)\ndups = [tid for tid, count in counts.items() if count > 1]\nprint(\"Duplicates in filtered dataset:\", len(dups))\n\n# Let's see basic counts for filtered dataset\ntp, fp, fn, tn = 0, 0, 0, 0\nfor r in filtered_rows:\n    y_true = int(r[1])\n    y_prob = float(r[2])\n    y_pred = 1 if y_prob >= 0.5 else 0\n    if y_true == 1 and y_pred == 1:\n        tp += 1\n    elif y_true == 0 and y_pred == 1:\n        fp += 1\n    elif y_true == 1 and y_pred == 0:\n        fn += 1\n    elif y_true == 0 and y_pred == 0:\n        tn += 1\n\nprint(f\"Filtered TP: {tp}, FP: {fp}, FN: {fn}, TN: {tn}\")\naccuracy = (tp + tn) / len(filtered_rows)\nprint(\"Filtered Accuracy:\", accuracy)\n\nfrom sklearn.metrics import roc_auc_score\ny_true_filt = [int(r[1]) for r in filtered_rows]\ny_prob_filt = [float(r[2]) for r in filtered_rows]\nprint(\"Filtered AUC:\", roc_auc_score(y_true_filt, y_prob_filt))\nEOF\npython3 filter_check.py\n"]
