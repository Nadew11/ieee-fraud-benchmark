[113.877364, "o", "y_true = [int(r[1]) for r in filtered_rows]\r\n\u001b[?2004l\r\u001b[?2004h> y_prob = [float(r[2]) for r in filtered_rows]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> N = len(filtered_rows)\r\n\u001b[?2004l\r\u001b[?2004h> pos = sum(y_true)\r\n\u001b[?2004l\r\u001b[?2004h> neg = N - pos\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> auc_roc = roc_auc_score(y_true, y_prob)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Recommended threshold metrics\r\n\u001b[?2004l\r\u001b[?2004h> t_rec = 0.644\r\n\u001b[?2004l\r\u001b[?2004h> tp_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp >= t_rec)\r\n\u001b[?2004l\r\u001b[?2004h> fp_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp >= t_rec)\r\n\u001b[?2004l\r\u001b[?2004h> fn_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp < t_rec)\r\n\u001b[?2004l\r\u001b[?2004h> tn_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp < t_rec)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> precision_rec = tp_rec / (tp_rec + fp_rec) if (tp_rec + fp_rec) > 0 else 0.0\r\n\u001b[?2004l\r\u001b[?2004h> recall_rec = tp_rec / (tp_rec + fn_rec) if (tp_rec + fn_rec) > 0 else 0.0\r\n\u001b[?2004l\r\u001b[?2004h> f1_rec = 2 * precision_rec * recall_rec / (precision_rec + recall_rec) if (precision_rec + recall_rec) > 0 else 0.0\r\n\u001b[?2004l\r\u001b[?2004h> accuracy_rec = (tp_rec + tn_rec) / N\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Analyst threshold (0.5) metrics\r\n\u001b[?2004l\r\u001b[?2004h> t_05 = 0.5\r\n\u001b[?2004l\r\u001b[?2004h> tp_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp >= t_05)\r\n\u001b[?2004l\r\u001b[?2004h> fp_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp >= t_05)\r\n\u001b[?2004l\r\u001b[?2004h> fn_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp < t_05)\r\n\u001b[?2004l\r\u001b[?2004h> tn_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp < t_05)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> precision_05 = tp_05 / (tp_05 + fp_05) if (tp_05 + fp_05) > 0 else 0.0\r\n\u001b[?2004l\r\u001b[?2004h> recall_05 = tp_05 / (tp_05 + fn_05) if (tp_05 + fn_05) > 0 else 0.0\r\n\u001b[?2004l\r\u001b[?2004h> f1_05 = 2 * precision_05 * recall_05 / (precision_05 + recall_05) if (precision_05 + recall_05) > 0 else 0.0\r\n\u001b[?2004l\r\u001b[?2004h> accuracy_05 = (tp_05 + tn_05) / N\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> metrics = {\r\n\u001b[?2004l\r\u001b[?2004h>     \"auc_roc\": float(auc_roc),\r\n\u001b[?2004l\r\u001b[?2004h>     \"unfiltered_auc_roc_reported_by_analyst\": 0.918213421549955,\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     \"recommended_threshold\": float(t_rec),\r\n\u001b[?2004l\r\u001b[?2004h>     \"precision_at_recommended_threshold\": float(precision_rec),\r\n\u001b[?2004l\r\u001b[?2004h>     \"recall_at_recommended_threshold\": float(recall_rec),\r\n\u001b[?2004l\r\u001b[?2004h>     \"f1_score_at_recommended_threshold\": float(f1_rec),\r\n\u001b[?2004l\r\u001b[?2004h>     \"accuracy_at_recommended_threshold\": float(accuracy_rec),\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     \"precision_at_analyst_threshold_0.5\": float(precision_05),\r\n\u001b[?2004l\r\u001b[?2004h>     \"recall_at_analyst_threshold_0.5\": float(recall_05),\r\n\u001b[?2004l\r\u001b[?2004h>     \"f1_score_at_analyst_threshold_0.5\": float(f1_05),\r\n\u001b[?2004l\r\u001b[?2004h>     \"accuracy_at_analyst_threshold_0.5\": float(accuracy_05),\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     \"total_eval_samples\": int(N),\r\n\u001b[?2004l\r\u001b[?2004h>     \"total_eval_fraud_cases\": int(pos),\r\n\u001b[?2004l\r\u001b[?2004h>     \"fraud_rate_pct\": float(pos / N * 100.0),\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     \"quarterly_loss_no_model\": 448110562.68509376,\r\n\u001b[?2004l\r\u001b[?2004h>     \"quarterly_loss_at_recommended_threshold\": 192730108.58835143,\r\n\u001b[?2004l\r\u001b[?2004h>     \"quarterly_savings_at_recommended_threshold\": 448110562.68509376 - 192730108.58835143\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open('/output/metrics.json', 'w') as out_f:\r\n\u001b[?2004l\r\u001b[?2004h>     json.dump(metrics, out_f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Saved metrics.json successfully!\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[113.877601, "o", "\u001b[?2004hroot@a7f99ad36897:/workspace# python3 make_json.py\r\n\u001b[?2004l\r"]
[114.726094, "o", "Saved metrics.json successfully!\r\n"]
