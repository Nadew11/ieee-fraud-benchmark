[113.844042, "i", "mkdir -p /output\ncat << 'EOF' > make_json.py\nimport csv\nfrom datetime import datetime\nimport json\nfrom sklearn.metrics import roc_auc_score\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\n# Filter to scoring period\nfiltered_rows = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') < datetime(2026, 5, 1)]\ny_true = [int(r[1]) for r in filtered_rows]\ny_prob = [float(r[2]) for r in filtered_rows]\n\nN = len(filtered_rows)\npos = sum(y_true)\nneg = N - pos\n\nauc_roc = roc_auc_score(y_true, y_prob)\n\n# Recommended threshold metrics\nt_rec = 0.644\ntp_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp >= t_rec)\nfp_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp >= t_rec)\nfn_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp < t_rec)\ntn_rec = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp < t_rec)\n\nprecision_rec = tp_rec / (tp_rec + fp_rec) if (tp_rec + fp_rec) > 0 else 0.0\nrecall_rec = tp_rec / (tp_rec + fn_rec) if (tp_rec + fn_rec) > 0 else 0.0\nf1_rec = 2 * precision_rec * recall_rec / (precision_rec + recall_rec) if (precision_rec + recall_rec) > 0 else 0.0\naccuracy_rec = (tp_rec + tn_rec) / N\n\n# Analyst threshold (0.5) metrics\nt_05 = 0.5\ntp_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp >= t_05)\nfp_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp >= t_05)\nfn_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 1 and yp < t_05)\ntn_05 = sum(1 for yt, yp in zip(y_true, y_prob) if yt == 0 and yp < t_05)\n\nprecision_05 = tp_05 / (tp_05 + fp_05) if (tp_05 + fp_05) > 0 else 0.0\nrecall_05 = tp_05 / (tp_05 + fn_05) if (tp_05 + fn_05) > 0 else 0.0\nf1_05 = 2 * precision_05 * recall_05 / (precision_05 + recall_05) if (precision_05 + recall_05) > 0 else 0.0\naccuracy_05 = (tp_05 + tn_05) / N\n\nmetrics = {\n    \"auc_roc\": float(auc_roc),\n    \"unfiltered_auc_roc_reported_by_analyst\": 0.918213421549955,\n    \n    \"recommended_threshold\": float(t_rec),\n    \"precision_at_recommended_threshold\": float(precision_rec),\n    \"recall_at_recommended_threshold\": float(recall_rec),\n    \"f1_score_at_recommended_threshold\": float(f1_rec),\n    \"accuracy_at_recommended_threshold\": float(accuracy_rec),\n    \n    \"precision_at_analyst_threshold_0.5\": float(precision_05),\n    \"recall_at_analyst_threshold_0.5\": float(recall_05),\n    \"f1_score_at_analyst_threshold_0.5\": float(f1_05),\n    \"accuracy_at_analyst_threshold_0.5\": float(accuracy_05),\n    \n    \"total_eval_samples\": int(N),\n    \"total_eval_fraud_cases\": int(pos),\n    \"fraud_rate_pct\": float(pos / N * 100.0),\n    \n    \"quarterly_loss_no_model\": 448110562.68509376,\n    \"quarterly_loss_at_recommended_threshold\": 192730108.58835143,\n    \"quarterly_savings_at_recommended_threshold\": 448110562.68509376 - 192730108.58835143\n}\n\nwith open('/output/metrics.json', 'w') as out_f:\n    json.dump(metrics, out_f, indent=2)\n    \nprint(\"Saved metrics.json successfully!\")\nEOF\npython3 make_json.py\n"]
