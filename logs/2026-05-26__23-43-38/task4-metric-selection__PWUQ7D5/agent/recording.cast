[40.699021, "i", "cat << 'EOF' > time_analyze.py\nimport csv\nfrom datetime import datetime\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\n# Header: ['TransactionID', 'y_true', 'y_pred_prob', 'scored_at', 'batch_id']\ndates = [datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') for r in rows]\nmin_date = min(dates)\nmax_date = max(dates)\nprint(f\"Overall date range: {min_date} to {max_date}\")\n\nout_of_bounds = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') > datetime(2026, 4, 30, 23, 59, 59)]\nprint(f\"Number of rows with scored_at > 2026-04-30: {len(out_of_bounds)}\")\n\n# Let's see if all these out_of_bounds are duplicate TransactionIDs\n# are they duplicate of some in-bound TransactionIDs?\nout_of_bounds_ids = set([r[0] for r in out_of_bounds])\nin_bound = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') <= datetime(2026, 4, 30, 23, 59, 59)]\nin_bound_ids = set([r[0] for r in in_bound])\n\nprint(\"Are out_of_bounds_ids in in_bound_ids?\", out_of_bounds_ids.issubset(in_bound_ids))\nprint(\"Intersection size:\", len(out_of_bounds_ids.intersection(in_bound_ids)))\nprint(\"Difference size (out of bounds but not in-bound):\", len(out_of_bounds_ids - in_bound_ids))\nEOF\npython3 time_analyze.py\n"]
[40.703371, "o", "cat << 'EOF' > time_analyze.py\r\n\u001b[?2004l\r\u001b[?2004h> import csv\r\n\u001b[?2004l\r\u001b[?2004h> from datetime import datetime\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open('/data/predictions.csv', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     reader = csv.reader(f)\r\n\u001b[?2004l\r\u001b[?2004h>     header = next(reader)\r\n\u001b[?2004l\r\u001b[?2004h>     rows = [r for r in reader]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Header: ['TransactionID', 'y_true', 'y_pred_prob', 'scored_at', 'batch_id']\r\n\u001b[?2004l\r\u001b[?2004h> dates = [datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') for r in rows]\r\n\u001b[?2004l\r\u001b[?2004h> min_date = min(dates)\r\n\u001b[?2004l\r\u001b[?2004h> max_date = max(dates)\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Overall date range: {min_date} to {max_date}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> out_of_bounds = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') > datetime(2026, 4, 30, 23, 59, 59)]\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Number of rows with scored_at > 2026-04-30: {len(out_of_bounds)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Let's see if all these out_of_bounds are duplicate TransactionIDs\r\n\u001b[?2004l\r\u001b[?2004h> # are they duplicate of some in-bound TransactionIDs?\r\n\u001b[?2004l\r\u001b[?2004h> out_of_bounds_ids = set([r[0] for r in out_of_bounds])\r\n\u001b[?2004l\r\u001b[?2004h> in_bound = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') <= datetime(2026, 4, 30, 23, 59, 59)]\r\n\u001b[?2004l\r\u001b[?2004h> in_bound_ids = set([r[0] for r in in_bound])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Are out_of_bounds_ids in in_bound_ids?\", out_of_bounds_ids.issubset(in_bound_ids))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Intersection size:\", len(out_of_bounds_ids.intersection(in_bound_ids)))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Difference size (out of bounds but not in-bound):\", len(out_of_bounds_ids - in_bound_ids))\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
