[7.021463, "o", "cat /data/dataset_info.txt\r\n\u001b[?2004l\r"]
[7.022026, "o", "Dataset: Fraud Detection Model - Holdout Evaluation Export\r\nSource: IEEE-CIS transaction scoring pipeline v4.2.1\r\nExport date: 2026-05-01\r\n\r\nOverall Statistics (as exported):\r\n  Columns: TransactionID, y_true, y_pred_prob, scored_at, batch_id\r\n  Model: XGBoost v2.0.3, trained on Q1-Q3 2025 data\r\n  Scoring period: January 15 - April 30, 2026\r\n\r\nNote: This export was generated from the raw scoring pipeline output\r\nand has not been pre-processed or filtered. The export contains all\r\nscored records from the evaluation period.\r\n\r\nFraud labels (y_true) are finalized after chargeback window closure\r\n(45 days). Labels in this export are considered final."]
