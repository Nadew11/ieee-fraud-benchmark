[52.505699, "i", "cat << 'EOF' > dup_check.py\nimport csv\nfrom datetime import datetime\nfrom collections import defaultdict\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\nby_id = defaultdict(list)\nfor r in rows:\n    by_id[r[0]].append(r)\n\ndup_info = []\nfor tid, records in by_id.items():\n    if len(records) > 1:\n        dup_info.append((tid, records))\n\nprint(\"Total duplicates (by ID):\", len(dup_info))\n# Let's see if one of the records in duplicate is always in May\nmay_count = 0\nboth_in_period = 0\nfor tid, records in dup_info:\n    dates = [datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') for r in records]\n    has_may = any(d >= datetime(2026, 5, 1) for d in dates)\n    all_period = all(d < datetime(2026, 5, 1) for d in dates)\n    if has_may:\n        may_count += 1\n    if all_period:\n        both_in_period += 1\n\nprint(\"Duplicates with at least one record in May:\", may_count)\nprint(\"Duplicates with both records in the scoring period (before May 1):\", both_in_period)\nEOF\npython3 dup_check.py\n"]
