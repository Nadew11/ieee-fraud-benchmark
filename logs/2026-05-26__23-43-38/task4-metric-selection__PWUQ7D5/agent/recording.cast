[90.772736, "i", "cat << 'EOF' > optimize_threshold.py\nimport csv\nfrom datetime import datetime\nimport numpy as np\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\n# Filter to scoring period: before May 1, 2026\nfiltered_rows = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') < datetime(2026, 5, 1)]\n\ny_true = np.array([int(r[1]) for r in filtered_rows])\ny_prob = np.array([float(r[2]) for r in filtered_rows])\n\nN = len(filtered_rows)\nnum_pos = sum(y_true)\nnum_neg = N - num_pos\n\nprint(\"Filtered dataset length:\", N)\nprint(\"Positives:\", num_pos)\nprint(\"Negatives:\", num_neg)\n\n# Cost parameters\nloss_per_fn = 4200.0\ncost_per_alert = 35.0\ncapacity_daily = 1500.0\nquarterly_volume = 2800000.0\n\ndaily_volume = quarterly_volume / 90.0\nprint(f\"Daily transaction volume: {daily_volume:.2f}\")\n\nbest_overall_cost = float('inf')\nbest_overall_t = None\nbest_overall_metrics = {}\n\nbest_feas_cost = float('inf')\nbest_feas_t = None\nbest_feas_metrics = {}\n\n# Scan thresholds from 0 to 1\nfor t in np.linspace(0.0, 1.0, 1001):\n    y_pred = (y_prob >= t).astype(int)\n    tp = int(sum((y_true == 1) & (y_pred == 1)))\n    fp = int(sum((y_true == 0) & (y_pred == 1)))\n    fn = int(sum((y_true == 1) & (y_pred == 0)))\n    tn = int(sum((y_true == 0) & (y_pred == 0)))\n    \n    tp_rate = tp / N\n    fp_rate = fp / N\n    fn_rate = fn / N\n    tn_rate = tn / N\n    \n    tp_q = tp_rate * quarterly_volume\n    fp_q = fp_rate * quarterly_volume\n    fn_q = fn_rate * quarterly_volume\n    tn_q = tn_rate * quarterly_volume\n    \n    alerts_q = tp_q + fp_q\n    alerts_daily = alerts_q / 90.0\n    \n    cost_fn = fn_q * loss_per_fn\n    cost_alert = alerts_q * cost_per_alert\n    total_cost = cost_fn + cost_alert\n    \n    # Check overall\n    if total_cost < best_overall_cost:\n        best_overall_cost = total_cost\n        best_overall_t = t\n        best_overall_metrics = {\n            'threshold': t,\n            'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,\n            'alerts_daily': alerts_daily,\n            'total_cost': total_cost\n        }\n    \n    # Check feasible\n    if alerts_daily <= capacity_daily:\n        if total_cost < best_feas_cost:\n            best_feas_cost = total_cost\n            best_feas_t = t\n            best_feas_metrics = {\n                'threshold': t,\n                'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,\n                'alerts_daily': alerts_daily,\n                'total_cost': total_cost\n            }\n\nprint(\"Unconstrained:\")\nprint(best_overall_metrics)\nprint(\"Feasible:\")\nprint(best_feas_metrics)\nEOF\npython3 optimize_threshold.py\n"]
