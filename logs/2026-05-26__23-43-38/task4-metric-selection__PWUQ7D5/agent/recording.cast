[99.020376, "i", "cat << 'EOF' > evaluate_thresholds.py\nimport csv\nfrom datetime import datetime\nimport numpy as np\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\n# Filter to scoring period: before May 1, 2026\nfiltered_rows = [r for r in rows if datetime.strptime(r[3], '%Y-%m-%d %H:%M:%S') < datetime(2026, 5, 1)]\ny_true = np.array([int(r[1]) for r in filtered_rows])\ny_prob = np.array([float(r[2]) for r in filtered_rows])\n\nN = len(filtered_rows)\nloss_per_fn = 4200.0\ncost_per_alert = 35.0\nquarterly_volume = 2800000.0\n\ndef eval_t(t):\n    if t == 1.0:\n        y_pred = np.zeros_like(y_true)\n    elif t == 0.0:\n        y_pred = np.ones_like(y_true)\n    else:\n        y_pred = (y_prob >= t).astype(int)\n    \n    tp = int(sum((y_true == 1) & (y_pred == 1)))\n    fp = int(sum((y_true == 0) & (y_pred == 1)))\n    fn = int(sum((y_true == 1) & (y_pred == 0)))\n    tn = int(sum((y_true == 0) & (y_pred == 0)))\n    \n    tp_rate = tp / N\n    fp_rate = fp / N\n    fn_rate = fn / N\n    tn_rate = tn / N\n    \n    tp_q = tp_rate * quarterly_volume\n    fp_q = fp_rate * quarterly_volume\n    fn_q = fn_rate * quarterly_volume\n    tn_q = tn_rate * quarterly_volume\n    \n    alerts_q = tp_q + fp_q\n    alerts_daily = alerts_q / 90.0\n    \n    cost_fn = fn_q * loss_per_fn\n    cost_alert = alerts_q * cost_per_alert\n    total_cost = cost_fn + cost_alert\n    \n    return {\n        'threshold': t,\n        'tp': tp, 'fp': fp, 'fn': fn, 'tn': tn,\n        'alerts_daily': alerts_daily,\n        'cost_fn': cost_fn,\n        'cost_alert': cost_alert,\n        'total_cost': total_cost\n    }\n\nfor t in [0.0, 0.1, 0.2, 0.29, 0.5, 0.6, 0.644, 0.7, 0.8, 0.9, 1.0]:\n    res = eval_t(t)\n    print(f\"Threshold: {res['threshold']:.3f} | TP: {res['tp']}, FP: {res['fp']}, FN: {res['fn']}, TN: {res['tn']} | Daily Alerts: {res['alerts_daily']:.1f} | Cost FN: ${res['cost_fn']:,.2f} | Cost Alert: ${res['cost_alert']:,.2f} | Total: ${res['total_cost']:,.2f}\")\nEOF\npython3 evaluate_thresholds.py\n"]
