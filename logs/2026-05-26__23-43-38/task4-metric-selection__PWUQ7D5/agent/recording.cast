[46.108788, "i", "cat << 'EOF' > detailed_time.py\nimport csv\nfrom datetime import datetime\n\nwith open('/data/predictions.csv', 'r') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\n# Group by scored_at month or day\nfrom collections import defaultdict\nby_day = defaultdict(int)\nfor r in rows:\n    dt = r[3].split()[0]  # YYYY-MM-DD\n    by_day[dt] += 1\n\nfor d in sorted(by_day.keys()):\n    print(f\"{d}: {by_day[d]} rows\")\nEOF\npython3 detailed_time.py\n"]
