erall_metrics = {\n            \'threshold\': t,\n            \'tp\': tp, \'fp\': fp, \'fn\': fn, \'tn\': tn,\n            \'alerts_daily\': alerts_daily,\n            \'total_cost\': total_cost\n        }\n    \n    # Check feasible\n    if alerts_daily <= capacity_daily:\n        if total_cost < best_feas_cost:\n            best_feas_cost = total_cost\n            best_feas_t = t\n            best_feas_metrics = {\n                \'threshold\': t,\n                \'tp\': tp, \'fp\': fp, \'fn\': fn, \'tn\': tn,\n                \'alerts_daily\': alerts_daily,\n                \'total_cost\': total_cost\n            }\n\nprint("Unconstrained:")\nprint(best_overall_metrics)\nprint("Feasible:")\nprint(best_feas_metrics)\nEOF\npython3 optimize_threshold.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
