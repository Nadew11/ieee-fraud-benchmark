Sending keys: ['cat << \'EOF\' > optimize_threshold.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.metrics import confusion_matrix, roc_auc_score\n\ndf = pd.read_csv(\'/data/predictions.csv\')\ndf[\'scored_at\'] = pd.to_datetime(df[\'scored_at\'])\n\n# Clean dataset\ndf_clean = df[(df[\'batch_id\'] != 99) & (df[\'scored_at\'] <= \'2026-04-30 23:59:59\')].copy()\n\nprint("Clean dataset count:", len(df_clean))\nprint("Clean dataset fraud count:", (df_clean[\'y_true\'] == 1).sum())\n\n# Cost parameters\nloss_per_fn = 4200\ncost_per_alert = 35\nquarterly_volume = 2800000\nholdout_volume = len(df_clean)\nscale_factor = quarterly_volume / holdout_volume\ndays_in_quarter = 90\ncapacity = 1500\n\nresults = []\nthresholds = np.linspace(0.0, 1.0, 101)\n\nfor t in thresholds:\n    df_clean[\'y_pred\'] = (df_clean[\'y_pred_prob\'] >= t).astype(int)\n    tn, fp, fn, tp = confusion_matrix(df_clean[\'y_true\'], df_clean[\'y_pred\']).ravel()\n    \n    # Holdout costs\n    holdout_fn_cost = fn * loss_per_fn\n    holdout_alert_cost = (tp + fp) * cost_per_alert\n    holdout_total_cost = holdout_fn_cost + holdout_alert_cost\n    \n    # Projected quarterly costs\n    proj_fn_cost = holdout_fn_cost * scale_factor\n    proj_alert_cost = holdout_alert_cost * scale_factor\n    proj_total_cost = holdout_total_cost * scale_factor\n    \n    # Alert volume\n    proj_quarterly_alerts = (tp + fp) * scale_factor\n    proj_daily_alerts = proj_quarterly_alerts / days_in_quarter\n    \n    # Metrics\n    recall = tp / (tp + fn) if (tp + fn) > 0 else 0\n    precision = tp / (tp + fp) if (tp + fp) > 0 else 0\n    f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0\n    acc = (tp + tn) / holdout_volume\n    \n    results.append({\n        \'threshold\': t,\n        \'tp\': tp, \'fp\': fp, \'fn\': fn, \'tn\': tn,\n        \'recall\': recall, \'precision\': precision, \'f1\': f1, \'accuracy\': acc,\n        \'proj_total_cost\': proj_total_cost,\n        \'proj_fn_cost\': proj_fn_cost,\n        \'proj_alert_cost\': proj_alert_cost,\n        \'proj_quarterly_alerts\': proj_quarterly_alerts,\n        \'proj_daily_alerts\': proj_daily_alerts\n    })\n\nres_df = pd.DataFrame(results)\n# Sort by projected total cost\nprint("Top 10 thresholds by lowest cost:")\nprint(res_df.sort_values(by=\'proj_total_cost\').head(10)[[\'threshold\', \'tp\', \'fp\', \'fn\', \'tn\', \'precision\', \'recall\', \'f1\', \'proj_daily_alerts\', \'proj_total_cost\']])\n\n# Let\'s see results where daily alerts <= capacity\nprint("\\nTop 10 thresholds by lowest cost within capacity (<= 1500 daily alerts):")\nwithin_cap = res_df[res_df[\'proj_daily_alerts\'] <= capacity]\nprint(within_cap.sort_values(by=\'proj_total_cost\').head(10)[[\'threshold\', \'tp\', \'fp\', \'fn\', \'tn\', \'precision\', \'recall\', \'f1\', \'proj_daily_alerts\', \'proj_total_cost\']])\nEOF\npython3 optimize_threshold.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
Sending keys: ['cat << \'EOF\' > evaluate_thresholds.py\nimport csv\nfrom datetime import datetime\nimport numpy as np\n\nwith open(\'/data/predictions.csv\', \'r\') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    rows = [r for r in reader]\n\n# Filter to scoring period: before May 1, 2026\nfiltered_rows = [r for r in rows if datetime.strptime(r[3], \'%Y-%m-%d %H:%M:%S\') < datetime(2026, 5, 1)]\ny_true = np.array([int(r[1]) for r in filtered_rows])\ny_prob = np.array([float(r[2]) for r in filtered_rows])\n\nN = len(filtered_rows)\nloss_per_fn = 4200.0\ncost_per_alert = 35.0\nquarterly_volume = 2800000.0\n\ndef eval_t(t):\n    if t == 1.0:\n        y_pred = np.zeros_like(y_true)\n    elif t == 0.0:\n        y_pred = np.ones_like(y_true)\n    else:\n        y_pred = (y_prob >= t).astype(int)\n    \n    tp = int(sum((y_true == 1) & (y_pred == 1)))\n    fp = int(sum((y_true == 0) & (y_pred == 1)))\n    fn = int(sum((y_true == 1) & (y_pred == 0)))\n    tn = int(sum((y_true == 0) & (y_pred == 0)))\n    \n    tp_rate = tp / N\n    fp_rate = fp / N\n    fn_rate = fn / N\n    tn_rate = tn / N\n    \n    tp_q = tp_rate * quarterly_volume\n    fp_q = fp_rate * quarterly_volume\n    fn_q = fn_rate * quarterly_volume\n    tn_q = tn_rate * quarterly_volume\n    \n    alerts_q = tp_q + fp_q\n    alerts_daily = alerts_q / 90.0\n    \n    cost_fn = fn_q * loss_per_fn\n    cost_alert = alerts_q * cost_per_alert\n    total_cost = cost_fn + cost_alert\n    \n    return {\n        \'threshold\': t,\n        \'tp\': tp, \'fp\': fp, \'fn\': fn, \'tn\': tn,\n        \'alerts_daily\': alerts_daily,\n        \'cost_fn\': cost_fn,\n        \'cost_alert\': cost_alert,\n        \'total_cost\': total_cost\n    }\n\nfor t in [0.0, 0.1, 0.2, 0.29, 0.5, 0.6, 0.644, 0.7, 0.8, 0.9, 1.0]:\n    res = eval_t(t)\n    print(f"Threshold: {res[\'threshold\']:.3f} | TP: {res[\'tp\']}, FP: {res[\'fp\']}, FN: {res[\'fn\']}, TN: {res[\'tn\']} | Daily Alerts: {res[\'alerts_daily\']:.1f} | Cost FN: ${res[\'cost_fn\']:,.2f} | Cost Alert: ${res[\'cost_alert\']:,.2f} | Total: ${res[\'total_cost\']:,.2f}")\nEOF\npython3 evaluate_thresholds.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
