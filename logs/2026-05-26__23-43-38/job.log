filtered_auc_roc_reported_by_analyst": 0.918213421549955,\n    \n    "recommended_threshold": float(t_rec),\n    "precision_at_recommended_threshold": float(precision_rec),\n    "recall_at_recommended_threshold": float(recall_rec),\n    "f1_score_at_recommended_threshold": float(f1_rec),\n    "accuracy_at_recommended_threshold": float(accuracy_rec),\n    \n    "precision_at_analyst_threshold_0.5": float(precision_05),\n    "recall_at_analyst_threshold_0.5": float(recall_05),\n    "f1_score_at_analyst_threshold_0.5": float(f1_05),\n    "accuracy_at_analyst_threshold_0.5": float(accuracy_05),\n    \n    "total_eval_samples": int(N),\n    "total_eval_fraud_cases": int(pos),\n    "fraud_rate_pct": float(pos / N * 100.0),\n    \n    "quarterly_loss_no_model": 448110562.68509376,\n    "quarterly_loss_at_recommended_threshold": 192730108.58835143,\n    "quarterly_savings_at_recommended_threshold": 448110562.68509376 - 192730108.58835143\n}\n\nwith open(\'/output/metrics.json\', \'w\') as out_f:\n    json.dump(metrics, out_f, indent=2)\n    \nprint("Saved metrics.json successfully!")\nEOF\npython3 make_json.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
