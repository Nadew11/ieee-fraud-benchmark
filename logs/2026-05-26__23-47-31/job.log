Sending keys: ['cat << \'EOF\' > run_solution.py\nimport pandas as pd\n\n# Load inputs\ntx = pd.read_csv(\'/data/transactions.csv\')\nident = pd.read_csv(\'/data/identity.csv\')\n\n# Deduplicate identity table on TransactionID to recover clean data\nident_clean = ident.drop_duplicates(subset=[\'TransactionID\'])\n\n# Join on TransactionID\nmerged = tx.merge(ident_clean, on=\'TransactionID\', how=\'left\')\n\n# Filter for fraud cases\nfraud_df = merged[merged[\'isFraud\'] == 1]\n\n# Compute total fraud amount broken down by DeviceType\nfraud_by_device = (\n    fraud_df.groupby(\'DeviceType\', dropna=False)\n    .agg(\n        total_fraud_amount=(\'TransactionAmt\', \'sum\'),\n        fraud_transaction_count=(\'TransactionID\', \'count\')\n    )\n    .reset_index()\n)\n\n# Save to /output/fraud_by_device.csv\nfraud_by_device.to_csv(\'/output/fraud_by_device.csv\', index=False)\n\n# Compute overall total fraud amount\ntotal_fraud = float(tx[tx[\'isFraud\'] == 1][\'TransactionAmt\'].sum())\n\n# Save overall total to /output/total_fraud.txt\nwith open(\'/output/total_fraud.txt\', \'w\') as f:\n    f.write(f"{total_fraud:.2f}\\n")\n\nprint("Saved fraud_by_device.csv:")\nprint(fraud_by_device)\nprint(f"Saved total_fraud.txt: {total_fraud:.2f}")\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
