[18.116326, "i", "cat << 'EOF' > process.py\nimport pandas as pd\n\ntx = pd.read_csv('/data/transactions.csv')\nprint(\"Total fraud transactions:\", tx[tx['isFraud'] == 1].shape[0])\nprint(\"Total fraud amount in transactions.csv:\", tx[tx['isFraud'] == 1]['TransactionAmt'].sum())\n\nident = pd.read_csv('/data/identity.csv')\nprint(\"Identity shape:\", ident.shape)\nprint(\"Transaction shape:\", tx.shape)\n\n# Let's merge them\nmerged = pd.merge(tx, ident, on='TransactionID', how='left')\nprint(\"Merged shape:\", merged.shape)\n\n# Fraud by DeviceType (including NaN if any)\nprint(merged[merged['isFraud'] == 1].groupby('DeviceType', dropna=False).agg(\n    total_fraud_amount=('TransactionAmt', 'sum'),\n    fraud_transaction_count=('TransactionID', 'count')\n))\nEOF\n"]
