[90.483389, "i", "cat << 'EOF' > /workspace/run.py\nimport pandas as pd\n\ntx = pd.read_csv('/data/transactions.csv')\nident = pd.read_csv('/data/identity.csv')\n\nident_unique = ident.drop_duplicates(subset=['TransactionID'])\nmerged = pd.merge(tx, ident_unique, on='TransactionID', how='left')\n\noverall_fraud_total = tx[tx['isFraud'] == 1]['TransactionAmt'].sum()\n\nwith open('/output/total_fraud.txt', 'w') as f:\n    f.write(f\"{overall_fraud_total}\\n\")\n\nres = merged[merged['isFraud'] == 1].groupby('DeviceType', dropna=True).agg(\n    total_fraud_amount=('TransactionAmt', 'sum'),\n    fraud_transaction_count=('TransactionID', 'count')\n).reset_index()\n\nres.to_csv('/output/fraud_by_device.csv', index=False)\n\nprint(\"Processing complete.\")\nEOF\n"]
