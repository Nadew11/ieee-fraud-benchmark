[?2004l[?2004h> ).reset_index()
[?2004l[?2004h> 
[?2004l[?2004h> # Round to 2 decimal places? Let's check if the requirement specifies formatting for the CSV
[?2004l[?2004h> # Usually standard float is fine, but maybe let's round or keep exact.
[?2004l[?2004h> # Let's write the csv.
[?2004l[?2004h> breakdown.to_csv('/output/fraud_by_device.csv', index=False)
