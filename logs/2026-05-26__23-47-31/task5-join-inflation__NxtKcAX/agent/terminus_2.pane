[?2004hroot@3532236a873b:/workspace# cat << 'EOF' > solution.py
[?2004l[?2004h> import os
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure output directory exists
[?2004l[?2004h> os.makedirs('/output', exist_ok=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Read input data
[?2004l[?2004h> trans = pd.read_csv('/data/transactions.csv')
[?2004l[?2004h> ident = pd.read_csv('/data/identity.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # 1. Join the two tables on TransactionID.
[?2004l[?2004h> # 2. Compute the total fraud amount (sum of TransactionAmt where isFraud=1)
[?2004l[?2004h> #    broken down by DeviceType.
[?2004l[?2004h> # 3. Save results to /output/fraud_by_device.csv with columns:
[?2004l[?2004h> #    DeviceType, total_fraud_amount, fraud_transaction_count.
[?2004l[?2004h> 
[?2004l[?2004h> # Join
[?2004l[?2004h> merged = pd.merge(trans, ident, on='TransactionID', how='inner')
[?2004l[?2004h> # Filter isFraud == 1
[?2004l[?2004h> fraud_merged = merged[merged['isFraud'] == 1]
[?2004l[?2004h> # Drop any rows where DeviceType is NaN
[?2004l[?2004h> fraud_merged = fraud_merged.dropna(subset=['DeviceType'])
[?2004l[?2004h> 
[?2004l[?2004h> # Compute breakdown
[?2004l[?2004h> breakdown = fraud_merged.groupby('DeviceType').agg(
[?2004l[?2004h>     total_fraud_amount=('TransactionAmt', 'sum'),
[?2004l[?2004h>     fraud_transaction_count=('TransactionAmt', 'count')
[?2004l[?2004h> ).reset_index()
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure columns are exactly as required
[?2004l[?2004h> breakdown = breakdown[['DeviceType', 'total_fraud_amount', 'fraud_transaction_count']]
[?2004l[?2004h> 
[?2004l[?2004h> # Save breakdown to CSV
[?2004l[?2004h> breakdown.to_csv('/output/fraud_by_device.csv', index=False)
[?2004l[?2004h> 
[?2004l[?2004h> # 4. Save the overall total fraud amount to /output/total_fraud.txt
[?2004l[?2004h> #    (single float, e.g. 142857.32)
[?2004l[?2004h> # Note: Some transactions may not have identity records — handle this appropriately.
[?2004l[?2004h> # This means we should compute overall total fraud from the full transactions table, NOT from the joined table.
[?2004l[?2004h> overall_fraud_total = trans.loc[trans['isFraud'] == 1, 'TransactionAmt'].sum()
[?2004l[?2004h> 
[?2004l[?2004h> # Let's save the exact value, without rounding or formatting, as it is a float.
[?2004l[?2004h> # But wait, python's default float format is standard and has full precision.
[?2004l[?2004h> with open('/output/total_fraud.txt', 'w') as f:
[?2004l[?2004h>     f.write(f"{overall_fraud_total}\n")
[?2004l[?2004h> 
[?2004l[?2004h> print("Done! Contents of /output/total_fraud.txt:")
[?2004l[?2004h> with open('/output/total_fraud.txt') as f:
[?2004l[?2004h>     print(f.read())
[?2004l[?2004h> 
[?2004l[?2004h> print("\nContents of /output/fraud_by_device.csv:")
[?2004l[?2004h> with open('/output/fraud_by_device.csv') as f:
[?2004l[?2004h>     print(f.read())
[?2004l[?2004h> EOF
