[?2004l[?2004h> ident = pd.read_csv('/data/identity.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate overall total fraud amount
[?2004l[?2004h> # "Save the overall total fraud amount to /output/total_fraud.txt (single float, e.g. 142857.32)"
[?2004l[?2004h> overall_fraud_total = trans.loc[trans['isFraud'] == 1, 'TransactionAmt'].sum()
[?2004l[?2004h> 
