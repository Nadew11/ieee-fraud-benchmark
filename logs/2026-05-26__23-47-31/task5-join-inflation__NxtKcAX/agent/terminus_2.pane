[?2004l[?2004h> print(f"Overall total fraud amount: {overall_fraud_total:.2f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Merge and calculate breakdown by DeviceType
[?2004l[?2004h> # Filter identity to only include valid DeviceTypes, or merge first and then filter
[?2004l[?2004h> # Let's perform inner join since only rows with DeviceType can have a DeviceType breakdown.
[?2004l[?2004h> # Wait, what if there are rows in identity with NaN DeviceType? We should filter them out.
[?2004l[?2004h> merged = pd.merge(trans, ident, on='TransactionID', how='inner')
[?2004l[?2004h> merged = merged[merged['isFraud'] == 1]
[?2004l[?2004h> 
[?2004l[?2004h> # Drop rows where DeviceType is NaN because we need to group by DeviceType
[?2004l[?2004h> merged = merged.dropna(subset=['DeviceType'])
[?2004l[?2004h> 
[?2004l[?2004h> breakdown = merged.groupby('DeviceType').agg(
[?2004l[?2004h>     total_fraud_amount=('TransactionAmt', 'sum'),
