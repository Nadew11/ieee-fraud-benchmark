[55.536149, "i", "python3 -c \"\nimport pandas as pd\ntx = pd.read_csv('/data/transactions.csv')\nid_df = pd.read_csv('/data/identity.csv')\n\n# Strategy 1: merge directly\nmrg1 = pd.merge(tx, id_df, on='TransactionID', how='left')\nprint('Strategy 1 sums where isFraud=1:')\nprint(mrg1[mrg1['isFraud'] == 1].groupby('DeviceType', dropna=False).agg(total_amt=('TransactionAmt', 'sum'), count=('TransactionAmt', 'count')))\n\n# Strategy 2: deduplicate identity first\nid_dedup = id_df.drop_duplicates(subset=['TransactionID'])\nmrg2 = pd.merge(tx, id_dedup, on='TransactionID', how='left')\nprint('\\nStrategy 2 sums where isFraud=1:')\nprint(mrg2[mrg2['isFraud'] == 1].groupby('DeviceType', dropna=False).agg(total_amt=('TransactionAmt', 'sum'), count=('TransactionAmt', 'count')))\n\nprint('\\nTotal unique fraud in tx:', tx[tx['isFraud'] == 1]['TransactionAmt'].sum(), tx[tx['isFraud'] == 1]['TransactionID'].count())\n\"\n"]
