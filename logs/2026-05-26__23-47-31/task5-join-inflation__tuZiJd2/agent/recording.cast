[85.077492, "i", "python3 -c \"\nimport pandas as pd\ntx = pd.read_csv('/data/transactions.csv')\nident = pd.read_csv('/data/identity.csv')\nprint('Unique IDs in ident:', ident['TransactionID'].nunique())\n# Since we know duplicates were injected by copying existing rows (and modifying DeviceInfo), \n# we can deduplicate 'ident' on 'TransactionID' and get the exact original 'ident_df'!\nident_clean = ident.drop_duplicates(subset=['TransactionID'])\nmerged = tx.merge(ident_clean, on='TransactionID', how='left')\nprint(merged[merged['isFraud'] == 1].groupby('DeviceType', dropna=False).agg(\n    total_fraud_amount=('TransactionAmt', 'sum'),\n    fraud_transaction_count=('TransactionID', 'count')\n).reset_index())\n\"\n"]
